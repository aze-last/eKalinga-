{
  "name": "attendance-shifting-management",
  "mode": "manual-session",
  "designDocument": "docs/dashboard-agent-team-design.md",
  "sharedState": {
    "tasksPath": ".agent-team/tasks",
    "mailboxPath": ".agent-team/mailbox",
    "templatesPath": ".agent-team/templates",
    "decisionsPath": ".agent-team/decisions.md"
  },
  "policies": {
    "defaultIsolation": "shared-workspace-bounded-paths",
    "verificationRequired": true,
    "riskyPaths": [
      "appsettings.json",
      "appsettings.template.json"
    ]
  },
  "workers": [
    {
      "id": "coordinator@attendance-shifting-management",
      "role": "Coordinator",
      "allowedPaths": [
        ".agent-team",
        "docs"
      ]
    },
    {
      "id": "manual-writer@attendance-shifting-management",
      "role": "User Manual Writer / Editor",
      "allowedPaths": [
        ".agent-team",
        "README.md",
        "docs/User-Manual-Ayuda.docx"
      ]
    },
    {
      "id": "repo-mapper@attendance-shifting-management",
      "role": "Repo Mapper",
      "allowedPaths": [
        "Views/BarangayDashboardPage.xaml",
        "Views/BarangayDashboardPage.xaml.cs",
        "ViewModels/BarangayMainViewModel.cs",
        "ViewModels/BarangayDashboardViewModel.cs"
      ]
    },
    {
      "id": "dashboard-ui@attendance-shifting-management",
      "role": "Dashboard UI Worker",
      "allowedPaths": [
        "Views/BarangayDashboardPage.xaml"
      ]
    },
    {
      "id": "dashboard-nav@attendance-shifting-management",
      "role": "Dashboard Navigation Worker",
