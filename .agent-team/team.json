    {
      "id": "ui-ux-auditor-redesigner@attendance-shifting-management",
      "role": "UI/UX Auditor / Redesigner",
      "allowedPaths": [
        ".agent-team",
        "docs",
        "Views",
        "ViewModels",
        "Images"
      ]
    },
    {
      "id": "verifier@attendance-shifting-management",
      "role": "Verifier",
      "allowedPaths": [
        "AttendanceShiftingManagement.sln",
        "AttendanceShiftingManagement.Tests",
