<UserControl x:Class="AttendanceShiftingManagement.Views.HRMetricPlaceholderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <materialDesign:Card Padding="24" materialDesign:ElevationAssist.Elevation="Dp2">
            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                           FontWeight="Bold"
                           Foreground="{StaticResource BrandMidnightBrush}"/>

                <TextBlock Text="{Binding Description}"
                           Margin="0,10,0,14"
                           Foreground="#4B5563"
                           TextWrapping="Wrap"/>

                <ItemsControl ItemsSource="{Binding BulletPoints}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="0,0,0,8">
                                <materialDesign:PackIcon Kind="CheckCircle"
                                                         Width="16"
                                                         Height="16"
                                                         Foreground="{StaticResource BrandRedBrush}"
                                                         Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#111827"/>
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
