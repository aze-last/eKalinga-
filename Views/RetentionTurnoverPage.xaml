<UserControl x:Class="AttendanceShiftingManagement.Views.RetentionTurnoverPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Retention &amp; Turnover Metrics"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrandMidnightBrush}"/>
            <Button DockPanel.Dock="Right"
                    Content="REFRESH"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="{StaticResource BrandRedBrush}"
                    BorderBrush="{StaticResource BrandRedBrush}"/>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,14">
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandMidnightBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding ActiveHeadcount}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="ACTIVE HEADCOUNT" FontSize="12" Foreground="#D1D5DB"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandRedBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding ExitsThisMonth}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="EXITS THIS MONTH" FontSize="12" Foreground="#FFE9D5"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#2563EB">
                <StackPanel>
                    <TextBlock Text="{Binding VoluntaryExitsThisMonth}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="VOLUNTARY EXITS" FontSize="12" Foreground="#DBEAFE"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#7C2D12">
                <StackPanel>
                    <TextBlock Text="{Binding InvoluntaryExitsThisMonth}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="INVOLUNTARY EXITS" FontSize="12" Foreground="#FED7AA"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#14532D">
                <StackPanel>
                    <TextBlock Text="{Binding NinetyDayRetentionPercent}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="90-DAY RETENTION" FontSize="12" Foreground="#DCFCE7"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <materialDesign:Card Grid.Row="2" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Turnover Trend (Last 6 Months)"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               Foreground="{StaticResource BrandMidnightBrush}"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding TurnoverTrends}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Month" Binding="{Binding MonthLabel}" Width="140"/>
                            <DataGridTextColumn Header="Voluntary" Binding="{Binding VoluntaryCount}" Width="90"/>
                            <DataGridTemplateColumn Header="Voluntary Trend" Width="190">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Height="16" VerticalAlignment="Center">
                                            <Border Width="{Binding VoluntaryBarWidth}"
                                                    Height="8"
                                                    HorizontalAlignment="Left"
                                                    Background="#2563EB"
                                                    CornerRadius="4"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Involuntary" Binding="{Binding InvoluntaryCount}" Width="95"/>
                            <DataGridTemplateColumn Header="Involuntary Trend" Width="190">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Height="16" VerticalAlignment="Center">
                                            <Border Width="{Binding InvoluntaryBarWidth}"
                                                    Height="8"
                                                    HorizontalAlignment="Left"
                                                    Background="{StaticResource BrandRedBrush}"
                                                    CornerRadius="4"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <TextBlock Text="Turnover Alerts"
                               FontWeight="Bold"
                               Margin="0,0,0,10"
                               Foreground="{StaticResource BrandMidnightBrush}"/>
                    <ItemsControl ItemsSource="{Binding TurnoverAlerts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FEF2F2"
                                        BorderBrush="#FCA5A5"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,8">
                                    <DockPanel>
                                        <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                                 Foreground="{StaticResource BrandRedBrush}"
                                                                 Width="16"
                                                                 Height="16"
                                                                 Margin="0,2,8,0"/>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#7F1D1D"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="3" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="1.0*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="2.6*"/>
                    <ColumnDefinition Width="2.0*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding ActiveEmployees}"
                          DisplayMemberPath="FullName"
                          SelectedItem="{Binding SelectedEmployee}"
                          AutomationProperties.Name="Employee Selector"
                          materialDesign:HintAssist.Hint="Employee"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,8,0"/>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding ExitTypes}"
                          SelectedItem="{Binding SelectedExitType}"
                          AutomationProperties.Name="Exit Type"
                          materialDesign:HintAssist.Hint="Exit Type"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,8,0"/>

                <CheckBox Grid.Column="2"
                          IsChecked="{Binding IsVoluntary}"
                          Content="Voluntary"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"/>

                <DatePicker Grid.Column="3"
                            SelectedDate="{Binding LastWorkingDate}"
                            AutomationProperties.Name="Last Working Date"
                            materialDesign:HintAssist.Hint="Last Working Date"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Margin="0,0,8,0"/>

                <TextBox Grid.Column="4"
                         Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Exit reason"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,8,0"/>

                <TextBox Grid.Column="5"
                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Notes"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,8,0"/>

                <Button Grid.Column="6"
                        Content="RECORD EXIT"
                        Command="{Binding RecordExitCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource BrandRedBrush}"
                        Foreground="White"
                        Padding="18,0"/>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="4" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
                    <TextBox Width="280"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Search exit records..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                    <ComboBox Width="170"
                              Margin="10,0,0,0"
                              ItemsSource="{Binding DepartmentFilterOptions}"
                              SelectedItem="{Binding SelectedDepartmentFilter}"
                              DisplayMemberPath="Label"
                              AutomationProperties.Name="Department Filter"
                              materialDesign:HintAssist.Hint="Filter Department"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    <ComboBox Width="170"
                              Margin="10,0,0,0"
                              ItemsSource="{Binding RecorderFilterOptions}"
                              SelectedItem="{Binding SelectedRecorderFilter}"
                              DisplayMemberPath="Label"
                              AutomationProperties.Name="Recorder Filter"
                              materialDesign:HintAssist.Hint="Filter Recorder"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    <TextBlock Text="{Binding TurnoverRatePercent, StringFormat='Turnover rate: {0}'}"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               FontWeight="SemiBold"
                               Foreground="#4B5563"/>
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding ExitRecordsView}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Employee" Binding="{Binding Employee.FullName}" Width="*"/>
                        <DataGridTextColumn Header="Position" Binding="{Binding Employee.Position.Name}" Width="140"/>
                        <DataGridTextColumn Header="Exit Type" Binding="{Binding ExitType}" Width="130"/>
                        <DataGridTextColumn Header="Voluntary" Binding="{Binding IsVoluntary}" Width="90"/>
                        <DataGridTextColumn Header="Last Day" Binding="{Binding LastWorkingDate, StringFormat='yyyy-MM-dd'}" Width="110"/>
                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="2*"/>
                        <DataGridTextColumn Header="Recorded By" Binding="{Binding RecordedByUser.Username}" Width="120"/>
                        <DataGridTextColumn Header="Recorded At" Binding="{Binding RecordedAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
