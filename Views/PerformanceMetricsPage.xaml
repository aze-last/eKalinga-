<UserControl x:Class="AttendanceShiftingManagement.Views.PerformanceMetricsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Performance Metrics"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrandMidnightBrush}"/>
            <Button DockPanel.Dock="Right"
                    Content="REFRESH"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="{StaticResource BrandRedBrush}"
                    BorderBrush="{StaticResource BrandRedBrush}"/>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,14">
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandMidnightBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding GoalCompletionRate, StringFormat='{}{0:0.0}%'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="GOAL COMPLETION" FontSize="11" Foreground="#D1D5DB"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandRedBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding AvgReviewScore, StringFormat='{}{0:0.00}/5'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="AVG REVIEW SCORE" FontSize="11" Foreground="#FFE9D5"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#1D4ED8">
                <StackPanel>
                    <TextBlock Text="{Binding AvgManagerFeedbackScore, StringFormat='{}{0:0.00}/5'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="MANAGER FEEDBACK" FontSize="11" Foreground="#DBEAFE"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#14532D">
                <StackPanel>
                    <TextBlock Text="{Binding TrainingCompletionRate, StringFormat='{}{0:0.0}%'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="TRAINING COMPLETION" FontSize="11" Foreground="#DCFCE7"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#7C2D12">
                <StackPanel>
                    <TextBlock Text="{Binding AvgTrainingEffectiveness, StringFormat='{}{0:0.00}/5'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="TRAINING EFFECTIVENESS" FontSize="11" Foreground="#FED7AA"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#111827">
                <StackPanel>
                    <TextBlock Text="{Binding OverdueGoalsCount}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="OVERDUE GOALS" FontSize="11" Foreground="#D1D5DB"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <materialDesign:Card Grid.Row="2" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Width="280"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Search by goal, employee, status"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <ComboBox Grid.Column="1"
                          Width="170"
                          Margin="10,0,0,0"
                          ItemsSource="{Binding DepartmentFilterOptions}"
                          SelectedItem="{Binding SelectedDepartmentFilter}"
                          DisplayMemberPath="Label"
                          AutomationProperties.Name="Performance Team Filter"
                          materialDesign:HintAssist.Hint="Team Filter"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                <ItemsControl Grid.Column="2" ItemsSource="{Binding RiskFlags}" Margin="16,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FEF2F2"
                                    BorderBrush="#FCA5A5"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8"
                                    Margin="0,0,0,6">
                                <DockPanel>
                                    <materialDesign:PackIcon Kind="AlertOutline"
                                                             Foreground="{StaticResource BrandRedBrush}"
                                                             Width="15"
                                                             Height="15"
                                                             Margin="0,2,8,0"/>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#7F1D1D"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="3" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Goal Tracking"
                           FontWeight="Bold"
                           Margin="0,0,0,10"
                           Foreground="{StaticResource BrandMidnightBrush}"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding GoalsView}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Employee" Binding="{Binding Employee.FullName}" Width="*"/>
                        <DataGridTextColumn Header="Team" Binding="{Binding Employee.Position.Area}" Width="90"/>
                        <DataGridTextColumn Header="Goal" Binding="{Binding GoalTitle}" Width="1.5*"/>
                        <DataGridTextColumn Header="Progress" Binding="{Binding CompletionPercent, StringFormat='{}{0:N0}%'}" Width="90"/>
                        <DataGridTextColumn Header="Review" Binding="{Binding ReviewScore, StringFormat='{}{0:N2}'}" Width="80"/>
                        <DataGridTextColumn Header="Manager" Binding="{Binding ManagerFeedbackScore, StringFormat='{}{0:N2}'}" Width="80"/>
                        <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat='yyyy-MM-dd'}" Width="110"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        <DataGridTemplateColumn Header="Actions" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="+10%"
                                                Margin="0,0,6,0"
                                                Command="{Binding DataContext.AdvanceGoalProgressCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                        <Button Content="Complete"
                                                Command="{Binding DataContext.CompleteGoalCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Foreground="#14532D"
                                                BorderBrush="#14532D"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="4" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Training Tracking"
                           FontWeight="Bold"
                           Margin="0,0,0,10"
                           Foreground="{StaticResource BrandMidnightBrush}"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding TrainingRecordsView}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Employee" Binding="{Binding Employee.FullName}" Width="*"/>
                        <DataGridTextColumn Header="Team" Binding="{Binding Employee.Position.Area}" Width="90"/>
                        <DataGridTextColumn Header="Training" Binding="{Binding TrainingName}" Width="1.5*"/>
                        <DataGridTextColumn Header="Mandatory" Binding="{Binding IsMandatory}" Width="90"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                        <DataGridTextColumn Header="Assigned" Binding="{Binding AssignedAt, StringFormat='yyyy-MM-dd'}" Width="100"/>
                        <DataGridTextColumn Header="Due" Binding="{Binding DueDate, StringFormat='yyyy-MM-dd'}" Width="100"/>
                        <DataGridTextColumn Header="Completed" Binding="{Binding CompletedAt, StringFormat='yyyy-MM-dd'}" Width="110"/>
                        <DataGridTextColumn Header="Effectiveness" Binding="{Binding EffectivenessScore, StringFormat='{}{0:N2}'}" Width="100"/>
                        <DataGridTemplateColumn Header="Action" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Mark Complete"
                                            Command="{Binding DataContext.CompleteTrainingCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Foreground="{StaticResource BrandRedBrush}"
                                            BorderBrush="{StaticResource BrandRedBrush}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
