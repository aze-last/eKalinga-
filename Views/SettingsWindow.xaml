<Window x:Class="AttendanceShiftingManagement.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Settings"
        Width="1280"
        Height="860"
        MinWidth="1120"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Settings"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrandMidnightBrush}" />
            <TextBlock Text="Manage remote beneficiary snapshots, staging imports, and database backups from one admin screen."
                       Margin="0,8,0,0"
                       FontSize="13"
                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                       TextWrapping="Wrap" />
        </StackPanel>

        <TabControl Grid.Row="1"
                    Margin="0,20,0,0"
                    Background="Transparent">
            <TabItem Header="Remote Snapshot">
                <Grid Margin="0,20,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="White"
                                BorderBrush="{StaticResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Remote Snapshot Source"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}" />
                                <TextBlock Text="Type the remote database credentials here, test them, then snapshot `val_beneficiaries` or import pending rows into `BeneficiaryStaging`."
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Server / Host" />
                                    <TextBox Grid.Column="2"
                                             Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Port" />
                                </Grid>

                                <TextBox Margin="0,12,0,0"
                                         Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Database Name" />

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Username / Email" />
                                    <TextBox Grid.Column="2"
                                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Password" />
                                </Grid>

                                <TextBlock Margin="0,16,0,0"
                                           Text="Local Target"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}" />

                                <Border Margin="0,8,0,0"
                                        Padding="14"
                                        Background="{StaticResource BrandSurfaceBrush}"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <TextBlock Text="{Binding ActiveTargetSummary}"
                                               Foreground="{StaticResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <Border Margin="0,16,0,0"
                                        Padding="14"
                                        CornerRadius="10"
                                        Background="#FFF7D6">
                                    <TextBlock Text="Snapshot Masterlist copies `val_beneficiaries` into the active database so the Masterlist page has local data. Import to Staging appends new records into `BeneficiaryStaging` as Pending."
                                               Foreground="#9A5A00"
                                               TextWrapping="Wrap" />
                                </Border>

                                <WrapPanel Margin="0,16,0,0">
                                    <Button Content="TEST CONNECTION"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource SecondaryActionButton}"
                                            Command="{Binding TestConnectionCommand}" />
                                    <Button Content="SAVE IMPORT CONNECTION"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource SecondaryActionButton}"
                                            Command="{Binding SaveImportConnectionCommand}" />
                                    <Button Content="SNAPSHOT MASTERLIST"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource GoldActionButton}"
                                            Command="{Binding SnapshotMasterListCommand}" />
                                    <Button Content="IMPORT TO STAGING"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource PrimaryActionButton}"
                                            Command="{Binding ImportToStagingCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="White"
                                BorderBrush="{StaticResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Local Snapshot Status"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}" />

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Margin="0,0,8,0"
                                            Padding="12"
                                            CornerRadius="10"
                                            Background="{StaticResource BrandSurfaceBrush}">
                                        <StackPanel>
                                            <TextBlock Text="MASTERLIST ROWS"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}" />
                                            <TextBlock Text="{Binding MasterListRowCount, StringFormat=N0}"
                                                       Margin="0,6,0,0"
                                                       FontSize="24"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Padding="12"
                                            CornerRadius="10"
                                            Background="{StaticResource BrandSurfaceBrush}">
                                        <StackPanel>
                                            <TextBlock Text="STAGING ROWS"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}" />
                                            <TextBlock Text="{Binding StagingRowCount, StringFormat=N0}"
                                                       Margin="0,6,0,0"
                                                       FontSize="24"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Margin="0,18,0,0"
                                        Padding="14"
                                        Background="{StaticResource BrandSurfaceBrush}"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="Import Status"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandMidnightBrush}" />
                                        <TextBlock Text="{Binding SnapshotStatusMessage}"
                                                   Margin="0,6,0,0"
                                                   Foreground="{Binding SnapshotStatusBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Button Margin="0,18,0,0"
                                        Content="ADVANCED LOAD TABLES"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding OpenAdvancedLoadTablesCommand}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            Background="White"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel>
                                <TextBlock Text="{Binding PreviewCardTitle}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}" />

                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal">
                                    <ComboBox Width="220"
                                              Margin="0,0,12,0"
                                              ItemsSource="{Binding PreviewOptions}"
                                              SelectedItem="{Binding SelectedPreviewLabel}"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                                    <Button Content="REFRESH PREVIEW"
                                            Style="{StaticResource SecondaryActionButton}"
                                            Command="{Binding RefreshPreviewCommand}" />
                                </StackPanel>
                            </DockPanel>

                            <TextBlock Grid.Row="1"
                                       Margin="0,14,0,14"
                                       Text="{Binding PreviewSummary}"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding PreviewRowsView}"
                                      AutoGenerateColumns="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      MinHeight="300" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Database Backup">
                <Grid Margin="0,20,0,0">
                    <Border Background="White"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Database Backup"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}" />
                            <TextBlock Text="Create or import a full snapshot of the currently selected app database preset. This does not connect to the municipality source."
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0"
                                       Text="Current Backup Target"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding BackupTargetSummary}"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <Border Margin="0,16,0,0"
                                    Padding="14"
                                    CornerRadius="10"
                                    Background="#FFF7D6">
                                <TextBlock Text="Backup archives contain Ayuda database rows only. Local configuration files and image files are excluded."
                                           Foreground="#9A5A00"
                                           TextWrapping="Wrap" />
                            </Border>

                            <WrapPanel Margin="0,18,0,0">
                                <Button Content="CREATE BACKUP"
                                        Margin="0,0,12,12"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding CreateBackupCommand}" />
                                <Button Content="IMPORT BACKUP"
                                        Margin="0,0,12,12"
                                        Style="{StaticResource PrimaryActionButton}"
                                        Command="{Binding ImportBackupCommand}" />
                            </WrapPanel>

                            <TextBlock Margin="0,14,0,0"
                                       Text="{Binding BackupStatusMessage}"
                                       Foreground="{Binding BackupStatusBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,12,0,0"
                                       Text="{Binding LastBackupActivity}"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Feature Rules">
                <Grid Margin="0,20,0,0">
                    <Border Background="White"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Large Assistance Warning Threshold"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}" />
                            <TextBlock Text="This amount is used as the warning-only limit when a beneficiary has already received significant ayuda. Records are not auto-declined when the threshold is reached."
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <TextBox Margin="0,18,0,0"
                                     Width="280"
                                     HorizontalAlignment="Left"
                                     Text="{Binding LargeAssistanceWarningThresholdText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Warning threshold amount" />

                            <Button Margin="0,18,0,0"
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    Content="SAVE FEATURE RULES"
                                    Style="{StaticResource GoldActionButton}"
                                    Command="{Binding SaveFeatureRulesCommand}" />

                            <TextBlock Margin="0,14,0,0"
                                       Text="{Binding FeatureRulesStatusMessage}"
                                       Foreground="{Binding FeatureRulesStatusBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
