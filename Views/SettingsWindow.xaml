<Window x:Class="AttendanceShiftingManagement.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:AttendanceShiftingManagement.Views"
        Title="Settings"
        Width="1280"
        Height="860"
        MinWidth="1120"
        MinHeight="760"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" 
                      ResizeBorderThickness="5" 
                      GlassFrameThickness="0" 
                      CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="WindowControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="0"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        </Style>

        <Style x:Key="WindowCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EF4444"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ProtectedSettingsContentGridStyle" TargetType="Grid">
            <Setter Property="IsEnabled" Value="True" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSensitiveSettingsLocked}" Value="True">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="Effect">
                        <Setter.Value>
                            <BlurEffect Radius="10" />
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsTabItemStyle"
               TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Margin="0,0,10,10"
                                Padding="18,11"
                                CornerRadius="18"
                                Background="{DynamicResource ThemeTabStripBrush}"
                                BorderBrush="{DynamicResource ThemeTabStripBorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ThemeCardBrush}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrandMidnightBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrandMidnightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSectionCardStyle"
               TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="AppearanceModeCardStyle"
               TargetType="RadioButton">
            <Setter Property="Background" Value="{DynamicResource ThemeCardRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource BrandMidnightBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="CardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource ThemeWindowShellBrush}"
            CornerRadius="14"
            BorderBrush="{DynamicResource ThemeWindowShellBorderBrush}"
            BorderThickness="1">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- CUSTOM WINDOW CONTROLS -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="99"
                    Margin="0,-24,-24,0">
            <Button Style="{StaticResource WindowControlButtonStyle}"
                    Click="Minimize_Click"
                    ToolTip="Minimize">
                <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18"/>
            </Button>
            <Button Style="{StaticResource WindowCloseButtonStyle}"
                    Click="Close_Click"
                    ToolTip="Close">
                <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
            </Button>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Settings"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource BrandMidnightBrush}" />
            <TextBlock Text="Manage system profile, signed-in account settings, security, remote beneficiary snapshots, and database backups from one admin screen."
                       Margin="0,8,0,0"
                       FontSize="13"
                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                       TextWrapping="Wrap" />
            <Border Margin="0,14,0,0"
                    Padding="14"
                    Background="{DynamicResource ThemeWarningSurfaceBrush}"
                    BorderBrush="{DynamicResource ThemeWarningBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding ShowUpdateBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding UpdateBannerTitle}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeWarningForegroundBrush}" />
                    <TextBlock Text="{Binding UpdateBannerMessage}"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource ThemeWarningForegroundBrush}"
                               TextWrapping="Wrap" />
                    <WrapPanel Margin="0,10,0,0">
                        <Button Content="DOWNLOAD UPDATE"
                                Margin="0,0,10,0"
                                Style="{StaticResource GoldActionButton}"
                                Command="{Binding DownloadUpdateCommand}"
                                Visibility="{Binding ShowDownloadUpdateActions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="INSTALL NOW"
                                Margin="0,0,10,0"
                                Style="{StaticResource PrimaryActionButton}"
                                Command="{Binding InstallPendingUpdateCommand}"
                                Visibility="{Binding ShowPendingUpdateActions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Content="REMIND ME LATER"
                                Style="{StaticResource SecondaryActionButton}"
                                Command="{Binding RemindMeLaterCommand}"
                                Visibility="{Binding ShowPendingUpdateActions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Margin="0,14,0,0"
                    Padding="18"
                    Background="{DynamicResource ThemeAccentSoftBrush}"
                    BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding ShowSensitiveSettingsOtpPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Protected settings save verification"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrandMidnightBrush}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding SensitiveSettingsOtpPromptText}"
                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                               TextWrapping="Wrap" />

                    <Border Margin="0,12,0,0"
                            Padding="12"
                            Background="{DynamicResource ThemeCardBrush}"
                            BorderBrush="{DynamicResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="EmailOutline"
                                                     Width="18"
                                                     Height="18"
                                                     Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Margin="8,0,0,0"
                                       Text="{Binding OfficialEmailMask}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                        </StackPanel>
                    </Border>

                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="SEND OTP"
                                Style="{StaticResource SecondaryActionButton}"
                                Command="{Binding SendSensitiveSettingsOtpCommand}" />
                        <Button Margin="10,0,0,0"
                                Content="{Binding SensitiveSettingsOtpResendButtonText}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding ResendSensitiveSettingsOtpCommand}" />
                    </WrapPanel>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding SensitiveSettingsOtpCode, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Enter 6-digit OTP" />
                        <Button Grid.Column="2"
                                MinWidth="132"
                                Content="VERIFY OTP"
                                Style="{StaticResource PrimaryActionButton}"
                                Command="{Binding VerifySensitiveSettingsOtpCommand}" />
                    </Grid>

                    <TextBlock Margin="0,12,0,0"
                               Text="{Binding SensitiveSettingsOtpStatusMessage}"
                               Foreground="{Binding SensitiveSettingsOtpStatusBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>

        <TabControl x:Name="SettingsTabs"
                    Grid.Row="1"
                    Margin="0,20,0,0"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemContainerStyle="{StaticResource SettingsTabItemStyle}">
            <TabItem Header="System User Management" Visibility="{Binding UserManagementVisibility}">
                <Grid Margin="0,20,0,0">
                    <Grid Style="{StaticResource ProtectedSettingsContentGridStyle}">
                        <local:UserManagementPage x:Name="UserManagementTab" />
                    </Grid>
                    
                    <Border Panel.ZIndex="10"
                            Background="#70FFFFFF"
                            Visibility="{Binding IsSensitiveSettingsLocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border MaxWidth="560"
                                Margin="24"
                                Padding="22"
                                CornerRadius="18"
                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource ThemeCardBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Protected settings"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding SensitiveSettingsUnlockPromptText}"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <PasswordBox Margin="0,16,0,0"
                                             PasswordChanged="ProtectedSettingsUnlockPasswordBox_PasswordChanged"
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                             materialDesign:HintAssist.Hint="Re-enter admin password" />
                                <Button Margin="0,16,0,0"
                                        Content="UNLOCK PROTECTED SETTINGS"
                                        Style="{StaticResource PrimaryActionButton}"
                                        Command="{Binding UnlockSensitiveSettingsCommand}" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding SensitiveSettingsUnlockStatusMessage}"
                                           Foreground="{Binding SensitiveSettingsUnlockStatusBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>
            </TabItem>
            
            <TabItem Header="System Profile">
                <Grid Margin="0,20,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <Border Background="{DynamicResource ThemeCardBrush}"
                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="20"
                                Padding="24">
                            <StackPanel>
                            <Border Padding="22"
                                    Background="{DynamicResource ThemeCardRaisedBrush}"
                                    BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*" />
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <Border Width="52"
                                                Height="52"
                                                CornerRadius="16"
                                                Background="{DynamicResource ThemeAccentSoftBrush}"
                                                BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                                                BorderThickness="1">
                                            <materialDesign:PackIcon Kind="ShieldCrownOutline"
                                                                     Width="26"
                                                                     Height="26"
                                                                     Foreground="{DynamicResource ThemeAccentBrush}"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Margin="0,16,0,0"
                                                   Text="System Profile"
                                                   FontSize="21"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="Manage the workstation identity, login presentation, and the premium light or dark experience used across this installation."
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Border Grid.Column="2"
                                            Padding="16"
                                            Background="{DynamicResource ThemeCardBrush}"
                                            BorderBrush="{DynamicResource BrandBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedAppearanceModeLabel}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Text="{Binding SelectedAppearanceModeDescription}"
                                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,12,0,0"
                                                       Text="{Binding SystemInstallSerial, Mode=OneWay}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThemeAccentBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <TextBlock Margin="0,20,0,0"
                                       Text="Identity"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Keep the official workstation details complete so records, login branding, and internal references stay consistent."
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <TextBox Margin="0,18,0,0"
                                     Text="{Binding SystemInstallSerial, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Company Serial Number" />

                            <TextBox Margin="0,12,0,0"
                                     Text="{Binding SystemName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="System Name" />

                            <TextBox Margin="0,12,0,0"
                                     Text="{Binding SystemOwner, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Owner / Office Name" />

                            <TextBox Margin="0,12,0,0"
                                     MinHeight="72"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalContentAlignment="Top"
                                     Text="{Binding SystemCompanyAddress, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Office / Company Address" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding SystemEmail, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Official Email" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding SystemContactNumber, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Contact Number" />
                            </Grid>

                            <Border Margin="0,22,0,0"
                                    Padding="18"
                                    Background="{DynamicResource ThemeCardSubtleBrush}"
                                    BorderBrush="{DynamicResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock Text="Appearance mode"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Choose the visual treatment that fits the workspace. The preview applies immediately, and saving keeps the preference for future sessions."
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />

                                    <Grid Margin="0,18,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <RadioButton Grid.Column="0"
                                                     GroupName="AppearanceModes"
                                                     Style="{StaticResource AppearanceModeCardStyle}"
                                                     IsChecked="{Binding IsLightAppearanceSelected}">
                                            <StackPanel>
                                                <Border Width="42"
                                                        Height="42"
                                                        CornerRadius="14"
                                                        Background="#FFF4D8"
                                                        BorderBrush="#E7D3A1"
                                                        BorderThickness="1">
                                                    <materialDesign:PackIcon Kind="WeatherSunny"
                                                                             Width="22"
                                                                             Height="22"
                                                                             Foreground="#A96E11"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Margin="0,16,0,0"
                                                           Text="Light"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="Bright, document-friendly surfaces with formal contrast for daytime admin work."
                                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </RadioButton>

                                        <RadioButton Grid.Column="2"
                                                     GroupName="AppearanceModes"
                                                     Style="{StaticResource AppearanceModeCardStyle}"
                                                     IsChecked="{Binding IsDarkAppearanceSelected}">
                                            <StackPanel>
                                                <Border Width="42"
                                                        Height="42"
                                                        CornerRadius="14"
                                                        Background="#1B2634"
                                                        BorderBrush="#384B63"
                                                        BorderThickness="1">
                                                    <materialDesign:PackIcon Kind="MoonWaningCrescent"
                                                                             Width="22"
                                                                             Height="22"
                                                                             Foreground="#D7E4FF"
                                                                             HorizontalAlignment="Center"
                                                                             VerticalAlignment="Center" />
                                                </Border>
                                                <TextBlock Margin="0,16,0,0"
                                                           Text="Dark"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="Midnight surfaces with refined contrast for long sessions and low-glare review."
                                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </RadioButton>
                                    </Grid>

                                    <Border Margin="0,14,0,0"
                                            Padding="14"
                                            Background="{DynamicResource ThemeCardBrush}"
                                            BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <TextBlock Text="{Binding SelectedAppearanceModeLabel}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,22,0,0"
                                       Text="Login branding"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="Refine the sign-in screen with official branding assets that match the selected theme and office identity."
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <Border Margin="0,18,0,0"
                                    Padding="16"
                                    Background="{DynamicResource ThemeCardSubtleBrush}"
                                    BorderBrush="{DynamicResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="108"
                                            Height="108"
                                            CornerRadius="16"
                                            Background="#EAF2FF">
                                        <Grid>
                                            <Border Width="60"
                                                    Height="60"
                                                    CornerRadius="12"
                                                    Background="#1F4BA5"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasSystemLogo}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <materialDesign:PackIcon Kind="TownHall"
                                                                         Width="30"
                                                                         Height="30"
                                                                         Foreground="{DynamicResource BrandYellowBrush}"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center" />
                                            </Border>

                                            <Image Source="{Binding SystemLogoImage}"
                                                   Stretch="Uniform"
                                                   Margin="10">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasSystemLogo}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Login logo"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                        <TextBlock Text="{Binding SystemLogoFileLabel}"
                                                   Margin="0,6,0,0"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="This logo appears on the left side of the login screen. If no custom logo is saved, the default icon stays in place."
                                                   Margin="0,8,0,0"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />

                                        <StackPanel Margin="0,14,0,0"
                                                    Orientation="Horizontal">
                                            <Button Content="UPLOAD LOGO"
                                                    Style="{StaticResource SecondaryActionButton}"
                                                    Command="{Binding BrowseSystemLogoCommand}" />
                                            <Button Content="REMOVE LOGO"
                                                    Margin="10,0,0,0"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Command="{Binding RemoveSystemLogoCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Margin="0,18,0,0"
                                    Padding="16"
                                    Background="{DynamicResource ThemeCardSubtleBrush}"
                                    BorderBrush="{DynamicResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="108"
                                            Height="108"
                                            CornerRadius="16"
                                            Background="#FFF3E0">
                                        <Grid>
                                            <Border Width="60"
                                                    Height="60"
                                                    CornerRadius="12"
                                                    Background="#FB8C00"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasSystemLoginBackground}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <materialDesign:PackIcon Kind="ImageOutline"
                                                                         Width="30"
                                                                         Height="30"
                                                                         Foreground="White"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center" />
                                            </Border>

                                            <Image Source="{Binding SystemLoginBackgroundImage}"
                                                   Stretch="UniformToFill"
                                                   Margin="0">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasSystemLoginBackground}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="Login Panel Background"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                        <TextBlock Text="{Binding SystemLoginBackgroundFileLabel}"
                                                   Margin="0,6,0,0"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="This image appears behind the login glass panels on the sign-in screen."
                                                   Margin="0,8,0,0"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />

                                        <StackPanel Margin="0,14,0,0"
                                                    Orientation="Horizontal">
                                            <Button Content="UPLOAD BACKGROUND"
                                                    Style="{StaticResource SecondaryActionButton}"
                                                    Command="{Binding BrowseSystemLoginBackgroundCommand}" />
                                            <Button Content="REMOVE BACKGROUND"
                                                    Margin="10,0,0,0"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Command="{Binding RemoveSystemLoginBackgroundCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Button Margin="0,18,0,0"
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    Content="SAVE SYSTEM PROFILE"
                                    Style="{StaticResource GoldActionButton}"
                                    Command="{Binding SaveSystemProfileCommand}" />

                                <TextBlock Margin="0,14,0,0"
                                           Text="{Binding SystemProfileStatusMessage}"
                                           Foreground="{Binding SystemProfileStatusBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="My Account"
                     IsEnabled="{Binding HasCurrentUser}">
                <Grid Margin="0,20,0,0">
                    <Border Background="{DynamicResource ThemeCardBrush}"
                            BorderBrush="{DynamicResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="My Account"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Text="Update the signed-in account name, username, email, and contact number."
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <TextBox Margin="0,18,0,0"
                                     Text="{Binding AccountFullName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Full Name" />

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding AccountUsername, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Username" />
                                <TextBox Grid.Column="2"
                                         Text="{Binding AccountContactNumber, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Contact Number" />
                            </Grid>

                            <TextBox Margin="0,12,0,0"
                                     Text="{Binding AccountEmail, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Email Address" />

                            <Button Margin="0,18,0,0"
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    Content="SAVE MY ACCOUNT"
                                    Style="{StaticResource PrimaryActionButton}"
                                    Command="{Binding SaveAccountCommand}" />

                            <TextBlock Margin="0,14,0,0"
                                       Text="{Binding AccountStatusMessage}"
                                       Foreground="{Binding AccountStatusBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Security"
                     IsEnabled="{Binding HasCurrentUser}">
                <Grid Margin="0,20,0,0">
                    <Border Background="{DynamicResource ThemeCardBrush}"
                            BorderBrush="{DynamicResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Security"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Text="Change the signed-in user's password. The current password is required before a new one can be saved."
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <PasswordBox x:Name="CurrentPasswordBox"
                                         Margin="0,18,0,0"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Current Password"
                                         PasswordChanged="CurrentPasswordBox_PasswordChanged" />

                            <PasswordBox x:Name="NewPasswordBox"
                                         Margin="0,12,0,0"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="New Password"
                                         PasswordChanged="NewPasswordBox_PasswordChanged" />

                            <PasswordBox x:Name="ConfirmPasswordBox"
                                         Margin="0,12,0,0"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Confirm New Password"
                                         PasswordChanged="ConfirmPasswordBox_PasswordChanged" />

                            <Button Margin="0,18,0,0"
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    Content="CHANGE PASSWORD"
                                    Style="{StaticResource GoldActionButton}"
                                    Click="ChangePassword_Click" />

                            <Border Margin="0,16,0,0"
                                    Padding="16"
                                    Background="{DynamicResource ThemeCardSubtleBrush}"
                                    BorderBrush="{DynamicResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Visibility="{Binding ShowPasswordChangeOtpPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Password Change Verification"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding PasswordChangeOtpPromptText}"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />

                                    <Border Margin="0,14,0,0"
                                            Padding="12"
                                            Background="{DynamicResource ThemeCardBrush}"
                                            BorderBrush="{DynamicResource BrandBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="EmailOutline"
                                                                     Width="18"
                                                                     Height="18"
                                                                     Foreground="{DynamicResource BrandMidnightBrush}" />
                                            <TextBlock Margin="8,0,0,0"
                                                       Text="{Binding OfficialEmailMask}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <WrapPanel Margin="0,16,0,0">
                                        <Button Content="SEND OTP"
                                                Style="{StaticResource SecondaryActionButton}"
                                                Command="{Binding SendPasswordChangeOtpCommand}" />
                                        <Button Margin="10,0,0,0"
                                                Content="{Binding PasswordChangeOtpResendButtonText}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Command="{Binding ResendPasswordChangeOtpCommand}" />
                                    </WrapPanel>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Grid.Column="0"
                                                 Text="{Binding PasswordChangeOtpCode, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 materialDesign:HintAssist.Hint="Enter 6-digit OTP" />
                                        <Button Grid.Column="2"
                                                MinWidth="132"
                                                Content="VERIFY OTP"
                                                Style="{StaticResource PrimaryActionButton}"
                                                Command="{Binding VerifyPasswordChangeOtpCommand}" />
                                    </Grid>

                                    <TextBlock Margin="0,14,0,0"
                                               Text="{Binding PasswordChangeOtpStatusMessage}"
                                               Foreground="{Binding PasswordChangeOtpStatusBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,14,0,0"
                                       Text="{Binding SecurityStatusMessage}"
                                       Foreground="{Binding SecurityStatusBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Remote Snapshot">
                <Grid Margin="0,20,0,0">
                    <Grid Style="{StaticResource ProtectedSettingsContentGridStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.2*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{DynamicResource ThemeCardBrush}"
                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Remote Snapshot Source"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                <TextBlock Text="Type the remote database credentials here, test them, then snapshot `val_beneficiaries` or import pending rows into `BeneficiaryStaging`."
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Server / Host" />
                                    <TextBox Grid.Column="2"
                                             Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Port" />
                                </Grid>

                                <TextBox Margin="0,12,0,0"
                                         Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Database Name" />

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Username / Email" />
                                    <TextBox Grid.Column="2"
                                             Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Password" />
                                </Grid>

                                <TextBlock Margin="0,16,0,0"
                                           Text="Local Target"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />

                                <Border Margin="0,8,0,0"
                                        Padding="14"
                                        Background="{DynamicResource ThemeCardSubtleBrush}"
                                        BorderBrush="{DynamicResource BrandBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <TextBlock Text="{Binding ActiveTargetSummary}"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <Border Margin="0,16,0,0"
                                        Padding="14"
                                        CornerRadius="10"
                                        Background="{DynamicResource ThemeWarningSurfaceBrush}"
                                        BorderBrush="{DynamicResource ThemeWarningBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="Snapshot Validated Beneficiaries copies `val_beneficiaries` into the active database so the Validated Beneficiaries page has local data. Import to Staging appends new records into `BeneficiaryStaging` as Pending."
                                               Foreground="{DynamicResource ThemeWarningForegroundBrush}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <WrapPanel Margin="0,16,0,0">
                                    <Button Content="TEST CONNECTION"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource SecondaryActionButton}"
                                            Command="{Binding TestConnectionCommand}" />
                                    <Button Content="SAVE IMPORT CONNECTION"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource SecondaryActionButton}"
                                            Command="{Binding SaveImportConnectionCommand}" />
                                    <Button Content="SNAPSHOT VALIDATED BENEFICIARIES"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource GoldActionButton}"
                                            Command="{Binding SnapshotMasterListCommand}" />
                                    <Button Content="IMPORT TO STAGING"
                                            Margin="0,0,12,12"
                                            Style="{StaticResource PrimaryActionButton}"
                                            Command="{Binding ImportToStagingCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{DynamicResource ThemeCardBrush}"
                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="Local Snapshot Status"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Margin="0,0,8,0"
                                            Padding="12"
                                            CornerRadius="10"
                                            Background="{DynamicResource ThemeCardSubtleBrush}">
                                        <StackPanel>
                                            <TextBlock Text="VALIDATED BENEFICIARIES ROWS"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                            <TextBlock Text="{Binding MasterListRowCount, StringFormat=N0}"
                                                       Margin="0,6,0,0"
                                                       FontSize="24"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Margin="8,0,0,0"
                                            Padding="12"
                                            CornerRadius="10"
                                            Background="{DynamicResource ThemeCardSubtleBrush}">
                                        <StackPanel>
                                            <TextBlock Text="STAGING ROWS"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                            <TextBlock Text="{Binding StagingRowCount, StringFormat=N0}"
                                                       Margin="0,6,0,0"
                                                       FontSize="24"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Margin="0,18,0,0"
                                        Padding="14"
                                        Background="{DynamicResource ThemeCardSubtleBrush}"
                                        BorderBrush="{DynamicResource BrandBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="Import Status"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                        <TextBlock Text="{Binding SnapshotStatusMessage}"
                                                   Margin="0,6,0,0"
                                                   Foreground="{Binding SnapshotStatusBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Button Margin="0,18,0,0"
                                        Content="ADVANCED LOAD TABLES"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding OpenAdvancedLoadTablesCommand}" />
                            </StackPanel>
                        </Border>
                        </Grid>

                        <Border Grid.Row="1"
                                Margin="0,18,0,0"
                                Background="{DynamicResource ThemeCardBrush}"
                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                            <DockPanel>
                                <TextBlock Text="{Binding PreviewCardTitle}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />

                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal">
                                    <ComboBox Width="220"
                                              Margin="0,0,12,0"
                                              ItemsSource="{Binding PreviewOptions}"
                                              SelectedItem="{Binding SelectedPreviewLabel}"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                                    <Button Content="REFRESH PREVIEW"
                                            Style="{StaticResource SecondaryActionButton}"
                                            Command="{Binding RefreshPreviewCommand}" />
                                </StackPanel>
                            </DockPanel>

                            <TextBlock Grid.Row="1"
                                       Margin="0,14,0,14"
                                       Text="{Binding PreviewSummary}"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding PreviewRowsView}"
                                      AutoGenerateColumns="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      MinHeight="300" />
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Panel.ZIndex="10"
                            Background="#70FFFFFF"
                            Visibility="{Binding IsSensitiveSettingsLocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border MaxWidth="560"
                                Margin="24"
                                Padding="22"
                                CornerRadius="18"
                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource ThemeCardBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Protected settings"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding SensitiveSettingsUnlockPromptText}"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <PasswordBox Margin="0,16,0,0"
                                             PasswordChanged="ProtectedSettingsUnlockPasswordBox_PasswordChanged"
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                             materialDesign:HintAssist.Hint="Re-enter admin password" />
                                <Button Margin="0,16,0,0"
                                        Content="UNLOCK PROTECTED SETTINGS"
                                        Style="{StaticResource PrimaryActionButton}"
                                        Command="{Binding UnlockSensitiveSettingsCommand}" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding SensitiveSettingsUnlockStatusMessage}"
                                           Foreground="{Binding SensitiveSettingsUnlockStatusBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Database Backup">
                <Grid Margin="0,20,0,0">
                    <Border Background="{DynamicResource ThemeCardBrush}"
                            BorderBrush="{DynamicResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Database Backup"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Text="Create full, incremental, and differential backups for the currently selected app preset. Restore uses the selected restore point and resolves the required backup chain automatically."
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0"
                                       Text="Active Backup Preset"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding BackupTargetSummary}"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Padding="14"
                                        CornerRadius="10"
                                        Background="{DynamicResource ThemeCardSubtleBrush}"
                                        BorderBrush="{DynamicResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Last Full Backup"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding LastFullBackupDisplay}"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Padding="14"
                                        CornerRadius="10"
                                        Background="{DynamicResource ThemeCardSubtleBrush}"
                                        BorderBrush="{DynamicResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Last Incremental Backup"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding LastIncrementalBackupDisplay}"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="4"
                                        Padding="14"
                                        CornerRadius="10"
                                        Background="{DynamicResource ThemeCardSubtleBrush}"
                                        BorderBrush="{DynamicResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Last Differential Backup"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding LastDifferentialBackupDisplay}"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Margin="0,16,0,0"
                                    Padding="14"
                                    CornerRadius="10"
                                    Background="{DynamicResource ThemeWarningSurfaceBrush}"
                                    BorderBrush="{DynamicResource ThemeWarningBorderBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding BackupGuidanceMessage}"
                                           Foreground="{DynamicResource ThemeWarningForegroundBrush}"
                                           TextWrapping="Wrap" />
                            </Border>

                            <WrapPanel Margin="0,18,0,0">
                                <Button Content="CREATE FULL BACKUP"
                                        Margin="0,0,12,12"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding CreateBackupCommand}" />
                                <Button Content="CREATE INCREMENTAL BACKUP"
                                        Margin="0,0,12,12"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding CreateIncrementalBackupCommand}" />
                                <Button Content="CREATE DIFFERENTIAL BACKUP"
                                        Margin="0,0,12,12"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding CreateDifferentialBackupCommand}" />
                                <Button Content="RESTORE BACKUP"
                                        Margin="0,0,12,12"
                                        Style="{StaticResource PrimaryActionButton}"
                                        Command="{Binding RestoreBackupCommand}" />
                            </WrapPanel>

                            <TextBlock Margin="0,14,0,0"
                                       Text="{Binding BackupStatusMessage}"
                                       Foreground="{Binding BackupStatusBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,12,0,0"
                                       Text="{Binding LastBackupActivity}"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="App Database">
                <Grid Margin="0,20,0,0">
                    <Grid Style="{StaticResource ProtectedSettingsContentGridStyle}">
                        <Border Background="{DynamicResource ThemeCardBrush}"
                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="App Database Presets"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                <TextBlock Text="Choose which preset the app uses for login, startup initialization, dashboard reads, and local snapshots. Before login, users can switch presets and configure only Network (LAN). Local and Remote stay fixed by the shipped app configuration."
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />

                                <TextBlock Margin="0,18,0,0"
                                           Text="Current App Database"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding ActiveTargetSummary}"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />

                                <Border Margin="0,16,0,0"
                                        Padding="14"
                                        CornerRadius="10"
                                        Background="{DynamicResource ThemeWarningSurfaceBrush}"
                                        BorderBrush="{DynamicResource ThemeWarningBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="Only Network (LAN) credentials are editable. Local and Remote are fixed by the shipped app configuration, and the migrate action below updates both Local and Remote after schema changes."
                                               Foreground="{DynamicResource ThemeWarningForegroundBrush}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <WrapPanel Margin="0,18,0,0">
                                    <Button Width="250"
                                            HorizontalAlignment="Left"
                                            Content="OPEN APP DATABASE SETTINGS"
                                            Style="{StaticResource PrimaryActionButton}"
                                            Click="OpenAppDatabaseSettings_Click" />
                                    <Button Margin="12,0,0,0"
                                            Content="MIGRATE LOCAL + REMOTE NOW"
                                            Style="{StaticResource GoldActionButton}"
                                            Command="{Binding MigrateLocalAndRemoteCommand}" />
                                </WrapPanel>

                                <TextBlock Margin="0,14,0,0"
                                           Text="{Binding AppDatabaseStatusMessage}"
                                           Foreground="{Binding AppDatabaseStatusBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Panel.ZIndex="10"
                            Background="#70FFFFFF"
                            Visibility="{Binding IsSensitiveSettingsLocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border MaxWidth="560"
                                Margin="24"
                                Padding="22"
                                CornerRadius="18"
                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource ThemeCardBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Protected settings"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding SensitiveSettingsUnlockPromptText}"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <PasswordBox Margin="0,16,0,0"
                                             PasswordChanged="ProtectedSettingsUnlockPasswordBox_PasswordChanged"
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                             materialDesign:HintAssist.Hint="Re-enter admin password" />
                                <Button Margin="0,16,0,0"
                                        Content="UNLOCK PROTECTED SETTINGS"
                                        Style="{StaticResource PrimaryActionButton}"
                                        Command="{Binding UnlockSensitiveSettingsCommand}" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding SensitiveSettingsUnlockStatusMessage}"
                                           Foreground="{Binding SensitiveSettingsUnlockStatusBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="GGMS Budget Source">
                <Grid Margin="0,20,0,0">
                    <Grid Style="{StaticResource ProtectedSettingsContentGridStyle}">
                        <Border Background="{DynamicResource ThemeCardBrush}"
                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="20">
                            <StackPanel>
                                <TextBlock Text="GGMS Budget Source"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                <TextBlock Text="Configure the external GGMS source used by the budget module. Credentials stay outside the shipped installer, and the table names can be changed if your GGMS schema differs."
                                           Margin="0,8,0,0"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />

                                <UniformGrid Margin="0,18,0,0" Columns="3">
                                    <TextBox Margin="0,0,8,0"
                                             Text="{Binding GgmsOfficeCode, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Ayuda office code" />
                                    <TextBox Margin="8,0,8,0"
                                             Text="{Binding GgmsOfficeTable, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Office table" />
                                    <TextBox Margin="8,0,0,0"
                                             Text="{Binding GgmsAllocationTable, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Allocation table" />
                                </UniformGrid>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Text="{Binding GgmsServer, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="GGMS server / host" />
                                    <TextBox Grid.Column="2"
                                             Text="{Binding GgmsPortText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Port" />
                                </Grid>

                                <TextBox Margin="0,12,0,0"
                                         Text="{Binding GgmsDatabase, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="GGMS database name" />

                                <UniformGrid Margin="0,12,0,0" Columns="2">
                                    <TextBox Margin="0,0,8,0"
                                             Text="{Binding GgmsUsername, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="GGMS username" />
                                    <TextBox Margin="8,0,0,0"
                                             Text="{Binding GgmsPassword, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="GGMS password" />
                                </UniformGrid>

                                <WrapPanel Margin="0,18,0,0">
                                    <Button Content="TEST GGMS CONNECTION"
                                            Margin="0,0,12,0"
                                            Style="{StaticResource SecondaryActionButton}"
                                            Command="{Binding TestGgmsConnectionCommand}" />
                                    <Button Content="SAVE GGMS SETTINGS"
                                            Style="{StaticResource GoldActionButton}"
                                            Command="{Binding SaveGgmsSettingsCommand}" />
                                </WrapPanel>

                                <TextBlock Margin="0,14,0,0"
                                           Text="{Binding GgmsStatusMessage}"
                                           Foreground="{Binding GgmsStatusBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Panel.ZIndex="10"
                            Background="#70FFFFFF"
                            Visibility="{Binding IsSensitiveSettingsLocked, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border MaxWidth="560"
                                Margin="24"
                                Padding="22"
                                CornerRadius="18"
                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource ThemeCardBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="Protected settings"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding SensitiveSettingsUnlockPromptText}"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <PasswordBox Margin="0,16,0,0"
                                             PasswordChanged="ProtectedSettingsUnlockPasswordBox_PasswordChanged"
                                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                             materialDesign:HintAssist.Hint="Re-enter admin password" />
                                <Button Margin="0,16,0,0"
                                        Content="UNLOCK PROTECTED SETTINGS"
                                        Style="{StaticResource PrimaryActionButton}"
                                        Command="{Binding UnlockSensitiveSettingsCommand}" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding SensitiveSettingsUnlockStatusMessage}"
                                           Foreground="{Binding SensitiveSettingsUnlockStatusBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Updates">
                <Grid Margin="0,20,0,0">
                    <Border Background="{DynamicResource ThemeCardBrush}"
                            BorderBrush="{DynamicResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="App Updates"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Text="Check the public release manifest for a newer installer. Startup checks stay quiet and only surface here inside Settings."
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <UniformGrid Margin="0,18,0,0" Columns="2">
                                <TextBox Margin="0,0,8,0"
                                         Text="{Binding CurrentAppVersion, Mode=OneWay}"
                                         IsReadOnly="True"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Current version" />
                                <TextBox Margin="8,0,0,0"
                                         Text="{Binding LatestAvailableVersion, Mode=OneWay}"
                                         IsReadOnly="True"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Latest version" />
                            </UniformGrid>

                            <TextBox Margin="0,12,0,0"
                                     Text="{Binding UpdatePublishedAt, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Published at" />

                            <TextBox Margin="0,12,0,0"
                                     Text="{Binding UpdateManifestUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Public version.json URL" />

                            <CheckBox Margin="0,16,0,0"
                                      Content="Check for updates on startup"
                                      IsChecked="{Binding CheckForUpdatesOnStartup}" />

                            <TextBox Margin="0,12,0,0"
                                     Height="120"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding UpdateReleaseNotes, Mode=OneWay}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Release notes" />

                            <TextBox Margin="0,12,0,0"
                                     Text="{Binding DownloadedInstallerLabel, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Downloaded installer" />

                            <ProgressBar Margin="0,12,0,0"
                                         Height="10"
                                         Maximum="100"
                                         Value="{Binding UpdateDownloadProgressPercent, Mode=OneWay}"
                                         Visibility="{Binding ShowUpdateDownloadProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <WrapPanel Margin="0,18,0,0">
                                <Button Content="SAVE UPDATE SETTINGS"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding SaveUpdatePreferencesCommand}" />
                                <Button Content="CHECK NOW"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding CheckForUpdatesCommand}" />
                                <Button Content="DOWNLOAD UPDATE"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding DownloadUpdateCommand}"
                                        Visibility="{Binding ShowDownloadUpdateActions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Content="INSTALL NOW"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource PrimaryActionButton}"
                                        Command="{Binding InstallPendingUpdateCommand}"
                                        Visibility="{Binding ShowPendingUpdateActions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Content="REMIND ME LATER"
                                        Margin="0,0,12,0"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding RemindMeLaterCommand}"
                                        Visibility="{Binding ShowPendingUpdateActions, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Content="OPEN DOWNLOAD PAGE"
                                        Style="{StaticResource PrimaryActionButton}"
                                        Command="{Binding OpenUpdateDownloadPageCommand}" />
                            </WrapPanel>

                            <TextBlock Margin="0,14,0,0"
                                       Text="{Binding UpdateStatusMessage}"
                                       Foreground="{Binding UpdateStatusBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Feature Rules">
                <Grid Margin="0,20,0,0">
                    <Border Background="{DynamicResource ThemeCardBrush}"
                            BorderBrush="{DynamicResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="Large Assistance Warning Threshold"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Text="This amount is used as the warning-only limit when a beneficiary has already received significant ayuda. Records are not auto-declined when the threshold is reached."
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <TextBox Margin="0,18,0,0"
                                     Width="280"
                                     HorizontalAlignment="Left"
                                     Text="{Binding LargeAssistanceWarningThresholdText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Warning threshold amount" />

                            <CheckBox Margin="0,16,0,0"
                                      Content="Enable OTP security verification (Disable for debugging)"
                                      IsChecked="{Binding IsOtpEnabled}"
                                      Foreground="{DynamicResource BrandMidnightBrush}" />

                            <Button Margin="0,18,0,0"
                                    Width="220"
                                    HorizontalAlignment="Left"
                                    Content="SAVE FEATURE RULES"
                                    Style="{StaticResource GoldActionButton}"
                                    Command="{Binding SaveFeatureRulesCommand}" />

                            <TextBlock Margin="0,14,0,0"
                                       Text="{Binding FeatureRulesStatusMessage}"
                                       Foreground="{Binding FeatureRulesStatusBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
    </Border>
</Window>
