<UserControl x:Class="AttendanceShiftingManagement.Views.PayrollPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" 
                   Text="Payroll Management" 
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <!-- Date Range Selection -->
        <materialDesign:Card Grid.Row="1" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Generate Payroll for Period" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <DatePicker Grid.Column="0"
                                materialDesign:HintAssist.Hint="Start Date"
                                SelectedDate="{Binding StartDate}"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>

                    <DatePicker Grid.Column="2"
                                materialDesign:HintAssist.Hint="End Date"
                                SelectedDate="{Binding EndDate}"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>

                    <Button Grid.Column="4"
                            Command="{Binding GeneratePayrollCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Height="56">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CashRegister" Margin="0,0,8,0"/>
                            <TextBlock Text="GENERATE"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </materialDesign:Card>

        <!-- Payroll Results -->
        <materialDesign:Card Grid.Row="2" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Summary Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Payroll Results" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PayrollSummary}" 
                               Margin="16,0,0,0" 
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                </StackPanel>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding PayrollItems}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="*"/>
                        <DataGridTextColumn Header="Total Hrs" Binding="{Binding TotalHours, StringFormat='N2'}" Width="100"/>
                        <DataGridTextColumn Header="OT Hrs" Binding="{Binding OvertimeHours, StringFormat='N2'}" Width="100"/>
                        <DataGridTextColumn Header="Holiday Hrs" Binding="{Binding HolidayHours, StringFormat='N2'}" Width="100"/>
                        <DataGridTextColumn Header="Regular Pay" Binding="{Binding RegularPay, StringFormat='₱{0:N2}'}" Width="120"/>
                        <DataGridTextColumn Header="OT Pay" Binding="{Binding OvertimePay, StringFormat='₱{0:N2}'}" Width="120"/>
                        <DataGridTextColumn Header="Holiday Pay" Binding="{Binding HolidayPay, StringFormat='₱{0:N2}'}" Width="120"/>
                        <DataGridTextColumn Header="Total Pay" Binding="{Binding TotalPay, StringFormat='₱{0:N2}'}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Save Button -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Command="{Binding SavePayrollCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#43A047">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ContentSave" Margin="0,0,8,0"/>
                            <TextBlock Text="SAVE TO DATABASE"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>