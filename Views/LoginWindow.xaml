<Window x:Class="AttendanceShiftingManagement.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:viewmodels="clr-namespace:AttendanceShiftingManagement.ViewModels"
        Title="Login - eKalinga+ Ayuda Management System"
        Height="615" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Window.Resources>
        <ResourceDictionary>
            <BitmapImage x:Key="DefaultBrandBackground" UriSource="pack://application:,,,/Images/image.png" />
            <Style x:Key="LoginInputLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Foreground" Value="#374151" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    
    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.3" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════
                 LEFT — LGU Identity Panel / drag handle
                 ═══════════════════════════════════════════════ -->
            <Grid Grid.Column="0" MouseLeftButtonDown="LeftPanel_MouseLeftButtonDown">
                <!-- Background photo -->
                <Image Source="{Binding BrandBackgroundImage, TargetNullValue={StaticResource DefaultBrandBackground}}"
                       Stretch="UniformToFill"/>
                <!-- Blue gradient overlay -->
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#E81E3A8A" Offset="0"/>
                            <GradientStop Color="#D42563EB" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <!-- Gold accent bar at top — government feel -->
                <Rectangle VerticalAlignment="Top" Height="5">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFD700" Offset="0"/>
                            <GradientStop Color="#FFA000" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="44,0,44,0">

                    <!-- ── LGU Seal (prominent, always shown) ── -->
                    <Border HorizontalAlignment="Center" Margin="0,0,0,18" 
                            Background="White" CornerRadius="64" Padding="12">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
                        </Border.Effect>
                        <Image x:Name="LguSealImage"
                               Source="{Binding BrandLogoImage}"
                               Width="110" Height="110" Stretch="Uniform"/>
                    </Border>

                    <!-- Government heading -->
                    <TextBlock Text="Republic of the Philippines"
                               FontSize="11" FontStyle="Italic"
                               Foreground="#BBDEFB" HorizontalAlignment="Center"
                               Margin="0,0,0,2"/>
                    <TextBlock Text="Province of Davao del Sur"
                               FontSize="11" FontStyle="Italic"
                               Foreground="#BBDEFB" HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>
                    <TextBlock x:Name="MunicipalityText"
                               Text="{Binding BrandTitle}"
                               FontSize="21" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               TextAlignment="Center" TextWrapping="Wrap"
                               Margin="0,0,0,4"/>
                    <TextBlock x:Name="AddressText"
                               Text="{Binding BrandAddress}"
                               FontSize="11" Foreground="#90CAF9"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,22"
                               Visibility="{Binding HasBrandAddress, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <Separator Background="#4DFFFFFF" Margin="16,0,16,20"/>

                    <!-- Serial / Connection Info -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <materialDesign:PackIcon Kind="Certificate" Width="14" Height="14"
                                                 Foreground="#90CAF9" VerticalAlignment="Center"/>
                        <TextBlock x:Name="SerialText" Text="{Binding BrandInstallSerialLabel}"
                                   FontSize="11" Foreground="White" FontFamily="Consolas"
                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <materialDesign:PackIcon Kind="Database" Width="14" Height="14"
                                                 Foreground="#90CAF9" VerticalAlignment="Center"/>
                        <TextBlock x:Name="ConnectionText" Text="{Binding ActiveConnectionSummary}"
                                   FontSize="11" Foreground="#BBDEFB"
                                   Margin="6,0,0,0" VerticalAlignment="Center"
                                   MaxWidth="300" TextWrapping="Wrap" TextAlignment="Center"/>
                    </StackPanel>

                    <Separator Background="#4DFFFFFF" Margin="16,0,16,16"/>

                    <TextBlock x:Name="TaglineText"
                               Text="Better Service, Better Care"
                               FontSize="12" FontStyle="Italic" Foreground="#B3FFFFFF"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════
                 RIGHT — System Identity + Login Form
                 ═══════════════════════════════════════════════ -->
            <Border Grid.Column="1" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Close / Minimize -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,4,8,0">
                        <Button Click="MinimizeButton_Click"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Minimize">
                            <materialDesign:PackIcon Kind="WindowMinimize" Foreground="#9E9E9E"/>
                        </Button>
                        <Button Click="CloseButton_Click"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Exit">
                            <materialDesign:PackIcon Kind="Close" Foreground="#9E9E9E"/>
                        </Button>
                    </StackPanel>

                    <!-- Login form -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel VerticalAlignment="Center" Margin="48,4,48,28">

                            <!-- System logo -->
                            <Image x:Name="LogoImage"
                               Source="{Binding BrandLogoImage}"
                               Width="100" Height="100" Stretch="Uniform"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>

                            <!-- System name -->
                            <TextBlock x:Name="SystemNameText"
                                       Text="eKalinga+"
                                       FontSize="24" FontWeight="Bold"
                                       Foreground="#1E3A8A" HorizontalAlignment="Center"
                                       TextAlignment="Center" TextWrapping="Wrap"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="Ayuda Management System"
                                       FontSize="12" Foreground="#9E9E9E"
                                       HorizontalAlignment="Center" Margin="0,0,0,20"/>

                            <Border BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Margin="0,0,0,20"/>

                            <TextBlock Text="{Binding FormTitle}"
                                       FontSize="15" FontWeight="SemiBold"
                                       Foreground="#1A1A1A" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding FormSubtitle}"
                                       FontSize="11" Foreground="#6B7280"
                                       Margin="0,0,0,20"/>

                            <TextBlock Text="Username" Style="{StaticResource LoginInputLabelStyle}"/>
                            <TextBox x:Name="UsernameInput" 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Enter your username or email"
                                     Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="13" Margin="0,0,0,16"/>
                            
                            <TextBlock Text="Password" Style="{StaticResource LoginInputLabelStyle}"/>
                            <PasswordBox x:Name="PasswordInput"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Enter your password"
                                         PasswordChanged="PasswordBox_PasswordChanged"
                                         FontSize="13" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{Binding StatusBrush}" FontSize="11" TextWrapping="Wrap"
                                       Margin="0,0,0,12" HorizontalAlignment="Center" TextAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Button Content="SIGN IN"
                                    Command="{Binding LoginCommand}"
                                    Height="44" FontSize="14" FontWeight="Bold"
                                    Margin="0,4,0,16">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                                        <Setter Property="Background" Value="#2563EB"/>
                                        <Setter Property="BorderBrush" Value="#2563EB"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1E3A8A"/>
                                                <Setter Property="BorderBrush" Value="#1E3A8A"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Border BorderBrush="#E5E7EB" BorderThickness="0,1,0,0"
                                    Padding="0,12,0,0" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Don't have an account? "
                                               Foreground="#6B7280" FontSize="12" VerticalAlignment="Center"/>
                                    <Button Content="Register here"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Foreground="#2563EB" FontSize="12" FontWeight="SemiBold"
                                            Padding="4,0" Click="RegisterButton_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Demo accounts -->
                            <Border Background="#F0F7FF" CornerRadius="8" Padding="14"
                                    BorderBrush="#BFDBFE" BorderThickness="1.5" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="DEMO ACCOUNTS" FontSize="11"
                                               FontWeight="Bold" Foreground="#1E40AF" Margin="0,0,0,8"/>
                                    <TextBlock FontSize="11" Margin="0,2">
                                        <Run Text="Admin: " FontWeight="SemiBold"/>
                                        <Run Text="admin@barangay.local / admin123" Foreground="#2563EB"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Button HorizontalAlignment="Center"
                                    Click="ConnectionSettingsButton_Click"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Foreground="#64748B" BorderBrush="#CBD5E1"
                                    Padding="12,6" FontSize="11">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="DatabaseSettings" Width="14" Height="14"
                                                             VerticalAlignment="Center"/>
                                    <TextBlock Text="Connection Settings" Margin="6,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- OTP toggle -->
                            <Border Background="#F8F9FA" CornerRadius="8" Padding="12,8"
                                    BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Grid.Column="0" Kind="ShieldLockOutline"
                                                             Width="16" Height="16"
                                                             Foreground="#757575" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="OTP Verification" FontSize="11"
                                                   FontWeight="Medium" Foreground="#374151"/>
                                        <TextBlock Text="Require email code for staff login"
                                                   FontSize="10" Foreground="#9E9E9E"/>
                                    </StackPanel>
                                    <ToggleButton Grid.Column="2"
                                                  Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                  IsChecked="{Binding IsOtpEnabled, Mode=TwoWay}"
                                                  VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
