<Window x:Class="AttendanceShiftingManagement.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Barangay Ayuda System"
        Height="720"
        Width="1180"
        MinHeight="680"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrandSurfaceBrush}"
        FontFamily="Segoe UI"
        Icon="/Images/app-icon.ico">

    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="0.9*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                CornerRadius="18"
                Background="{StaticResource BrandMidnightBrush}"
                Padding="36">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="58"
                            Height="58"
                            CornerRadius="12"
                            Background="#1F4BA5"
                            HorizontalAlignment="Left">
                        <materialDesign:PackIcon Kind="TownHall"
                                                 Width="30"
                                                 Height="30"
                                                 Foreground="{StaticResource BrandYellowBrush}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Text="Bagong Pilipinas"
                               Margin="0,26,0,0"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="Barangay Ayuda System"
                               Margin="0,6,0,0"
                               FontSize="16"
                               Foreground="{StaticResource BrandYellowBrush}" />
                    <TextBlock Text="Manage local household records, staged beneficiaries, cash-for-work operations, and synced municipal tables from one admin portal."
                               Margin="0,18,0,0"
                               MaxWidth="520"
                               FontSize="14"
                               Foreground="#D7E3FF"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center">
                    <WrapPanel Margin="0,0,0,18">
                        <Border Margin="0,0,12,12"
                                Padding="12,8"
                                CornerRadius="10"
                                Background="#1F4BA5">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseSync"
                                                         Width="18"
                                                         Height="18"
                                                         Foreground="{StaticResource BrandYellowBrush}" />
                                <TextBlock Margin="8,0,0,0"
                                           Text="Load municipal tables into local storage"
                                           Foreground="White" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,12"
                                Padding="12,8"
                                CornerRadius="10"
                                Background="#123980">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountGroup"
                                                         Width="18"
                                                         Height="18"
                                                         Foreground="{StaticResource BrandYellowBrush}" />
                                <TextBlock Margin="8,0,0,0"
                                           Text="Review households and beneficiaries"
                                           Foreground="White" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <Border Padding="20"
                            CornerRadius="14"
                            Background="#163A87">
                        <StackPanel>
                            <TextBlock Text="Default admin credentials"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#C9D7FF" />
                            <TextBlock Text="admin@barangay.local"
                                       Margin="0,8,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock Text="admin123"
                                       Margin="0,4,0,0"
                                       FontSize="14"
                                       Foreground="{StaticResource BrandYellowBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="App database settings are available before sign-in so you can choose whether the app targets Local or Hostinger. External source databases are loaded later from Settings and Advanced Load Tables."
                           Foreground="#C9D7FF"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Border Grid.Column="2"
                CornerRadius="18"
                Background="White"
                Padding="36">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="Admin Login"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}" />
                        <TextBlock Text="Sign in to manage barangay operations."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrandTextSecondaryBrush}" />
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Height="40"
                            Padding="16,0"
                            Style="{StaticResource SecondaryActionButton}"
                            Click="OpenConnectionSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseCog"
                                                     Width="18"
                                                     Height="18"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="App Database"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </DockPanel>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center">
                    <Border Padding="14"
                            Background="{StaticResource BrandSurfaceBrush}"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Active database"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}" />
                            <TextBlock Text="{Binding ActiveConnectionSummary}"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <TextBox Margin="0,22,0,12"
                             Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Username or email" />

                    <PasswordBox x:Name="PasswordBox"
                                 Margin="0,0,0,12"
                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                 materialDesign:HintAssist.Hint="Password"
                                 PasswordChanged="PasswordBox_PasswordChanged" />

                    <TextBlock Text="{Binding ErrorMessage}"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource BrandRedBrush}"
                               TextWrapping="Wrap" />

                    <Button Content="SIGN IN"
                            Margin="0,22,0,0"
                            Height="46"
                            Style="{StaticResource PrimaryActionButton}"
                            Command="{Binding LoginCommand}" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="Use App Database if you need to switch between Local and Hostinger before logging in. External source databases are handled in Settings and Advanced Load Tables."
                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
