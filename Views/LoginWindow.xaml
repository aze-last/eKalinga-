<Window x:Class="AttendanceShiftingManagement.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Barangay Ayuda System"
        Height="720"
        Width="1180"
        MinHeight="680"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrandSurfaceBrush}"
        FontFamily="Segoe UI"
        Icon="/Images/app-icon.ico">

    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="0.9*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                CornerRadius="18"
                Background="{StaticResource BrandMidnightBrush}"
                Padding="36">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="104"
                                Height="104"
                                CornerRadius="18"
                                Background="#1F4BA5"
                                HorizontalAlignment="Left">
                            <Grid>
                                <Border Width="58"
                                        Height="58"
                                        CornerRadius="12"
                                        Background="#2A5BC0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCustomBrandLogo}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <materialDesign:PackIcon Kind="TownHall"
                                                             Width="30"
                                                             Height="30"
                                                             Foreground="{StaticResource BrandYellowBrush}"
                                                             HorizontalAlignment="Center"
                                                             VerticalAlignment="Center" />
                                </Border>

                                <Image Source="{Binding BrandLogoImage}"
                                       Stretch="Uniform"
                                       Margin="10">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasCustomBrandLogo}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding BrandTitle}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding BrandSubtitle}"
                                       Margin="0,6,0,0"
                                       FontSize="16"
                                       Foreground="{StaticResource BrandYellowBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding BrandAddress}"
                                       Margin="0,10,0,0"
                                       MaxWidth="360"
                                       FontSize="13"
                                       Foreground="#D7E3FF"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding HasBrandAddress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Border Margin="0,14,0,0"
                                    Padding="10,6"
                                    CornerRadius="10"
                                    Background="#163A87"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding BrandInstallSerialLabel}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#D7E3FF" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Manage local household records, staged beneficiaries, cash-for-work operations, and synced municipal tables from one admin portal."
                               Margin="0,18,0,0"
                               MaxWidth="520"
                               FontSize="14"
                               Foreground="#D7E3FF"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center">
                    <WrapPanel Margin="0,0,0,18">
                        <Border Margin="0,0,12,12"
                                Padding="12,8"
                                CornerRadius="10"
                                Background="#1F4BA5">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DatabaseSync"
                                                         Width="18"
                                                         Height="18"
                                                         Foreground="{StaticResource BrandYellowBrush}" />
                                <TextBlock Margin="8,0,0,0"
                                           Text="Load municipal tables into local storage"
                                           Foreground="White" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,12"
                                Padding="12,8"
                                CornerRadius="10"
                                Background="#123980">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountGroup"
                                                         Width="18"
                                                         Height="18"
                                                         Foreground="{StaticResource BrandYellowBrush}" />
                                <TextBlock Margin="8,0,0,0"
                                           Text="Review households and beneficiaries"
                                           Foreground="White" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <Border Padding="20"
                            CornerRadius="14"
                            Background="#163A87">
                        <StackPanel>
                            <TextBlock Text="Security note"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#C9D7FF" />
                            <TextBlock Text="No default admin password is shipped with this build."
                                       Margin="0,8,0,0"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                            <TextBlock Text="If the selected database has no admin yet, the right panel switches to first-run setup."
                                       Margin="0,4,0,0"
                                       FontSize="14"
                                       Foreground="{StaticResource BrandYellowBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Text="App database settings are available before sign-in so you can choose Local, Network LAN, or Hostinger. Network LAN credentials are managed later from System Settings."
                           Foreground="#C9D7FF"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Border Grid.Column="2"
                CornerRadius="18"
                Background="White"
                Padding="36">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding FormTitle}"
                                   FontSize="28"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}" />
                        <TextBlock Text="{Binding FormSubtitle}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrandTextSecondaryBrush}" />
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Height="40"
                            Padding="16,0"
                            Style="{StaticResource SecondaryActionButton}"
                            Click="OpenConnectionSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseCog"
                                                     Width="18"
                                                     Height="18"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="App Database"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </DockPanel>

                <Grid Grid.Row="1"
                      VerticalAlignment="Center">
                    <StackPanel Visibility="{Binding IsLoginMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Padding="14"
                                Background="{StaticResource BrandSurfaceBrush}"
                                BorderBrush="{StaticResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="Active database"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}" />
                                <TextBlock Text="{Binding ActiveConnectionSummary}"
                                           Margin="0,6,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBox Margin="0,22,0,12"
                                 Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Username or email" />

                        <PasswordBox x:Name="PasswordBox"
                                     Margin="0,0,0,12"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     materialDesign:HintAssist.Hint="Password"
                                     PasswordChanged="PasswordBox_PasswordChanged" />

                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,4,0,0"
                                   Foreground="{Binding StatusBrush}"
                                   TextWrapping="Wrap" />

                        <Button Content="SIGN IN"
                                Margin="0,22,0,0"
                                Height="46"
                                Style="{StaticResource PrimaryActionButton}"
                                Command="{Binding LoginCommand}" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding IsBootstrapMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Padding="14"
                                Background="{StaticResource BrandSurfaceBrush}"
                                BorderBrush="{StaticResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <TextBlock Text="Active database"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}" />
                                <TextBlock Text="{Binding ActiveConnectionSummary}"
                                           Margin="0,6,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBox Margin="0,22,0,12"
                                 Text="{Binding BootstrapFullName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Admin full name" />

                        <TextBox Margin="0,0,0,12"
                                 Text="{Binding BootstrapUsername, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Admin username" />

                        <TextBox Margin="0,0,0,12"
                                 Text="{Binding BootstrapEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Admin email" />

                        <PasswordBox Margin="0,0,0,12"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     materialDesign:HintAssist.Hint="Admin password"
                                     PasswordChanged="BootstrapPasswordBox_PasswordChanged" />

                        <PasswordBox Margin="0,0,0,12"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     materialDesign:HintAssist.Hint="Confirm admin password"
                                     PasswordChanged="BootstrapConfirmPasswordBox_PasswordChanged" />

                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,4,0,0"
                                   Foreground="{Binding StatusBrush}"
                                   TextWrapping="Wrap" />

                        <Button Content="CREATE INITIAL ADMIN"
                                Margin="0,22,0,0"
                                Height="46"
                                Style="{StaticResource PrimaryActionButton}"
                                Command="{Binding CreateInitialAdminCommand}" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="2"
                           Text="Use App Database if you need to switch between Local, Network LAN, and Hostinger before logging in. Network LAN credentials are configured later from System Settings."
                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                           FontSize="12"
                           TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
