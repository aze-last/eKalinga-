<Window x:Class="AttendanceShiftingManagement.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Login - eKalinga+"
        Height="640"
        Width="968"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <SolidColorBrush x:Key="LoginBluePrimaryBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="LoginBlueHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="LoginBlueSoftBrush" Color="#DBEAFE" />
        <SolidColorBrush x:Key="LoginBlueTextBrush" Color="#1E3A8A" />
        <SolidColorBrush x:Key="LoginPanelBorderBrush" Color="#D9E2EC" />
        <SolidColorBrush x:Key="LoginMutedBrush" Color="#64748B" />
        <SolidColorBrush x:Key="LoginTitleBrush" Color="#0F172A" />

        <Style x:Key="LoginInputLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="LoginInputTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Height" Value="50" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="LoginInputPasswordStyle" TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
            <Setter Property="Height" Value="50" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PrimaryLoginButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="50" />
            <Setter Property="Background" Value="{StaticResource LoginBluePrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
        </Style>

        <Style x:Key="GhostActionButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D7DEE8" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="18" />
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="0"
            ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="58*" />
                <ColumnDefinition Width="42*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#1E3A8A"
                                      Offset="0" />
                        <GradientStop Color="#2563EB"
                                      Offset="1" />
                    </LinearGradientBrush>
                </Grid.Background>

                <Grid.Clip>
                    <RectangleGeometry Rect="0,0,560,640" />
                </Grid.Clip>

                <Image Source="{Binding BrandBackgroundImage}"
                       Stretch="UniformToFill"
                       Opacity="1"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Effect>
                        <BlurEffect Radius="18" />
                    </Image.Effect>
                </Image>

                <Rectangle Fill="#C91E40AF" />
                <Rectangle Fill="#751D4ED8" />

                <Grid Margin="44">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                MaxWidth="320">
                        <Border Width="122"
                                Height="122"
                                Background="#F8FAFC"
                                CornerRadius="18"
                                Padding="18"
                                HorizontalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="22"
                                                  ShadowDepth="6"
                                                  Opacity="0.18" />
                            </Border.Effect>
                            <Image Source="{Binding BrandLogoImage}"
                                   Stretch="Uniform" />
                        </Border>

                        <TextBlock Text="{Binding BrandTitle}"
                                   Margin="0,28,0,0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="{Binding BrandSubtitle}"
                                   Margin="0,8,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#E0E7FF"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />

                        <TextBlock Text="{Binding BrandAddress}"
                                   Margin="0,10,0,0"
                                   FontSize="13"
                                   Foreground="#DBEAFE"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasBrandAddress, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <Border Margin="0,34,0,0"
                                Padding="0,18,0,0"
                                BorderBrush="#7FB3D7FF"
                                BorderThickness="0,1,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,10">
                                    <materialDesign:PackIcon Kind="BadgeAccountOutline"
                                                             Width="16"
                                                             Height="16"
                                                             Foreground="White"
                                                             Margin="0,0,10,0" />
                                    <TextBlock Text="{Binding BrandInstallSerialLabel}"
                                               Foreground="#E0E7FF"
                                               FontSize="12" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,10">
                                    <materialDesign:PackIcon Kind="EmailOutline"
                                                             Width="16"
                                                             Height="16"
                                                             Foreground="White"
                                                             Margin="175,0,10,0" />
                                    <TextBlock Text="{Binding ActiveConnectionSummary}"
                                               Foreground="#E0E7FF"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Width="240" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Better Service, Better Care"
                                   Margin="0,34,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   FontStyle="Italic"
                                   Foreground="#DBEAFE"
                                   Opacity="0.95" />
                    </StackPanel>
                </Grid>
            </Grid>

            <Grid Grid.Column="1"
                  Background="White">
                <Button Width="40"
                        Height="34"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="20,16,0,0"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Click="Close_Click">
                    <materialDesign:PackIcon Kind="Close"
                                             Foreground="#64748B"
                                             Width="32"
                                             Height="20" HorizontalAlignment="Center" />
                </Button>

                <Grid Margin="48,42,48,42"
                      VerticalAlignment="Center"
                      MaxWidth="360">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="18" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="22" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="20" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="26" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="22" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{Binding FormTitle}"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource LoginBlueTextBrush}" />
                        <TextBlock Text="{Binding FormSubtitle}"
                                   Margin="0,8,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource LoginMutedBrush}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="Username"
                                   Style="{StaticResource LoginInputLabelStyle}" />
                        <TextBox x:Name="UsernameInput"
                                 Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource LoginInputTextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4">
                        <TextBlock Text="Password"
                                   Style="{StaticResource LoginInputLabelStyle}" />
                        <PasswordBox x:Name="PasswordInput"
                                     Style="{StaticResource LoginInputPasswordStyle}"
                                     PasswordChanged="PasswordBox_PasswordChanged" />
                    </StackPanel>

                    <Button Grid.Row="6"
                            Content="LOGIN"
                            Style="{StaticResource PrimaryLoginButtonStyle}"
                            Command="{Binding LoginCommand}" />

                    <Border Grid.Row="8"
                            Background="#F8FBFF"
                            BorderBrush="#D8E7FB"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="Demo Accounts"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource LoginBlueTextBrush}"
                                       FontSize="12" />

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,10,0,4">
                                <materialDesign:PackIcon Kind="ShieldAccountOutline"
                                                         Foreground="{StaticResource LoginBluePrimaryBrush}"
                                                         Width="14"
                                                         Height="14"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,6,0" />
                                <TextBlock FontSize="12"
                                           Foreground="#334155">
                                    <Run Text="Admin: " FontWeight="SemiBold" />
                                    <Run Text="admin@barangay.local / admin123"
                                         Foreground="{StaticResource LoginBluePrimaryBrush}"
                                         FontWeight="Bold" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Grid.Row="10"
                            HorizontalAlignment="Center"
                            Style="{StaticResource GhostActionButtonStyle}"
                            Click="OpenConnectionSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseSettings"
                                                     Width="16"
                                                     Height="16"
                                                     Margin="0,0,8,0" />
                            <TextBlock Text="Connection Settings" />
                        </StackPanel>
                    </Button>

                    <TextBlock Grid.Row="14"
                               Text="{Binding StatusMessage}"
                               Foreground="{Binding StatusBrush}"
                               FontSize="12"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="340"
                               HorizontalAlignment="Center" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
