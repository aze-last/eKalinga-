<Window x:Class="AttendanceShiftingManagement.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ATHLETE LOGIN" 
        Height="700" Width="450"
        Icon="/Images/app-icon.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="20" ClipToBounds="True">
        <Grid>
            <!-- Background Image -->
            <Image Source="/Images/Mcdo_bg.jpg" 
                   Stretch="UniformToFill" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center">
                <Image.Effect>
                    <BlurEffect Radius="5"/>
                </Image.Effect>
            </Image>

            <!-- Dark Overlay -->
            <Border Background="#CC000000"/> 

            <!-- Close Button for Chromeless Window -->
            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="10" Foreground="White"
                    Click="Close_Click">
                <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
            </Button>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="350">
                
                <TextBlock Text="MCDONALD'S
" 
                           Style="{StaticResource MaterialDesignHeadline4TextBlock}" 
                           Foreground="White" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,10" 
                           FontWeight="Light"/>

                <TextBlock Text="STAFF ATTENDANCE SYSTEM" 
                           Foreground="#F2A900" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30" 
                           FontSize="12"
                           FontWeight="Bold"/>

                <!-- Username -->
                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,10"
                         Foreground="White"
                         BorderBrush="Gray"
                         materialDesign:HintAssist.Hint="Username"
                         materialDesign:TextFieldAssist.LeadingIcon="Account"
                         materialDesign:HintAssist.Foreground="LightGray"
                         CaretBrush="White"
                         Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Password -->
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="0,0,0,15"
                             Foreground="White"
                             BorderBrush="Gray"
                             materialDesign:HintAssist.Hint="Password"
                             materialDesign:TextFieldAssist.LeadingIcon="Lock"
                             materialDesign:HintAssist.Foreground="LightGray"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="#FF5252" 
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"
                           TextWrapping="Wrap"/>

                <Button Style="{StaticResource MaterialDesignFlatButton}"
                        Content="SIGN IN"
                        Height="50"
                        Margin="0,0,0,10"
                        Background="#F2A900" 
                        BorderBrush="#F2A900"
                        Foreground="White"
                        FontWeight="Bold"
                        Command="{Binding LoginCommand}"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"/>

            </StackPanel>
        </Grid>
    </Border>
</Window>
