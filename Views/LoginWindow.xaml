<Window x:Class="AttendanceShiftingManagement.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Login - SCMS"
        Height="610"
        Width="950"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" 
                      ResizeBorderThickness="0" 
                      GlassFrameThickness="0" 
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- SCMS Light Blue Theme -->
        <SolidColorBrush x:Key="SCMSBluePrimary" Color="#1D4ED8" />
        <SolidColorBrush x:Key="SCMSBlueLight" Color="#3B82F6" />
        <SolidColorBrush x:Key="SCMSBlueAccent" Color="#BFDBFE" />
        <SolidColorBrush x:Key="SCMSBgGradientStart" Color="#2563EB" />
        <SolidColorBrush x:Key="SCMSBgGradientEnd" Color="#3B82F6" />

        <Style x:Key="SCMSLoginInput" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
            <Setter Property="Margin" Value="0,8,0,16" />
            <Setter Property="Height" Value="54" />
        </Style>

        <Style x:Key="SCMSPasswordInput" TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignOutlinedPasswordBox}">
            <Setter Property="Margin" Value="0,8,0,16" />
            <Setter Property="Height" Value="54" />
        </Style>

        <Style x:Key="SCMSLoginButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatMidBgButton}">
            <Setter Property="Background" Value="#15803D" /> <!-- Or Blue, image shows Green but user said Light Blue theme. I'll use Blue later or Green as seen in photo but follow 'Light Blue theme' text -->
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="50" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#16A34A" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="0" Background="White" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT BRAND PANEL (Light Blue Gradient) -->
            <Grid Grid.Column="0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E3A8A" Offset="0" />
                        <GradientStop Color="#2563EB" Offset="1" />
                    </LinearGradientBrush>
                </Grid.Background>

                <!-- Optional background overlay/image effect -->
                <Rectangle Fill="Black" Opacity="0.15" />

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <Border Background="White" Width="140" Height="140" CornerRadius="24" Margin="0,0,0,30">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" Direction="-90" RenderingBias="Quality" ShadowDepth="4" Opacity="0.15" />
                        </Border.Effect>
                        <Image Source="/Images/default icon.png" Stretch="Uniform" Margin="20" />
                    </Border>

                    <TextBlock Text="eKalinga+" FontSize="36" FontWeight="Black" Foreground="White" HorizontalAlignment="Center" />
                    <TextBlock Text="Social Care Management System" FontSize="18" Foreground="#E0E7FF" HorizontalAlignment="Center" Margin="0,5,0,0" />
                    <TextBlock Text="Municipality of Sulop" FontSize="12" Foreground="#C7D2FE" HorizontalAlignment="Center" Margin="0,2,0,40" />

                    <Border BorderBrush="#6366F1" BorderThickness="0,1,0,0" Padding="0,30,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="AccountCircleOutline" Foreground="White" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="Bien Josef G. Regidor" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <materialDesign:PackIcon Kind="EmailOutline" Foreground="White" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="bernegidor@gmail.com" Foreground="#E0E7FF" FontSize="13" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="BadgeAccountOutline" Foreground="White" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0" />
                                <TextBlock Text="S/N: EKAL-2026-00381947" Foreground="#C7D2FE" FontSize="11" FontStyle="Italic" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Better Service, Better Care" Margin="0,50,0,0" HorizontalAlignment="Center" FontStyle="Italic" Foreground="#C7D2FE" FontSize="12" Opacity="0.8" />
                </StackPanel>
            </Grid>

            <!-- RIGHT LOGIN PANEL (White) -->
            <Grid Grid.Column="1" Background="White">
                <!-- Window Controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                    <Button Width="40" Height="34"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Click="Minimize_Click">
                        <materialDesign:PackIcon Kind="WindowMinimize" Foreground="#64748B" Width="18" Height="18" />
                    </Button>
                    <Button Width="40" Height="34"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Click="Close_Click">
                        <materialDesign:PackIcon Kind="Close" Foreground="#64748B" Width="20" Height="20" />
                    </Button>
                </StackPanel>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="60,0">
                    <TextBlock Text="Welcome back" FontSize="32" FontWeight="Bold" Foreground="#1E293B" />
                    <TextBlock Text="Sign in to your account to continue" Foreground="#64748B" Margin="0,5,0,30" />

                    <TextBlock Text="Username" FontWeight="SemiBold" Foreground="#334155" />
                    <TextBox Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SCMSLoginInput}"
                             materialDesign:HintAssist.Hint="Enter your username" />

                    <TextBlock Text="Password" FontWeight="SemiBold" Foreground="#334155" />
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource SCMSPasswordInput}"
                                 materialDesign:HintAssist.Hint="Enter your password"
                                 PasswordChanged="PasswordBox_PasswordChanged" />

                    <Button Content="LOGIN" 
                            Style="{StaticResource SCMSLoginButton}"
                            Background="#2563EB"
                            Command="{Binding LoginCommand}"
                            Margin="0,10,0,0" />

                    <Border Background="#F0FDF4" BorderBrush="#DCFCE7" BorderThickness="1" CornerRadius="8" Margin="0,30,0,0" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Demo Accounts" FontWeight="Bold" Foreground="#166534" FontSize="12" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,4">
                                <materialDesign:PackIcon Kind="ShieldCheckOutline" Foreground="#166534" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock FontSize="12" Foreground="#166534">
                                    <Run Text="Admin: " FontWeight="SemiBold" /><Run Text="admin@barangay.local / admin123" Foreground="#15803D" FontWeight="Bold" />
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Margin="0,30,0,0" HorizontalAlignment="Center"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="#64748B" FontSize="12"
                            Click="OpenConnectionSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseSettings" Margin="0,0,8,0" />
                            <TextBlock Text="Connection Settings" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Status Message Overlay at bottom -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding StatusBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,20"
                           FontSize="12"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="400" />
            </Grid>
        </Grid>
    </Border>
</Window>



