<Window x:Class="AttendanceShiftingManagement.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Barangay Ayuda System Login"
        Height="700"
        Width="450"
        Icon="/Images/app-icon.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="16"
            ClipToBounds="True"
            Background="{StaticResource BrandSurfaceBrush}"
            BorderBrush="{StaticResource BrandBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource BrandMidnightBrush}"
                    Padding="20">
                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="Barangay Ayuda System"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Secure sign in for household assistance and cash-for-work operations."
                                   Margin="0,6,0,0"
                                   Foreground="#D6DEEE"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Foreground="White"
                            Click="Close_Click">
                        <materialDesign:PackIcon Kind="Close" Width="22" Height="22"/>
                    </Button>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1" Margin="28">
                <materialDesign:Card Width="360"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Padding="24">
                    <StackPanel>
                        <Border Width="56"
                                Height="56"
                                CornerRadius="28"
                                Background="{StaticResource BrandYellowBrush}"
                                HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="ShieldAccountOutline"
                                                     Width="28"
                                                     Height="28"
                                                     Foreground="{StaticResource BrandGoldTextBrush}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Sign In"
                                   Margin="0,18,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}"/>

                        <TextBlock Text="Use your assigned account to open the ayuda operations dashboard."
                                   Margin="0,8,0,20"
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{StaticResource BrandTextSecondaryBrush}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>

                        <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,12"
                                 AutomationProperties.Name="Username or Email"
                                 materialDesign:HintAssist.Hint="Username or email"
                                 materialDesign:TextFieldAssist.LeadingIcon="Account"
                                 Text="{Binding UsernameOrEmail, UpdateSourceTrigger=PropertyChanged}"/>

                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     Margin="0,0,0,12"
                                     AutomationProperties.Name="Password"
                                     materialDesign:HintAssist.Hint="Password"
                                     materialDesign:TextFieldAssist.LeadingIcon="Lock"
                                     PasswordChanged="PasswordBox_PasswordChanged"/>

                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#B91C1C"
                                   FontSize="12"
                                   Margin="0,0,0,12"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>

                        <Button Style="{StaticResource PrimaryActionButton}"
                                Content="Sign In"
                                Height="44"
                                Command="{Binding LoginCommand}"/>

                        <Button Margin="0,10,0,0"
                                Height="40"
                                Content="Connection Settings"
                                Style="{StaticResource SecondaryActionButton}"
                                Click="OpenConnectionSettings_Click"/>

                        <Border Margin="0,14,0,0"
                                Padding="10"
                                Background="#EAF2FF"
                                BorderBrush="{StaticResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Current database preset"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Text="{Binding ConnectionProfileSummary}"
                                           Margin="0,6,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,18,0,0"
                                Padding="12"
                                Background="{StaticResource BrandSurfaceBrush}"
                                BorderBrush="{StaticResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Demo access"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Text="Admin: admin@barangay.local / admin123"
                                           Margin="0,6,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                <TextBlock Text="Treasurer: treasurer@barangay.local / treasurer123"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Border>
</Window>
