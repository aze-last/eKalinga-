<UserControl x:Class="AttendanceShiftingManagement.Views.ProjectManagementPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="600" Height="500">
    
    <Border Background="White" CornerRadius="18" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="20" />
                <RowDefinition Height="*" />
                <RowDefinition Height="20" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Settings" Width="28" Height="28" VerticalAlignment="Center" Foreground="{StaticResource BrandMidnightBrush}"/>
                <TextBlock Text="Project Management" Margin="12,0,0,0" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource BrandMidnightBrush}"/>
            </StackPanel>

            <TabControl Grid.Row="2" Style="{StaticResource MaterialDesignNavigationRailTabControl}">
                <!-- Tab 1: Scanner Setup -->
                <TabItem Header="SCANNER">
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="Mobile Scanner Configuration" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="Allow workers to release benefits using their mobile phones. Shared the PIN and URL below." 
                                   TextWrapping="Wrap" Foreground="{StaticResource BrandTextSecondaryBrush}" Margin="0,0,0,20"/>
                        
                        <Border Background="#F8FAFC" Padding="20" CornerRadius="12" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="SESSION PIN" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                <TextBlock Text="{Binding ScannerPin, FallbackValue='----'}" HorizontalAlignment="Center" FontSize="36" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}" Margin="0,5"/>
                                
                                <Separator Margin="0,15"/>
                                
                                <TextBlock Text="SCANNER URL" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                <TextBox Text="{Binding ScannerUrl, Mode=OneWay}" IsReadOnly="True" HorizontalContentAlignment="Center" Margin="0,10" FontWeight="SemiBold"/>
                                
                                <Button Content="CREATE NEW SESSION" 
                                        Command="{Binding CreateScannerSessionCommand}"
                                        Style="{StaticResource SecondaryActionButton}" 
                                        Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </TabItem>

                <!-- Tab 2: Add Beneficiaries -->
                <TabItem Header="ADD BENEFICIARY">
                    <Grid Margin="0,10,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Assign Beneficiaries to Project" FontWeight="Bold"/>
                        
                        <ListBox Grid.Row="2" ItemsSource="{Binding AvailableBeneficiaries}" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding BeneficiaryId}" FontSize="11" Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="ADD" 
                                                    Command="{Binding DataContext.AddBeneficiaryCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}" Height="28" Padding="10,0" FontSize="11"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>
            </TabControl>

            <Button Grid.Row="4" Content="CLOSE" 
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    Style="{StaticResource MaterialDesignFlatButton}" HorizontalAlignment="Right" />
        </Grid>
    </Border>
</UserControl>
