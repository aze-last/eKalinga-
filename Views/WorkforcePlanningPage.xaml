<UserControl x:Class="AttendanceShiftingManagement.Views.WorkforcePlanningPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Workforce Planning"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrandMidnightBrush}"/>
            <Button DockPanel.Dock="Right"
                    Content="REFRESH"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="{StaticResource BrandRedBrush}"
                    BorderBrush="{StaticResource BrandRedBrush}"/>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="7" Margin="0,0,0,14">
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandMidnightBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding ActiveHeadcount}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="ACTIVE" FontSize="11" Foreground="#D1D5DB"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandRedBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding OpenPipelineCount}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="OPEN PIPELINE" FontSize="11" Foreground="#FFE9D5"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#7C2D12">
                <StackPanel>
                    <TextBlock Text="{Binding ExitsLast30Days}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="EXITS (30D)" FontSize="11" Foreground="#FED7AA"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#14532D">
                <StackPanel>
                    <TextBlock Text="{Binding ForecastedHeadcount}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="FORECAST HEADCOUNT" FontSize="11" Foreground="#DCFCE7"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#1D4ED8">
                <StackPanel>
                    <TextBlock Text="{Binding RequiredShiftSlots}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="REQ SLOTS (7D)" FontSize="11" Foreground="#DBEAFE"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#0F766E">
                <StackPanel>
                    <TextBlock Text="{Binding AssignedShiftSlots}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="ASSIGNED SLOTS (7D)" FontSize="11" Foreground="#CCFBF1"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#111827">
                <StackPanel>
                    <TextBlock Text="{Binding CoveragePercent, StringFormat='{}{0:0.0}%'}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="COVERAGE" FontSize="11" Foreground="#D1D5DB"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <materialDesign:Card Grid.Row="2" Padding="12" Margin="0,0,0,14">
            <ItemsControl ItemsSource="{Binding Alerts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FEF2F2"
                                BorderBrush="#FCA5A5"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Margin="0,0,0,6">
                            <DockPanel>
                                <materialDesign:PackIcon Kind="AlertCircle"
                                                         Foreground="{StaticResource BrandRedBrush}"
                                                         Width="16"
                                                         Height="16"
                                                         Margin="0,2,8,0"/>
                                <TextBlock Text="{Binding}" Foreground="#7F1D1D" TextWrapping="Wrap"/>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="3" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Coverage Gap by Area (Next 7 Days)"
                           FontWeight="Bold"
                           Margin="0,0,0,10"
                           Foreground="{StaticResource BrandMidnightBrush}"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding AreaGaps}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="*"/>
                        <DataGridTextColumn Header="Required Slots" Binding="{Binding RequiredSlots}" Width="120"/>
                        <DataGridTextColumn Header="Assigned Slots" Binding="{Binding AssignedSlots}" Width="120"/>
                        <DataGridTextColumn Header="Gap" Binding="{Binding Gap}" Width="80"/>
                        <DataGridTextColumn Header="Available Employees" Binding="{Binding AvailableEmployees}" Width="140"/>
                        <DataGridTextColumn Header="Assigned Employees" Binding="{Binding AssignedEmployees}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
