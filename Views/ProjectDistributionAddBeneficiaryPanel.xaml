<UserControl x:Class="AttendanceShiftingManagement.Views.ProjectDistributionAddBeneficiaryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <UserControl.Resources>
        <DropShadowEffect x:Key="PanelShadow"
                          BlurRadius="25"
                          ShadowDepth="8"
                          Color="#44000000"
                          Opacity="0.45" />

        <Style x:Key="EnrollmentRowStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="4,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4,14,14,4"
                                Padding="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ThemeCardSubtleBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource ThemePrimaryActionBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ThemeCardSubtleBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniMetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Modal Backdrop -->
        <Border Background="#CC0F172A" />

        <!-- Main Enrollment Card -->
        <Border Width="920"
                MaxHeight="820"
                Background="{DynamicResource ThemeCardBrush}"
                CornerRadius="28"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Effect="{StaticResource PanelShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header -->
                    <RowDefinition Height="*" />    <!-- Content -->
                    <RowDefinition Height="Auto" /> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header: Project Badge Design -->
                <Border Grid.Row="0"
                        Padding="32,28"
                        Background="{DynamicResource ThemePrimaryActionBrush}"
                        CornerRadius="28,28,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <WrapPanel VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="AccountPlus" Width="24" Height="24" Foreground="{DynamicResource BrandGoldBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Project Enrollment Registry"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ThemePrimaryActionForegroundBrush}"
                                           VerticalAlignment="Center"/>
                            </WrapPanel>
                            
                            <Border Margin="0,16,0,0"
                                    Padding="16,12"
                                    CornerRadius="16"
                                    Background="{DynamicResource BrandMidnightBrush}"
                                    HorizontalAlignment="Left"
                                    BorderBrush="{DynamicResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    Opacity="0.8">
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel>
                                        <TextBlock Text="ACTIVE PROJECT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedProgram.ProgramName, TargetNullValue='No project selected'}"
                                                   FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="20,0" Background="{DynamicResource BrandBorderBrush}" Opacity="0.3"/>
                                    <StackPanel>
                                        <TextBlock Text="ALLOCATED BUDGET" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedProgramBudgetCapText}"
                                                   FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrandGoldBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Button Grid.Row="0"
                                    Width="36" Height="36"
                                    Padding="10,0,0,0"
                                    Margin="0,16,16,0"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{DynamicResource ThemePrimaryActionForegroundBrush}"
                                    Command="{Binding CloseAddBeneficiaryPanelCommand}"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">
                                <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
                            </Button>
                            
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0" HorizontalAlignment="Right">
                                <Border Style="{StaticResource MiniMetricCardStyle}" Background="#26F9C231" BorderThickness="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding PendingTotalCount}" FontWeight="Bold" Foreground="#7A5A00" FontSize="13"/>
                                        <TextBlock Text=" PENDING" FontSize="9" FontWeight="Bold" Foreground="#7A5A00" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MiniMetricCardStyle}" Background="#2610B981" BorderThickness="0" Margin="0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding ReleasedTotalCount}" FontWeight="Bold" Foreground="#065F46" FontSize="13"/>
                                        <TextBlock Text=" RELEASED" FontSize="9" FontWeight="Bold" Foreground="#065F46" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Content Area -->
                <Grid Grid.Row="1" Margin="32,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="480" />
                        <ColumnDefinition Width="32" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Search & List -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0"
                                 Text="{Binding AddBeneficiarySearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Search approved registry by name or ID"
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 FontSize="14"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Content="SELECT ALL FILTERED"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{DynamicResource BrandGoldBrush}"
                                    Command="{Binding SelectAllFilteredCommand}" />
                            <Button Content="DESELECT ALL"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                    Command="{Binding DeselectAllCommand}"
                                    Margin="8,0,0,0" />
                        </StackPanel>

                        <ListBox Grid.Row="2"
                                 ItemsSource="{Binding FilteredAvailableBeneficiaries}"
                                 SelectedItem="{Binding SelectedAvailableBeneficiary}"
                                 ItemContainerStyle="{StaticResource EnrollmentRowStyle}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" 
                                                  IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                                  VerticalAlignment="Center" 
                                                  Margin="0,0,12,0"/>

                                        <!-- Avatar -->
                                        <Grid Grid.Column="1">
                                            <Ellipse Width="48" Height="48" Fill="{DynamicResource ThemeWindowShellBrush}"/>
                                            <TextBlock Text="{Binding Initials}" Foreground="{DynamicResource ThemePrimaryActionBrush}" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>

                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                            <WrapPanel Margin="0,4,0,0">
                                                <TextBlock Text="{Binding BeneficiaryId}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                
                                                <Border Padding="6,1" CornerRadius="4" Background="#DCFCE7" Visibility="{Binding IsSenior, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,4,0">
                                                    <TextBlock Text="Senior" FontSize="9" FontWeight="Bold" Foreground="#166534"/>
                                                </Border>
                                                <Border Padding="6,1" CornerRadius="4" Background="#F3E8FF" Visibility="{Binding IsPwd, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="PWD" FontSize="9" FontWeight="Bold" Foreground="#6B21A8"/>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <!-- Right: Membership Card Preview -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ENROLLMENT PREVIEW" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,16"/>
                        
                        <!-- Membership "Card" -->
                        <materialDesign:Card UniformCornerRadius="20" Padding="24" Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedBeneficiariesCount, StringFormat='{} {0} Beneficiaries Selected'}" 
                                           FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                <TextBlock Text="Batch Enrollment Setup" 
                                           FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>

                                <Separator Margin="0,20" Background="{DynamicResource BrandBorderBrush}"/>

                                <Border Margin="0,24,0,0" Padding="14" CornerRadius="12" Background="#26F9C231" BorderBrush="{DynamicResource BrandYellowBrush}" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Information" Width="18" Height="18" Foreground="{DynamicResource BrandGoldBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="Selected beneficiaries will be added as PENDING for verification." 
                                                   FontSize="11" Foreground="{DynamicResource BrandGoldBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- Status Alert -->
                        <Border Margin="0,20,0,0" Padding="16,12" CornerRadius="12" 
                                Background="Transparent" 
                                Visibility="{Binding AddBeneficiaryStatusMessage, Converter={StaticResource NullToHiddenConverter}}">
                            <TextBlock Text="{Binding AddBeneficiaryStatusMessage}" 
                                       Foreground="{Binding AddBeneficiaryStatusBrush}" 
                                       FontWeight="SemiBold" FontSize="13" TextAlignment="Center" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Footer Actions -->
                <Border Grid.Row="2" Padding="32,24" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="0,0,28,28">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center" 
                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                   Text="Confirming enrollment will move the beneficiary into this project's active queue."
                                   FontSize="12"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="DISMISS"
                                    Width="120"
                                    Height="46"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                    Command="{Binding CloseAddBeneficiaryPanelCommand}"
                                    Margin="0,0,12,0"/>
                            <Button Content="ENROLL IN PROJECT"
                                    Width="220"
                                    Height="46"
                                    Style="{StaticResource GoldActionButton}"
                                    Command="{Binding ConfirmAddBeneficiaryCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
