<UserControl x:Class="AttendanceShiftingManagement.Views.CompensationBenefitsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Compensation &amp; Benefits"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrandMidnightBrush}"/>
            <Button DockPanel.Dock="Right"
                    Content="REFRESH"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="{StaticResource BrandRedBrush}"
                    BorderBrush="{StaticResource BrandRedBrush}"/>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,14">
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandMidnightBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding MonthlyPayrollTotal, StringFormat='{}{0:N2}'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="MONTHLY PAYROLL" FontSize="11" Foreground="#D1D5DB"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandRedBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding MonthlyOvertimeTotal, StringFormat='{}{0:N2}'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="OVERTIME COST" FontSize="11" Foreground="#FFE9D5"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#14532D">
                <StackPanel>
                    <TextBlock Text="{Binding AverageNetPay, StringFormat='{}{0:N2}'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="AVG NET PAY" FontSize="11" Foreground="#DCFCE7"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#1D4ED8">
                <StackPanel>
                    <TextBlock Text="{Binding MonthlyApprovedLeaveCount}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="APPROVED LEAVES" FontSize="11" Foreground="#DBEAFE"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#7C2D12">
                <StackPanel>
                    <TextBlock Text="{Binding YearToDatePayrollTotal, StringFormat='{}{0:N2}'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="YTD PAYROLL" FontSize="11" Foreground="#FED7AA"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <materialDesign:Card Grid.Row="2" Padding="12" Margin="0,0,0,14">
            <ItemsControl ItemsSource="{Binding Alerts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FEF2F2"
                                BorderBrush="#FCA5A5"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Margin="0,0,0,6">
                            <DockPanel>
                                <materialDesign:PackIcon Kind="AlertOutline"
                                                         Foreground="{StaticResource BrandRedBrush}"
                                                         Width="16"
                                                         Height="16"
                                                         Margin="0,2,8,0"/>
                                <TextBlock Text="{Binding}" Foreground="#7F1D1D" TextWrapping="Wrap"/>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="3" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Width="280"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Search by employee/team/generator"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <ComboBox Grid.Column="1"
                          Width="170"
                          Margin="10,0,0,0"
                          ItemsSource="{Binding DepartmentFilterOptions}"
                          SelectedItem="{Binding SelectedDepartmentFilter}"
                          DisplayMemberPath="Label"
                          AutomationProperties.Name="Compensation Team Filter"
                          materialDesign:HintAssist.Hint="Team Filter"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                <DataGrid Grid.Column="2"
                          Margin="16,0,0,0"
                          ItemsSource="{Binding MonthlyTrend}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Month" Binding="{Binding MonthLabel}" Width="110"/>
                        <DataGridTextColumn Header="Total Pay" Binding="{Binding TotalPay, StringFormat='{}{0:N2}'}" Width="120"/>
                        <DataGridTemplateColumn Header="Total Trend" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Height="16" VerticalAlignment="Center">
                                        <Border Width="{Binding TotalPayBarWidth}"
                                                Height="8"
                                                HorizontalAlignment="Left"
                                                Background="{StaticResource BrandRedBrush}"
                                                CornerRadius="4"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Overtime" Binding="{Binding OvertimePay, StringFormat='{}{0:N2}'}" Width="100"/>
                        <DataGridTemplateColumn Header="OT Trend" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Height="16" VerticalAlignment="Center">
                                        <Border Width="{Binding OvertimePayBarWidth}"
                                                Height="8"
                                                HorizontalAlignment="Left"
                                                Background="#14532D"
                                                CornerRadius="4"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="4" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Payroll Records"
                           FontWeight="Bold"
                           Margin="0,0,0,10"
                           Foreground="{StaticResource BrandMidnightBrush}"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding PayrollRecordsView}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Employee" Binding="{Binding Employee.FullName}" Width="*"/>
                        <DataGridTextColumn Header="Team" Binding="{Binding Employee.Position.Area}" Width="90"/>
                        <DataGridTextColumn Header="Period Start" Binding="{Binding PeriodStart, StringFormat='yyyy-MM-dd'}" Width="110"/>
                        <DataGridTextColumn Header="Period End" Binding="{Binding PeriodEnd, StringFormat='yyyy-MM-dd'}" Width="110"/>
                        <DataGridTextColumn Header="Regular Pay" Binding="{Binding RegularPay, StringFormat='{}{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="Overtime Pay" Binding="{Binding OvertimePay, StringFormat='{}{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="Holiday Pay" Binding="{Binding HolidayPay, StringFormat='{}{0:N2}'}" Width="100"/>
                        <DataGridTextColumn Header="Total Pay" Binding="{Binding TotalPay, StringFormat='{}{0:N2}'}" Width="110"/>
                        <DataGridTextColumn Header="Generated By" Binding="{Binding GeneratedByUser.Username}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
