<UserControl x:Class="AttendanceShiftingManagement.Views.BeneficiaryVerificationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  PanningMode="VerticalOnly">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24"
                CornerRadius="18"
                Background="{StaticResource BrandMidnightBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Validated Beneficiaries"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="Read the local `val_beneficiaries` snapshot, keep every new account pending by default, then approve or reject each beneficiary before they appear in downstream operations."
                               Margin="0,8,0,0"
                               MaxWidth="760"
                               Foreground="#D6E3FF"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="REFRESH"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource GoldActionButton}"
                        Height="40"
                        VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="1" Margin="0,18,0,18">
            <materialDesign:Card Width="150" Margin="8" Padding="16" Background="{StaticResource BrandMidnightBrush}" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding TotalCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="TOTAL" Foreground="#A5B4FC" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Width="150" Margin="8" Padding="16" Background="{StaticResource BrandYellowBrush}" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding PendingCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="{StaticResource BrandGoldTextBrush}"/>
                    <TextBlock Text="PENDING" Foreground="#7A5A00" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Width="150" Margin="8" Padding="16" Background="#2563EB" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding VerifiedCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="VERIFIED" Foreground="#DBEAFE" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Width="150" Margin="8" Padding="16" Background="{StaticResource BrandSuccessBrush}" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding ApprovedCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="APPROVED" Foreground="#CFECD8" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Width="150" Margin="8" Padding="16" Background="#C2410C" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding DuplicateCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="DUPLICATE" Foreground="#FFEDD5" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Width="150" Margin="8" Padding="16" Background="#4B5563" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding InactiveCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="INACTIVE" Foreground="#E5E7EB" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Width="150" Margin="8" Padding="16" Background="#991B1B" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding RejectedCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="REJECTED" Foreground="#FECACA" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>
        </WrapPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Padding="16" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="Validated Snapshot Approval Queue"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <ComboBox Width="160"
                                      Margin="0,0,12,0"
                                      ItemsSource="{Binding StatusFilters}"
                                      SelectedItem="{Binding SelectedStatusFilter}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                            <TextBox Width="280"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Search name, IDs, address, or notes"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,0,0,14"
                               FontWeight="SemiBold"
                               Foreground="{Binding StatusBrush}"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"/>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding RecordsView}"
                              SelectedItem="{Binding SelectedBeneficiary}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Beneficiary ID" Binding="{Binding BeneficiaryId}" Width="120"/>
                            <DataGridTextColumn Header="Civil Registry ID" Binding="{Binding CivilRegistryId}" Width="130"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="180"/>
                            <DataGridTemplateColumn Header="Status" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusBrush}" CornerRadius="12" Padding="8,4" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusTextBrush}" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Notes" Binding="{Binding ReviewNotes}" Width="160"/>
                            <DataGridTextColumn Header="Imported" Binding="{Binding ImportedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}" Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Margin="0,0,10,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       Text="Rows per page"/>
                            <ComboBox Width="100"
                                      ItemsSource="{Binding PageSizeOptions}"
                                      SelectedItem="{Binding SelectedPageSize}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </StackPanel>

                        <Grid Grid.Column="2" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       Text="{Binding PageSummary}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1"
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}"
                                       Text="{Binding PageIndicator}"/>
                        </Grid>

                        <StackPanel Grid.Column="4"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Width="110"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    Command="{Binding PreviousPageCommand}"
                                    Content="PREVIOUS"
                                    Style="{StaticResource SecondaryActionButton}"/>
                            <Button Width="90"
                                    Height="36"
                                    Command="{Binding NextPageCommand}"
                                    Content="NEXT"
                                    Style="{StaticResource GoldActionButton}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2" Padding="16" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Registry Checklist"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}"/>

                    <Border Grid.Row="1"
                            Margin="0,12,0,14"
                            Padding="16"
                            CornerRadius="10"
                            Background="#EEF4FF"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedBeneficiary.FullName, TargetNullValue=Select a staged beneficiary}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedBeneficiary.BeneficiaryId, StringFormat='Beneficiary ID: {0}', TargetNullValue=Beneficiary ID: --}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding SelectedBeneficiary.CivilRegistryId, StringFormat='Civil Registry ID: {0}', TargetNullValue=Civil Registry ID: --}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding SelectedBeneficiary.StatusText, StringFormat='Checklist Status: {0}', TargetNullValue=Checklist Status: --}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding SelectedBeneficiary.LinkSummary, TargetNullValue=Not linked to a registry record yet}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="Approval Target"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}"/>
                        <ComboBox Margin="0,8,0,0"
                                  ItemsSource="{Binding Households}"
                                  SelectedItem="{Binding SelectedHousehold}"
                                  DisplayMemberPath="DisplayLabel"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        <TextBlock Text="{Binding SelectedHousehold.AddressLine, TargetNullValue=Select a household before approval.}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource BrandTextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                        <ComboBox Margin="0,10,0,0"
                                  ItemsSource="{Binding AvailableHouseholdMembers}"
                                  SelectedItem="{Binding SelectedHouseholdMember}"
                                  DisplayMemberPath="DisplayLabel"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Optional: link to an existing household member"/>
                        <TextBlock Text="{Binding ApprovalActionLabel}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource BrandTextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="3" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Editable Staged Details"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}"/>

                            <UniformGrid Margin="0,12,0,0" Columns="2">
                                <TextBox Margin="0,0,8,10"
                                         Text="{Binding EditableBeneficiaryId, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Beneficiary ID"/>
                                <TextBox Margin="8,0,0,10"
                                         Text="{Binding EditableCivilRegistryId, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Civil Registry ID"/>

                                <TextBox Margin="0,0,8,10"
                                         Text="{Binding EditableFirstName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="First Name"/>
                                <TextBox Margin="8,0,0,10"
                                         Text="{Binding EditableMiddleName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Middle Name"/>

                                <TextBox Margin="0,0,8,10"
                                         Text="{Binding EditableLastName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Last Name"/>
                                <TextBox Margin="8,0,0,10"
                                         Text="{Binding EditableFullName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Full Name"/>

                                <TextBox Margin="0,0,8,10"
                                         Text="{Binding EditableSex, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Sex"/>
                                <TextBox Margin="8,0,0,10"
                                         Text="{Binding EditableDateOfBirth, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Date of Birth"/>

                                <TextBox Margin="0,0,8,10"
                                         Text="{Binding EditableAge, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Age"/>
                                <TextBox Margin="8,0,0,10"
                                         Text="{Binding EditableMaritalStatus, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Marital Status"/>

                                <TextBox Margin="0,0,8,10"
                                         Text="{Binding EditablePwdIdNo, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="PWD ID No."/>
                                <TextBox Margin="8,0,0,10"
                                         Text="{Binding EditableSeniorIdNo, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Senior ID No."/>

                                <TextBox Margin="0,0,8,10"
                                         Text="{Binding EditableDisabilityType, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Disability Type"/>
                                <TextBlock Margin="8,8,0,10"
                                           Text="{Binding SelectedBeneficiary.SexAgeSummary, TargetNullValue=Select a beneficiary to review}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </UniformGrid>

                            <TextBox Margin="0,0,0,10"
                                     Text="{Binding EditableAddress, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Address"/>

                            <TextBox Height="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding EditableReviewNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Review notes (required for duplicate, inactive, and reject)"/>

                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="SAVE CORRECTIONS"
                                        Command="{Binding SaveCorrectionsCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource BrandMidnightBrush}"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                                <Button Content="MARK VERIFIED"
                                        Command="{Binding VerifyCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#2563EB"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                                <Button Content="APPROVE"
                                        Command="{Binding ApproveCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource BrandSuccessBrush}"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                                <Button Content="MARK DUPLICATE"
                                        Command="{Binding MarkDuplicateCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#C2410C"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                                <Button Content="MARK INACTIVE"
                                        Command="{Binding MarkInactiveCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#4B5563"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                                <Button Content="REJECT"
                                        Command="{Binding RejectCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource BrandRedBrush}"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                            </WrapPanel>

                            <Border Margin="0,18,0,0"
                                    Padding="16"
                                    CornerRadius="12"
                                    Background="#F8FAFC"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Digital ID"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                    <TextBlock Text="{Binding DigitalIdCardNumber}"
                                               Margin="0,6,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                    <TextBlock Text="{Binding DigitalIdIssuedAtText}"
                                               Margin="0,4,0,0"
                                               Foreground="{StaticResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="120"
                                                Height="120"
                                                Background="#DBEAFE"
                                                CornerRadius="12"
                                                BorderBrush="{StaticResource BrandBorderBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Image Source="{Binding DigitalIdPhotoImage}" Stretch="UniformToFill"/>
                                                <TextBlock Text="PHOTO"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="#1D4ED8"
                                                           FontWeight="SemiBold"/>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Column="2"
                                                Width="120"
                                                Height="120"
                                                Background="White"
                                                CornerRadius="12"
                                                BorderBrush="{StaticResource BrandBorderBrush}"
                                                BorderThickness="1">
                                            <Image Source="{Binding DigitalIdQrImage}" Stretch="Uniform"/>
                                        </Border>

                                        <StackPanel Grid.Column="3" Margin="16,0,0,0">
                                            <TextBlock Text="Printable card-sized ID with QR lookup handle."
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                            <Button Content="UPLOAD PHOTO"
                                                    Command="{Binding UploadDigitalIdPhotoCommand}"
                                                    Margin="0,12,0,0"
                                                    Height="38"
                                                    Style="{StaticResource SecondaryActionButton}"/>
                                            <Button Content="PRINT ID"
                                                    Command="{Binding PrintDigitalIdCommand}"
                                                    Margin="0,10,0,0"
                                                    Height="38"
                                                    Style="{StaticResource GoldActionButton}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Margin="0,18,0,14"/>

                                    <TextBlock Text="Lookup Scanner Session"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                    <TextBlock Text="Generate a same-Wi-Fi scanner QR plus temporary PIN for employee phones."
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                    <Button Content="CREATE LOOKUP SCANNER SESSION"
                                            Command="{Binding CreateLookupScannerSessionCommand}"
                                            Margin="0,12,0,0"
                                            Height="40"
                                            Style="{StaticResource PrimaryActionButton}"/>
                                    <TextBox Margin="0,12,0,0"
                                             IsReadOnly="True"
                                             Text="{Binding LookupScannerSessionUrl, Mode=OneWay}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Scanner URL"/>
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding LookupScannerSessionPin}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding LookupScannerSessionExpiresAtText}"
                                               Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                    <Border Margin="0,12,0,0"
                                            Width="150"
                                            Height="150"
                                            HorizontalAlignment="Left"
                                            Background="White"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <Image Source="{Binding LookupScannerQrImage}" Stretch="Uniform"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
    </ScrollViewer>
</UserControl>
