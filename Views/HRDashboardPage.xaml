<UserControl x:Class="AttendanceShiftingManagement.Views.HRDashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="HRHeaderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#DA291C" Offset="0"/>
            <GradientStop Color="#B91C1C" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="HRMetricButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Height" Value="92"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource BrandMidnightBrush}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="0,0,0,18" Background="{StaticResource HRHeaderBrush}" CornerRadius="12" Padding="16">
                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="HR Intelligence Dashboard"
                                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Role-based monitoring for recruitment, retention, performance, wellbeing, DEI, compensation, and planning."
                                   Foreground="#FFE9D5"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Width="760"/>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentDateTime}" HorizontalAlignment="Right" Foreground="White"/>
                        <TextBlock Text="{Binding CurrentTime}" HorizontalAlignment="Right" Foreground="White" FontWeight="Bold"/>
                        <TextBlock Text="{Binding LastMetricsRefresh, StringFormat='Data synced: {0}'}" HorizontalAlignment="Right" Foreground="#FFE9D5" FontSize="12"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,18">
                <materialDesign:Card Margin="6" Background="{StaticResource BrandMidnightBrush}" Padding="14" materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalEmployees}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="ACTIVE EMPLOYEES" FontSize="12" Foreground="#D1D5DB"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="6" Background="{StaticResource BrandRedBrush}" Padding="14" materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="{Binding PresentCount}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="PRESENT TODAY" FontSize="12" Foreground="#FFE9D5"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="6" Background="{StaticResource BrandYellowBrush}" Padding="14" materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="{Binding PendingLeaveCount}" FontSize="24" FontWeight="Bold" Foreground="#27251F"/>
                        <TextBlock Text="PENDING LEAVES" FontSize="12" Foreground="#27251F"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="6" Background="#111827" Padding="14" materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="{Binding ShiftCoveragePercent, StringFormat='{}{0}%'}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="SHIFT COVERAGE" FontSize="12" Foreground="#D1D5DB"/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <materialDesign:Card Grid.Row="2" Padding="16" Margin="0,0,0,18" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Essential Metrics To Include"
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                               FontWeight="Bold"
                               Foreground="{StaticResource BrandMidnightBrush}"/>
                    <TextBlock Text="Each button opens the module/view where you can manage or review that metric area."
                               Foreground="#64748B"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </materialDesign:Card>

            <UniformGrid Grid.Row="3" Columns="3" Margin="0,0,0,18">
                <Button Style="{StaticResource HRMetricButtonStyle}" Margin="6" Command="{Binding OpenRecruitmentMetricsCommand}" Background="{StaticResource BrandMidnightBrush}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlus" Width="22" Height="22" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Recruitment" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Hiring pipeline and onboarding" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource HRMetricButtonStyle}" Margin="6" Command="{Binding OpenRetentionMetricsCommand}" Background="#374151">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountGroup" Width="22" Height="22" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Retention &amp; Turnover" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Active/inactive status and exits" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource HRMetricButtonStyle}" Margin="6" Command="{Binding OpenPerformanceMetricsCommand}" Background="{StaticResource BrandRedBrush}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="TimerOutline" Width="22" Height="22" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Performance" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Attendance and punctuality trends" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource HRMetricButtonStyle}" Margin="6" Command="{Binding OpenEngagementMetricsCommand}" Background="#2563EB">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Bullhorn" Width="22" Height="22" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Engagement &amp; Wellbeing" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Leave requests and response flow" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource HRMetricButtonStyle}" Margin="6" Command="{Binding OpenDeiMetricsCommand}" Background="#7C3AED">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="BadgeAccount" Width="22" Height="22" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="DEI" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Representation and equity tracker" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource HRMetricButtonStyle}" Margin="6" Command="{Binding OpenCompensationMetricsCommand}" Background="#14532D">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CashRegister" Width="22" Height="22" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Compensation &amp; Benefits" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Payroll and overtime cost review" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource HRMetricButtonStyle}" Margin="6" Command="{Binding OpenWorkforcePlanningMetricsCommand}" Background="#0F766E">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CalendarClock" Width="22" Height="22" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Workforce Planning" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Headcount and shift coverage view" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <materialDesign:Card Grid.Row="4" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Live HR Alerts" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="#D32F2F" Margin="0,0,0,10"/>
                    <ItemsControl ItemsSource="{Binding Alerts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="6">
                                    <DockPanel>
                                        <materialDesign:PackIcon Kind="AlertCircle" Foreground="#D32F2F" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding Message}" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </materialDesign:Card>
        </Grid>
    </ScrollViewer>
</UserControl>
