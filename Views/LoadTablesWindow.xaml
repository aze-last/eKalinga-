<Window x:Class="AttendanceShiftingManagement.Views.LoadTablesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Load Tables"
        Width="1220"
        Height="780"
        MinWidth="1080"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Load Tables"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrandMidnightBrush}" />
                <TextBlock Text="Connect to the municipality source, inspect available tables, and sync the selected table into the active app database."
                           Margin="0,8,0,0"
                           FontSize="13"
                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Button DockPanel.Dock="Right"
                    Height="40"
                    Padding="16,0"
                    Style="{StaticResource GoldActionButton}"
                    Command="{Binding SyncSelectedTableCommand}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="DatabaseImport"
                                             Width="18"
                                             Height="18"
                                             Margin="0,0,8,0" />
                    <TextBlock Text="Sync Selected Table" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </DockPanel>

        <Grid Grid.Row="1" Margin="0,20,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="{StaticResource BrandBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Municipality Source Connection"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}" />

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Server / Host" />
                        <TextBox Grid.Column="2"
                                 Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Port" />
                    </Grid>

                    <TextBox Margin="0,12,0,0"
                             Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Database Name" />

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Username / Email" />
                        <TextBox Grid.Column="2"
                                 Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Password" />
                    </Grid>

                    <Border Margin="0,16,0,0"
                            Padding="14"
                            Background="{StaticResource BrandSurfaceBrush}"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Active target database"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}" />
                            <TextBlock Text="{Binding TargetSummary}"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <WrapPanel Margin="0,16,0,0">
                        <Button Content="TEST CONNECTION"
                                Margin="0,0,12,12"
                                Style="{StaticResource SecondaryActionButton}"
                                Command="{Binding TestConnectionCommand}" />
                        <Button Content="SAVE SOURCE CONNECTION"
                                Margin="0,0,12,12"
                                Style="{StaticResource SecondaryActionButton}"
                                Command="{Binding SaveSourceConnectionCommand}" />
                        <Button Content="LOAD TABLES"
                                Margin="0,0,12,12"
                                Style="{StaticResource PrimaryActionButton}"
                                Command="{Binding LoadTablesCommand}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="{StaticResource BrandBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Selected Table Summary"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}" />

                    <TextBlock Margin="0,14,0,0"
                               Text="{Binding SelectedTable, TargetNullValue=No table selected}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}" />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Margin="0,0,8,0"
                                Padding="12"
                                CornerRadius="10"
                                Background="{StaticResource BrandSurfaceBrush}">
                            <StackPanel>
                                <TextBlock Text="REMOTE ROWS"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}" />
                                <TextBlock Text="{Binding RemoteRowCount}"
                                           Margin="0,6,0,0"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="12"
                                CornerRadius="10"
                                Background="{StaticResource BrandSurfaceBrush}">
                            <StackPanel>
                                <TextBlock Text="LOCAL ROWS"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}" />
                                <TextBlock Text="{Binding LocalRowCount}"
                                           Margin="0,6,0,0"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Margin="0,16,0,0"
                               Foreground="{StaticResource BrandTextSecondaryBrush}"
                               TextWrapping="Wrap">
                        <Run Text="Remote exists: " />
                        <Run Text="{Binding ExistsInRemote}" />
                        <Run Text=" | Local exists: " />
                        <Run Text="{Binding ExistsInLocal}" />
                    </TextBlock>

                    <Border Margin="0,18,0,0"
                            Padding="14"
                            Background="{StaticResource BrandSurfaceBrush}"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel>
                            <TextBlock Text="Status"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="0,6,0,0"
                                       FontSize="12"
                                       Foreground="{Binding StatusBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="{StaticResource BrandBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Available Tables"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}" />

                    <ListBox Margin="0,14,0,0"
                             ItemsSource="{Binding Tables}"
                             SelectedItem="{Binding SelectedTable}"
                             BorderThickness="0"
                             Background="Transparent" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="{StaticResource BrandBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Table Preview"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}" />

                    <DataGrid Margin="0,14,0,0"
                              ItemsSource="{Binding PreviewRowsView}"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              MinHeight="360" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
