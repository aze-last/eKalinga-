<Window x:Class="AttendanceShiftingManagement.Views.ReportPrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report Preview"
        Width="980"
        Height="760"
        MinWidth="860"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrandSurfaceBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,16" Padding="18" CornerRadius="18" Background="White" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1">
            <DockPanel>
                <StackPanel>
                    <TextBlock x:Name="TitleTextBlock" Text="Report Preview" FontSize="20" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}" />
                    <TextBlock Margin="0,6,0,0" Text="Use Print and choose Microsoft Print to PDF if you need a PDF file." Foreground="{StaticResource BrandTextSecondaryBrush}" TextWrapping="Wrap" />
                </StackPanel>

                <WrapPanel DockPanel.Dock="Right">
                    <Button Content="PRINT / SAVE AS PDF" Margin="0,0,10,0" Style="{StaticResource GoldActionButton}" Click="PrintButton_Click" />
                    <Button Content="CLOSE" Style="{StaticResource SecondaryActionButton}" Click="CloseButton_Click" />
                </WrapPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Padding="14" CornerRadius="18" Background="White" BorderBrush="{StaticResource BrandBorderBrush}" BorderThickness="1">
            <FlowDocumentScrollViewer x:Name="PreviewViewer" VerticalScrollBarVisibility="Auto" IsSelectionEnabled="True" />
        </Border>
    </Grid>
</Window>
