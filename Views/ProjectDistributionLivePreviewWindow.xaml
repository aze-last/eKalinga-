<Window x:Class="AttendanceShiftingManagement.Views.ProjectDistributionLivePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Distribution Live Preview"
        Width="1280"
        Height="720"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="#FF0F172A">
    <Grid Margin="42">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="20" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="28" />
            <RowDefinition Height="*" />
            <RowDefinition Height="28" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock Text="Distribution Queue Monitor"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#FFCBD5E1" />
            <TextBlock Margin="0,12,0,0"
                       Text="{Binding LivePreviewProgramName}"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="White"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,8,0,0"
                       Text="{Binding LivePreviewWindowCount, StringFormat={}{0} Windows}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#FFCBD5E1" />
        </StackPanel>

        <Border Grid.Column="0"
                Grid.Row="2"
                Background="#142033"
                BorderBrush="#22324D"
                BorderThickness="2"
                CornerRadius="28"
                Padding="44">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Now Serving"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#FF93C5FD"
                           HorizontalAlignment="Center" />

                <TextBlock Grid.Row="2"
                           Text="{Binding LivePreviewPrimaryLabel}"
                           FontSize="96"
                           FontWeight="Bold"
                           Foreground="White"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center" />

                <TextBlock Grid.Row="4"
                           Text="{Binding LivePreviewSecondaryLabel}"
                           FontSize="42"
                           FontWeight="SemiBold"
                           Foreground="#FFE2E8F0"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center" />
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Grid.Row="0"
                Grid.RowSpan="5"
                Background="#142033"
                BorderBrush="#22324D"
                BorderThickness="2"
                CornerRadius="28"
                Padding="24">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Call Board"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#FFCBD5E1" />
                    <TextBlock Margin="0,10,0,0"
                               Text="Recently called beneficiaries"
                               FontSize="13"
                               Foreground="#FFE2E8F0"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,16,0,24">
                    <ItemsControl ItemsSource="{Binding LivePreviewCallBoard}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0F172A"
                                        CornerRadius="14"
                                        Padding="12"
                                        Margin="0,0,0,8"
                                        BorderBrush="#22324D"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding WindowLabel}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FF93C5FD" />
                                        <TextBlock Margin="0,3,0,0"
                                                   Text="{Binding FullName}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Next in queue"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#FFCBD5E1"
                               Margin="0,0,0,16" />

                    <ItemsControl ItemsSource="{Binding LivePreviewQueueItems}"
                                  MaxHeight="200">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0F172A"
                                        CornerRadius="14"
                                        Padding="12"
                                        Margin="0,0,0,8"
                                        BorderBrush="#22324D"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding WindowLabel}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FF93C5FD" />
                                        <TextBlock Margin="0,3,0,0"
                                                   Text="{Binding FullName}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Button Content="NEXT"
                        Command="{Binding NextLivePreviewItemCommand}"
                        Height="46"
                        DockPanel.Dock="Bottom"
                        Margin="0,12,0,0"
                        Style="{StaticResource PrimaryActionButton}" />
            </DockPanel>
        </Border>

        <Border Grid.Column="0"
                Grid.Row="4"
                Background="#142033"
                BorderBrush="#22324D"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">
            <TextBlock Text="{Binding LivePreviewQueueStatusText}"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#FFCBD5E1"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
