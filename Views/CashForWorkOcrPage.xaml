<UserControl x:Class="AttendanceShiftingManagement.Views.CashForWorkOcrPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1440"
             Background="{DynamicResource BrandSurfaceBrush}">
    <UserControl.Resources>
        <helpers:NullToHiddenConverter x:Key="NullToHiddenConverter" />
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="SidebarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryActionBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>

        <Style x:Key="DetailCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.15" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Layout Container with Blur Effect -->
        <Grid>
            <Grid.Effect>
                <BlurEffect Radius="0" x:Name="BackgroundBlur"/>
            </Grid.Effect>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnyOverlayOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="15" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar Navigation -->
                <Border Grid.Column="0" Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Dashboard Navigation -->
                        <StackPanel Grid.Row="0" Margin="20,20,20,10">
                            <Button Content="DASHBOARD" 
                                    Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="45" Margin="0,0,0,20"/>
                        </StackPanel>

                        <!-- Sidebar Actions -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Border Padding="20,0,20,20">
                                <StackPanel>
                                    <TextBlock Text="OPERATIONS" Style="{StaticResource SidebarHeaderStyle}"/>

                                    <Button Content="NEW EVENT" 
                                            Command="{Binding OpenCreateEventPanelCommand}"
                                            Style="{StaticResource GoldActionButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,8" FontSize="14"/>

                                    <Button Content="BROWSE EVENTS" 
                                            Click="Browse_Click"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,20" FontSize="14"/>

                                    <TextBlock Text="EVENT WORKFLOW" Style="{StaticResource SidebarHeaderStyle}"/>
                                    
                                    <Button Content="ADD BENEFICIARIES" 
                                            Command="{Binding OpenAddBeneficiariesPanelCommand}"
                                            Visibility="{Binding AddBeneficiariesRailVisibility}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,8" FontSize="14"/>

                                    <Button Content="SCAN ATTENDANCE" 
                                            Command="{Binding OpenScanAttendancePanelCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,8" FontSize="14"/>

                                    <Button Content="RELEASE PAYOUT" 
                                            Command="{Binding OpenPayoutPanelCommand}"
                                            Visibility="{Binding PayoutRailVisibility}"
                                            Style="{StaticResource GoldActionButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,20" FontSize="14"/>

                                    <TextBlock Text="COMMUNICATION" Style="{StaticResource SidebarHeaderStyle}"/>
                                    <Button Content="ANNOUNCEMENTS" 
                                            Command="{Binding OpenAnnouncementsPanelCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,20" FontSize="14"/>

                                    <TextBlock Text="PERSISTENCE" Style="{StaticResource SidebarHeaderStyle}"/>
                                    <Button Content="REFRESH WORKSPACE" 
                                            Command="{Binding RefreshWorkspaceCommand}" 
                                            Margin="0,0,0,8" Height="44" 
                                            Style="{StaticResource MaterialDesignOutlinedButton}" FontWeight="Bold"/>
                                    
                                    <Button Content="DELETE EVENT" 
                                            Command="{Binding DeleteEventCommand}" 
                                            Height="40" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource BrandRedBrush}"/>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>

                        <!-- Status Area -->
                        <Border Grid.Row="2" Padding="20" Background="{DynamicResource ThemeCardBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <TextBlock Text="MODULE STATUS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Main Content Area -->
                <Grid Grid.Column="1" Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Style="{StaticResource DetailCardStyle}" Padding="20,15" Margin="0,0,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: Title -->
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="CASH-FOR-WORK WORKSPACE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedEventLabel}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                            </StackPanel>

                            <!-- Center: Navigation -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                        Padding="8" Width="40" Height="40"
                                        Command="{Binding NavigatePreviousCommand}"
                                        ToolTip="Previous Event">
                                    <materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                </Button>
                                
                                <Border Margin="12,0" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="20" Padding="16,6" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                                    <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}">
                                        <Run Text="{Binding CurrentPosition, Mode=OneWay}"/>
                                    </TextBlock>
                                </Border>

                                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                        Padding="8" Width="40" Height="40"
                                        Command="{Binding NavigateNextCommand}"
                                        ToolTip="Next Event">
                                    <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                </Button>
                            </StackPanel>

                            <!-- Right: Global Actions -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="BROWSE EVENTS" Click="Browse_Click" Style="{StaticResource SecondaryActionButton}" Height="40" Padding="20,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Page Content -->
                    <Grid Grid.Row="1">
                        <!-- Empty State -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    Visibility="{Binding HasSelectedEvent, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}">
                            <materialDesign:PackIcon Kind="CalendarSearch" Width="80" Height="80" Foreground="{DynamicResource BrandBorderBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="No Event Selected" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,16,0,8" HorizontalAlignment="Center"/>
                            <TextBlock Text="Select a cash-for-work event or seminar to manage attendance and payouts." FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <Button Content="BROWSE EVENTS" Style="{StaticResource SecondaryActionButton}" Margin="0,24,0,0" Height="44" Click="Browse_Click"/>
                        </StackPanel>

                        <!-- Detail View -->
                        <ScrollViewer Visibility="{Binding HasSelectedEvent, Converter={StaticResource NullToHiddenConverter}}" 
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,0,10,0">
                                <!-- Main Summary Card -->
                                <Border Style="{StaticResource DetailCardStyle}" Padding="40,30">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header Info -->
                                        <Grid Grid.Row="0" Margin="0,0,0,30">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="EVENT TITLE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding SelectedEvent.Title}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <Border Grid.Column="1" VerticalAlignment="Top" Padding="12,6" CornerRadius="20" Background="{Binding StatusBrush}">
                                                <TextBlock Text="{Binding SelectedEvent.Status, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=UPPER}" 
                                                           Foreground="White" FontSize="12" FontWeight="Bold" Typography.Capitals="AllSmallCaps"/>
                                            </Border>
                                        </Grid>

                                        <!-- Primary Details Grid -->
                                        <UniformGrid Grid.Row="1" Columns="2">
                                            <StackPanel Margin="0,0,20,24">
                                                <TextBlock Text="LOCATION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding SelectedEvent.Location}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,0,24">
                                                <TextBlock Text="ATTENDANCE SUMMARY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding AttendanceSummary}" FontSize="16" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel Margin="0,0,20,0">
                                                <TextBlock Text="PROGRAM CAP" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding GlobalCfwBudgetCapRemaining, StringFormat='PHP {0:N2}'}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                            </StackPanel>

                                            <StackPanel>
                                                <TextBlock Text="EVENT TYPE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding EventEditorKindLabel}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                            </StackPanel>
                                        </UniformGrid>

                                        <!-- Timeline -->
                                        <Border Grid.Row="3" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="12" Padding="20" Margin="0,20,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="EVENT DATE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding SelectedEvent.EventDate, StringFormat='MMMM dd, yyyy'}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="START TIME" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding SelectedEvent.StartTime, StringFormat='hh\\:mm'}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="END TIME" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding SelectedEvent.EndTime, StringFormat='hh\\:mm'}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Actions -->
                                        <StackPanel Grid.Row="4" Margin="0,30,0,0" Orientation="Horizontal">
                                            <Button Content="EDIT EVENT DETAILS" Command="{Binding OpenEditEventPanelCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="45" Padding="20,0" Margin="0,0,12,0"/>
                                            <Button Content="SAVE PDF SHEET" Command="{Binding SaveAttendanceSheetPdfCommand}" Style="{StaticResource GoldActionButton}" Height="45" Padding="20,0" Margin="0,0,12,0"/>
                                            <Button Content="PRINT PREVIEW" Command="{Binding PrintAttendanceSheetCommand}" Style="{StaticResource MaterialDesignFlatButton}" Height="45" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Attendance List Section -->
                                <Border Style="{StaticResource DetailCardStyle}" Margin="0,10,0,30">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False" Margin="0,0,0,20">
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="ATTENDANCE LOG" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}" Typography.Capitals="AllSmallCaps" Margin="0,0,0,4"/>
                                                <TextBlock Text="Recent captures for this workspace." Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                            </StackPanel>
                                            
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="EDIT LOG" Command="{Binding EditAttendanceCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource ThemePrimaryActionBrush}" Margin="0,0,8,0"/>
                                                <Button Content="DELETE" Command="{Binding DeleteAttendanceCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource BrandRedBrush}"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <DataGrid ItemsSource="{Binding SavedAttendanceRows}"
                                                  SelectedItem="{Binding SelectedAttendanceRow}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  IsReadOnly="True"
                                                  Height="400"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  HeadersVisibility="Column"
                                                  materialDesign:DataGridAssist.CellPadding="12,8">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="NAME" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                                                <DataGridTextColumn Header="BENEFICIARY ID" Binding="{Binding BeneficiaryId}" Width="130"/>
                                                <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="110"/>
                                                <DataGridTextColumn Header="SOURCE" Binding="{Binding Source}" Width="130"/>
                                                <DataGridTextColumn Header="RECORDED" Binding="{Binding RecordedAt, StringFormat='{}{0:MMM dd, hh:mm tt}'}" Width="150"/>
                                            </DataGrid.Columns>
                                        </DataGrid>

                                        <!-- Pagination -->
                                        <Border Margin="0,20,0,0" Padding="0,15,0,0" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                                            <Grid>
                                                <TextBlock Text="{Binding AttendancePageSummary}" VerticalAlignment="Center" Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                                
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Command="{Binding PreviousAttendancePageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0">
                                                        <materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24"/>
                                                    </Button>
                                                    <TextBlock Text="{Binding AttendanceCurrentPage}" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                    <Button Command="{Binding NextAttendancePageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0">
                                                        <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- Backdrop for Overlays -->
        <Border Background="#CC0F172A" Visibility="{Binding IsAnyOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="100"/>

        <!-- Operational Overlays -->
        <Grid Panel.ZIndex="110" Visibility="{Binding IsAnyOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Margin" Value="100,60" />
                    <Style.Triggers>
                        <!-- Larger margin for announcements panel -->
                        <DataTrigger Binding="{Binding AnnouncementsVisibility}" Value="Visible">
                            <Setter Property="Margin" Value="60,40" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Border Style="{StaticResource PanelCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Panel Header -->
                    <Border Grid.Row="0" Padding="30,20" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="16,16,0,0" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DrawerTitle, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=UPPER}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4" Typography.Capitals="AllSmallCaps"/>
                                <TextBlock Text="{Binding DrawerSubtitle}" FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button Grid.Column="1" Command="{Binding ClosePanelCommand}" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0">
                                <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Panel Content Area -->
                    <Grid Grid.Row="1">
                        <ScrollViewer Visibility="{Binding EventEditorVisibility}" VerticalScrollBarVisibility="Auto" Padding="30">
                            <StackPanel>
                                <TextBlock Text="EVENT DETAILS" Style="{StaticResource SidebarHeaderStyle}" Margin="0,0,0,20"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Event Title" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                        <TextBox Text="{Binding EventTitle, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="e.g. Clean-up Drive Batch 1"/>

                                        <TextBlock Text="Location" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,8,0,8"/>
                                        <TextBox Text="{Binding EventLocation, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="e.g. Barangay Hall Plaza"/>

                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Start Date" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                                <DatePicker SelectedDate="{Binding EventDate}" Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Finish Date" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                                <DatePicker SelectedDate="{Binding FinishDate}" Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Event Type" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding EventKinds}" SelectedItem="{Binding EventEditorKind}" Height="45" Margin="0,0,0,20"/>

                                        <TextBlock Text="Benefit Type" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding BenefitTypes}" SelectedItem="{Binding BenefitType}" Height="45" Margin="0,0,0,20"/>

                                        <StackPanel Visibility="{Binding IsCashBenefit, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Per-Person Amount" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                            <TextBox Text="{Binding EventAmountText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="0.00"/>
                                        </StackPanel>

                                        <StackPanel Visibility="{Binding IsGoodsBenefit, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock Text="Goods Description" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                            <TextBox Text="{Binding BenefitDescription, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="e.g. 5kg Rice, Canned Goods"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,24,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Start Time" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                        <TextBox Text="{Binding EventStartTime, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="HH:mm (24-hour)"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="End Time" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                        <TextBox Text="{Binding EventEndTime, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="HH:mm (24-hour)"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,24,0,0">
                                    <TextBlock Text="Internal Notes" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                    <TextBox Text="{Binding EventNotes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" AcceptsReturn="True" MinHeight="100" VerticalContentAlignment="Top" materialDesign:HintAssist.Hint="Optional remarks..."/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Beneficiaries Panel -->
                        <Grid Visibility="{Binding BeneficiariesVisibility}" Margin="30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Margin="0,0,0,24">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" Margin="0,0,16,0" ItemsSource="{Binding EligibleBeneficiaries}" SelectedItem="{Binding SelectedEligibleBeneficiary}" DisplayMemberPath="DisplayLabel" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:HintAssist.Hint="Search approved beneficiary..."/>
                                    <Button Grid.Column="1" Content="ADD TO EVENT" Command="{Binding AddParticipantCommand}" Style="{StaticResource GoldActionButton}" Height="45" Padding="30,0"/>
                                </Grid>
                            </Border>

                            <DataGrid Grid.Row="1" ItemsSource="{Binding Participants}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Background="Transparent" BorderThickness="0" HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="NAME" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                                    <DataGridTextColumn Header="BENEFICIARY ID" Binding="{Binding BeneficiaryId}" Width="150"/>
                                    <DataGridTextColumn Header="CIVIL REGISTRY ID" Binding="{Binding CivilRegistryId}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <!-- Scan Attendance Panel -->
                        <Grid Visibility="{Binding ScanAttendanceVisibility}" Margin="30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="400" />
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Scanner Controls -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MOBILE GATEWAY" Style="{StaticResource SidebarHeaderStyle}" Margin="0,0,0,20"/>
                                
                                <Border Style="{StaticResource DetailCardStyle}" Padding="20">
                                    <StackPanel>
                                        <Button Content="CREATE SCANNER SESSION" Command="{Binding CreateAttendanceScannerSessionCommand}" Style="{StaticResource GoldActionButton}" Height="45" Margin="0,0,0,20"/>
                                        
                                        <materialDesign:Card Visibility="{Binding AttendanceScannerSessionUrl, Converter={StaticResource NullToHiddenConverter}}" Padding="16" Background="{DynamicResource BrandMidnightBrush}" UniformCornerRadius="12">
                                            <StackPanel>
                                                <Border Background="White" Padding="8" CornerRadius="8" HorizontalAlignment="Center">
                                                    <Image Source="{Binding AttendanceScannerQrImage}" Height="180" Width="180" Stretch="Uniform"/>
                                                </Border>
                                                
                                                <StackPanel Margin="0,16,0,0" HorizontalAlignment="Center">
                                                    <TextBlock Text="PIN CODE" FontSize="10" Foreground="#94A3B8" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding AttendanceScannerSessionPin}" FontSize="32" Foreground="White" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding AttendanceScannerSessionExpiresAtText}" FontSize="11" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </materialDesign:Card>
                                        
                                        <TextBlock Text="Scan the QR above using the staff phone app or navigate to the session URL to begin capturing attendance." Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12" Margin="0,16,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Manual Attendance / Participant List -->
                            <Border Grid.Column="2" Visibility="{Binding ManualAttendanceVisibility}" Style="{StaticResource DetailCardStyle}" Padding="24">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,20">
                                        <TextBlock Text="MANUAL MARKING" Style="{StaticResource SidebarHeaderStyle}" DockPanel.Dock="Left"/>
                                        <Button Content="SAVE PRESENT" Command="{Binding SaveManualAttendanceCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="36" DockPanel.Dock="Right"/>
                                    </DockPanel>

                                    <DataGrid Grid.Row="1" ItemsSource="{Binding Participants}" AutoGenerateColumns="False" CanUserAddRows="False" Background="Transparent" BorderThickness="0" HeadersVisibility="Column">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Header="PRESENT" Binding="{Binding IsMarkedPresent, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                            <DataGridTextColumn Header="NAME" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="ID" Binding="{Binding BeneficiaryId}" Width="120" IsReadOnly="True"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    
                                    <TextBlock Grid.Row="2" Text="Mark beneficiaries as present manually if scanning is not available." FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,12,0,0"/>
                                </Grid>
                            </Border>
                            
                            <!-- Seminar Hint -->
                            <Border Grid.Column="2" Visibility="{Binding SeminarScannerHintVisibility}" VerticalAlignment="Top" Style="{StaticResource DetailCardStyle}" Background="{DynamicResource ThemeAccentSoftBrush}" BorderBrush="{DynamicResource ThemeAccentBorderBrush}">
                                <StackPanel>
                                    <TextBlock Text="SEMINAR ATTENDANCE" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="Seminar attendance is open scan-based. Beneficiaries register their attendance by scanning their QR IDs without prior assignment." Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Payout Panel -->
                        <ScrollViewer Visibility="{Binding PayoutVisibility}" VerticalScrollBarVisibility="Auto" Padding="30">
                            <StackPanel>
                                <Border Style="{StaticResource DetailCardStyle}" Background="{DynamicResource ThemeAccentSoftBrush}" BorderBrush="{DynamicResource ThemeAccentBorderBrush}" Padding="30">
                                    <StackPanel>
                                        <TextBlock Text="PAYOUT SUMMARY" Style="{StaticResource SidebarHeaderStyle}" Margin="0,0,0,20"/>
                                        
                                        <TextBlock Text="{Binding ReleaseSummaryEventLabel}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding ReleaseSummaryStatusText}" Foreground="{Binding ReleaseSummaryStatusBrush}" FontWeight="Bold" Margin="0,8,0,0" FontSize="16"/>
                                        <TextBlock Text="{Binding ReleaseSummaryDetail}" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,8,0,24" TextWrapping="Wrap"/>

                                        <UniformGrid Columns="4">
                                            <StackPanel>
                                                <TextBlock Text="APPROVED" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding ApprovedParticipantCount}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="PRESENT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandSuccessBrush}"/>
                                                <TextBlock Text="{Binding PresentParticipantCount}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrandSuccessBrush}"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="PENDING" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding PendingParticipantCount}" FontSize="28" FontWeight="Bold" Foreground="#92400E"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="MANUAL" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding ManualAttendanceCount}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource DetailCardStyle}" Margin="0,20,0,0">
                                    <StackPanel>
                                        <TextBlock Text="RELEASE DISBURSEMENT" Style="{StaticResource SidebarHeaderStyle}" Margin="0,0,0,20"/>
                                        
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="200"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0" Margin="0,0,24,0">
                                                <TextBlock Text="Amount to Release (per person)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                                <TextBox Text="{Binding ReleaseAmountText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="PHP 0.00"/>
                                            </StackPanel>
                                            
                                            <Button Grid.Column="1" Content="RELEASE BUDGET" Command="{Binding ReleaseBudgetCommand}" Style="{StaticResource GoldActionButton}" Height="45" VerticalAlignment="Bottom"/>
                                        </Grid>
                                        
                                        <TextBlock Text="Performing this action will record the payout for all present participants and deduct from the global program budget." Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12" Margin="0,20,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Announcements Panel -->
                        <Grid Visibility="{Binding AnnouncementsVisibility}" Margin="30">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <DockPanel Grid.Row="0" Margin="0,0,0,24">
                                <TextBlock Text="ACTIVE ANNOUNCEMENTS" Style="{StaticResource SidebarHeaderStyle}" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0"/>
                                <Button Content="REFRESH WORKSPACE" Command="{Binding RefreshWorkspaceCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="36" DockPanel.Dock="Right"/>
                            </DockPanel>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding OpenAnnouncements}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource DetailCardStyle}" Padding="24">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                        <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,4,0,12" TextWrapping="Wrap"/>
                                                        
                                                        <StackPanel Orientation="Horizontal">
                                                            <Border Background="{DynamicResource ThemeCardSubtleBrush}" Padding="10,4" CornerRadius="4" Margin="0,0,8,0">
                                                                <TextBlock Text="{Binding Kind}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding DateLabel}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                            <TextBlock Text="{Binding Location}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    
                                                    <Button Grid.Column="1" Content="LOAD EVENT" 
                                                            Command="{Binding DataContext.SelectAnnouncementEventCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                            CommandParameter="{Binding EventId}"
                                                            Style="{StaticResource GoldActionButton}" Height="40" Padding="20,0" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- Panel Footer -->
                    <Border Grid.Row="2" Padding="30,20" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="0,0,16,16" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="CLOSE" Command="{Binding ClosePanelCommand}" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,12,0"/>
                                
                                <Button Content="{Binding EventEditorSubmitLabel}" Command="{Binding SaveEventCommand}" Style="{StaticResource GoldActionButton}" Width="200" Height="45" Visibility="{Binding EventEditorVisibility}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
