<UserControl x:Class="AttendanceShiftingManagement.Views.CashForWorkOcrPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1440"
             Background="{DynamicResource BrandSurfaceBrush}">
    <UserControl.Resources>
        <Style x:Key="RailButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButton}">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,0" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="OverviewPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelCardStyle}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DrawerVisibility}" Value="Visible">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="24"
                Padding="20"
                CornerRadius="22"
                Background="{DynamicResource ThemeCardRaisedBrush}"
                BorderBrush="{DynamicResource BrandBorderBrush}"
                BorderThickness="1">
            <StackPanel>
                <Border Padding="14"
                        Margin="0,0,0,18"
                        CornerRadius="16"
                        Background="{DynamicResource ThemeAccentSoftBrush}"
                        BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Selected Event"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding SelectedEventLabel}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrandMidnightBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Button Content="Dashboard"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                <Button Content="Create Event"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding OpenCreateEventPanelCommand}" />
                <Button Content="Seminar"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding OpenSeminarPanelCommand}" />
                <Button Content="Add Beneficiaries"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding OpenAddBeneficiariesPanelCommand}" />
                <Button Content="Scan Attendance"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding OpenScanAttendancePanelCommand}" />
                <Button Content="Payout"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding OpenPayoutPanelCommand}" />
                <Button Content="Refresh Workspace"
                        Height="42"
                        Margin="0,12,0,0"
                        Style="{StaticResource GoldActionButton}"
                        Command="{Binding RefreshWorkspaceCommand}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="2"
                      Margin="0,24,24,24"
                      VerticalScrollBarVisibility="Auto">
            <Border Padding="20"
                    CornerRadius="22"
                    Background="{DynamicResource ThemeCardBrush}"
                    BorderBrush="{DynamicResource BrandBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.6*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  Margin="0,0,16,0"
                                  ItemsSource="{Binding Events}"
                                  SelectedItem="{Binding SelectedEvent}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Select Event">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                        <TextBlock Text="{Binding WorkspaceLabel}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Border Grid.Column="1"
                                Padding="16"
                                CornerRadius="16"
                                Background="{DynamicResource ThemeAccentSoftBrush}"
                                BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedEventLabel}"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrandMidnightBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding AttendanceSummary}"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Margin="0,0,0,18"
                               Text="{Binding StatusMessage}"
                               FontWeight="SemiBold"
                               Foreground="{Binding StatusBrush}"
                               TextWrapping="Wrap" />

                    <Border Style="{StaticResource OverviewPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Attendance List"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="Use the left rail to switch workflows. The selected event attendance stays here by default."
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,18,0,0"
                                       Text="Select an event from the dropdown to load attendance."
                                       Visibility="{Binding NoSelectedEventVisibility}"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" />

                            <DataGrid Margin="0,18,0,0"
                                      Visibility="{Binding SelectedEventVisibility}"
                                      ItemsSource="{Binding SavedAttendanceRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      MinHeight="320"
                                      Background="{DynamicResource ThemeCardSubtleBrush}"
                                      BorderBrush="{DynamicResource BrandBorderBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*" />
                                    <DataGridTextColumn Header="Beneficiary ID" Binding="{Binding BeneficiaryId}" Width="130" />
                                    <DataGridTextColumn Header="Civil Registry ID" Binding="{Binding CivilRegistryId}" Width="150" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="140" />
                                    <DataGridTextColumn Header="Recorded" Binding="{Binding RecordedAt, StringFormat='{}{0:MMM dd, yyyy hh:mm tt}'}" Width="180" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}"
                            Visibility="{Binding EventEditorVisibility}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding DrawerTitle}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding DrawerSubtitle}"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Back to List"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding ClosePanelCommand}" />
                            </DockPanel>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0"
                                         Grid.Column="0"
                                         Margin="0,0,12,12"
                                         Text="{Binding EventTitle, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Event Title" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="12,0,0,12"
                                         Text="{Binding EventLocation, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Location" />

                                <DatePicker Grid.Row="1"
                                            Grid.Column="0"
                                            Margin="0,0,12,12"
                                            SelectedDate="{Binding EventDate}"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                            materialDesign:HintAssist.Hint="Event Date" />
                                <Grid Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="12,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Margin="0,0,6,0"
                                             Text="{Binding EventStartTime, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Start Time (HH:mm)" />
                                    <TextBox Grid.Column="1"
                                             Margin="6,0,0,0"
                                             Text="{Binding EventEndTime, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="End Time (HH:mm)" />
                                </Grid>

                                <TextBox Grid.Row="2"
                                         Grid.ColumnSpan="2"
                                         MinHeight="120"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding EventNotes, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Notes" />
                            </Grid>

                            <Button Content="{Binding EventEditorSubmitLabel}"
                                    Margin="0,18,0,0"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource GoldActionButton}"
                                    Command="{Binding SaveEventCommand}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}"
                            Visibility="{Binding BeneficiariesVisibility}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding DrawerTitle}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding DrawerSubtitle}"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Back to List"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding ClosePanelCommand}" />
                            </DockPanel>

                            <TextBlock Margin="0,18,0,0"
                                       Visibility="{Binding NoSelectedEventVisibility}"
                                       Text="Select an event first before assigning beneficiaries."
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" />

                            <StackPanel Margin="0,18,0,0"
                                        Visibility="{Binding SelectedEventVisibility}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0"
                                              Margin="0,0,16,0"
                                              ItemsSource="{Binding EligibleBeneficiaries}"
                                              SelectedItem="{Binding SelectedEligibleBeneficiary}"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              materialDesign:HintAssist.Hint="Approved Beneficiary">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayLabel}" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <Button Grid.Column="1"
                                            Content="Add Beneficiary"
                                            Style="{StaticResource GoldActionButton}"
                                            Command="{Binding AddParticipantCommand}" />
                                </Grid>

                                <DataGrid Margin="0,18,0,0"
                                          ItemsSource="{Binding Participants}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          MinHeight="260"
                                          Background="{DynamicResource ThemeCardSubtleBrush}"
                                          BorderBrush="{DynamicResource BrandBorderBrush}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*" />
                                        <DataGridTextColumn Header="Beneficiary ID" Binding="{Binding BeneficiaryId}" Width="150" />
                                        <DataGridTextColumn Header="Civil Registry ID" Binding="{Binding CivilRegistryId}" Width="170" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}"
                            Visibility="{Binding ScanAttendanceVisibility}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding DrawerTitle}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding DrawerSubtitle}"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Back to List"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding ClosePanelCommand}" />
                            </DockPanel>

                            <TextBlock Margin="0,18,0,0"
                                       Visibility="{Binding NoSelectedEventVisibility}"
                                       Text="Select an event first before capturing attendance."
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" />

                            <Grid Margin="0,18,0,0"
                                  Visibility="{Binding SelectedEventVisibility}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.05*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="1.2*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Padding="18"
                                        CornerRadius="16"
                                        Background="{DynamicResource ThemeAccentSoftBrush}"
                                        BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Scanner Session"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="Open a phone scanner session using the shared scanner gateway."
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />

                                        <Button Margin="0,16,0,0"
                                                Content="Start Scanner Session"
                                                HorizontalAlignment="Left"
                                                Style="{StaticResource GoldActionButton}"
                                                Command="{Binding CreateAttendanceScannerSessionCommand}" />

                                        <TextBox Margin="0,16,0,0"
                                                 IsReadOnly="True"
                                                 Text="{Binding AttendanceScannerSessionUrl, Mode=OneWay}"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 materialDesign:HintAssist.Hint="Scanner URL" />

                                        <Border Margin="0,12,0,0"
                                                Padding="16"
                                                CornerRadius="14"
                                                Background="{DynamicResource ThemeCardBrush}"
                                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="Session PIN"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding AttendanceScannerSessionPin}"
                                                           FontSize="28"
                                                           FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding AttendanceScannerSessionExpiresAtText}"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="0,12,0,0"
                                                Padding="14"
                                                CornerRadius="14"
                                                Background="{DynamicResource ThemeCardBrush}"
                                                BorderBrush="{DynamicResource BrandBorderBrush}"
                                                BorderThickness="1">
                                            <Viewbox Stretch="Uniform">
                                                <Border Width="180"
                                                        Height="180"
                                                        Background="{DynamicResource ThemeCardSubtleBrush}"
                                                        BorderBrush="{DynamicResource BrandBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Image Source="{Binding AttendanceScannerQrImage}"
                                                           Stretch="Uniform" />
                                                </Border>
                                            </Viewbox>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Padding="18"
                                        CornerRadius="16"
                                        Background="{DynamicResource ThemeCardSubtleBrush}"
                                        BorderBrush="{DynamicResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel LastChildFill="False">
                                            <StackPanel DockPanel.Dock="Left">
                                                <TextBlock Text="Manual Attendance"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                                <TextBlock Margin="0,6,0,0"
                                                           Text="Mark assigned beneficiaries as present when attendance is captured manually."
                                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Content="Save Manual Attendance"
                                                    Style="{StaticResource SecondaryActionButton}"
                                                    Command="{Binding SaveManualAttendanceCommand}" />
                                        </DockPanel>

                                        <TextBlock Margin="0,16,0,0"
                                                   Text="Add beneficiaries from the left rail first if the attendance list is empty."
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />

                                        <DataGrid Margin="0,16,0,0"
                                                  ItemsSource="{Binding Participants}"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  HeadersVisibility="Column"
                                                  RowHeaderWidth="0"
                                                  MinHeight="300"
                                                  Background="{DynamicResource ThemeCardBrush}"
                                                  BorderBrush="{DynamicResource BrandBorderBrush}">
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Header="Present"
                                                                        Binding="{Binding IsMarkedPresent}"
                                                                        Width="90" />
                                                <DataGridTextColumn Header="Name"
                                                                    Binding="{Binding FullName}"
                                                                    Width="*" />
                                                <DataGridTextColumn Header="Beneficiary ID"
                                                                    Binding="{Binding BeneficiaryId}"
                                                                    Width="140" />
                                                <DataGridTextColumn Header="Civil Registry ID"
                                                                    Binding="{Binding CivilRegistryId}"
                                                                    Width="160" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource PanelCardStyle}"
                            Visibility="{Binding PayoutVisibility}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding DrawerTitle}"
                                               FontSize="22"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding DrawerSubtitle}"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="Back to List"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding ClosePanelCommand}" />
                            </DockPanel>

                            <TextBlock Margin="0,18,0,0"
                                       Visibility="{Binding NoSelectedEventVisibility}"
                                       Text="Select an event first before releasing funds."
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" />

                            <StackPanel Margin="0,18,0,0"
                                        Visibility="{Binding SelectedEventVisibility}">
                                <Border Padding="18"
                                        CornerRadius="16"
                                        Background="{DynamicResource ThemeAccentSoftBrush}"
                                        BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ReleaseSummaryEventLabel}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource BrandMidnightBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding ReleaseSummaryStatusText}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding ReleaseSummaryStatusBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding ReleaseSummaryDetail}"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />

                                        <UniformGrid Margin="0,16,0,0"
                                                     Columns="4">
                                            <Border Style="{StaticResource MetricCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ApprovedParticipantCount, StringFormat=N0}"
                                                               FontSize="24"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                                    <TextBlock Text="APPROVED"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource MetricCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding PresentParticipantCount, StringFormat=N0}"
                                                               FontSize="24"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource BrandSuccessBrush}" />
                                                    <TextBlock Text="PRESENT"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Style="{StaticResource MetricCardStyle}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding PendingParticipantCount, StringFormat=N0}"
                                                               FontSize="24"
                                                               FontWeight="Bold"
                                                               Foreground="#92400E" />
                                                    <TextBlock Text="PENDING"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Padding="14"
                                                    Margin="0,0,0,12"
                                                    CornerRadius="14"
                                                    Background="{DynamicResource ThemeCardBrush}"
                                                    BorderBrush="{DynamicResource BrandBorderBrush}"
                                                    BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ManualAttendanceCount, StringFormat=N0}"
                                                               FontSize="24"
                                                               FontWeight="Bold"
                                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                                    <TextBlock Text="MANUAL"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <ComboBox Grid.Column="0"
                                              Margin="0,0,12,0"
                                              ItemsSource="{Binding AyudaPrograms}"
                                              SelectedItem="{Binding SelectedAyudaProgram}"
                                              DisplayMemberPath="ProgramName"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              materialDesign:HintAssist.Hint="Ayuda Program" />

                                    <TextBox Grid.Column="1"
                                             Margin="12,0,12,0"
                                             Text="{Binding ReleaseAmountText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Release Amount" />

                                    <Button Grid.Column="2"
                                            Content="Release Budget"
                                            Style="{StaticResource GoldActionButton}"
                                            Command="{Binding ReleaseBudgetCommand}" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
