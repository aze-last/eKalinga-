<UserControl x:Class="AttendanceShiftingManagement.Views.CashForWorkOcrPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1280"
             Background="{StaticResource BrandSurfaceBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Margin="0,0,0,20" Padding="20" Background="White">
                <StackPanel>
                    <TextBlock Text="Cash-for-Work Operations" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                    <TextBlock Text="Create work events, assign approved participants, record attendance manually or through the phone scanner, and release cash-for-work budgets."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource BrandTextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </materialDesign:Card>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <materialDesign:Card Padding="18" Margin="0,0,0,16" Background="White">
                        <StackPanel>
                            <TextBlock Text="Create Event" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBox Margin="0,14,0,0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Event Title"
                                     Text="{Binding EventTitle, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Margin="0,12,0,0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Location / Site"
                                     Text="{Binding EventLocation, UpdateSourceTrigger=PropertyChanged}"/>
                            <DatePicker Margin="0,12,0,0" SelectedDate="{Binding EventDate}"/>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Start (HH:mm)"
                                         Text="{Binding EventStartTime, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBox Grid.Column="2"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="End (HH:mm)"
                                         Text="{Binding EventEndTime, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBox Margin="0,12,0,0"
                                     Height="70"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Notes"
                                     Text="{Binding EventNotes, UpdateSourceTrigger=PropertyChanged}"/>

                            <Button Content="Create Cash-for-Work Event"
                                    Margin="0,14,0,0"
                                    Height="42"
                                    Style="{StaticResource PrimaryActionButton}"
                                    Command="{Binding CreateEventCommand}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="18" Margin="0,0,0,16" Background="White">
                        <StackPanel>
                            <TextBlock Text="Select Event" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <ComboBox Margin="0,14,0,0"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding Events}"
                                      SelectedItem="{Binding SelectedEvent}"
                                      DisplayMemberPath="Title"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="18" Margin="0,0,0,16" Background="White">
                        <StackPanel>
                            <TextBlock Text="Phone Scanner Session" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBlock Text="Create a temporary QR session plus 6-digit PIN for the employee phone scanner."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                            <Button Content="Create Attendance Scanner Session"
                                    Margin="0,14,0,0"
                                    Height="42"
                                    Style="{StaticResource GoldActionButton}"
                                    Command="{Binding CreateAttendanceScannerSessionCommand}"/>
                            <TextBox Margin="0,12,0,0"
                                     IsReadOnly="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Scanner URL"
                                     Text="{Binding AttendanceScannerSessionUrl, Mode=OneWay}"/>
                            <TextBlock Margin="0,10,0,0"
                                       Text="{Binding AttendanceScannerSessionPin}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding AttendanceScannerSessionExpiresAtText}"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                            <Border Margin="0,14,0,0"
                                    Width="180"
                                    Height="180"
                                    HorizontalAlignment="Left"
                                    Background="White"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Image Source="{Binding AttendanceScannerQrImage}" Stretch="Uniform"/>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="18" Background="White">
                        <StackPanel>
                            <TextBlock Text="Approved Beneficiaries" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBlock Text="{Binding AttendanceSummary}" Margin="0,6,0,0" Foreground="{StaticResource BrandTextSecondaryBrush}" TextWrapping="Wrap"/>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding EligibleBeneficiaries}"
                                          SelectedItem="{Binding SelectedEligibleBeneficiary}"
                                          DisplayMemberPath="DisplayLabel"/>

                                <Button Grid.Column="2"
                                        Content="Add"
                                        Width="100"
                                        Height="42"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding AddParticipantCommand}"/>
                            </Grid>

                            <DataGrid Margin="0,14,0,0"
                                      ItemsSource="{Binding Participants}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      Height="250"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Present" Binding="{Binding IsMarkedPresent}" Width="70"/>
                                    <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                                    <DataGridTextColumn Header="Beneficiary ID" Binding="{Binding BeneficiaryId}" Width="120"/>
                                    <DataGridTextColumn Header="Civil Registry ID" Binding="{Binding CivilRegistryId}" Width="140"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Button Content="Save Manual Attendance"
                                    Margin="0,14,0,0"
                                    Height="42"
                                    Style="{StaticResource PrimaryActionButton}"
                                    Command="{Binding SaveManualAttendanceCommand}"/>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <materialDesign:Card Padding="18" Margin="0,0,0,16" Background="White">
                        <StackPanel>
                            <TextBlock Text="Operation Status" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBlock Text="Current workflow and release updates appear here."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>

                            <Border Margin="0,14,0,0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BrandBorderBrush}">
                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="{StaticResource BrandMidnightBrush}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="18" Background="White">
                        <StackPanel>
                            <TextBlock Text="Release-ready Summary" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBlock Text="{Binding ReleaseSummaryEventLabel}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>

                            <Border Margin="0,12,0,0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding ReleaseSummaryStatusText}"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding ReleaseSummaryStatusBrush}"/>
                                    <TextBlock Text="{Binding ReleaseSummaryDetail}"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <UniformGrid Margin="0,14,0,0" Columns="4">
                                <Border Margin="0,0,8,0" Padding="10" CornerRadius="8" Background="#EEF4FF">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ApprovedParticipantCount, StringFormat=N0}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                        <TextBlock Text="APPROVED" FontSize="10" Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,8,0" Padding="10" CornerRadius="8" Background="#ECFDF5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding PresentParticipantCount, StringFormat=N0}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource BrandSuccessBrush}"/>
                                        <TextBlock Text="PRESENT" FontSize="10" Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,8,0" Padding="10" CornerRadius="8" Background="#FEF3C7">
                                    <StackPanel>
                                        <TextBlock Text="{Binding PendingParticipantCount, StringFormat=N0}" FontSize="22" FontWeight="SemiBold" Foreground="#92400E"/>
                                        <TextBlock Text="PENDING" FontSize="10" Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,8,0" Padding="10" CornerRadius="8" Background="#F3F4F6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ManualAttendanceCount, StringFormat=N0}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                        <TextBlock Text="MANUAL" FontSize="10" Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="180"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding AyudaPrograms}"
                                          SelectedItem="{Binding SelectedAyudaProgram}"
                                          DisplayMemberPath="ProgramName"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          materialDesign:HintAssist.Hint="Ayuda program / event"/>

                                <TextBox Grid.Column="2"
                                         Text="{Binding ReleaseAmountText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Release amount"/>

                                <Button Grid.Column="4"
                                        Content="Release C4W Budget"
                                        Height="42"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding ReleaseBudgetCommand}"/>
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="18" Margin="0,16,0,0" Background="White">
                        <StackPanel>
                            <TextBlock Text="Release-ready Attendance Records" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <DataGrid Margin="0,14,0,0"
                                      ItemsSource="{Binding SavedAttendanceRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      MinHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                                    <DataGridTextColumn Header="Beneficiary ID" Binding="{Binding BeneficiaryId}" Width="120"/>
                                    <DataGridTextColumn Header="Civil Registry ID" Binding="{Binding CivilRegistryId}" Width="140"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="90"/>
                                    <DataGridTextColumn Header="Recorded" Binding="{Binding RecordedAt, StringFormat='{}{0:MMM dd, hh:mm tt}'}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
