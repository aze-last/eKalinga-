<UserControl x:Class="AttendanceShiftingManagement.Views.CashForWorkOcrPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="860"
             d:DesignWidth="1280"
             Background="{StaticResource BrandSurfaceBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0" Margin="0,0,0,20" Padding="20" Background="White">
                <DockPanel LastChildFill="False">
                    <StackPanel>
                        <TextBlock Text="Cash-for-Work Operations" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                        <TextBlock Text="Create work events, assign approved participants, save manual attendance, and optionally test OCR-assisted attendance later."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource BrandTextSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border DockPanel.Dock="Right"
                            Padding="12,8"
                            CornerRadius="8"
                            Background="{StaticResource BrandSurfaceBrush}"
                            BorderThickness="1"
                            BorderBrush="{StaticResource BrandBorderBrush}">
                        <StackPanel>
                            <TextBlock Text="OCR Tools (Optional)" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <ComboBox Margin="0,10,0,0"
                                      MinWidth="260"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding OcrProfiles}"
                                      SelectedItem="{Binding SelectedOcrProfile}"
                                      DisplayMemberPath="Name"/>
                            <TextBlock Text="{Binding OcrStatusText}" Foreground="{Binding OcrStatusBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                            <Button Content="Refresh Status"
                                    Margin="0,10,0,0"
                                    Style="{StaticResource SecondaryActionButton}"
                                    Command="{Binding RefreshOcrStatusCommand}"/>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </materialDesign:Card>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <materialDesign:Card Padding="18" Margin="0,0,0,16" Background="White">
                        <StackPanel>
                            <TextBlock Text="Create Event" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBox Margin="0,14,0,0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Event Title"
                                     Text="{Binding EventTitle, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Margin="0,12,0,0"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Location / Site"
                                     Text="{Binding EventLocation, UpdateSourceTrigger=PropertyChanged}"/>
                            <DatePicker Margin="0,12,0,0" SelectedDate="{Binding EventDate}"/>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Start (HH:mm)"
                                         Text="{Binding EventStartTime, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBox Grid.Column="2"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="End (HH:mm)"
                                         Text="{Binding EventEndTime, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBox Margin="0,12,0,0"
                                     Height="70"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Notes"
                                     Text="{Binding EventNotes, UpdateSourceTrigger=PropertyChanged}"/>

                            <Button Content="Create Cash-for-Work Event"
                                    Margin="0,14,0,0"
                                    Height="42"
                                    Style="{StaticResource PrimaryActionButton}"
                                    Command="{Binding CreateEventCommand}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="18" Margin="0,0,0,16" Background="White">
                        <StackPanel>
                            <TextBlock Text="Select Event" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <ComboBox Margin="0,14,0,0"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      ItemsSource="{Binding Events}"
                                      SelectedItem="{Binding SelectedEvent}"
                                      DisplayMemberPath="Title"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="18" Background="White">
                        <StackPanel>
                            <TextBlock Text="Approved Participants" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBlock Text="{Binding AttendanceSummary}" Margin="0,6,0,0" Foreground="{StaticResource BrandTextSecondaryBrush}" TextWrapping="Wrap"/>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding EligibleMembers}"
                                          SelectedItem="{Binding SelectedEligibleMember}"
                                          DisplayMemberPath="FullName"/>

                                <Button Grid.Column="2"
                                        Content="Add"
                                        Width="100"
                                        Height="42"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding AddParticipantCommand}"/>
                            </Grid>

                            <DataGrid Margin="0,14,0,0"
                                      ItemsSource="{Binding Participants}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      Height="250"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Present" Binding="{Binding IsMarkedPresent}" Width="70"/>
                                    <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                                    <DataGridTextColumn Header="Household" Binding="{Binding HouseholdCode}" Width="110"/>
                                    <DataGridTextColumn Header="Purok" Binding="{Binding Purok}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Button Content="Save Manual Attendance"
                                    Margin="0,14,0,0"
                                    Height="42"
                                    Style="{StaticResource PrimaryActionButton}"
                                    Command="{Binding SaveManualAttendanceCommand}"/>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <materialDesign:Card Padding="18" Margin="0,0,0,16" Background="White">
                        <StackPanel>
                            <TextBlock Text="Optional OCR Upload" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         IsReadOnly="True"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Uploaded Image"
                                         Text="{Binding SelectedImagePath}"/>

                                <Button Grid.Column="2"
                                        Content="Upload Image"
                                        Height="42"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding BrowseImageCommand}"/>

                                <Button Grid.Column="4"
                                        Content="Process OCR"
                                        Height="42"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding ProcessImageCommand}"/>
                            </Grid>

                            <Border Margin="0,14,0,0"
                                    Padding="12"
                                    CornerRadius="8"
                                    Background="{StaticResource BrandSurfaceBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{StaticResource BrandBorderBrush}">
                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="{StaticResource BrandMidnightBrush}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="18" Background="White">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="OCR Review" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                <Button DockPanel.Dock="Right"
                                        Content="Save Selected Attendance"
                                        Height="36"
                                        Padding="16,0"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding SaveAttendanceCommand}"/>
                            </DockPanel>

                            <DataGrid Margin="0,14,0,0"
                                      ItemsSource="{Binding ReviewRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      MinHeight="420">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Save" Binding="{Binding IsSelected}" Width="70"/>
                                    <DataGridTextColumn Header="Extracted Name" Binding="{Binding ExtractedName}" Width="*"/>
                                    <DataGridTextColumn Header="Match Status" Binding="{Binding MatchStatus}" Width="130"/>
                                    <DataGridTextColumn Header="Suggested Participant" Binding="{Binding SuggestedParticipantName}" Width="200"/>
                                    <DataGridTextColumn Header="Similarity" Binding="{Binding SimilarityPercent}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="18" Margin="0,16,0,0" Background="White">
                        <StackPanel>
                            <TextBlock Text="Saved Attendance" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <DataGrid Margin="0,14,0,0"
                                      ItemsSource="{Binding SavedAttendanceRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      MinHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="*"/>
                                    <DataGridTextColumn Header="Household" Binding="{Binding HouseholdCode}" Width="100"/>
                                    <DataGridTextColumn Header="Purok" Binding="{Binding Purok}" Width="90"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="90"/>
                                    <DataGridTextColumn Header="Recorded" Binding="{Binding RecordedAt, StringFormat='{}{0:MMM dd, hh:mm tt}'}" Width="150"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
