<Window x:Class="AttendanceShiftingManagement.Views.DigitalIdPrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Digital ID Preview"
        Height="720"
        Width="760"
        MinHeight="620"
        MinWidth="640"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" 
                      ResizeBorderThickness="5" 
                      GlassFrameThickness="0" 
                      CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="WindowControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="0"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        </Style>

        <Style x:Key="WindowCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EF4444"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#F8FAFC"
            CornerRadius="20"
            BorderBrush="#CBD5E1"
            BorderThickness="1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CUSTOM WINDOW CONTROLS -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="99"
                    Margin="0,-20,-20,0">
            <Button Style="{StaticResource WindowControlButtonStyle}"
                    Click="Minimize_Click"
                    ToolTip="Minimize">
                <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18"/>
            </Button>
            <Button Style="{StaticResource WindowCloseButtonStyle}"
                    Click="Close_Click"
                    ToolTip="Close">
                <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
            </Button>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Digital ID Preview"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#0F172A"/>
            <TextBlock Text="Review the beneficiary card layout before sending it to the printer."
                       Margin="0,6,0,0"
                       Foreground="#475569"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,20,0,20"
                Padding="24"
                Background="White"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="20">
            <Viewbox Stretch="Uniform">
                <ContentControl x:Name="PreviewHost"/>
            </Viewbox>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="CLOSE"
                    Width="120"
                    Height="40"
                    Margin="0,0,12,0"
                    Click="CloseButton_Click"/>
            <Button Content="PRINT"
                    Width="140"
                    Height="40"
                    Background="#1D4ED8"
                    Foreground="White"
                    Click="PrintButton_Click"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>



