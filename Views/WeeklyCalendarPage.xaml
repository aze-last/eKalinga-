<UserControl x:Class="AttendanceShiftingManagement.Views.WeeklyCalendarPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:AttendanceShiftingManagement.Models"
             Background="{StaticResource BrandSurfaceBrush}">
    
    <UserControl.Resources>
        <Style x:Key="AddShiftButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding HasShift}" Value="False"/>
                        <Condition Binding="{Binding DataContext.CanEditSchedule, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="DayCellTemplate" DataType="{x:Type models:DayCell}">
            <Border Background="{Binding CellColor, FallbackValue='#F8FAFC'}" Margin="4,8" CornerRadius="8" Padding="5">
                <Grid>
                    <StackPanel x:Name="ViewPanel" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{Binding TimeDisplay}" FontWeight="Black" FontSize="10" HorizontalAlignment="Center" Foreground="{Binding ForegroundColor}"/>
                        <Border Background="#20000000" Height="1" Margin="4,4"/>
                        <TextBlock Text="{Binding PositionName}" FontSize="9" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{Binding ForegroundColor}"/>
                        <StackPanel x:Name="ActionPanel" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasShift}" Value="True"/>
                                                <Condition Binding="{Binding DataContext.CanEditSchedule, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding HasShift}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DataContext.CanEditSchedule, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </StackPanel.Style>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Width="24" Height="24"
                                    Command="{Binding DataContext.BeginEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14"/>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignFlatButton}" Padding="0" Width="24" Height="24" Foreground="#DA291C"
                                    Command="{Binding DataContext.DeleteDayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <materialDesign:PackIcon Kind="Delete" Width="14" Height="14"/>
                            </Button>
                        </StackPanel>
                        <Button x:Name="AddButton" Padding="0" Width="24" Height="24"
                                Command="{Binding DataContext.AddDayCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource AddShiftButtonStyle}">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>

                    <StackPanel x:Name="EditPanel" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBox Text="{Binding StartTimeText, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="0,0,4,0"/>
                            <TextBlock Text="-" VerticalAlignment="Center" Foreground="#555"/>
                            <TextBox Text="{Binding EndTimeText, UpdateSourceTrigger=PropertyChanged}" Width="60" Margin="4,0,0,0"/>
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding DataContext.Positions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding PositionId, UpdateSourceTrigger=PropertyChanged}"
                                  Width="130" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    Command="{Binding DataContext.SaveEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Content="Save" Margin="0,0,6,0"/>
                            <Button Style="{StaticResource MaterialDesignFlatButton}"
                                    Command="{Binding DataContext.CancelEditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Content="Cancel"/>
                        </StackPanel>
                    </StackPanel>

                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,20" Padding="0,0,0,15" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource BrandMidnightBrush}" Width="48" Height="48" CornerRadius="12" Margin="0,0,15,0">
                        <materialDesign:PackIcon Kind="CalendarClock" Width="26" Height="26" Foreground="{StaticResource BrandYellowBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="STORE ROSTER" FontSize="22" FontWeight="Black" Foreground="{StaticResource BrandMidnightBrush}"/>
                        <TextBlock Text="Manager View: Shift Optimization" FontSize="12" Foreground="#64748B" FontWeight="Medium"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBox Width="220"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Search employee..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,12,0"/>
                    <Border Background="White" CornerRadius="20" Padding="5" materialDesign:ElevationAssist.Elevation="Dp1">
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding PreviousWeekCommand}" Style="{StaticResource MaterialDesignIconButton}" Width="35" Height="35">
                                <materialDesign:PackIcon Kind="ChevronLeft" Foreground="{StaticResource BrandRedBrush}"/>
                            </Button>
                            <TextBlock Text="{Binding WeekRangeDisplay, FallbackValue='Feb 2 - Feb 8, 2026'}" 
                                       FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0" Foreground="#27251F"/>
                            <Button Command="{Binding NextWeekCommand}" Style="{StaticResource MaterialDesignIconButton}" Width="35" Height="35">
                                <materialDesign:PackIcon Kind="ChevronRight" Foreground="{StaticResource BrandRedBrush}"/>
                            </Button>
                        </StackPanel>
                    </Border>
                    <Button Content="TODAY" Command="{Binding TodayCommand}" Margin="15,0,0,0"
                            Background="{StaticResource BrandMidnightBrush}" Foreground="White" BorderBrush="{StaticResource BrandMidnightBrush}"
                            materialDesign:ButtonAssist.CornerRadius="18" Height="36" Width="90"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <materialDesign:Card Grid.Row="1" Padding="15" Margin="0,0,0,20" UniformCornerRadius="12" Background="#FFF8E1" BorderBrush="#FFC72C" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <materialDesign:PackIcon Kind="AlertDecagram" Foreground="{StaticResource BrandRedBrush}" Width="24" Height="24" VerticalAlignment="Top" Margin="0,2,12,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Scheduling Efficiency Alerts" FontWeight="Black" Foreground="{StaticResource BrandMidnightBrush}" FontSize="13" Margin="0,0,0,5"/>
                    <ItemsControl ItemsSource="{Binding ScheduleWarnings}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.ScrollToEmployeeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding EmployeeName}"
                                        Background="{StaticResource BrandYellowBrush}" Foreground="#5D4037"
                                        Padding="10,2" Margin="0,2,8,2"
                                        Height="24"
                                        materialDesign:ButtonAssist.CornerRadius="12"
                                        Style="{StaticResource MaterialDesignFlatButton}">
                                    <TextBlock Text="{Binding Message}" FontSize="11"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="2" UniformCornerRadius="15" materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource BrandMidnightBrush}" CornerRadius="15,15,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TEAM MEMBER" Foreground="{StaticResource BrandYellowBrush}" FontWeight="Black" FontSize="11" VerticalAlignment="Center" Margin="20,0,0,0"/>
                        <TextBlock Grid.Column="1" Text="MON" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="TUE" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="WED" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="THU" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="FRI" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="SAT" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="SUN" HorizontalAlignment="Center" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ScheduleItemsControl" ItemsSource="{Binding EmployeeWeeklySchedulesView}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Background="White">
                                    <Grid MinHeight="90">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="20,0">
                                            <TextBlock Text="{Binding EmployeeName}" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}" FontSize="14"/>
                                            <TextBlock Text="Full-Time" FontSize="10" Foreground="#64748B" FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <ContentControl Grid.Column="1" Content="{Binding Monday}" ContentTemplate="{StaticResource DayCellTemplate}"/>
                                        <ContentControl Grid.Column="2" Content="{Binding Tuesday}" ContentTemplate="{StaticResource DayCellTemplate}"/>
                                        <ContentControl Grid.Column="3" Content="{Binding Wednesday}" ContentTemplate="{StaticResource DayCellTemplate}"/>
                                        <ContentControl Grid.Column="4" Content="{Binding Thursday}" ContentTemplate="{StaticResource DayCellTemplate}"/>
                                        <ContentControl Grid.Column="5" Content="{Binding Friday}" ContentTemplate="{StaticResource DayCellTemplate}"/>
                                        <ContentControl Grid.Column="6" Content="{Binding Saturday}" ContentTemplate="{StaticResource DayCellTemplate}"/>
                                        <ContentControl Grid.Column="7" Content="{Binding Sunday}" ContentTemplate="{StaticResource DayCellTemplate}"/>

                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
