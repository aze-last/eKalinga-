<UserControl x:Class="AttendanceShiftingManagement.Views.WeeklyCalendarPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:AttendanceShiftingManagement.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100"
             Background="White">
    
    <UserControl.DataContext>
        <vm:WeeklyCalendarViewModel/>
    </UserControl.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header / Navigation -->
            <RowDefinition Height="Auto"/>  <!-- Days Header -->
            <RowDefinition Height="*"/>     <!-- Calendar Body -->
        </Grid.RowDefinitions>

        <!-- Top Navigation -->
        <Border Grid.Row="0" Margin="0,0,0,24" Padding="0,0,0,16" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="CalendarWeek" Width="32" Height="32" Foreground="#1E293B" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Weekly Schedule" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold" Foreground="#1E293B"/>
                        <TextBlock Text="At-a-glance view of all employee shifts" FontSize="12" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding PreviousWeekCommand}" Style="{StaticResource MaterialDesignIconButton}" ToolTip="Previous Week">
                        <materialDesign:PackIcon Kind="ChevronLeft"/>
                    </Button>

                    <TextBlock Text="{Binding WeekRangeDisplay}" 
                               FontSize="16" FontWeight="SemiBold" 
                               VerticalAlignment="Center" Margin="16,0" MinWidth="180" TextAlignment="Center"/>

                    <Button Command="{Binding NextWeekCommand}" Style="{StaticResource MaterialDesignIconButton}" ToolTip="Next Week">
                        <materialDesign:PackIcon Kind="ChevronRight"/>
                    </Button>

                    <Button Content="TODAY" Command="{Binding TodayCommand}" 
                            Style="{StaticResource MaterialDesignOutlinedButton}" Margin="16,0,0,0" Height="32"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Calendar Header -->
        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1,1,1,0" CornerRadius="8,8,0,0">
            <Grid Height="50">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="EMPLOYEE" FontWeight="Bold" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="#475569"/>

                <TextBlock Grid.Column="1" Text="{Binding MondayHeader}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Foreground="#475569"/>
                <TextBlock Grid.Column="2" Text="{Binding TuesdayHeader}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Foreground="#475569"/>
                <TextBlock Grid.Column="3" Text="{Binding WednesdayHeader}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Foreground="#475569"/>
                <TextBlock Grid.Column="4" Text="{Binding ThursdayHeader}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Foreground="#475569"/>
                <TextBlock Grid.Column="5" Text="{Binding FridayHeader}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Foreground="#475569"/>
                <TextBlock Grid.Column="6" Text="{Binding SaturdayHeader}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Foreground="#475569"/>
                <TextBlock Grid.Column="7" Text="{Binding SundayHeader}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" Foreground="#475569"/>
            </Grid>
        </Border>

        <!-- Calendar Body -->
        <Border Grid.Row="2" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding EmployeeWeeklySchedules}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Background="White">
                                <Grid MinHeight="80">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Employee Name -->
                                    <TextBlock Grid.Column="0" Text="{Binding EmployeeName}" 
                                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="20,0,0,0"
                                               Foreground="#334155"/>

                                    <!-- Monday -->
                                    <Border Grid.Column="1" Background="{Binding Monday.CellColor}" Margin="4" CornerRadius="6" Padding="4">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Monday.TimeDisplay}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Foreground="{Binding Monday.ForegroundColor}"/>
                                            <TextBlock Text="{Binding Monday.PositionName}" FontSize="10" HorizontalAlignment="Center" Opacity="0.9" Foreground="{Binding Monday.ForegroundColor}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Tuesday -->
                                    <Border Grid.Column="2" Background="{Binding Tuesday.CellColor}" Margin="4" CornerRadius="6" Padding="4">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Tuesday.TimeDisplay}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Foreground="{Binding Tuesday.ForegroundColor}"/>
                                            <TextBlock Text="{Binding Tuesday.PositionName}" FontSize="10" HorizontalAlignment="Center" Opacity="0.9" Foreground="{Binding Tuesday.ForegroundColor}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Wednesday -->
                                    <Border Grid.Column="3" Background="{Binding Wednesday.CellColor}" Margin="4" CornerRadius="6" Padding="4">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Wednesday.TimeDisplay}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Foreground="{Binding Wednesday.ForegroundColor}"/>
                                            <TextBlock Text="{Binding Wednesday.PositionName}" FontSize="10" HorizontalAlignment="Center" Opacity="0.9" Foreground="{Binding Wednesday.ForegroundColor}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Thursday -->
                                    <Border Grid.Column="4" Background="{Binding Thursday.CellColor}" Margin="4" CornerRadius="6" Padding="4">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Thursday.TimeDisplay}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Foreground="{Binding Thursday.ForegroundColor}"/>
                                            <TextBlock Text="{Binding Thursday.PositionName}" FontSize="10" HorizontalAlignment="Center" Opacity="0.9" Foreground="{Binding Thursday.ForegroundColor}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Friday -->
                                    <Border Grid.Column="5" Background="{Binding Friday.CellColor}" Margin="4" CornerRadius="6" Padding="4">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Friday.TimeDisplay}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Foreground="{Binding Friday.ForegroundColor}"/>
                                            <TextBlock Text="{Binding Friday.PositionName}" FontSize="10" HorizontalAlignment="Center" Opacity="0.9" Foreground="{Binding Friday.ForegroundColor}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Saturday -->
                                    <Border Grid.Column="6" Background="{Binding Saturday.CellColor}" Margin="4" CornerRadius="6" Padding="4">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Saturday.TimeDisplay}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Foreground="{Binding Saturday.ForegroundColor}"/>
                                            <TextBlock Text="{Binding Saturday.PositionName}" FontSize="10" HorizontalAlignment="Center" Opacity="0.9" Foreground="{Binding Saturday.ForegroundColor}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Sunday -->
                                    <Border Grid.Column="7" Background="{Binding Sunday.CellColor}" Margin="4" CornerRadius="6" Padding="4">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Sunday.TimeDisplay}" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" Foreground="{Binding Sunday.ForegroundColor}"/>
                                            <TextBlock Text="{Binding Sunday.PositionName}" FontSize="10" HorizontalAlignment="Center" Opacity="0.9" Foreground="{Binding Sunday.ForegroundColor}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
