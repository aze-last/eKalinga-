<UserControl x:Class="AttendanceShiftingManagement.Views.ProjectDistributionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AttendanceShiftingManagement.Views"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1440"
             Background="{DynamicResource BrandSurfaceBrush}">
    
    <UserControl.Resources>
        <helpers:NullToHiddenConverter x:Key="NullToHiddenConverter" />
        <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />

        <Style x:Key="SidebarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryActionBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>

        <Style x:Key="DetailCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.15" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Global Header (Midnight Blue) -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePrimaryActionBrush}" Padding="20,15" Panel.ZIndex="10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="HandCoinOutline" Width="32" Height="32" Foreground="White" VerticalAlignment="Center"/>
                    <StackPanel Margin="15,0,0,0">
                        <TextBlock Text="PROJECT DISTRIBUTION" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Manage active aid projects, enroll beneficiaries, and execute physical payouts." FontSize="12" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Noticeable Sidebar Toggle -->
                    <Button Command="{Binding ToggleSidebarCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White"
                            Width="150" Height="40" Padding="10,0"
                            ToolTip="Toggle Sidebar View">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Kind" Value="MenuOpen"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                <Setter Property="Kind" Value="Menu"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock VerticalAlignment="Center" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="HIDE SIDEBAR"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                <Setter Property="Text" Value="SHOW SIDEBAR"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.Effect>
                <BlurEffect Radius="0" x:Name="BackgroundBlur"/>
            </Grid.Effect>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnyOverlayOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="15" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding SidebarWidth, FallbackValue=320}" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Collapsible Sidebar (Light Slate) -->
                <Border Grid.Column="0" Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,0,1,0" x:Name="SidebarContainer">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Dashboard Navigation -->
                        <Grid Grid.Row="0" Margin="20,20,20,10">
                            <Button Content="DASHBOARD" 
                                    Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="45" Margin="0,0,0,0"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Border Padding="20,0,20,20">
                                <StackPanel>
                                    <TextBlock Text="PROJECT MANAGEMENT" Style="{StaticResource SidebarHeaderStyle}"/>
                                    <Button Content="BROWSE PROJECTS" Click="ChangeProject_Click" Style="{StaticResource GoldActionButton}" HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,8" FontSize="14"/>
                                    <Button Content="CREATE PROJECT" Command="{Binding OpenCreateProjectPanelCommand}" Style="{StaticResource GoldActionButton}" HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,8" FontSize="14" Visibility="Collapsed"/>
                                    <Button Content="REFRESH PROJECTS" Command="{Binding RefreshCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,20" FontSize="14"/>
                                    
                                    <!-- Browse Projects List -->
                                    <StackPanel Margin="0,0,0,20">
                                        <TextBlock Text="ACTIVE PROJECTS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding ProgramSummaries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                            <Button Command="{Binding DataContext.OpenProjectActionMenuCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                    CommandParameter="{Binding}" 
                                                                    HorizontalContentAlignment="Stretch" Height="Auto" Padding="10,8" Margin="0,0,0,4">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsActionMenuOpen}" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            
                                                            <TextBlock Text="{Binding ProgramName}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                                            <TextBlock Grid.Row="1" Text="{Binding DistributionStatus}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,4,0,0"/>
                                                            <Border Grid.Row="2" Background="#EBF4FB" CornerRadius="3" Padding="5,2" Margin="0,4,0,0"
                                                                    Visibility="{Binding SourceFundLabel, Converter={StaticResource StringToVisibilityConverter}}">
                                                                <TextBlock Text="{Binding SourceFundLabel}" FontSize="10" Foreground="#1E4E89" FontWeight="SemiBold"/>
                                                            </Border>

                                                            <!-- Inline Action Menu for the selected project -->
                                                            <StackPanel Grid.Row="3" Margin="0,12,0,4">
                                                                <Button Content="ADD BENEFICIARIES" 
                                                                        Command="{Binding DataContext.OpenProgramAddBeneficiaryPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                                        CommandParameter="{Binding}" 
                                                                        Style="{StaticResource MaterialDesignOutlinedButton}" Height="36" FontSize="12" Margin="0,0,0,8"/>
                                                                <!-- Removed Mobile Scanner Config -->
                                                            </StackPanel>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <TextBlock Text="LIVE OPERATIONS" Style="{StaticResource SidebarHeaderStyle}"/>
                                    <Button Content="OPEN LIVE PREVIEW" Command="{Binding OpenLivePreviewCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,8" FontSize="14"/>
                                    <TextBox x:Name="HiddenScannerTextBox" Text="{Binding ScannerInputText, UpdateSourceTrigger=PropertyChanged}" 
                                             Opacity="0" Width="1" Height="1" Focusable="True"
                                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,16"
                                             KeyDown="HiddenScannerTextBox_KeyDown">
                                    </TextBox>
                                    <Border CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{DynamicResource ThemeCardSubtleBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsScannerActive}" Value="True">
                                                        <Setter Property="Background" Value="#E8F5E9"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="BarcodeScan" Width="20" Height="20" VerticalAlignment="Center">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsScannerActive}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource BrandSuccessBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                            <TextBlock FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="SCANNER INACTIVE"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsScannerActive}" Value="True">
                                                                <Setter Property="Text" Value="POS SCANNER READY"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource BrandSuccessBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                    <!-- Last Scan Summary -->
                                    <TextBlock Text="{Binding LastScanSummaryText}" Foreground="{Binding LastScanSummaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,16" TextWrapping="Wrap"
                                               Visibility="{Binding LastScanSummaryText, Converter={StaticResource NullToHiddenConverter}}"/>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>

                        <!-- Status Area -->
                        <Border Grid.Row="2" Padding="20" Background="{DynamicResource ThemeCardBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <TextBlock Text="MODULE STATUS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Center Content: Registry (Budget Style) -->
                <Grid Grid.Column="1" Background="Transparent" Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Empty State -->
                    <StackPanel Grid.RowSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}">
                        <materialDesign:PackIcon Kind="HandCoinOutline" Width="80" Height="80" Foreground="{DynamicResource BrandBorderBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="No Project Selected" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,16,0,8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a distribution project from the sidebar to manage beneficiaries and execute payouts." FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Page Content (When Project Selected) -->
                    <ScrollViewer Grid.RowSpan="2" Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}}" 
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Collapsible Summary Section -->
                            <StackPanel Visibility="{Binding IsSummaryCollapsed, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <!-- Hybrid Metrics Row -->
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Remaining Budget -->
                                    <materialDesign:Card Grid.Column="0" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="REMAINING BUDGET" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding SelectedProgramRemainingBudgetText}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <!-- Total Recipients -->
                                    <materialDesign:Card Grid.Column="2" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="TOTAL RECIPIENTS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding SelectedProgramBeneficiaryCountText}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <!-- Pending Distribution -->
                                    <materialDesign:Card Grid.Column="4" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="PENDING DISTRIBUTION" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding PendingTotalCount, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <!-- Released -->
                                    <materialDesign:Card Grid.Column="6" Padding="15">
                                        <StackPanel>
                                            <TextBlock Text="SUCCESSFULLY RELEASED" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding ReleasedTotalCount, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandSuccessBrush}"/>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </Grid>

                                <!-- Event Detail Header Card -->
                                <Border Style="{StaticResource DetailCardStyle}" Padding="40,30">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="20"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header Info -->
                                        <Grid Grid.Row="0" Margin="0,0,0,30">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding SelectedProgram.ProgramCode}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding SelectedProgram.ProgramName}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <Border Grid.Column="1" VerticalAlignment="Top" Padding="12,6" CornerRadius="20" Background="{DynamicResource ThemeCardSubtleBrush}">
                                                <TextBlock Text="{Binding SelectedProgram.DistributionStatus, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=UPPER}" 
                                                           Foreground="{DynamicResource BrandMidnightBrush}" FontSize="12" FontWeight="Bold" Typography.Capitals="AllSmallCaps"/>
                                            </Border>
                                        </Grid>

                                        <!-- Primary Details UniformGrid -->
                                        <UniformGrid Grid.Row="1" Columns="3">
                                            <StackPanel>
                                                <TextBlock Text="ASSISTANCE SUMMARY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding SelectedProgramAssistanceSummary}" FontSize="14" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap" Margin="0,0,20,0"/>
                                            </StackPanel>

                                            <StackPanel>
                                                <TextBlock Text="WORKFLOW SUMMARY" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding SelectedProgramWorkflowSummary}" FontSize="14" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap" Margin="0,0,20,0"/>
                                            </StackPanel>

                                            <StackPanel>
                                                <TextBlock Text="DESCRIPTION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding SelectedProgramDescriptionText}" FontSize="14" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- Vertical Toggle Bar (Noticeable UI) -->
                            <Button Command="{Binding ToggleSummaryCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    HorizontalAlignment="Stretch" Height="40" Margin="0,0,0,20"
                                    Background="{DynamicResource ThemeCardSubtleBrush}"
                                    ToolTip="Toggle Project Summary">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Width="24" Height="24" Foreground="{DynamicResource BrandMidnightBrush}" VerticalAlignment="Center">
                                        <materialDesign:PackIcon.Style>
                                            <Style TargetType="materialDesign:PackIcon">
                                                <Setter Property="Kind" Value="ChevronUp"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSummaryCollapsed}" Value="True">
                                                        <Setter Property="Kind" Value="ChevronDown"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </materialDesign:PackIcon.Style>
                                    </materialDesign:PackIcon>
                                    <TextBlock VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="8,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="COLLAPSE SUMMARY"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSummaryCollapsed}" Value="True">
                                                        <Setter Property="Text" Value="EXPAND SUMMARY (SHOW METRICS &amp; DETAILS)"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                            <!-- Clean Distribution Registry (Budget Style) -->
                            <materialDesign:Card Padding="24" Margin="0,0,0,30">
                                <StackPanel>
                                    <!-- Tabs for Pending/Released -->
                                    <TabControl materialDesign:ColorZoneAssist.Mode="Standard" BorderThickness="0" Background="Transparent">
                                        <TabItem Header="PENDING DISTRIBUTION" FontSize="12" FontWeight="Bold">
                                            <Grid Margin="0,20,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="350"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Pending List -->
                                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                                    <Border Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="8" Padding="12,4" Margin="0,0,0,20" HorizontalAlignment="Left">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="Magnify" Foreground="{DynamicResource BrandTextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBox Text="{Binding PendingSearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search pending beneficiaries..." Width="250" BorderThickness="0" Background="Transparent"/>
                                                        </StackPanel>
                                                    </Border>

                                                    <DataGrid ItemsSource="{Binding PendingBeneficiaries}"
                                                              SelectedItem="{Binding SelectedPendingBeneficiary}"
                                                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MinHeight="350"
                                                              Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                                                              materialDesign:DataGridAssist.CellPadding="12,8">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="FULL NAME" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                                                            <DataGridTextColumn Header="BENEFICIARY ID" Binding="{Binding BeneficiaryId}" Width="150"/>
                                                            <DataGridTextColumn Header="ADDED" Binding="{Binding AddedAt, StringFormat='MMM dd, yyyy'}" Width="120"/>
                                                        </DataGrid.Columns>
                                                    </DataGrid>

                                                    <!-- Pagination -->
                                                    <Border Margin="0,20,0,0" Padding="0,15,0,0" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                                                        <Grid>
                                                            <TextBlock Text="{Binding PendingPaginationText}" VerticalAlignment="Center" Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                                <Button Command="{Binding PrevPendingPageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0">
                                                                    <materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24"/>
                                                                </Button>
                                                                <Button Command="{Binding NextPendingPageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0" Margin="8,0,0,0">
                                                                    <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Verification & Release Panel -->
                                                <Border Grid.Column="1" Style="{StaticResource DetailCardStyle}" Margin="0">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                                            <TextBlock Text="PAYOUT VERIFICATION" Style="{StaticResource SidebarHeaderStyle}"/>
                                                            <TextBlock Text="Select a beneficiary from the list to review their Digital ID and confirm release." Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="1" Visibility="{Binding SelectedPendingBeneficiary, Converter={StaticResource NullToHiddenConverter}}">
                                                            <TextBlock Text="{Binding SelectedPendingBeneficiary.FullName}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                            <TextBlock Text="{Binding SelectedPendingDigitalIdCardNumber}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,20"/>

                                                            <Border Background="White" Padding="10" CornerRadius="8" HorizontalAlignment="Center" Margin="0,0,0,20" Visibility="{Binding SelectedPendingDigitalIdQrImage, Converter={StaticResource NullToHiddenConverter}}">
                                                                <Image Source="{Binding SelectedPendingDigitalIdQrImage}" Height="150" Width="150" Stretch="Uniform"/>
                                                            </Border>

                                                            <TextBlock Text="{Binding SelectedPendingDigitalIdStatusText}" Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
                                                        </StackPanel>

                                                        <Button Grid.Row="2" Content="CONFIRM RELEASE" Command="{Binding ConfirmReleaseCommand}" Style="{StaticResource GoldActionButton}" Height="45" Margin="0,20,0,0"/>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </TabItem>

                                        <TabItem Header="RELEASED HISTORY" FontSize="12" FontWeight="Bold">
                                            <StackPanel Margin="0,20,0,0">
                                                <DataGrid ItemsSource="{Binding ReleasedClaims}"
                                                          SelectedItem="{Binding SelectedReleasedClaim}"
                                                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MinHeight="350"
                                                          Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                                                          materialDesign:DataGridAssist.CellPadding="12,8">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="FULL NAME" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                                                        <DataGridTextColumn Header="ASSISTANCE" Binding="{Binding AssistanceLabel}" Width="150"/>
                                                        <DataGridTextColumn Header="AMOUNT" Binding="{Binding AmountText}" Width="120" FontWeight="Bold">
                                                            <DataGridTextColumn.ElementStyle>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                </Style>
                                                            </DataGridTextColumn.ElementStyle>
                                                        </DataGridTextColumn>
                                                        <DataGridTextColumn Header="RELEASED AT" Binding="{Binding ReleasedAt, StringFormat='MMM dd, yyyy hh:mm tt'}" Width="180"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>

                                                <!-- Pagination -->
                                                <Border Margin="0,20,0,0" Padding="0,15,0,0" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                                                    <Grid>
                                                        <TextBlock Text="{Binding ReleasedPaginationText}" VerticalAlignment="Center" Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <Button Command="{Binding PrevReleasedPageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0">
                                                                <materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24"/>
                                                            </Button>
                                                            <Button Command="{Binding NextReleasedPageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0" Margin="8,0,0,0">
                                                                <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </TabItem>
                                    </TabControl>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Grid>

        <!-- Backdrop for Overlays -->
        <Border Grid.RowSpan="2" Background="#CC0F172A" Visibility="{Binding IsAnyOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="100"/>

        <!-- Create Project Panel -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="110" Visibility="{Binding IsCreateProjectPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <local:ProjectDistributionCreateProjectPanel/>
        </Grid>

        <!-- Add Beneficiary Panel -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="110" Visibility="{Binding IsAddBeneficiaryPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <local:ProjectDistributionAddBeneficiaryPanel/>
        </Grid>

        <!-- Removed Scanner Panels -->

        <!-- Scanned Claim Result Dialog -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="130" Visibility="{Binding IsScannedResultVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Style="{StaticResource PanelCardStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" Height="500">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Side: Visual Prompt -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="BarcodeScan" Width="80" Height="80" Foreground="{DynamicResource ThemePrimaryActionBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="SCAN NEXT ID" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextAlignment="Center" Margin="0,16,0,8"/>
                            <TextBlock Text="System is listening..." FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="{DynamicResource BrandBorderBrush}" Margin="0,30"/>

                        <!-- Center: Beneficiary Profile -->
                        <StackPanel Grid.Column="2" Margin="30,40" HorizontalAlignment="Center">
                            <TextBlock Text="BENEFICIARY PROFILE" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,20" TextAlignment="Center"/>
                            
                            <Border Width="120" Height="120" CornerRadius="60" Background="{DynamicResource ThemeCardSubtleBrush}" Margin="0,0,0,20">
                                <Ellipse Width="120" Height="120">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding ScannedBeneficiaryPhoto}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Border>

                            <TextBlock Text="{Binding ScannedBeneficiary.FullName}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ScannedBeneficiary.BeneficiaryId}" FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextAlignment="Center" Margin="0,4,0,20"/>

                            <!-- Dynamic Status Badge -->
                            <Border Background="{Binding ScannedBeneficiaryStatusColor}" Padding="20,10" CornerRadius="8">
                                <TextBlock Text="{Binding ScannedBeneficiaryStatus}" FontSize="14" FontWeight="Bold" Foreground="White" TextAlignment="Center" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="3" Background="{DynamicResource BrandBorderBrush}" Margin="0,30"/>

                        <!-- Right Side: Distribution History -->
                        <Grid Grid.Column="4" Margin="20,40">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="DISTRIBUTION HISTORY" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,16"/>
                            
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding ScannedBeneficiaryHistory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding AssistanceLabel}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding ReleasedAt, StringFormat=MMM yyyy}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                    <TextBlock Text=" - " FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                    <TextBlock Text="Released" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource BrandSuccessBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <TextBlock Grid.Row="1" Text="No previous distributions." FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}" 
                                       Visibility="{Binding HasScannedHistory, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                       VerticalAlignment="Top" Margin="0,10,0,0"/>
                        </Grid>
                    </Grid>

                    <!-- Bottom: Action Bar -->
                    <Border Grid.Row="1" Padding="20" Background="{DynamicResource BrandMidnightBrush}" CornerRadius="0,0,16,16">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,30,0">
                                    <TextBlock Text="FUNDING SOURCE" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedProgram.FundSourceCode}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,30,0">
                                    <TextBlock Text="PROJECT" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedProgram.ProgramName}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="AMOUNT" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedProgram.UnitAmount, StringFormat='PHP {0:N2}'}" FontSize="18" Foreground="{DynamicResource BrandYellowBrush}" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="CANCEL" Command="{Binding CancelScannedClaimCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Margin="0,0,16,0"/>
                                <Button Content="{Binding ScannerActionLabel}" Command="{Binding ConfirmScannedClaimCommand}" Style="{StaticResource GoldActionButton}" Height="45" Padding="30,0" FontSize="16"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Success Overlay -->
                    <Grid Grid.RowSpan="2" Visibility="{Binding IsReleaseSuccessState, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Background="#DD15803D" CornerRadius="16">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CheckCircleOutline" Width="80" Height="80" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="RELEASE SUCCESSFUL" FontSize="28" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0,16,0,8"/>
                                <TextBlock Text="{Binding ScannedBeneficiary.FullName}" FontSize="18" Foreground="#DDFFFFFF" TextAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedProgram.ProgramName}" FontSize="14" Foreground="#AAFFFFFF" TextAlignment="Center" Margin="0,4,0,0"/>
                                <TextBlock Text="Auto closes in 1.5 seconds..." FontSize="11" Foreground="#88FFFFFF" TextAlignment="Center" Margin="0,20,0,0" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>