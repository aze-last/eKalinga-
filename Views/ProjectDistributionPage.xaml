<UserControl x:Class="AttendanceShiftingManagement.Views.ProjectDistributionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AttendanceShiftingManagement.Views"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1440"
             Background="{DynamicResource BrandSurfaceBrush}">
    
    <UserControl.Resources>

        <!-- Matches the Budget module's operational-button accent (Gemini.md Action Accent #F59E0B). -->
        <SolidColorBrush x:Key="ActionAccentBrush" Color="#F59E0B"/>
        <Style x:Key="OperationalActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="{StaticResource ActionAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="SidebarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryActionBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>

        <Style x:Key="DetailCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.15" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ======================== HEADER (Row 0) — Midnight Blue ======================== -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePrimaryActionBrush}" Padding="30,24" Panel.ZIndex="10"
                BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- Top Row: Icon + Title & Subtitle -->
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="PackageVariant" Width="36" Height="36" Foreground="White" VerticalAlignment="Center"/>
                        <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="PROJECT DISTRIBUTION" FontSize="26" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Manage active aid projects, verify beneficiaries, and release assistance." FontSize="13" Foreground="#E0FFFFFF" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Middle Row: Current Project & Status -->
                <Border Margin="0,20,0,20" Padding="0,12" BorderBrush="#33FFFFFF" BorderThickness="0,1,0,1">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Current Project: " FontSize="14" Foreground="#CCFFFFFF" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedProgram.ProgramName, TargetNullValue='No Active Project Selected', FallbackValue='No Active Project Selected'}"
                                       FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Status Indicator (visible only when project is selected) -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}}">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="LightGray"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProgram.DistributionStatus}" Value="Draft">
                                                <Setter Property="Fill" Value="#F59E0B"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedProgram.DistributionStatus}" Value="Open">
                                                <Setter Property="Fill" Value="#10B981"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding SelectedProgram.DistributionStatus}" Value="Closed">
                                                <Setter Property="Fill" Value="#EF4444"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding SelectedProgram.DistributionStatus}" FontSize="13" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Bottom Row: Navigation / Action buttons -->
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Browse Projects Button -->
                        <Button Click="ChangeProject_Click"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="White" Height="36" Padding="12,0" Margin="0,0,16,0" FontWeight="Bold">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderOpenOutline" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Browse Projects" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <!-- Refresh Button -->
                        <Button Command="{Binding RefreshCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="White" Height="36" Padding="12,0" FontWeight="Bold">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Dashboard Button on the far right -->
                    <Button Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" Height="36" Padding="12,0" HorizontalAlignment="Right" FontWeight="Bold">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartBar" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ======================== MAIN WORKSPACE (Row 1) — Blurrable ======================== -->
        <Grid Grid.Row="1">
            <Grid.Effect>
                <BlurEffect Radius="0" x:Name="BackgroundBlur"/>
            </Grid.Effect>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnyOverlayOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="15" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ==================== PROFILE BAR / PAYOUT CONSOLE (Col 0) ==================== -->
                <Border Grid.Column="0" Background="{DynamicResource ThemeCardSubtleBrush}"
                        BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Hidden POS scanner textbox (keyboard capture) -->
                        <TextBox x:Name="HiddenScannerTextBox" Text="{Binding ScannerInputText, UpdateSourceTrigger=PropertyChanged}" 
                                 Opacity="0" Width="1" Height="1" Focusable="True"
                                 HorizontalAlignment="Left" VerticalAlignment="Top"
                                 KeyDown="HiddenScannerTextBox_KeyDown"/>

                        <!-- Row 0: Profile + Household Members (scrollable, occupies whole height) -->
                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="20,20,20,20">

                                <!-- Profile: Pending beneficiary selected -->
                                <StackPanel Visibility="{Binding SelectedPendingBeneficiary, Converter={StaticResource NullToHiddenConverter}}">
                                    <!-- Photo -->
                                    <Grid Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <Ellipse Width="80" Height="80" Fill="{DynamicResource ThemeCardSubtleBrush}"
                                                 Stroke="{DynamicResource BrandBorderBrush}" StrokeThickness="1"/>
                                        <Ellipse Width="80" Height="80"
                                                 Visibility="{Binding HouseholdConfirmBeneficiaryPhoto, Converter={StaticResource NullToHiddenConverter}}">
                                            <Ellipse.Fill>
                                                <ImageBrush ImageSource="{Binding HouseholdConfirmBeneficiaryPhoto}" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <materialDesign:PackIcon Kind="AccountCircle" Width="56" Height="56"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                                 Visibility="{Binding HouseholdConfirmBeneficiaryPhoto, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}"/>
                                    </Grid>
                                    <!-- Name -->
                                    <TextBlock Text="{Binding SelectedPendingBeneficiary.FullName}" FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
                                    <!-- Beneficiary ID -->
                                    <TextBlock Text="{Binding SelectedPendingBeneficiary.BeneficiaryId}" FontSize="12"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}" TextAlignment="Center" Margin="0,4,0,0"/>
                                    <!-- Digital ID Card Number -->
                                    <TextBlock Text="{Binding SelectedPendingDigitalIdCardNumber}" FontSize="11"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}" TextAlignment="Center" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Profile: Released claim selected (read-only) -->
                                <StackPanel Visibility="{Binding SelectedReleasedClaim, Converter={StaticResource NullToHiddenConverter}}">
                                    <Grid Width="80" Height="80" HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <Ellipse Width="80" Height="80" Fill="{DynamicResource ThemeCardSubtleBrush}"
                                                 Stroke="{DynamicResource BrandBorderBrush}" StrokeThickness="1"/>
                                        <materialDesign:PackIcon Kind="AccountCircle" Width="56" Height="56"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                    </Grid>
                                    <TextBlock Text="{Binding SelectedReleasedClaim.FullName}" FontSize="16" FontWeight="Bold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
                                    <Border Background="{DynamicResource BrandSuccessBrush}" Padding="10,4" CornerRadius="4"
                                            HorizontalAlignment="Center" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding SelectedReleasedClaim.AmountText}" FontSize="13" FontWeight="Bold"
                                                   Foreground="White"/>
                                    </Border>
                                    <TextBlock Text="{Binding SelectedReleasedClaim.ReleasedAt, StringFormat='Released: MMM dd, yyyy hh:mm tt'}"
                                               FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>

                                <!-- Household aid-received summary -->
                                <Border Margin="0,16,0,0" Padding="14,10" CornerRadius="8"
                                        Background="{DynamicResource ThemeCardSubtleBrush}"
                                        BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1"
                                        Visibility="{Binding HasHouseholdContext, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <materialDesign:PackIcon Kind="HomeGroup" Width="20" Height="20" VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                        <TextBlock Text="{Binding HouseholdAidReceivedSummary}" FontSize="12" FontWeight="SemiBold"
                                                   TextWrapping="Wrap" Margin="8,0,0,0" VerticalAlignment="Center" MaxWidth="220"
                                                   Foreground="{DynamicResource BrandMidnightBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Household Members -->
                                <StackPanel Margin="0,16,0,0"
                                            Visibility="{Binding HasHouseholdMembers, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="HOUSEHOLD MEMBERS" FontSize="11" FontWeight="Bold"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding HouseholdContextSummary}" FontSize="11" TextWrapping="Wrap"
                                               Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,8"/>

                                    <ItemsControl ItemsSource="{Binding ScannedHouseholdMembers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6" Padding="10,6" Margin="0,0,0,4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource ThemeSurfaceBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding AlreadyReceivedSameAssistanceType}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource BrandRedBrush}"/>
                                                                    <Setter Property="BorderThickness" Value="2"/>
                                                                    <Setter Property="Background" Value="#FFF1F2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding FullName}" FontSize="12" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                                                <materialDesign:PackIcon Kind="AccountCheck" Width="14" Height="14" Margin="6,0,0,0"
                                                                                         VerticalAlignment="Center"
                                                                                         Foreground="{DynamicResource BrandSuccessBrush}"
                                                                                         Visibility="{Binding IsScannedBeneficiary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding RelationshipToHead}" FontSize="10"
                                                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" VerticalAlignment="Center"
                                                                Background="{DynamicResource BrandRedBrush}" CornerRadius="3" Padding="5,2"
                                                                Visibility="{Binding AlreadyReceivedSameAssistanceType, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock Text="RECEIVED" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Row 1: DISTRIBUTE AID button (visible only when a pending beneficiary is selected) -->
                        <Border Grid.Row="1" Padding="20,12"
                                BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0"
                                Visibility="{Binding SelectedPendingBeneficiary, Converter={StaticResource NullToHiddenConverter}}">
                            <Button Content="DISTRIBUTE AID" Command="{Binding ConfirmReleaseCommand}"
                                    Style="{StaticResource OperationalActionButton}" Height="50" FontSize="16" FontWeight="Bold"/>
                        </Border>

                        <!-- Row 2: MODULE STATUS footer -->
                        <Border Grid.Row="2" Padding="20" Background="{DynamicResource ThemeCardBrush}"
                                BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <TextBlock Text="MODULE STATUS" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}"
                                           FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold"/>
                                <!-- DEV: one-time idempotent seed of 4 mock households (24 beneficiaries) -->
                                <TextBlock FontSize="10" Margin="0,8,0,0">
                                    <Hyperlink Command="{Binding SeedMockDataCommand}" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextDecorations="Underline">
                                        <Run Text="SEED MOCK DATA (DEV)"/>
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ==================== CENTER CONTENT (Col 1) ==================== -->
                <Grid Grid.Column="1" Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Empty State (no project selected) -->
                    <StackPanel Grid.RowSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}">
                        <materialDesign:PackIcon Kind="HandCoinOutline" Width="80" Height="80"
                                                 Foreground="{DynamicResource BrandBorderBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="No Project Selected" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,16,0,8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a distribution project to manage beneficiaries and execute payouts."
                                   FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Metrics Row (Row 0) — always visible when project selected -->
                    <Grid Grid.Row="0" Margin="0,0,0,20"
                          Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <materialDesign:Card Grid.Column="0" Padding="15">
                            <StackPanel>
                                <TextBlock Text="REMAINING BUDGET" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedProgramRemainingBudgetText}" FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource BrandMidnightBrush}"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="2" Padding="15">
                            <StackPanel>
                                <TextBlock Text="TOTAL RECIPIENTS" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedProgramBeneficiaryCountText}" FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource BrandMidnightBrush}"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="4" Padding="15">
                            <StackPanel>
                                <TextBlock Text="PENDING DISTRIBUTION" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding PendingTotalCount, StringFormat=N0}" FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource BrandMidnightBrush}"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="6" Padding="15">
                            <StackPanel>
                                <TextBlock Text="SUCCESSFULLY RELEASED" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ReleasedTotalCount, StringFormat=N0}" FontSize="20" FontWeight="Bold"
                                           Foreground="{DynamicResource BrandSuccessBrush}"/>
                            </StackPanel>
                        </materialDesign:Card>
                    </Grid>

                    <!-- Lists area (Row 1) — side-by-side PENDING / RELEASED -->
                    <Grid Grid.Row="1"
                          Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ===== PENDING LIST (Col 0) ===== -->
                        <materialDesign:Card Grid.Column="0" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <TextBlock Grid.Row="0" Text="PENDING DISTRIBUTION" FontSize="13" FontWeight="Bold"
                                           Foreground="{DynamicResource ThemePrimaryActionBrush}" Margin="0,0,0,12"
                                           Typography.Capitals="AllSmallCaps"/>

                                <!-- Search -->
                                <Border Grid.Row="1" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="8"
                                        Padding="12,4" Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Magnify" Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Text="{Binding PendingSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Search pending..."
                                                 Width="200" BorderThickness="0" Background="Transparent"/>
                                    </StackPanel>
                                </Border>

                                <!-- DataGrid -->
                                <DataGrid Grid.Row="2"
                                          ItemsSource="{Binding PendingBeneficiaries}"
                                          SelectedItem="{Binding SelectedPendingBeneficiary}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                                          materialDesign:DataGridAssist.CellPadding="12,8"
                                          MouseDoubleClick="PendingGrid_MouseDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="FULL NAME" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                                        <DataGridTextColumn Header="BENEFICIARY ID" Binding="{Binding BeneficiaryId}" Width="130"/>
                                        <DataGridTextColumn Header="ADDED" Binding="{Binding AddedAt, StringFormat='MMM dd'}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Pagination -->
                                <Border Grid.Row="3" Margin="0,12,0,0" Padding="0,12,0,0"
                                        BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <TextBlock Text="{Binding PendingPaginationText}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Command="{Binding PrevPendingPageCommand}"
                                                    Style="{StaticResource MaterialDesignFlatButton}" Width="36" Height="36" Padding="0">
                                                <materialDesign:PackIcon Kind="ChevronLeft" Width="20" Height="20"/>
                                            </Button>
                                            <Button Command="{Binding NextPendingPageCommand}"
                                                    Style="{StaticResource MaterialDesignFlatButton}" Width="36" Height="36" Padding="0" Margin="4,0,0,0">
                                                <materialDesign:PackIcon Kind="ChevronRight" Width="20" Height="20"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </materialDesign:Card>

                        <!-- ===== RELEASED LIST (Col 2) ===== -->
                        <materialDesign:Card Grid.Column="2" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <TextBlock Grid.Row="0" Text="RELEASED HISTORY" FontSize="13" FontWeight="Bold"
                                           Foreground="{DynamicResource ThemePrimaryActionBrush}" Margin="0,0,0,12"
                                           Typography.Capitals="AllSmallCaps"/>

                                <!-- DataGrid -->
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding ReleasedClaims}"
                                          SelectedItem="{Binding SelectedReleasedClaim}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                                          materialDesign:DataGridAssist.CellPadding="12,8"
                                          MouseDoubleClick="ReleasedGrid_MouseDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="FULL NAME" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                                        <DataGridTextColumn Header="AMOUNT" Binding="{Binding AmountText}" Width="90" FontWeight="Bold">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="RELEASED AT" Binding="{Binding ReleasedAt, StringFormat='MMM dd, hh:mm tt'}" Width="130"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Pagination -->
                                <Border Grid.Row="2" Margin="0,12,0,0" Padding="0,12,0,0"
                                        BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <TextBlock Text="{Binding ReleasedPaginationText}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Command="{Binding PrevReleasedPageCommand}"
                                                    Style="{StaticResource MaterialDesignFlatButton}" Width="36" Height="36" Padding="0">
                                                <materialDesign:PackIcon Kind="ChevronLeft" Width="20" Height="20"/>
                                            </Button>
                                            <Button Command="{Binding NextReleasedPageCommand}"
                                                    Style="{StaticResource MaterialDesignFlatButton}" Width="36" Height="36" Padding="0" Margin="4,0,0,0">
                                                <materialDesign:PackIcon Kind="ChevronRight" Width="20" Height="20"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </materialDesign:Card>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ======================== OVERLAYS ======================== -->

        <!-- Backdrop -->
        <Border Grid.RowSpan="2" Background="#CC0F172A"
                Visibility="{Binding IsAnyOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Panel.ZIndex="100"/>

        <!-- Create Project Panel -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="110"
              Visibility="{Binding IsCreateProjectPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <local:ProjectDistributionCreateProjectPanel/>
        </Grid>

        <!-- Add Beneficiary Panel (dormant — enrollment is the Budget module's job) -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="110"
              Visibility="{Binding IsAddBeneficiaryPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <local:ProjectDistributionAddBeneficiaryPanel/>
        </Grid>

        <!-- Scanned Claim Result Dialog -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="130"
              Visibility="{Binding IsScannedResultVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Style="{StaticResource PanelCardStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="900" Height="540">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Side: Visual Prompt -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="BarcodeScan" Width="80" Height="80" Foreground="{DynamicResource ThemePrimaryActionBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="SCAN NEXT ID" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextAlignment="Center" Margin="0,16,0,8"/>
                            <TextBlock Text="System is listening..." FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextAlignment="Center"/>
                        </StackPanel>

                        <Border Grid.Column="1" Background="{DynamicResource BrandBorderBrush}" Margin="0,30"/>

                        <!-- Center: Beneficiary Profile -->
                        <StackPanel Grid.Column="2" Margin="30,40" HorizontalAlignment="Center">
                            <TextBlock Text="BENEFICIARY PROFILE" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,20" TextAlignment="Center"/>
                            
                            <Border Width="120" Height="120" CornerRadius="60" Background="{DynamicResource ThemeCardSubtleBrush}" Margin="0,0,0,20">
                                <Ellipse Width="120" Height="120">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding ScannedBeneficiaryPhoto}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Border>

                            <TextBlock Text="{Binding ScannedBeneficiary.FullName}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ScannedBeneficiary.BeneficiaryId}" FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextAlignment="Center" Margin="0,4,0,20"/>

                            <!-- Dynamic Status Badge -->
                            <Border Background="{Binding ScannedBeneficiaryStatusColor}" Padding="20,10" CornerRadius="8">
                                <TextBlock Text="{Binding ScannedBeneficiaryStatus}" FontSize="14" FontWeight="Bold" Foreground="White" TextAlignment="Center" TextWrapping="Wrap"/>
                            </Border>

                            <!-- Household aid-received summary -->
                            <Border Margin="0,16,0,0" Padding="14,10" CornerRadius="8"
                                    Background="{DynamicResource ThemeCardSubtleBrush}"
                                    BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1"
                                    Visibility="{Binding HasHouseholdContext, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="HomeGroup" Width="20" Height="20" VerticalAlignment="Center" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                    <TextBlock Text="{Binding HouseholdAidReceivedSummary}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"
                                               Margin="8,0,0,0" VerticalAlignment="Center" MaxWidth="220" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="3" Background="{DynamicResource BrandBorderBrush}" Margin="0,30"/>

                        <!-- Right Side: Household Members + Distribution History -->
                        <ScrollViewer Grid.Column="4" Margin="20,40" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="HOUSEHOLD MEMBERS" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding HouseholdContextSummary}" FontSize="11" TextWrapping="Wrap" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,8"/>

                                <ItemsControl ItemsSource="{Binding ScannedHouseholdMembers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="10,6" Margin="0,0,0,4" Background="{DynamicResource ThemeSurfaceBrush}"
                                                    BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding FullName}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                                            <materialDesign:PackIcon Kind="AccountCheck" Width="14" Height="14" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                                     Foreground="{DynamicResource BrandSuccessBrush}"
                                                                                     Visibility="{Binding IsScannedBeneficiary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding RelationshipToHead}" FontSize="10" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <!-- BUG FIX: BrandDangerBrush → BrandRedBrush -->
                                                    <Border Grid.Column="1" VerticalAlignment="Center" Background="{DynamicResource BrandRedBrush}" CornerRadius="3" Padding="5,2"
                                                            Visibility="{Binding AlreadyReceivedSameAssistanceType, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="RECEIVED" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No household members on file." FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,2,0,0"
                                           Visibility="{Binding HasHouseholdMembers, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                                <!-- Distribution history -->
                                <TextBlock Text="DISTRIBUTION HISTORY" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,16,0,8"/>
                                <ItemsControl ItemsSource="{Binding ScannedBeneficiaryHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding AssistanceLabel}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding ReleasedAt, StringFormat=MMM yyyy}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                        <TextBlock Text=" - " FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                        <TextBlock Text="Released" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource BrandSuccessBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No previous distributions." FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           Visibility="{Binding HasScannedHistory, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Household Duplicate Warning -->
                    <Border Grid.Row="1" Padding="16,12" Background="{DynamicResource ThemeCardSubtleBrush}"
                            BorderBrush="{DynamicResource BrandWarningBrush}" BorderThickness="1,1,1,0"
                            Visibility="{Binding HasHouseholdWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertOutline" Width="18" Height="18" VerticalAlignment="Center" Foreground="{DynamicResource BrandWarningBrush}"/>
                            <TextBlock Text="{Binding HouseholdWarningMessage}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" Margin="8,0,0,0"
                                       VerticalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Bottom: Action Bar -->
                    <Border Grid.Row="2" Padding="20" Background="{DynamicResource BrandMidnightBrush}" CornerRadius="0,0,16,16">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,30,0">
                                    <TextBlock Text="FUNDING SOURCE" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedProgram.FundSourceCode}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,30,0">
                                    <TextBlock Text="PROJECT" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedProgram.ProgramName}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedProgram.ReleaseKind}" Value="Cash">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="AMOUNT" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedProgram.UnitAmount, StringFormat='PHP {0:N2}'}" FontSize="18" Foreground="{DynamicResource BrandYellowBrush}" FontWeight="Bold"/>
                                </StackPanel>
                                
                                <StackPanel Margin="0,0,30,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedProgram.ReleaseKind}" Value="Goods">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="ITEM" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedProgram.ItemName}" FontSize="18" Foreground="{DynamicResource BrandYellowBrush}" FontWeight="Bold"/>
                                </StackPanel>

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedProgram.ReleaseKind}" Value="Goods">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="QUANTITY" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SelectedProgram.QuantityPerBeneficiary, StringFormat='{}{0:0.##}'}" FontSize="18" Foreground="{DynamicResource BrandYellowBrush}" FontWeight="Bold" Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding SelectedProgram.UnitOfMeasure}" FontSize="18" Foreground="{DynamicResource BrandYellowBrush}" FontWeight="Bold"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="DECLINE" Command="{Binding CancelScannedClaimCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Margin="0,0,16,0"/>
                                <Button Content="{Binding ScannerActionLabel}" Command="{Binding ConfirmScannedClaimCommand}" Style="{StaticResource OperationalActionButton}" Height="45" Padding="30,0" FontSize="16"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Success Overlay -->
                    <Grid Grid.RowSpan="2" Visibility="{Binding IsReleaseSuccessState, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Background="#DD15803D" CornerRadius="16">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CheckCircleOutline" Width="80" Height="80" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="RELEASE SUCCESSFUL" FontSize="28" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0,16,0,8"/>
                                <TextBlock Text="{Binding ScannedBeneficiary.FullName}" FontSize="18" Foreground="#DDFFFFFF" TextAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedProgram.ProgramName}" FontSize="14" Foreground="#AAFFFFFF" TextAlignment="Center" Margin="0,4,0,0"/>
                                <TextBlock Text="Auto closes in 1.5 seconds..." FontSize="11" Foreground="#88FFFFFF" TextAlignment="Center" Margin="0,20,0,0" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ============================ HOUSEHOLD REVIEW MODAL ============================ -->
        <!-- Pops on every CONFIRM so the operator reviews the household before releasing (scanner path). -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="140"
              Visibility="{Binding IsHouseholdConfirmVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#CC0F172A"/>
            <Border Style="{StaticResource PanelCardStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="560" MaxHeight="600">
                <Grid Margin="28,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding RequiresHouseholdOverride, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <materialDesign:PackIcon Kind="HomeGroup" Width="26" Height="26" VerticalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}"/>
                            <TextBlock Text="HOUSEHOLD REVIEW" FontSize="16" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding RequiresHouseholdOverride, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <materialDesign:PackIcon Kind="HomeAlert" Width="26" Height="26" VerticalAlignment="Center" Foreground="{DynamicResource BrandWarningBrush}"/>
                            <TextBlock Text="HOUSEHOLD VERIFICATION" FontSize="16" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Summary + who this is -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Beneficiary photo -->
                            <Grid Grid.Column="0" Width="64" Height="64" Margin="0,0,14,0">
                                <Ellipse Width="64" Height="64" Fill="{DynamicResource ThemeCardSubtleBrush}" Stroke="{DynamicResource BrandBorderBrush}" StrokeThickness="1"/>
                                <Ellipse Width="64" Height="64"
                                         Visibility="{Binding HouseholdConfirmBeneficiaryPhoto, Converter={StaticResource NullToHiddenConverter}}">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding HouseholdConfirmBeneficiaryPhoto}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <materialDesign:PackIcon Kind="AccountCircle" Width="48" Height="48"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                                         Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                         Visibility="{Binding HouseholdConfirmBeneficiaryPhoto, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}"/>
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding HouseholdConfirmBeneficiaryName}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding HouseholdContextSummary}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                        <!-- Neutral summary card -->
                        <Border Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10"
                                Visibility="{Binding RequiresHouseholdOverride, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding HouseholdAidReceivedSummary}" FontSize="13" FontWeight="Bold" TextWrapping="Wrap" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </Border>
                        <!-- Warning summary card -->
                        <Border Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandWarningBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10"
                                Visibility="{Binding RequiresHouseholdOverride, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding HouseholdAidReceivedSummary}" FontSize="13" FontWeight="Bold" TextWrapping="Wrap" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Household roster -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="HOUSEHOLD MEMBERS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding ScannedHouseholdMembers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="10,7" Margin="0,0,0,5" Background="{DynamicResource ThemeSurfaceBrush}"
                                                BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding FullName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                                        <materialDesign:PackIcon Kind="AccountCheck" Width="15" Height="15" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                                 Foreground="{DynamicResource BrandSuccessBrush}"
                                                                                 Visibility="{Binding IsScannedBeneficiary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding RelationshipToHead}" FontSize="10" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                </StackPanel>
                                                <!-- BUG FIX: BrandDangerBrush → BrandRedBrush -->
                                                <Border Grid.Column="1" VerticalAlignment="Center" Background="{DynamicResource BrandRedBrush}" CornerRadius="3" Padding="6,2"
                                                        Visibility="{Binding AlreadyReceivedSameAssistanceType, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="RECEIVED" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Override acknowledgment -->
                    <CheckBox Grid.Row="3" Margin="0,14,0,0"
                              Content="I have verified this beneficiary and authorize the release despite the household warning."
                              IsChecked="{Binding HouseholdOverrideAcknowledged}"
                              Visibility="{Binding RequiresHouseholdOverride, Converter={StaticResource BooleanToVisibilityConverter}}"
                              FontSize="12" Foreground="{DynamicResource BrandMidnightBrush}"/>

                    <!-- Actions -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="DECLINE" Command="{Binding CancelHouseholdConfirmCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="44" Padding="24,0" Margin="0,0,12,0"/>
                        <Button Content="CONFIRM RELEASE" Command="{Binding ConfirmHouseholdReleaseCommand}" Style="{StaticResource OperationalActionButton}" Height="44" Padding="28,0" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>