<UserControl x:Class="AttendanceShiftingManagement.Views.ProjectDistributionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AttendanceShiftingManagement.Views"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1440"
             Background="{DynamicResource BrandSurfaceBrush}">
    
    <UserControl.Resources>

        <!-- Matches the Budget module's operational-button accent (Gemini.md Action Accent #F59E0B). -->
        <SolidColorBrush x:Key="ActionAccentBrush" Color="#F59E0B"/>
        <Style x:Key="OperationalActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="{StaticResource ActionAccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="SidebarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryActionBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>

        <Style x:Key="DetailCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.15" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ======================== HEADER (Row 0) — Client Aligned ======================== -->
        <Grid Grid.Row="0" Background="#F1F5F9" Panel.ZIndex="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Green Header Bar -->
            <Border Grid.Row="0" Background="#15803D" Padding="20,10">
                <Grid>
                    <TextBlock Text="DESTRIBUTION FORM" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Command="{Binding RefreshCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Height="32" Padding="8,0" Margin="0,0,12,0">
                            <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
                        </Button>
                        <Button Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Height="32" Padding="12,0"
                                Content="DASHBOARD" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Fields Row -->
            <Border Grid.Row="1" Padding="20,15" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,0,0,1" Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Project Code -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Project Code:" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" CornerRadius="4" Background="#F8FAFC" Padding="10,6" Width="180">
                                <TextBlock Text="{Binding SelectedProgram.ProgramCode, TargetNullValue='--', FallbackValue='--'}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}"/>
                            </Border>
                            <Button Grid.Column="1" Click="ChangeProject_Click" Style="{StaticResource MaterialDesignFlatButton}" Margin="5,0,0,0" Padding="12,0" Height="32"
                                    Content="BROWSE" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                        </Grid>
                    </StackPanel>

                    <!-- Right: Number of Beneficiaries & Source of Fund -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Number of Beneficiaries:" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                        <Border BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" CornerRadius="4" Background="#F8FAFC" Padding="10,6" Width="200" Margin="0,0,20,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedProgramBeneficiaryCountText, TargetNullValue='0'}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                <TextBlock Text=" Barangay Kabos" FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Source of Fund:" FontSize="13" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                        <Border BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" CornerRadius="4" Background="#F8FAFC" Padding="10,6" Width="250">
                            <TextBlock Text="{Binding SelectedProgram.FundSourceCode, TargetNullValue='--', FallbackValue='--'}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ======================== MAIN WORKSPACE (Row 1) — Blurrable ======================== -->
        <Grid Grid.Row="1">
            <Grid.Effect>
                <BlurEffect Radius="0" x:Name="BackgroundBlur"/>
            </Grid.Effect>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnyOverlayOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="15" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>            <!-- Hidden POS scanner textbox (keyboard capture) - placed in visible part of root tree -->
            <TextBox x:Name="HiddenScannerTextBox" Text="{Binding ScannerInputText, UpdateSourceTrigger=PropertyChanged}" 
                     Opacity="0" Width="1" Height="1" Focusable="True"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     KeyDown="HiddenScannerTextBox_KeyDown"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Sidebar collapsed to 0 width to match Image 2 mockup -->
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ==================== COLLAPSED PROFILE BAR / PAYOUT CONSOLE (Col 0) ==================== -->
                <!-- Retained in tree but collapsed to preserve bindings without code breakage -->
                <Border Grid.Column="0" Background="{DynamicResource ThemeCardSubtleBrush}" Width="0" Visibility="Collapsed"
                        BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <!-- Roster and buttons omitted from rendering but bound -->
                        <TextBlock Text="{Binding SelectedPendingBeneficiary.FullName}"/>
                        <TextBlock Text="{Binding SelectedReleasedClaim.FullName}"/>
                        <TextBlock Text="{Binding HouseholdAidReceivedSummary}"/>
                        <Button Command="{Binding ConfirmReleaseCommand}"/>
                    </Grid>
                </Border>

                <!-- ==================== CENTER CONTENT (Col 1) ==================== -->
                <Grid Grid.Column="1" Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Empty State (no project selected) -->
                    <StackPanel Grid.RowSpan="3" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}">
                        <materialDesign:PackIcon Kind="HandCoinOutline" Width="80" Height="80"
                                                 Foreground="{DynamicResource BrandBorderBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="No Project Selected" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ThemePrimaryActionBrush}" Margin="0,16,0,8" HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a distribution project to manage beneficiaries and execute payouts."
                                   FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Center Banner & Description (Row 0) -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,24" HorizontalAlignment="Center"
                                Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}}">
                        <!-- Bordered Banner -->
                        <Border BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1.5" CornerRadius="8" Padding="30,12" Background="{DynamicResource ThemeCardBrush}">
                            <TextBlock Text="{Binding SelectedProgram.ProgramName}" FontSize="28" FontWeight="ExtraBold" Foreground="{DynamicResource BrandMidnightBrush}" TextAlignment="Center"/>
                        </Border>
                        <!-- Description -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                            <TextBlock Text="Project Description: " FontSize="13" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding SelectedProgram.Description, TargetNullValue='No description provided'}" FontSize="13" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Centered Swipe ID Card Button (Row 1) -->
                    <Button Grid.Row="1" Command="{Binding OpenPcScannerCommand}" Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="#1E6B65" BorderBrush="#1E6B65" Height="48" Width="260" Margin="0,0,0,30" HorizontalAlignment="Center"
                            Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BarcodeScan" Width="20" Height="20" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Swipe ID Card/Search ID" FontSize="15" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Lists area (Row 2) — reference 3-column buckets: RELEASED / PENDING / NOT ELIGIBLE -->
                    <Grid Grid.Row="2"
                          Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ===== Column 1: RELEASED / CLAIMED (Col 0) ===== -->
                        <materialDesign:Card Grid.Column="0" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Ellipse Width="10" Height="10" Fill="{DynamicResource BrandSuccessBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="RELEASED / CLAIMED" FontSize="13" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemePrimaryActionBrush}"
                                               Typography.Capitals="AllSmallCaps"/>
                                </StackPanel>

                                <!-- DataGrid -->
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding ReleasedClaims}"
                                          SelectedItem="{Binding SelectedReleasedClaim}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                                          materialDesign:DataGridAssist.CellPadding="12,8"
                                          MouseDoubleClick="ReleasedGrid_MouseDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Beneficiaries" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                                        <DataGridTemplateColumn Header="Status" Width="85">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="Released" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrandSuccessBrush}" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Remarks" Width="85">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="Claimed" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrandSuccessBrush}" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Pagination -->
                                <Border Grid.Row="2" Margin="0,12,0,0" Padding="0,12,0,0"
                                        BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <TextBlock Text="{Binding ReleasedPaginationText}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Command="{Binding PrevReleasedPageCommand}"
                                                    Style="{StaticResource MaterialDesignFlatButton}" Width="32" Height="32" Padding="0">
                                                <materialDesign:PackIcon Kind="ChevronLeft" Width="18" Height="18"/>
                                            </Button>
                                            <Button Command="{Binding NextReleasedPageCommand}"
                                                    Style="{StaticResource MaterialDesignFlatButton}" Width="32" Height="32" Padding="0" Margin="4,0,0,0">
                                                <materialDesign:PackIcon Kind="ChevronRight" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </materialDesign:Card>

                        <!-- ===== Column 2: PENDING (awaiting release) (Col 2) ===== -->
                        <materialDesign:Card Grid.Column="2" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Ellipse Width="10" Height="10" Fill="{DynamicResource BrandYellowBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="PENDING" FontSize="13" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemePrimaryActionBrush}"
                                               Typography.Capitals="AllSmallCaps"/>
                                </StackPanel>

                                <!-- DataGrid -->
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding PendingBeneficiaries}"
                                          SelectedItem="{Binding SelectedPendingBeneficiary}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                                          materialDesign:DataGridAssist.CellPadding="12,8"
                                          MouseDoubleClick="PendingGrid_MouseDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Beneficiaries" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                                        <DataGridTemplateColumn Header="Status" Width="85">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="Pending" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrandYellowBrush}" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Remarks" Width="85">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="For Release" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrandMidnightBrush}" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Pagination -->
                                <Border Grid.Row="2" Margin="0,12,0,0" Padding="0,12,0,0"
                                        BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <TextBlock Text="{Binding PendingPaginationText}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Command="{Binding PrevPendingPageCommand}"
                                                    Style="{StaticResource MaterialDesignFlatButton}" Width="32" Height="32" Padding="0">
                                                <materialDesign:PackIcon Kind="ChevronLeft" Width="18" Height="18"/>
                                            </Button>
                                            <Button Command="{Binding NextPendingPageCommand}"
                                                    Style="{StaticResource MaterialDesignFlatButton}" Width="32" Height="32" Padding="0" Margin="4,0,0,0">
                                                <materialDesign:PackIcon Kind="ChevronRight" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </materialDesign:Card>

                        <!-- ===== Column 3: UNRELEASED / UNCLAIMED (not eligible) (Col 4) ===== -->
                        <materialDesign:Card Grid.Column="4" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Header -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                    <Ellipse Width="10" Height="10" Fill="{DynamicResource BrandRedBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="UNRELEASED / UNCLAIMED" FontSize="13" FontWeight="Bold"
                                               Foreground="{DynamicResource ThemePrimaryActionBrush}"
                                               Typography.Capitals="AllSmallCaps"/>
                                </StackPanel>

                                <!-- DataGrid -->
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding RejectedBeneficiaries}"
                                          SelectedItem="{Binding SelectedProgramBeneficiary}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                                          Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                                          materialDesign:DataGridAssist.CellPadding="12,8">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Beneficiaries" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                                        <DataGridTemplateColumn Header="Status" Width="85">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="Unreleased" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrandMidnightBrush}" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="Remarks" Width="85">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="Unclaimed" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource BrandRedBrush}" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <!-- Pagination -->
                                <Border Grid.Row="2" Margin="0,12,0,0" Padding="0,12,0,0"
                                        BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                                    <Grid>
                                        <TextBlock Text="{Binding RejectedPaginationText}" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Command="{Binding PrevRejectedPageCommand}"
                                                    Style="{StaticResource MaterialDesignFlatButton}" Width="32" Height="32" Padding="0">
                                                <materialDesign:PackIcon Kind="ChevronLeft" Width="18" Height="18"/>
                                            </Button>
                                            <Button Command="{Binding NextRejectedPageCommand}"
                                                    Style="{StaticResource MaterialDesignFlatButton}" Width="32" Height="32" Padding="0" Margin="4,0,0,0">
                                                <materialDesign:PackIcon Kind="ChevronRight" Width="18" Height="18"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </materialDesign:Card>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- ======================== OVERLAYS ======================== -->

        <!-- Backdrop -->
        <Border Grid.RowSpan="2" Background="#CC0F172A"
                Visibility="{Binding IsAnyOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Panel.ZIndex="100"/>

        <!-- Create Project Panel -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="110"
              Visibility="{Binding IsCreateProjectPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <local:ProjectDistributionCreateProjectPanel/>
        </Grid>

        <!-- Add Beneficiary Panel (dormant — enrollment is the Budget module's job) -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="110"
              Visibility="{Binding IsAddBeneficiaryPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <local:ProjectDistributionAddBeneficiaryPanel/>
        </Grid>

        <!-- PC Scanner Overlay -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="120" Visibility="{Binding IsPcScannerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <local:DesktopScannerOverlay QrCodeScanned="Scanner_QrCodeScanned"
                                       Closed="Scanner_Closed"/>
        </Grid>

        <!-- Scanned Claim Result Dialog — Beneficiaries Profile Form (reference-aligned) -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="130"
              Visibility="{Binding IsScannedResultVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Style="{StaticResource PanelCardStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="960" Height="620">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Form header: title + project context + allocated amount -->
                    <Border Grid.Row="0" Background="{DynamicResource ThemePrimaryActionBrush}" Padding="24,16" CornerRadius="16,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="BENEFICIARIES PROFILE FORM" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding SelectedProgram.ProgramCode, StringFormat='Project Code: {0}'}" FontSize="12" Foreground="#CCFFFFFF"/>
                                    <TextBlock Text="  ·  " FontSize="12" Foreground="#CCFFFFFF"/>
                                    <TextBlock Text="{Binding SelectedProgram.FundSourceCode, StringFormat='Source of Fund: {0}'}" FontSize="12" Foreground="#CCFFFFFF"/>
                                </StackPanel>
                                <TextBlock Text="{Binding SelectedProgram.ProgramName}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandYellowBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <!-- Received Amount / Item -->
                            <Border Grid.Column="1" Background="#22FFFFFF" CornerRadius="8" Padding="16,10" VerticalAlignment="Center">
                                <StackPanel>
                                    <TextBlock Text="RECEIVED AMOUNT / ITEM" FontSize="10" FontWeight="Bold" Foreground="#CCFFFFFF"/>
                                    <TextBlock Text="{Binding ScannedAllocatedAmountText}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrandYellowBrush}"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Photo + Beneficiary ID -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                            <Border Width="150" Height="150" CornerRadius="12" Background="{DynamicResource ThemeCardSubtleBrush}"
                                    BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <materialDesign:PackIcon Kind="AccountCircle" Width="90" Height="90"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                                             Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                    <Border CornerRadius="12" Visibility="{Binding ScannedBeneficiaryPhoto, Converter={StaticResource NullToHiddenConverter}}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding ScannedBeneficiaryPhoto}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Border>
                            <TextBlock Text="Beneficiary ID:" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextAlignment="Center" Margin="0,14,0,2"/>
                            <TextBlock Text="{Binding ScannedBeneficiary.BeneficiaryId}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" TextAlignment="Center"/>
                            <!-- Dynamic Status Badge -->
                            <Border Background="{Binding ScannedBeneficiaryStatusColor}" Padding="14,8" CornerRadius="8" Margin="0,14,0,0">
                                <TextBlock Text="{Binding ScannedBeneficiaryStatus}" FontSize="12" FontWeight="Bold" Foreground="White"
                                           TextAlignment="Center" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="1" Background="{DynamicResource BrandBorderBrush}" Margin="0,24"/>

                        <!-- Center: Beneficiary detail block (reference form fields) -->
                        <ScrollViewer Grid.Column="2" Margin="26,24" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="BENEFICIARY PROFILE" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,16"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Household Member:" FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,14,12"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ScannedHouseholdRole}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,12"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Household Number:" FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,14,12"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ScannedHouseholdNumber}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,12"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Name:" FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,14,12"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ScannedBeneficiary.FullName}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Address:" FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,14,12"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ScannedBeneficiaryAddress}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Age:" FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,14,12"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ScannedBeneficiaryAge}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,12"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Gender:" FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,14,0"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ScannedBeneficiaryGender}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                </Grid>

                                <!-- Household aid-received summary -->
                                <Border Margin="0,18,0,0" Padding="14,10" CornerRadius="8"
                                        Background="{DynamicResource ThemeCardSubtleBrush}"
                                        BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1"
                                        Visibility="{Binding HasHouseholdContext, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="HomeGroup" Width="20" Height="20" VerticalAlignment="Center" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                        <TextBlock Text="{Binding HouseholdAidReceivedSummary}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"
                                                   Margin="8,0,0,0" VerticalAlignment="Center" MaxWidth="280" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Scan-next hint -->
                                <StackPanel Orientation="Horizontal" Margin="0,18,0,0" Opacity="0.75">
                                    <materialDesign:PackIcon Kind="BarcodeScan" Width="18" Height="18" VerticalAlignment="Center" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                    <TextBlock Text="Scanner armed — swipe the next ID anytime." FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Column="3" Background="{DynamicResource BrandBorderBrush}" Margin="0,24"/>

                        <!-- Right: Household Relationship table + Distribution History -->
                        <ScrollViewer Grid.Column="4" Margin="20,24" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Background="{DynamicResource ThemePrimaryActionBrush}" CornerRadius="6,6,0,0" Padding="10,7">
                                    <TextBlock Text="HOUSEHOLD RELATIONSHIP" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </Border>
                                <Border BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1,0,1,1" CornerRadius="0,0,6,6" Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding HouseholdContextSummary}" FontSize="10" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="2,0,2,8"/>
                                        <ItemsControl ItemsSource="{Binding ScannedHouseholdMembers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="6" Padding="10,6" Margin="0,0,0,4" Background="{DynamicResource ThemeSurfaceBrush}"
                                                            BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding FullName}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                                                    <materialDesign:PackIcon Kind="AccountCheck" Width="14" Height="14" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                                             Foreground="{DynamicResource BrandSuccessBrush}"
                                                                                             Visibility="{Binding IsScannedBeneficiary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding RelationshipToHead}" FontSize="10" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                            </StackPanel>
                                                            <!-- Claimed / Unclaimed remarks column (reference form) -->
                                                            <Border Grid.Column="1" VerticalAlignment="Center" Background="{DynamicResource BrandRedBrush}" CornerRadius="3" Padding="5,2"
                                                                    Visibility="{Binding AlreadyReceivedSameAssistanceType, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock Text="RECEIVED" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="No household members on file." FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="2,2,0,0"
                                                   Visibility="{Binding HasHouseholdMembers, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Distribution history -->
                                <TextBlock Text="DISTRIBUTION HISTORY" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,16,0,8"/>
                                <ItemsControl ItemsSource="{Binding ScannedBeneficiaryHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource ThemeSurfaceBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding AssistanceLabel}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                        <TextBlock Text="{Binding ReleasedAt, StringFormat=MMM yyyy}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                        <TextBlock Text=" - " FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                        <TextBlock Text="Released" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource BrandSuccessBrush}"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="No previous distributions." FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           Visibility="{Binding HasScannedHistory, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Household Duplicate Warning -->
                    <Border Grid.Row="2" Padding="16,12" Background="{DynamicResource ThemeCardSubtleBrush}"
                            BorderBrush="{DynamicResource BrandWarningBrush}" BorderThickness="1,1,1,0"
                            Visibility="{Binding HasHouseholdWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertOutline" Width="18" Height="18" VerticalAlignment="Center" Foreground="{DynamicResource BrandWarningBrush}"/>
                            <TextBlock Text="{Binding HouseholdWarningMessage}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" Margin="8,0,0,0"
                                       VerticalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Bottom: Action Bar (Confirm Release / Decline — reference form buttons) -->
                    <Border Grid.Row="3" Padding="20" Background="{DynamicResource BrandMidnightBrush}" CornerRadius="0,0,16,16">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,30,0">
                                    <TextBlock Text="FUNDING SOURCE" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedProgram.FundSourceCode}" FontSize="14" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="RECEIVED AMOUNT / ITEM" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding ScannedAllocatedAmountText}" FontSize="18" Foreground="{DynamicResource BrandYellowBrush}" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="{Binding ScannerCancelLabel}" Command="{Binding CancelScannedClaimCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Margin="0,0,16,0"/>
                                <Button Content="{Binding ScannerActionLabel}" Command="{Binding ConfirmScannedClaimCommand}" Visibility="{Binding IsScannedBeneficiaryEligible, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource OperationalActionButton}" Height="45" Padding="30,0" FontSize="16"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Success Overlay -->
                    <Grid Grid.RowSpan="4" Visibility="{Binding IsReleaseSuccessState, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Background="#DD15803D" CornerRadius="16">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CheckCircleOutline" Width="80" Height="80" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Text="RELEASE SUCCESSFUL" FontSize="28" FontWeight="Bold" Foreground="White" TextAlignment="Center" Margin="0,16,0,8"/>
                                <TextBlock Text="{Binding ScannedBeneficiary.FullName}" FontSize="18" Foreground="#DDFFFFFF" TextAlignment="Center"/>
                                <TextBlock Text="{Binding SelectedProgram.ProgramName}" FontSize="14" Foreground="#AAFFFFFF" TextAlignment="Center" Margin="0,4,0,0"/>
                                <TextBlock Text="Auto closes in 1.5 seconds..." FontSize="11" Foreground="#88FFFFFF" TextAlignment="Center" Margin="0,20,0,0" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ============================ HOUSEHOLD REVIEW MODAL ============================ -->
        <!-- Pops on every CONFIRM so the operator reviews the household before releasing (scanner path). -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="140"
              Visibility="{Binding IsHouseholdConfirmVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="#CC0F172A"/>
            <Border Style="{StaticResource PanelCardStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="560" MaxHeight="600">
                <Grid Margin="28,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding RequiresHouseholdOverride, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <materialDesign:PackIcon Kind="HomeGroup" Width="26" Height="26" VerticalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}"/>
                            <TextBlock Text="HOUSEHOLD REVIEW" FontSize="16" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding RequiresHouseholdOverride, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <materialDesign:PackIcon Kind="HomeAlert" Width="26" Height="26" VerticalAlignment="Center" Foreground="{DynamicResource BrandWarningBrush}"/>
                            <TextBlock Text="HOUSEHOLD VERIFICATION" FontSize="16" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Summary + who this is -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Beneficiary photo -->
                            <Grid Grid.Column="0" Width="64" Height="64" Margin="0,0,14,0">
                                <Ellipse Width="64" Height="64" Fill="{DynamicResource ThemeCardSubtleBrush}" Stroke="{DynamicResource BrandBorderBrush}" StrokeThickness="1"/>
                                <Ellipse Width="64" Height="64"
                                         Visibility="{Binding HouseholdConfirmBeneficiaryPhoto, Converter={StaticResource NullToHiddenConverter}}">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding HouseholdConfirmBeneficiaryPhoto}" Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <materialDesign:PackIcon Kind="AccountCircle" Width="48" Height="48"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                                         Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                         Visibility="{Binding HouseholdConfirmBeneficiaryPhoto, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}"/>
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding HouseholdConfirmBeneficiaryName}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding HouseholdContextSummary}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                        <!-- Neutral summary card -->
                        <Border Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10"
                                Visibility="{Binding RequiresHouseholdOverride, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding HouseholdAidReceivedSummary}" FontSize="13" FontWeight="Bold" TextWrapping="Wrap" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </Border>
                        <!-- Warning summary card -->
                        <Border Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandWarningBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10"
                                Visibility="{Binding RequiresHouseholdOverride, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding HouseholdAidReceivedSummary}" FontSize="13" FontWeight="Bold" TextWrapping="Wrap" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Household roster + requirements checklist -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="HOUSEHOLD MEMBERS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding ScannedHouseholdMembers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="10,7" Margin="0,0,0,5" Background="{DynamicResource ThemeSurfaceBrush}"
                                                BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding FullName}" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                                        <materialDesign:PackIcon Kind="AccountCheck" Width="15" Height="15" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                                 Foreground="{DynamicResource BrandSuccessBrush}"
                                                                                 Visibility="{Binding IsScannedBeneficiary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding RelationshipToHead}" FontSize="10" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                </StackPanel>
                                                <!-- BUG FIX: BrandDangerBrush → BrandRedBrush -->
                                                <Border Grid.Column="1" VerticalAlignment="Center" Background="{DynamicResource BrandRedBrush}" CornerRadius="3" Padding="6,2"
                                                        Visibility="{Binding AlreadyReceivedSameAssistanceType, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="RECEIVED" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Requirements checklist: cedula / barangay certificate must be presented before release. -->
                            <TextBlock Text="REQUIREMENTS CHECKLIST" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,12,0,6"/>
                            <ItemsControl ItemsSource="{Binding ReleaseRequirementRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="10,7" Margin="0,0,0,5" Background="{DynamicResource ThemeSurfaceBrush}"
                                                BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsComplete, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DocumentName}" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0"
                                                           VerticalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                                <TextBlock Grid.Column="2" Text="MISSING" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource BrandRedBrush}"
                                                           Visibility="{Binding IsComplete, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Missing-requirements warning: beneficiary stays in UNRELEASED / UNCLAIMED. -->
                            <Border Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandRedBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10"
                                    Visibility="{Binding HasMissingReleaseRequirements, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding ReleaseRequirementsSummaryText}" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" Foreground="{DynamicResource BrandRedBrush}"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Override acknowledgment -->
                    <CheckBox Grid.Row="3" Margin="0,14,0,0"
                              Content="I have verified this beneficiary and authorize the release despite the household warning."
                              IsChecked="{Binding HouseholdOverrideAcknowledged}"
                              Visibility="{Binding RequiresHouseholdOverride, Converter={StaticResource BooleanToVisibilityConverter}}"
                              FontSize="12" Foreground="{DynamicResource BrandMidnightBrush}"/>

                    <!-- Actions -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="DECLINE" Command="{Binding CancelHouseholdConfirmCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="44" Padding="24,0" Margin="0,0,12,0"/>
                        <Button Content="CONFIRM RELEASE" Command="{Binding ConfirmHouseholdReleaseCommand}" Style="{StaticResource OperationalActionButton}" Height="44" Padding="28,0" FontSize="14"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>