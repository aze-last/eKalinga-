<UserControl x:Class="AttendanceShiftingManagement.Views.ProjectDistributionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AttendanceShiftingManagement.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <Style x:Key="DistributionPanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource BrandMidnightBrush}" />
        </Style>

        <Style x:Key="SectionBodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Resources>
            <Style x:Key="PageBlurStyle" TargetType="Border">
                <Setter Property="Effect">
                    <Setter.Value>
                        <BlurEffect Radius="0" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAddBeneficiaryPanelOpen}" Value="True">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <BlurEffect Radius="15" RenderingBias="Quality" />
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsScannerPanelOpen}" Value="True">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <BlurEffect Radius="15" RenderingBias="Quality" />
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Border Style="{StaticResource PageBlurStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Projects List -->
                    <Border Grid.Column="0"
                            Style="{StaticResource DistributionPanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Projects"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="Select a project to load the manual release workspace."
                                           Style="{StaticResource SectionBodyTextStyle}" />
                            </StackPanel>

                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding ProgramSummaries}"
                                     SelectedItem="{Binding SelectedProgramSummary}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12">
                                            <Border Padding="16"
                                                    CornerRadius="16"
                                                    Background="{DynamicResource ThemeCardSubtleBrush}"
                                                    BorderBrush="{DynamicResource BrandBorderBrush}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="{Binding ProgramName}"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource BrandMidnightBrush}"
                                                                   TextWrapping="Wrap" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding ProgramCode, StringFormat='Code: {0}'}"
                                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="{Binding DistributionStatus, StringFormat='Status: {0}'}"
                                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                                        <TextBlock Margin="0,10,0,0"
                                                                   Text="{Binding ClaimCountText}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="{Binding ClaimedAmountText}"
                                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                                    </StackPanel>

                                                    <Button x:Name="ProjectActionButton"
                                                            Grid.Column="1"
                                                            Width="34"
                                                            Height="34"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                            Command="{Binding DataContext.OpenProjectActionMenuCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                            CommandParameter="{Binding}">
                                                        <materialDesign:PackIcon Kind="Settings" />
                                                    </Button>
                                                </Grid>
                                            </Border>

                                            <!-- Cog Action Menu -->
                                            <Border Panel.ZIndex="20"
                                                    Width="190"
                                                    Padding="10"
                                                    Background="{DynamicResource ThemeCardBrush}"
                                                    BorderBrush="{DynamicResource BrandBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    Margin="0,26,-120,0"
                                                    Visibility="{Binding IsActionMenuOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel>
                                                    <Button Content="Add Beneficiaries"
                                                            Height="34"
                                                            Style="{StaticResource SecondaryActionButton}"
                                                            Command="{Binding DataContext.OpenProgramAddBeneficiaryPanelCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Scanner Configuration"
                                                            Margin="0,8,0,0"
                                                            Height="34"
                                                            Style="{StaticResource SecondaryActionButton}"
                                                            Command="{Binding DataContext.OpenProgramScannerPanelCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                            CommandParameter="{Binding}" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel Grid.Row="4">
                                <Button Content="REFRESH"
                                        Height="38"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding RefreshCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Center Operations -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="20" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Style="{StaticResource DistributionPanelCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Manual Project Distribution"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding SelectedProgram.ProgramName, TargetNullValue='No project selected yet'}"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrandMidnightBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding SelectedProgramBudgetCapText, StringFormat='Allocated Amount: {0}'}"
                                               Style="{StaticResource SectionBodyTextStyle}" />
                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding StatusMessage}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{Binding StatusBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="DASHBOARD"
                                        Width="140"
                                        Height="40"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="0.95*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="1.1*" />
                            </Grid.ColumnDefinitions>

                            <!-- Column 1: UNRELEASED (Pending) -->
                            <Border Grid.Column="0"
                                    Style="{StaticResource DistributionPanelCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="UNRELEASED"
                                                   Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="Search and select a beneficiary."
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>

                                    <!-- NEW SEARCH BAR -->
                                    <TextBox Grid.Row="2"
                                             Text="{Binding PendingSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Search Name/ID..."
                                             materialDesign:TextFieldAssist.HasClearButton="True" />

                                    <ListBox Grid.Row="4"
                                             ItemsSource="{Binding PendingBeneficiaries}"
                                             SelectedItem="{Binding SelectedPendingBeneficiary}"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="14"
                                                        CornerRadius="14"
                                                        Background="{DynamicResource ThemeCardSubtleBrush}"
                                                        BorderBrush="{DynamicResource BrandBorderBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FullName}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding BeneficiaryId, StringFormat='ID: {0}'}"
                                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Grid Grid.Row="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Content="PREV" Width="60" Height="34" Style="{StaticResource SecondaryActionButton}" Command="{Binding PrevPendingPageCommand}" />
                                        <TextBlock Grid.Column="1" Text="{Binding PendingPaginationText}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" VerticalAlignment="Center" />
                                        <Button Grid.Column="2" Content="NEXT" Width="60" Height="34" Style="{StaticResource SecondaryActionButton}" Command="{Binding NextPendingPageCommand}" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Column 2: DIGITAL ID & VERIFICATION -->
                            <Border Grid.Column="2"
                                    Style="{StaticResource DistributionPanelCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="18" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="DIGITAL ID"
                                               Style="{StaticResource SectionTitleTextStyle}" />

                                    <Border Grid.Row="2"
                                            Background="{DynamicResource ThemeCardSubtleBrush}"
                                            BorderBrush="{DynamicResource BrandBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="18">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="14" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding SelectedPendingBeneficiary.FullName, TargetNullValue='No selection'}"
                                                           FontSize="21"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrandMidnightBrush}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="{Binding SelectedPendingDigitalIdCardNumber}"
                                                           Style="{StaticResource SectionBodyTextStyle}" />
                                            </StackPanel>

                                            <Border Grid.Row="2"
                                                    Width="160"
                                                    Height="160"
                                                    HorizontalAlignment="Center"
                                                    Background="{DynamicResource ThemeCardBrush}"
                                                    BorderBrush="{DynamicResource BrandBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="16">
                                                <Image Source="{Binding SelectedPendingDigitalIdQrImage}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                                                       SnapsToDevicePixels="True" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="4">
                                        <TextBlock Text="{Binding SelectedProgramAssistanceSummary}"
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="{Binding SelectedProgramWorkflowSummary}"
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>

                                    <Button Grid.Row="6"
                                            Content="CONFIRM RELEASE"
                                            Height="42"
                                            Style="{StaticResource PrimaryActionButton}"
                                            Command="{Binding ConfirmReleaseCommand}" />
                                </Grid>
                            </Border>

                            <!-- Column 3: RELEASED -->
                            <Border Grid.Column="4"
                                    Style="{StaticResource DistributionPanelCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="RELEASED"
                                                   Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="Recently released history."
                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                    </StackPanel>

                                    <ListBox Grid.Row="2"
                                             ItemsSource="{Binding ReleasedClaims}"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10"
                                                        Padding="14"
                                                        CornerRadius="14"
                                                        Background="{DynamicResource ThemeCardSubtleBrush}"
                                                        BorderBrush="{DynamicResource BrandBorderBrush}"
                                                        BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FullName}"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource BrandMidnightBrush}" />
                                                        <TextBlock Margin="0,6,0,0"
                                                                   Text="{Binding AmountText}"
                                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Text="{Binding ReleasedAt, StringFormat='Released: {0:yyyy-MM-dd hh:mm tt}'}"
                                                                   Style="{StaticResource SectionBodyTextStyle}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Grid Grid.Row="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Content="PREV" Width="60" Height="34" Style="{StaticResource SecondaryActionButton}" Command="{Binding PrevReleasedPageCommand}" />
                                        <TextBlock Grid.Column="1" Text="{Binding ReleasedPaginationText}" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" VerticalAlignment="Center" />
                                        <Button Grid.Column="2" Content="NEXT" Width="60" Height="34" Style="{StaticResource SecondaryActionButton}" Command="{Binding NextReleasedPageCommand}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- OVERLAYS -->
        <local:ProjectDistributionAddBeneficiaryPanel
            Panel.ZIndex="99"
            DataContext="{Binding}"
            Visibility="{Binding IsAddBeneficiaryPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <local:ProjectDistributionScannerConfigPanel
            Panel.ZIndex="99"
            DataContext="{Binding}"
            Visibility="{Binding IsScannerPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />
    </Grid>
</UserControl>
