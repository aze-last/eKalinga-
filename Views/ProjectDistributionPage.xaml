<UserControl x:Class="AttendanceShiftingManagement.Views.ProjectDistributionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AttendanceShiftingManagement.Views"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <Style x:Key="DistributionPanelCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource BrandMidnightBrush}" />
        </Style>

        <Style x:Key="SectionBodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Resources>
            <Style x:Key="PageBlurStyle" TargetType="Border">
                <Setter Property="Effect">
                    <Setter.Value>
                        <BlurEffect Radius="0" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAddBeneficiaryPanelOpen}" Value="True">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <BlurEffect Radius="15" RenderingBias="Quality" />
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsScannerPanelOpen}" Value="True">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <BlurEffect Radius="15" RenderingBias="Quality" />
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Resources>

        <Border Style="{StaticResource PageBlurStyle}">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header Section -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Title & Icon -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="56" Height="56" 
                                Background="{DynamicResource BrandSubtleBrush}" 
                                CornerRadius="16">
                            <materialDesign:PackIcon Kind="HandHeart" Width="32" Height="32" 
                                                   Foreground="{DynamicResource BrandMidnightBrush}" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Project Distribution" 
                                       FontSize="24" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Text="{Binding SelectedProgram.ProgramName, TargetNullValue='No project selected'}" 
                                       FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Summary Card (Budget Stats) -->
                    <Border Grid.Column="1" Margin="40,0" 
                            Style="{StaticResource DistributionPanelCardStyle}" 
                            Padding="20,10" VerticalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="1" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="Allocated" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedProgramBudgetCapText}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" HorizontalAlignment="Center" />
                            </StackPanel>

                            <Border Grid.Column="1" Background="{DynamicResource BrandBorderBrush}" Margin="10,5" />

                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="Released" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedProgramDistributedText}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" HorizontalAlignment="Center" />
                            </StackPanel>

                            <Border Grid.Column="3" Background="{DynamicResource BrandBorderBrush}" Margin="10,5" />

                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <TextBlock Text="Remaining" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedProgramRemainingBudgetText}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Header Actions -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="CHANGE PROJECT" 
                                Height="40" Padding="16,0"
                                Style="{StaticResource SecondaryActionButton}" 
                                Click="ChangeProject_Click" />
                        
                        <Button Margin="12,0,0,0"
                                Content="REFRESH" 
                                Height="40" Width="100"
                                Style="{StaticResource SecondaryActionButton}" 
                                Command="{Binding RefreshCommand}" />
                    </StackPanel>
                </Grid>

                <!-- Main Content (Pattern B) -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Column 1: PENDING -->
                    <Border Grid.Column="0" Style="{StaticResource DistributionPanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="PENDING BENEFICIARIES" Style="{StaticResource SectionTitleTextStyle}" />
                            
                            <!-- Search -->
                            <TextBox Grid.Row="2"
                                     Text="{Binding PendingSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Search Name/ID..."
                                     materialDesign:TextFieldAssist.HasClearButton="True" />

                            <!-- DataGrid -->
                            <DataGrid Grid.Row="4"
                                      ItemsSource="{Binding PendingBeneficiaries}"
                                      SelectedItem="{Binding SelectedPendingBeneficiary}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      MouseDoubleClick="PendingGrid_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Beneficiary Name" Binding="{Binding FullName}" Width="*" />
                                    <DataGridTextColumn Header="ID Number" Binding="{Binding BeneficiaryId}" Width="150" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Pagination -->
                            <Grid Grid.Row="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Content="PREV" Width="70" Height="34" Style="{StaticResource SecondaryActionButton}" Command="{Binding PrevPendingPageCommand}" />
                                <TextBlock Grid.Column="1" Text="{Binding PendingPaginationText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <Button Grid.Column="2" Content="NEXT" Width="70" Height="34" Style="{StaticResource SecondaryActionButton}" Command="{Binding NextPendingPageCommand}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Column 2: ACTION COLUMN (Narrow) -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Width="42" Height="42"
                                Style="{StaticResource GoldActionButton}"
                                Command="{Binding ConfirmReleaseCommand}"
                                ToolTip="Confirm Release Selected">
                            <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24" />
                        </Button>
                        
                        <Button Margin="0,16,0,0"
                                Width="42" Height="42"
                                Style="{StaticResource SecondaryActionButton}"
                                Command="{Binding OpenScannerPanelCommand}"
                                ToolTip="Open Scanner Tool">
                            <materialDesign:PackIcon Kind="QrcodeScan" Width="20" Height="20" />
                        </Button>
                    </StackPanel>

                    <!-- Column 3: RELEASED -->
                    <Border Grid.Column="2" Style="{StaticResource DistributionPanelCardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="RELEASED CLAIMS" Style="{StaticResource SectionTitleTextStyle}" />

                            <!-- DataGrid -->
                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding ReleasedClaims}"
                                      SelectedItem="{Binding SelectedReleasedClaim}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      MouseDoubleClick="ReleasedGrid_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Beneficiary Name" Binding="{Binding FullName}" Width="*" />
                                    <DataGridTextColumn Header="Amount" Binding="{Binding AmountText}" Width="120" />
                                    <DataGridTextColumn Header="Time Released" Binding="{Binding ReleasedAt, StringFormat='{}{0:hh:mm tt}'}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Pagination -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Content="PREV" Width="70" Height="34" Style="{StaticResource SecondaryActionButton}" Command="{Binding PrevReleasedPageCommand}" />
                                <TextBlock Grid.Column="1" Text="{Binding ReleasedPaginationText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                <Button Grid.Column="2" Content="NEXT" Width="70" Height="34" Style="{StaticResource SecondaryActionButton}" Command="{Binding NextReleasedPageCommand}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- OVERLAYS -->
        <local:ProjectDistributionAddBeneficiaryPanel
            Panel.ZIndex="99"
            DataContext="{Binding}"
            Visibility="{Binding IsAddBeneficiaryPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />

        <local:ProjectDistributionScannerConfigPanel
            Panel.ZIndex="99"
            DataContext="{Binding}"
            Visibility="{Binding IsScannerPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />
    </Grid>
</UserControl>
