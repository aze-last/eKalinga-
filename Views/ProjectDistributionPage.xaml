<UserControl x:Class="AttendanceShiftingManagement.Views.ProjectDistributionPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:AttendanceShiftingManagement.Views"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1200"
             Background="{DynamicResource BrandSurfaceBrush}">
    <UserControl.Resources>
        <helpers:NullToHiddenConverter x:Key="NullToHiddenConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:PercentToWidthConverter x:Key="PercentToWidthConverter" />

        <Style x:Key="SidebarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryActionBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>

        <Style x:Key="DetailCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.15" />
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Layout Container with Blur Effect -->
        <Grid>
            <Grid.Effect>
                <BlurEffect Radius="0" x:Name="BackgroundBlur"/>
            </Grid.Effect>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnyOverlayOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="15" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar Navigation -->
                <Border Grid.Column="0" Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Dashboard Navigation -->
                        <StackPanel Grid.Row="0" Margin="20,20,20,10">
                            <Button Content="DASHBOARD" 
                                    Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="45" Margin="0,0,0,20"/>
                        </StackPanel>

                        <!-- Sidebar Actions -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Border Padding="20,0,20,20">
                                <StackPanel>
                                    <TextBlock Text="PROJECT OPERATIONS" Style="{StaticResource SidebarHeaderStyle}"/>

                                    <Button Content="CREATE PROJECT" 
                                            Command="{Binding OpenCreateProjectPanelCommand}"
                                            Style="{StaticResource GoldActionButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,8" FontSize="14"/>

                                    <Button Content="CHANGE PROJECT" 
                                            Click="ChangeProject_Click"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,20" FontSize="14"/>

                                    <TextBlock Text="SCANNER &amp; QUEUE" Style="{StaticResource SidebarHeaderStyle}"/>

                                    <Button Content="OPEN MOBILE SCANNER" 
                                            Command="{Binding OpenScannerPanelCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,8" FontSize="14"/>

                                    <Button Content="SCAN VIA PC CAMERA" 
                                            Command="{Binding OpenPcScannerCommand}"
                                            Style="{StaticResource GoldActionButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,8" FontSize="14">
                                        <Button.ContentTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Camera" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="SCAN VIA PC CAMERA" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </Button.ContentTemplate>
                                    </Button>

                                    <Button Content="QUEUE MONITOR" 
                                            Command="{Binding OpenLivePreviewCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,20" FontSize="14"/>

                                    <TextBlock Text="DATA ACTIONS" Style="{StaticResource SidebarHeaderStyle}"/>

                                    <Button Content="REFRESH DATA" 
                                            Command="{Binding RefreshCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,8" FontSize="14"/>
                                    
                                    <Button Content="ADD BENEFICIARY" 
                                            Command="{Binding OpenAddBeneficiaryPanelCommand}"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" 
                                            HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,20" FontSize="14"/>

                                    <!-- Confirm Release primary button -->
                                    <Button Content="CONFIRM RELEASE" 
                                            Command="{Binding ConfirmReleaseCommand}"
                                            Style="{StaticResource GoldActionButton}" 
                                            Height="50" Margin="0,0,0,25" FontSize="15" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>

                        <!-- Status Area -->
                        <Border Grid.Row="2" Padding="20" Background="{DynamicResource ThemeCardBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <TextBlock Text="MONITOR STATUS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Main Content Area -->
                <Grid Grid.Column="1" Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header & Stats Section -->
                    <Grid Grid.Row="0" Margin="0,0,0,24" Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Project Info -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="ACTIVE PROJECT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedProgram.ProgramName, FallbackValue='No project selected'}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                            <TextBlock Text="{Binding SelectedProgramAssistanceSummary}" FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Metric Cards -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Style="{StaticResource DetailCardStyle}" Padding="20,15" Margin="0,0,16,0" Width="200" Height="90">
                                <StackPanel>
                                    <TextBlock Text="ALLOCATED" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SelectedProgramBudgetCapText}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource DetailCardStyle}" Padding="20,15" Margin="0,0,16,0" Width="200" Height="90">
                                <StackPanel>
                                    <TextBlock Text="RELEASED" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SelectedProgramDistributedText}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandSuccessBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource DetailCardStyle}" Padding="20,15" Width="200" Height="90">
                                <StackPanel>
                                    <TextBlock Text="REMAINING" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding SelectedProgramRemainingBudgetText}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Page Content -->
                    <Grid Grid.Row="1">
                        <!-- Project Selector Empty State -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}">
                            <materialDesign:PackIcon Kind="PackageVariant" Width="80" Height="80" Foreground="{DynamicResource BrandBorderBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="No Project Selected" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,16,0,8" HorizontalAlignment="Center"/>
                            <TextBlock Text="Select a distribution project to begin monitoring releases and queue management." FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}" HorizontalAlignment="Center"/>
                            <Button Content="CHOOSE PROJECT" Style="{StaticResource GoldActionButton}" Margin="0,24,0,0" Height="44" Click="ChangeProject_Click"/>
                        </StackPanel>

                        <!-- Project View: Side-by-Side Cards -->
                        <Grid Visibility="{Binding SelectedProgram, Converter={StaticResource NullToHiddenConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: Pending Releases Card -->
                            <Border Grid.Column="0" Style="{StaticResource DetailCardStyle}" Padding="28">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Card Header -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                        <materialDesign:PackIcon Kind="ClockOutline" Foreground="{DynamicResource ThemePrimaryActionBrush}" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="PENDING RELEASES" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}" VerticalAlignment="Center"/>
                                        <Border Background="{DynamicResource ThemePrimaryActionBrush}" CornerRadius="12" Padding="10,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PendingTotalCount}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Search -->
                                    <TextBox Grid.Row="1" Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                             materialDesign:HintAssist.Hint="Search Name/ID..." 
                                             Text="{Binding PendingSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Height="44" Margin="0,0,0,24"/>

                                    <!-- DataGrid -->
                                    <DataGrid Grid.Row="2" ItemsSource="{Binding PendingBeneficiaries}" SelectedItem="{Binding SelectedPendingBeneficiary}" 
                                              Style="{StaticResource PatternBGridStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Beneficiary" Binding="{Binding FullName}" Width="*"/>
                                            <DataGridTextColumn Header="ID Number" Binding="{Binding BeneficiaryId}" Width="150"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- Pagination -->
                                    <Grid Grid.Row="3" Margin="0,20,0,0">
                                        <Button Content="PREV" Command="{Binding PrevPendingPageCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" HorizontalAlignment="Left" Width="90" Height="38"/>
                                        <TextBlock Text="{Binding PendingPaginationText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        <Button Content="NEXT" Command="{Binding NextPendingPageCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" HorizontalAlignment="Right" Width="90" Height="38"/>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Right: Released Claims Card -->
                            <Border Grid.Column="2" Style="{StaticResource DetailCardStyle}" Padding="28">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Card Header -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                        <materialDesign:PackIcon Kind="CheckCircleOutline" Foreground="{DynamicResource BrandSuccessBrush}" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="RELEASED CLAIMS" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource BrandSuccessBrush}" VerticalAlignment="Center"/>
                                        <Border Background="{DynamicResource BrandSuccessBrush}" CornerRadius="12" Padding="10,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ReleasedTotalCount}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- DataGrid -->
                                    <DataGrid Grid.Row="1" ItemsSource="{Binding ReleasedClaims}" SelectedItem="{Binding SelectedReleasedClaim}" 
                                              Style="{StaticResource PatternBGridStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Beneficiary" Binding="{Binding FullName}" Width="*"/>
                                            <DataGridTextColumn Header="Amount" Binding="{Binding AmountText}" Width="110"/>
                                            <DataGridTextColumn Header="Time" Binding="{Binding ReleasedAt, StringFormat='{}{0:hh:mm tt}'}" Width="110"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <!-- Pagination -->
                                    <Grid Grid.Row="2" Margin="0,20,0,0">
                                        <Button Content="PREV" Command="{Binding PrevReleasedPageCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" HorizontalAlignment="Left" Width="90" Height="38"/>
                                        <TextBlock Text="{Binding ReleasedPaginationText}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        <Button Content="NEXT" Command="{Binding NextReleasedPageCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" HorizontalAlignment="Right" Width="90" Height="38"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <!-- Backdrop for Overlays -->
        <Border Background="#CC0F172A" Visibility="{Binding IsAnyOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="100"/>

        <!-- Operational Overlays -->
        <Grid Panel.ZIndex="110" Visibility="{Binding IsAnyOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <!-- Add Beneficiary Panel -->
            <local:ProjectDistributionAddBeneficiaryPanel Visibility="{Binding IsAddBeneficiaryPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                                         Margin="100,60"/>
            
            <!-- Mobile Scanner Config Panel -->
            <local:ProjectDistributionScannerConfigPanel Visibility="{Binding IsScannerPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                                       Margin="200,100"/>

            <!-- PC Scanner Overlay -->
            <local:DesktopScannerOverlay Visibility="{Binding IsPcScannerOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       QrCodeScanned="Scanner_QrCodeScanned"
                                       Closed="Scanner_Closed"/>
        </Grid>
    </Grid>
</UserControl>