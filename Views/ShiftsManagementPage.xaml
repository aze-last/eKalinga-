<UserControl x:Class="AttendanceShiftingManagement.Views.ShiftsManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:AttendanceShiftingManagement.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100"
             Background="{StaticResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Planning Tool Card -->
        <materialDesign:Card Grid.Row="0" Margin="0,0,0,24" Padding="20" UniformCornerRadius="12" Background="White">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="Shift Planner" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <DatePicker Width="150" SelectedDate="{Binding SelectedDay}" 
                                    materialDesign:HintAssist.Hint="Selected Date"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}" Margin="0,0,12,0"/>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}" Content="Refresh" Command="{Binding RefreshCommand}"/>
                    </StackPanel>
                </DockPanel>

                <Separator Margin="0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Employee Selector -->
                    <StackPanel Grid.Column="0" Margin="0,0,24,0">
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Select Crew Members" FontWeight="SemiBold" DockPanel.Dock="Left"/>
                            <CheckBox Content="Select All"
                                      IsChecked="{Binding IsAllSelected}"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Height="150">
                            <ScrollViewer>
                                <ItemsControl ItemsSource="{Binding Employees}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding Employee.FullName}" 
                                                      IsChecked="{Binding IsSelected}" 
                                                      Margin="8,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <!-- Search -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Search Crew" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="Search employee..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Height="60"
                                 Margin="0,0,0,12"/>

                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0"
                                    Content="CREATE WEEKLY SHIFT" 
                                    Command="{Binding CreateBatchCommand}"
                                    Height="50"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource BrandMidnightBrush}" BorderBrush="{StaticResource BrandMidnightBrush}"
                                    Foreground="White"
                                    Margin="0,0,10,0"/>

                            <Button Grid.Column="1"
                                    Content="CLEAR" 
                                    Command="{Binding ClearShiftsCommand}"
                                    Height="50"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    BorderBrush="{StaticResource BrandRedBrush}" Foreground="{StaticResource BrandRedBrush}"
                                    ToolTip="Clear all shifts for this week"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </materialDesign:Card>

        <!-- Roster Table Card -->
        <materialDesign:Card Grid.Row="1" UniformCornerRadius="12" Padding="0" Background="White">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Time Headers + Search -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Grid.Column="0" Background="#F1F5F9" Padding="10" BorderBrush="#E2E8F0" BorderThickness="1,1,0,1">
                            <StackPanel>
                                <TextBlock Text="CREW MEMBER" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Search employee..."
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Margin="0,8,0,0"
                                         Height="32"/>
                            </StackPanel>
                        </Border>

                        <ItemsControl Grid.Column="1" ItemsSource="{Binding HoursLabels}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F1F5F9" Padding="5" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <TextBlock Text="{Binding}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <!-- Roster Body -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding RosterView}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Padding="12" BorderBrush="#E2E8F0" BorderThickness="1,0,1,1">
                                        <TextBlock Text="{Binding EmployeeName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Border>

                                    <ItemsControl Grid.Column="1" ItemsSource="{Binding Segments}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,1,1" Height="40">
                                                    <Button Command="{Binding DataContext.EditShiftCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="0" Margin="0" BorderThickness="0" Background="Transparent"
                                                            Height="40" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                                                        <Grid>
                                                            <Rectangle Fill="#F2A900" 
                                                                       Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                       Margin="1"/>
                                                            <TextBlock Text="{Binding Label}" 
                                                                       FontSize="8" 
                                                                       Foreground="White"
                                                                       FontWeight="Bold"
                                                                       HorizontalAlignment="Center" 
                                                                       VerticalAlignment="Center"
                                                                       Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                        </Grid>
                                                    </Button>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </materialDesign:Card>
        <!-- Edit Shift Overlay -->
        <Grid Grid.RowSpan="2" Background="#112233" Opacity="0.5" 
              Visibility="{Binding IsEditingShift, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        
        <materialDesign:Card Grid.RowSpan="2" Width="400" Height="300" 
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             UniformCornerRadius="12" Padding="20"
                             Visibility="{Binding IsEditingShift, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="Edit Shift Details" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,20"/>
                
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Start Time" Foreground="Gray" FontSize="12"/>
                        <materialDesign:TimePicker SelectedTime="{Binding SelectedShiftToEdit.StartTime}" Is24Hours="True"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="End Time" Foreground="Gray" FontSize="12"/>
                        <materialDesign:TimePicker SelectedTime="{Binding SelectedShiftToEdit.EndTime}" Is24Hours="True"/>
                    </StackPanel>
                </Grid>

                <ComboBox materialDesign:HintAssist.Hint="Position" 
                          ItemsSource="{Binding SelectedShiftToEdit.Position.Name}" 
                          IsEnabled="False" Margin="0,0,0,20"
                          ToolTip="Position editing is locked to Employee's role"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="CANCEL" Command="{Binding CancelEditCommand}" 
                            Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,8,0"/>
                    <Button Content="SAVE CHANGES" Command="{Binding SaveShiftEditCommand}" 
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
