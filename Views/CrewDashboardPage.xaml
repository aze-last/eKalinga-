<UserControl x:Class="AttendanceShiftingManagement.Views.CrewDashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" UniformCornerRadius="20" Background="#DA291C" Foreground="White" Padding="25" materialDesign:ElevationAssist.Elevation="Dp4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText, FallbackValue='OFF DUTY'}" FontSize="30" FontWeight="ExtraBold"/>
                    <TextBlock Text="{Binding StatusDetails, FallbackValue='Lobby | Next Shift: 11:00 AM'}" FontSize="15" Opacity="0.9" Margin="0,5,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Height="60" Width="180" Background="#FFC72C" BorderBrush="#FFC72C" Foreground="#27251F"
                        materialDesign:ButtonAssist.CornerRadius="30" FontWeight="Black" FontSize="18"
                        Content="{Binding ActionButtonText, FallbackValue='TIME IN'}"
                        Command="{Binding TimeInOutCommand}"/>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="1" Margin="0,25,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <TextBlock Text="Quick Actions" FontWeight="Bold" FontSize="18" Margin="5,0,0,15" Foreground="#27251F"/>
                <UniformGrid Columns="1" Margin="0,0,0,25">
                    <materialDesign:Card Margin="5" UniformCornerRadius="15" Padding="15">
                        <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="#DA291C" Height="80" Command="{Binding OpenScheduleCommand}">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="CalendarMonth" HorizontalAlignment="Center" Width="30" Height="30"/>
                                <TextBlock Text="Schedule" FontWeight="Bold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Button>
                    </materialDesign:Card>
                </UniformGrid>

                <materialDesign:Card UniformCornerRadius="15" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Weekly Roster" FontWeight="Black" FontSize="18" Margin="0,0,0,15"/>
                        <DataGrid ItemsSource="{Binding WeeklyShifts}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="None" Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="DAY" Binding="{Binding Day}" Width="100" FontWeight="Bold"/>
                                <DataGridTextColumn Header="POSITION" Binding="{Binding Position}" Width="*"/>
                                <DataGridTemplateColumn Header="TIME" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFF1CC" CornerRadius="10" Padding="10,5">
                                                <TextBlock Text="{Binding TimeRange}" Foreground="#27251F" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="12,0,0,0">
                <materialDesign:Card UniformCornerRadius="15" Background="#27251F" Foreground="White" Padding="20" Margin="0,42,0,20">
                    <StackPanel>
                        <TextBlock Text="Total Earnings (Est.)" Opacity="0.6" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalPay, FallbackValue='? 5,525.00'}" FontSize="32" FontWeight="Black" Foreground="#FFC72C" Margin="0,5"/>
                        <Separator Background="White" Opacity="0.1" Margin="0,15"/>
                        <UniformGrid Columns="2">
                            <StackPanel>
                                <TextBlock Text="Total Hours" Opacity="0.6" FontSize="11"/>
                                <TextBlock Text="{Binding TotalHoursCount}" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right">
                                <TextBlock Text="Overtime" Opacity="0.6" FontSize="11"/>
                                <TextBlock Text="{Binding OvertimeHoursCount}" FontWeight="Bold" FontSize="16" Foreground="#FFC72C"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card UniformCornerRadius="15" Padding="20">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="Announcements" FontWeight="Bold" FontSize="16"/>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <ComboBox Width="140"
                                          ItemsSource="{Binding NotificationTypes}"
                                          SelectedItem="{Binding SelectedNotificationType}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          Margin="0,0,8,0"/>
                                <Button Content="Mark All Read"
                                        Command="{Binding MarkAllReadCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Foreground="#DA291C"
                                        BorderBrush="#DA291C"/>
                            </StackPanel>
                        </DockPanel>

                        <ItemsControl ItemsSource="{Binding NotificationsView}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="0,10">
                                        <DockPanel>
                                            <materialDesign:PackIcon Kind="Information" Foreground="#DA291C" Margin="0,0,10,0"/>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="12" Opacity="0.8"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='MMM dd, yyyy hh:mm tt'}" FontSize="10" Opacity="0.6"/>
                                            </StackPanel>
                                            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                                <TextBlock Text="NEW"
                                                           Foreground="#DA291C"
                                                           FontWeight="Bold"
                                                           FontSize="10"
                                                           HorizontalAlignment="Right">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Button Content="Mark Read"
                                                        Command="{Binding DataContext.MarkReadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignFlatButton}"/>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
