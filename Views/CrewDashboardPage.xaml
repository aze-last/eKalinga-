<UserControl x:Class="AttendanceShiftingManagement.Views.CrewDashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100"
             Background="#F5F7FA">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" 
                             UniformCornerRadius="15" 
                             Background="{Binding StatusColor, FallbackValue='#43A047'}" 
                             Foreground="White"
                             Padding="24"
                             materialDesign:ElevationAssist.Elevation="Dp3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusText, FallbackValue='ON DUTY'}" 
                               FontSize="28" FontWeight="ExtraBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <materialDesign:PackIcon Kind="ClockOutline" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding StatusDetails, FallbackValue='Shift: 08:00 AM - 04:00 PM | Kitchen'}" 
                                   FontSize="16" Opacity="0.9"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" 
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Background="White" Foreground="{Binding StatusColor, FallbackValue='#43A047'}"
                        Height="54" Width="160" 
                        materialDesign:ButtonAssist.CornerRadius="27"
                        Command="{Binding TimeInOutCommand}"
                        Content="{Binding ActionButtonText, FallbackValue='TIME OUT'}"
                        IsEnabled="{Binding IsActionEnabled}"
                        FontSize="16" FontWeight="Bold"/>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="1" Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,12,0">

                <TextBlock Text="Daily Management" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="4,0,0,12" FontWeight="SemiBold"/>
                <UniformGrid Columns="3" Margin="0,0,0,24">
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Height="100" Margin="4" 
                            BorderBrush="{DynamicResource PrimaryHueMidBrush}" BorderThickness="1.5"
                            materialDesign:ButtonAssist.CornerRadius="12" Background="White"
                            Command="{Binding OpenScheduleCommand}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="CalendarWeek" HorizontalAlignment="Center" Width="28" Height="28"/>
                            <TextBlock Text="Schedule" Margin="0,8,0,0" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Height="100" Margin="4" 
                            materialDesign:ButtonAssist.CornerRadius="12" Background="White">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="History" HorizontalAlignment="Center" Width="28" Height="28"/>
                            <TextBlock Text="History" Margin="0,8,0,0" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Height="100" Margin="4" 
                            materialDesign:ButtonAssist.CornerRadius="12" Background="White">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="FileDocumentOutline" HorizontalAlignment="Center" Width="28" Height="28"/>
                            <TextBlock Text="Payslip" Margin="0,8,0,0" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>

                <materialDesign:Card UniformCornerRadius="15" Padding="20" Background="White">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,15">
                            <TextBlock Text="Weekly Roster" Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="Bold"/>
                            <materialDesign:Chip Content="Current Week" HorizontalAlignment="Right" Background="#E3F2FD" Foreground="#1976D2"/>
                        </DockPanel>

                        <DataGrid ItemsSource="{Binding WeeklyShifts}" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  HeadersVisibility="Column"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  GridLinesVisibility="None">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="DAY" Binding="{Binding Day}" Width="Auto" FontWeight="Bold"/>
                                <DataGridTextColumn Header="POSITION" Binding="{Binding Position}" Width="*"/>
                                <DataGridTemplateColumn Header="TIME" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="#F5F5F5" CornerRadius="5" Padding="8,4">
                                                <TextBlock Text="{Binding TimeRange}" Foreground="#444"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="12,0,0,0">

                <materialDesign:Card UniformCornerRadius="15" Padding="20" Background="#1A237E" Foreground="White" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Estimated Earnings" Opacity="0.7" FontSize="14"/>
                        <TextBlock Text="{Binding TotalPay, FallbackValue='₱ 5,525.00'}" FontSize="36" FontWeight="Bold" Margin="0,4,0,0"/>

                        <Separator Background="White" Opacity="0.2" Margin="0,15"/>

                        <UniformGrid Columns="2">
                            <StackPanel>
                                <TextBlock Text="Total Hours" Opacity="0.7" FontSize="12"/>
                                <TextBlock Text="{Binding TotalHoursCount, FallbackValue='80.0h'}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right">
                                <TextBlock Text="Overtime" Opacity="0.7" FontSize="12"/>
                                <TextBlock Text="{Binding OvertimeHoursCount, FallbackValue='5.2h'}" FontWeight="SemiBold" Foreground="#FFD600"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card UniformCornerRadius="15" Padding="20" Background="White">
                    <StackPanel>
                        <TextBlock Text="Alerts &amp; Updates" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,15" FontWeight="Bold"/>

                        <ItemsControl ItemsSource="{Binding Notifications}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" CornerRadius="8" Margin="0,0,0,8" Padding="12">
                                        <DockPanel>
                                            <materialDesign:PackIcon Kind="InformationOutline" Foreground="#1A237E" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="13"/>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
