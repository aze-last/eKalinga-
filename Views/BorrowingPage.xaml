<UserControl x:Class="AttendanceShiftingManagement.Views.BorrowingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:AttendanceShiftingManagement.Views"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             Background="{DynamicResource BrandSurfaceBrush}">
    <UserControl.Resources>
    </UserControl.Resources>

    <materialDesign:DialogHost IsOpen="{Binding IsDialogOpen}" Identifier="BorrowingDialog">
        <materialDesign:DialogHost.DialogContent>
            <Grid Background="{DynamicResource ThemeCardBrush}" Width="500">
                <!-- Batch Issue/Return Dialog Content -->
                <StackPanel Margin="24" Visibility="{Binding IsBatchMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding DialogTitle}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,16"/>
                    
                    <!-- Beneficiary Info Section -->
                    <Border Padding="16" CornerRadius="12" Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="BENEFICIARY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding TargetBeneficiaryName, FallbackValue='Scanning/Waiting...'}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                <TextBlock Text="{Binding TargetBeneficiaryId}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                            </StackPanel>
                            <materialDesign:PackIcon Grid.Column="1" Kind="AccountCheck" Width="32" Height="32" Foreground="{DynamicResource BrandSuccessBrush}" VerticalAlignment="Center" Visibility="{Binding TargetBeneficiaryId, Converter={StaticResource NullToHiddenConverter}}"/>
                        </Grid>
                    </Border>

                    <!-- Item Entry / Scanner Listener -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding DialogSearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                 materialDesign:HintAssist.Hint="Scan Asset Tag or Type Name..." 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding ProcessDialogScanCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1" Command="{Binding ProcessDialogScanCommand}" 
                                Style="{StaticResource MaterialDesignIconButton}" 
                                Width="44" Height="44" Margin="8,0,0,0" Background="{DynamicResource BrandMidnightBrush}" Foreground="White">
                            <materialDesign:PackIcon Kind="Plus" Width="24" Height="24"/>
                        </Button>
                    </Grid>

                    <!-- Cart/Staged Items -->
                    <TextBlock Text="ITEMS IN SESSION" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                    <Border MaxHeight="200" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" CornerRadius="8">
                        <ListBox ItemsSource="{Binding CartItems}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding AssetTag}" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                            <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Command="{Binding DataContext.RemoveFromCartCommand, RelativeSource={RelativeSource AncestorType={x:Type ListBox}}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource BrandRedBrush}" Padding="4" Height="32">
                                            <materialDesign:PackIcon Kind="Delete" Width="18" Height="18"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Actions -->
                    <Grid Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="DUE DATE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                            <DatePicker SelectedDate="{Binding SelectedDueDate}" Style="{StaticResource MaterialDesignOutlinedDatePicker}" Width="150" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <Button Content="CANCEL" Command="{Binding CloseDialogCommand}" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,8,0"/>
                            <Button Content="PROCESS ALL" Command="{Binding SubmitTransactionCommand}" Style="{StaticResource GoldActionButton}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Add New Asset Dialog Content -->
                <StackPanel Margin="24" Visibility="{Binding IsAddAssetMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Add New Asset" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Register a new numbered asset to the barangay registry." FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,16" TextWrapping="Wrap"/>

                    <TextBox Text="{Binding NewAssetTag}" materialDesign:HintAssist.Hint="Asset Tag (e.g. TENT-001)" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12"/>
                    <TextBox Text="{Binding NewAssetCategory}" materialDesign:HintAssist.Hint="Category (e.g. Chair, Tent)" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,12"/>
                    <TextBox Text="{Binding NewAssetDescription}" materialDesign:HintAssist.Hint="Description (Optional)" Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,0,24"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCEL" Command="{Binding CloseDialogCommand}" Style="{StaticResource MaterialDesignFlatButton}" Margin="0,0,8,0"/>
                        <Button Content="REGISTER ASSET" Command="{Binding SubmitAddAssetCommand}" Style="{StaticResource GoldActionButton}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </materialDesign:DialogHost.DialogContent>

        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar (Actions & Filters) -->
            <materialDesign:Card Grid.Column="0" Padding="20" Background="{DynamicResource ThemeCardBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Equipment" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                        <TextBlock Text="BORROWING &amp; ASSETS" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,-4,0,16"/>
                        
                        <TextBox Text="{Binding SidebarSearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                                 materialDesign:HintAssist.Hint="Search or Scan ID..." 
                                 Margin="0,0,0,16">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding ProcessSidebarScanCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                    </StackPanel>

                    <StackPanel Grid.Row="1">
                        <Button Content="ISSUE BATCH" Style="{StaticResource GoldActionButton}" Height="48" Margin="0,0,0,8" Command="{Binding OpenIssueDialogCommand}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="TrayArrowUp" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="ISSUE BATCH" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                        <Button Content="PROCESS RETURN" Style="{StaticResource SecondaryActionButton}" Height="48" Margin="0,0,0,16" Command="{Binding OpenReturnDialogCommand}">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="TrayArrowDown" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="PROCESS RETURN" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="FILTERS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                            <RadioButton Content="Active Borrowings" IsChecked="{Binding FilterMode, Converter={StaticResource NullToHiddenConverter}, ConverterParameter='ACTIVE'}" Style="{StaticResource MaterialDesignTabRadioButton}" Margin="0,0,0,4"/>
                            <RadioButton Content="Overdue Only" IsChecked="{Binding FilterMode, Converter={StaticResource NullToHiddenConverter}, ConverterParameter='OVERDUE'}" Style="{StaticResource MaterialDesignTabRadioButton}" Margin="0,0,0,4"/>
                            <RadioButton Content="Full History" IsChecked="{Binding FilterMode, Converter={StaticResource NullToHiddenConverter}, ConverterParameter='HISTORY'}" Style="{StaticResource MaterialDesignTabRadioButton}" Margin="0,0,0,16"/>

                            <TextBlock Text="ASSET MANAGEMENT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                            <Button Content="Asset Registry" Style="{StaticResource MaterialDesignFlatButton}" HorizontalContentAlignment="Left" Command="{Binding ShowAssetRegistryCommand}"/>
                            <Button Content="Add New Asset" Style="{StaticResource MaterialDesignFlatButton}" HorizontalContentAlignment="Left" Command="{Binding OpenAddAssetDialogCommand}"/>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="3" Padding="14" CornerRadius="12" Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="MODULE STATUS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </materialDesign:Card>

            <!-- Main Content (Registry) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <materialDesign:Card Padding="24" Background="{DynamicResource ThemeCardBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Borrowing Registry" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Border Background="{DynamicResource BrandRedBrush}" CornerRadius="10" Padding="8,2" Margin="0,0,12,0" Visibility="{Binding HasOverdue, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding OverdueCount, StringFormat='{}{0} OVERDUE'}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                                </Border>
                                <TextBlock Text="{Binding CurrentFilterDescription}" FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Content="REFRESH" Style="{StaticResource SecondaryActionButton}" Command="{Binding RefreshCommand}"/>
                    </Grid>
                </materialDesign:Card>

                <materialDesign:Card Grid.Row="1" Margin="0,20,0,0" Padding="0" Background="{DynamicResource ThemeCardBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DataGrid ItemsSource="{Binding Transactions}" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0" Background="Transparent" SelectionUnit="FullRow">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TAG" Binding="{Binding Asset.AssetTag}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource BrandMidnightBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="BORROWER" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="12,8">
                                                <TextBlock Text="{Binding BeneficiaryName}" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                <TextBlock Text="{Binding BeneficiaryId}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="BORROWED" Binding="{Binding BorrowDate, StringFormat='MMM dd, yyyy'}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource BrandMidnightBrush}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="DUE" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DueDate, StringFormat='MMM dd, yyyy'}" 
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource BrandMidnightBrush}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="STATUS" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="12" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#F1F5F9"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ReturnDate, Converter={StaticResource NullToHiddenConverter}}" Value="Visible">
                                                                <Setter Property="Background" Value="#DCFCE7"/>
                                                            </DataTrigger>
                                                            <!-- Simplified Overdue Logic for UI display -->
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding ReturnDate, Converter={StaticResource NullToHiddenConverter}, ConverterParameter='Returned|Active'}" 
                                                           FontSize="11" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#64748B"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ReturnDate, Converter={StaticResource NullToHiddenConverter}}" Value="Visible">
                                                                    <Setter Property="Foreground" Value="#166534"/>
                                                                    <Setter Property="Text" Value="RETURNED"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding ReturnDate, Converter={StaticResource NullToHiddenConverter}}" Value="Collapsed">
                                                                    <Setter Property="Foreground" Value="#1E40AF"/>
                                                                    <Setter Property="Text" Value="ACTIVE"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Pagination (Placeholder) -->
                        <Border Grid.Row="1" Padding="16" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="Page 1 of 1" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                <Button Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32">
                                    <materialDesign:PackIcon Kind="ChevronLeft"/>
                                </Button>
                                <Button Style="{StaticResource MaterialDesignIconButton}" Width="32" Height="32">
                                    <materialDesign:PackIcon Kind="ChevronRight"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
