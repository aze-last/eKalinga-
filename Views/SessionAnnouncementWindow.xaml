<Window x:Class="AttendanceShiftingManagement.Views.SessionAnnouncementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Team Activity"
        Width="600"
        Height="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        FontFamily="Segoe UI"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="ActivityIconBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="CornerRadius" Value="21" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CategoryKey}" Value="Approvals">
                    <Setter Property="Background" Value="#FFF7ED" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CategoryKey}" Value="Budget">
                    <Setter Property="Background" Value="#ECFDF5" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CategoryKey}" Value="CashForWork">
                    <Setter Property="Background" Value="#EFF6FF" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CategoryKey}" Value="Distribution">
                    <Setter Property="Background" Value="#F5F3FF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActivityIconStyle" TargetType="materialDesign:PackIcon">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CategoryKey}" Value="Approvals">
                    <Setter Property="Kind" Value="AccountCheckOutline" />
                    <Setter Property="Foreground" Value="#C2410C" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CategoryKey}" Value="Budget">
                    <Setter Property="Kind" Value="WalletOutline" />
                    <Setter Property="Foreground" Value="#047857" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CategoryKey}" Value="CashForWork">
                    <Setter Property="Kind" Value="HammerWrench" />
                    <Setter Property="Foreground" Value="#1D4ED8" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CategoryKey}" Value="Distribution">
                    <Setter Property="Kind" Value="GiftOutline" />
                    <Setter Property="Foreground" Value="#6D28D9" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Storyboard x:Key="WindowEntrance">
            <DoubleAnimation Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetName="RootTranslate" Storyboard.TargetProperty="Y" From="30" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowEntrance}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border x:Name="RootBorder" 
            BorderBrush="#E2E8F0" 
            BorderThickness="1" 
            CornerRadius="16" 
            Background="White"
            Margin="10"
            Opacity="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.1"/>
        </Border.Effect>
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTranslate" Y="30"/>
        </Border.RenderTransform>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Feed -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="32,32,32,24">
                <StackPanel>
                    <TextBlock Text="Recent Team Activity" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#0F172A"/>
                    <TextBlock Text="While you were away, here's what your team achieved." 
                               Margin="0,4,0,0" 
                               FontSize="14" 
                               Foreground="#64748B"/>
                </StackPanel>
            </Border>

            <!-- Activity Feed -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Border Padding="32,0">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Snapshot.Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Grid.Column="0" Style="{StaticResource ActivityIconBorderStyle}">
                                        <materialDesign:PackIcon Style="{StaticResource ActivityIconStyle}"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                        <TextBlock TextWrapping="Wrap" FontSize="15">
                                            <Run Text="{Binding UpdatedBy}" FontWeight="Bold" Foreground="#1E293B"/>
                                            <Run Text=" " />
                                            <Run Text="{Binding Title}" Foreground="#334155"/>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Module}" 
                                                       FontSize="12" 
                                                       FontWeight="SemiBold" 
                                                       Foreground="#64748B"/>
                                            <TextBlock Text=" • " Foreground="#CBD5E1" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding TimestampLabel}" 
                                                       FontSize="11" 
                                                       Foreground="#94A3B8"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty State -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0"
                                Visibility="{Binding HasUpdates, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                        <materialDesign:PackIcon Kind="CheckCircleOutline" Width="48" Height="48" Foreground="#E2E8F0" HorizontalAlignment="Center"/>
                        <TextBlock Text="No major team activity recorded." 
                                   Margin="0,16,0,0" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#94A3B8"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                </Border>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="32,24" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0">
                <Button x:Name="ContinueButton"
                        Content="CONTINUE TO DASHBOARD"
                        Height="48"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Background="#0F172A"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Bold"
                        materialDesign:ButtonAssist.CornerRadius="12"
                        Click="Continue_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>
