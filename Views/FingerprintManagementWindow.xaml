<Window x:Class="AttendanceShiftingManagement.Views.FingerprintManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Fingerprint Management"
        Height="620"
        Width="980"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="14"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                   Text="{Binding HeaderText}"
                   Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <materialDesign:Card Grid.Row="1" Grid.Column="0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Registered Templates"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Templates}"
                          SelectedItem="{Binding SelectedTemplate}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Finger" Binding="{Binding FingerIndex}" Width="80"/>
                        <DataGridTextColumn Header="Format" Binding="{Binding TemplateFormat}" Width="100"/>
                        <DataGridTextColumn Header="Quality" Binding="{Binding QualityScore}" Width="80"/>
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70"/>
                        <DataGridTextColumn Header="Enrolled At" Binding="{Binding EnrolledAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="170"/>
                        <DataGridTextColumn Header="Last Verified" Binding="{Binding LastVerifiedAt, StringFormat='yyyy-MM-dd HH:mm'}" Width="170"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="1" Grid.Column="2" Padding="14">
            <StackPanel>
                <TextBlock Text="Capture and Management"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,0,4">
                    <Ellipse Width="12"
                             Height="12"
                             Fill="{Binding ScannerStatusBrush}"
                             Stroke="#4B5563"
                             StrokeThickness="1"
                             Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ScannerStatusText}"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <TextBlock Text="{Binding ScannerStatusDetail}"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"
                           Margin="20,0,0,10"/>

                <TextBlock Text="Enrollment needs multiple accepted scans. Keep capturing the same finger until the template is ready."
                           Foreground="#6B7280"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>

                <ComboBox ItemsSource="{Binding FingerOptions}"
                          SelectedValuePath="Index"
                          DisplayMemberPath="Label"
                          SelectedValue="{Binding SelectedFingerIndex}"
                          materialDesign:HintAssist.Hint="Finger Index"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,0,10"/>

                <Button Content="Capture Enrollment Sample"
                        Command="{Binding CaptureCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,0,0,8"/>

                <Border Background="#FFF8E1"
                        BorderBrush="#F59E0B"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,0,0,8"
                        Visibility="{Binding CaptureGuideVisibility}">
                    <StackPanel>
                        <TextBlock Text="{Binding CaptureGuideTitle}"
                                   FontWeight="SemiBold"
                                   Foreground="#92400E"/>
                        <TextBlock Text="{Binding CaptureGuideMessage}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Foreground="#78350F"/>
                    </StackPanel>
                </Border>

                <Button Content="Save Ready Template"
                        Command="{Binding EnrollOrUpdateCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Margin="0,0,0,8"/>

                <Button Content="Verify Selected Template"
                        Command="{Binding VerifySelectedCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,0,8"/>

                <Button Content="Delete Selected Template"
                        Command="{Binding DeleteSelectedCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#B91C1C"
                        Margin="0,0,0,12"/>

                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="0,0,0,12"/>

                <TextBlock Text="Capture Status"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBox Text="{Binding CaptureStatus}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         MinHeight="80"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
            </StackPanel>
        </materialDesign:Card>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="Close"
                    Click="Close_Click"
                    Style="{StaticResource MaterialDesignFlatButton}"/>
        </StackPanel>
    </Grid>
</Window>
