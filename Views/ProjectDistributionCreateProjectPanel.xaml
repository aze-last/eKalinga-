<UserControl x:Class="AttendanceShiftingManagement.Views.ProjectDistributionCreateProjectPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <UserControl.Resources>
        <DropShadowEffect x:Key="PanelShadow"
                          BlurRadius="25"
                          ShadowDepth="8"
                          Color="#44000000"
                          Opacity="0.45" />

        <Style x:Key="EnrollmentRowStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="4,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4,14,14,4"
                                Padding="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ThemeCardSubtleBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource ThemePrimaryActionBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ThemeCardSubtleBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Modal Backdrop -->
        <Border Background="#CC0F172A" />

        <!-- Main Enrollment Card -->
        <Border Width="1100"
                MaxHeight="850"
                Background="{DynamicResource ThemeCardBrush}"
                CornerRadius="28"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Effect="{StaticResource PanelShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header -->
                    <RowDefinition Height="*" />    <!-- Content -->
                    <RowDefinition Height="Auto" /> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Padding="32,28"
                        Background="{DynamicResource ThemePrimaryActionBrush}"
                        CornerRadius="28,28,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <WrapPanel VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="PlaylistPlus" Width="24" Height="24" Foreground="{DynamicResource BrandGoldBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Create Distribution Project"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ThemePrimaryActionForegroundBrush}"
                                           VerticalAlignment="Center"/>
                            </WrapPanel>
                            <TextBlock Text="Set up a new distribution event and enroll beneficiaries." 
                                       FontSize="13" Foreground="{DynamicResource ThemePrimaryActionForegroundBrush}" Opacity="0.8" Margin="0,4,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1" Width="36" Height="36"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="{DynamicResource ThemePrimaryActionForegroundBrush}"
                                Command="{Binding CloseCreateProjectPanelCommand}"
                                VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Content Area -->
                <Grid Grid.Row="1" Margin="32,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Project Configuration -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="BASIC INFORMATION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,16"/>

                            <TextBox Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Project Name *"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,16"/>

                            <TextBox Text="{Binding NewProjectCode, Mode=OneWay}"
                                     materialDesign:HintAssist.Hint="Project Code (Auto-generated)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     IsReadOnly="True"
                                     Margin="0,0,0,16"/>

                            <TextBox Text="{Binding NewProjectDescription}"
                                     materialDesign:HintAssist.Hint="Description"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     AcceptsReturn="True"
                                     Height="80"
                                     Margin="0,0,0,24"/>

                            <TextBlock Text="TYPE &amp; ALLOCATION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,16"/>

                            <ComboBox ItemsSource="{Binding ProgramTypes}"
                                      SelectedItem="{Binding NewProjectSelectedType}"
                                      materialDesign:HintAssist.Hint="Assistance Category *"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Margin="0,0,0,16"/>

                            <ComboBox ItemsSource="{Binding ReleaseKinds}"
                                      SelectedItem="{Binding NewProjectSelectedReleaseKind}"
                                      materialDesign:HintAssist.Hint="Release Format *"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Margin="0,0,0,16"/>

                            <!-- Cash Amount (Visible if Cash) -->
                            <TextBox Text="{Binding NewProjectUnitAmountText}"
                                     materialDesign:HintAssist.Hint="Unit Amount (PHP) *"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,16"
                                     Visibility="{Binding NewProjectIsCashKind, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <!-- Item Description (Visible if Goods) -->
                            <TextBox Text="{Binding NewProjectItemDescription}"
                                     materialDesign:HintAssist.Hint="Item/Goods Detail *"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,16"
                                     Visibility="{Binding NewProjectIsCashKind, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <TextBox Text="{Binding NewProjectBudgetCapText}"
                                     materialDesign:HintAssist.Hint="Total Budget Cap (Optional)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,24"/>

                            <TextBlock Text="SCHEDULE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <DatePicker SelectedDate="{Binding NewProjectStartDate}"
                                            materialDesign:HintAssist.Hint="Start Date"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                                <DatePicker Grid.Column="2" SelectedDate="{Binding NewProjectEndDate}"
                                            materialDesign:HintAssist.Hint="End Date"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Right: Beneficiary Enrollment -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="BENEFICIARY ENROLLMENT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>

                        <TextBox Grid.Row="0"
                                 Text="{Binding NewProjectSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Search unassigned approved beneficiaries..."
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 FontSize="14"/>

                        <!-- Dual List Interaction -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Available List -->
                            <Border Grid.Column="0" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" CornerRadius="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Background="{DynamicResource ThemeCardSubtleBrush}" Padding="12,8" CornerRadius="12,12,0,0">
                                        <TextBlock Text="AVAILABLE REGISTRY" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding AvailableUnpickedBeneficiaries}"
                                             SelectedItem="{Binding SelectedAvailableUnpickedBeneficiary}"
                                             ItemContainerStyle="{StaticResource EnrollmentRowStyle}"
                                             BorderThickness="0" Margin="8">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="13"/>
                                                        <TextBlock Text="{Binding BeneficiaryId}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="+" 
                                                            Style="{StaticResource MaterialDesignIconButton}" 
                                                            Width="28" Height="28"
                                                            Command="{Binding DataContext.MoveToSelectedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>

                            <!-- Arrows -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                <Button Command="{Binding MoveAllToSelectedCommand}" Style="{StaticResource MaterialDesignIconButton}" Margin="0,0,0,8">
                                    <materialDesign:PackIcon Kind="ChevronDoubleRight"/>
                                </Button>
                                <Button Command="{Binding MoveAllToAvailableCommand}" Style="{StaticResource MaterialDesignIconButton}">
                                    <materialDesign:PackIcon Kind="ChevronDoubleLeft"/>
                                </Button>
                            </StackPanel>

                            <!-- Selected List -->
                            <Border Grid.Column="2" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" CornerRadius="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Background="{DynamicResource BrandMidnightBrush}" Padding="12,8" CornerRadius="12,12,0,0">
                                        <TextBlock Text="SELECTED FOR PROJECT" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding SelectedProjectBeneficiaries}"
                                             ItemContainerStyle="{StaticResource EnrollmentRowStyle}"
                                             BorderThickness="0" Margin="8">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="13"/>
                                                        <TextBlock Text="{Binding BeneficiaryId}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="-" 
                                                            Style="{StaticResource MaterialDesignIconButton}" 
                                                            Width="28" Height="28" Foreground="{DynamicResource BrandErrorBrush}"
                                                            Command="{Binding DataContext.MoveToAvailableCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Summary Metrics -->
                        <Border Grid.Row="3" Margin="0,16,0,0" Padding="16" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="12">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,32,0">
                                        <TextBlock Text="ENROLLED" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding NewProjectSelectedCount}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="TOTAL ESTIMATED COST" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding NewProjectTotalCost, StringFormat='PHP {0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Footer -->
                <Border Grid.Row="2" Padding="32,24" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="0,0,28,28">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center" 
                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                   Text="Verify project details before finalization. Enrolled beneficiaries will be moved to the pending queue."
                                   FontSize="12"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="DISCARD"
                                    Width="120"
                                    Height="46"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                    Command="{Binding CloseCreateProjectPanelCommand}"
                                    Margin="0,0,12,0"/>
                            <Button Content="FINALIZE &amp; CREATE PROJECT"
                                    Width="260"
                                    Height="46"
                                    Style="{StaticResource GoldActionButton}"
                                    Command="{Binding ConfirmCreateProjectCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Success Success state -->
        <Border Visibility="{Binding IsCreateProjectSuccessPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="#EE0F172A"
                Panel.ZIndex="100">
            <materialDesign:Card Width="450" Padding="40" UniformCornerRadius="24">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CheckCircle" Width="80" Height="80" Foreground="{DynamicResource BrandSuccessBrush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <TextBlock Text="PROJECT CREATED!" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}"/>
                    <TextBlock Text="{Binding StatusMessage}" TextAlignment="Center" FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,16,0,32" TextWrapping="Wrap"/>
                    <Button Content="CONTINUE TO WORKSPACE" 
                            Command="{Binding CloseCreateProjectSuccessPanelCommand}"
                            Style="{StaticResource GoldActionButton}"
                            Height="50"/>
                </StackPanel>
            </materialDesign:Card>
        </Border>
    </Grid>
</UserControl>
