<UserControl x:Class="AttendanceShiftingManagement.Views.ProjectDistributionCreateProjectPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">

    <UserControl.Resources>
        <DropShadowEffect x:Key="PanelShadow"
                          BlurRadius="25"
                          ShadowDepth="8"
                          Color="#44000000"
                          Opacity="0.45" />

        <Style x:Key="EnrollmentRowStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="4,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4,14,14,4"
                                Padding="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ThemeCardSubtleBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource ThemePrimaryActionBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource ThemeCardSubtleBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Modal Backdrop -->
        <Border Background="#CC0F172A" />

        <!-- Main Enrollment Card -->
        <Border Width="1100"
                MaxHeight="850"
                Background="{DynamicResource ThemeCardBrush}"
                CornerRadius="28"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Effect="{StaticResource PanelShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header -->
                    <RowDefinition Height="*" />    <!-- Content -->
                    <RowDefinition Height="Auto" /> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0"
                        Padding="32,28"
                        Background="{DynamicResource ThemePrimaryActionBrush}"
                        CornerRadius="28,28,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <WrapPanel VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="PlaylistPlus" Width="24" Height="24" Foreground="{DynamicResource BrandGoldBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Create Distribution Project"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource ThemePrimaryActionForegroundBrush}"
                                           VerticalAlignment="Center"/>
                            </WrapPanel>
                            <TextBlock Text="Set up a new distribution event and enroll beneficiaries." 
                                       FontSize="13" Foreground="{DynamicResource ThemePrimaryActionForegroundBrush}" Opacity="0.8" Margin="0,4,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1" Width="36" Height="36"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="{DynamicResource ThemePrimaryActionForegroundBrush}"
                                Command="{Binding CloseCreateProjectPanelCommand}"
                                VerticalAlignment="Top">
                            <materialDesign:PackIcon Kind="Close" Width="24" Height="24"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Content Area -->
                <Grid Grid.Row="1" Margin="32,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="400" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Project Configuration -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="BASIC INFORMATION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,16"/>

                            <TextBox Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Project Name *"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,16"/>

                            <TextBox Text="{Binding NewProjectCode, Mode=OneWay}"
                                     materialDesign:HintAssist.Hint="Project Code (Auto-generated)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     IsReadOnly="True"
                                     Margin="0,0,0,16"/>

                            <TextBox Text="{Binding NewProjectDescription}"
                                     materialDesign:HintAssist.Hint="Description"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     AcceptsReturn="True"
                                     Height="80"
                                     Margin="0,0,0,24"/>

                            <TextBlock Text="TYPE &amp; ALLOCATION" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,16"/>

                            <ComboBox ItemsSource="{Binding ProgramTypes}"
                                      SelectedItem="{Binding NewProjectSelectedType}"
                                      materialDesign:HintAssist.Hint="Assistance Category *"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Margin="0,0,0,16"/>

                            <ComboBox ItemsSource="{Binding ReleaseKinds}"
                                      SelectedItem="{Binding NewProjectSelectedReleaseKind}"
                                      materialDesign:HintAssist.Hint="Release Format *"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Margin="0,0,0,16"/>

                            <!-- Cash Amount (Visible if Cash) -->
                            <TextBox Text="{Binding NewProjectUnitAmountText}"
                                     materialDesign:HintAssist.Hint="Unit Amount (PHP) *"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,16"
                                     Visibility="{Binding NewProjectIsCashKind, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                            <!-- Item Description (Visible if Goods) -->
                            <TextBox Text="{Binding NewProjectItemDescription}"
                                     materialDesign:HintAssist.Hint="Item/Goods Detail *"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,16"
                                     Visibility="{Binding NewProjectIsCashKind, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                            <TextBox Text="{Binding NewProjectBudgetCapText}"
                                     materialDesign:HintAssist.Hint="Total Budget Cap (Optional)"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,0,24"/>

                            <TextBlock Text="SCHEDULE" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,16"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <DatePicker SelectedDate="{Binding NewProjectStartDate}"
                                            materialDesign:HintAssist.Hint="Start Date"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                                <DatePicker Grid.Column="2" SelectedDate="{Binding NewProjectEndDate}"
                                            materialDesign:HintAssist.Hint="End Date"
                                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Right: Beneficiary Enrollment -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="BENEFICIARY ENROLLMENT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>

                        <TextBox Grid.Row="0"
                                 Text="{Binding NewProjectSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Search unassigned approved beneficiaries..."
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 FontSize="14"/>

                        <!-- Dual List Interaction -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Available List -->
                            <Border Grid.Column="0" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" CornerRadius="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border Background="{DynamicResource ThemeCardSubtleBrush}" Padding="12,8" CornerRadius="12,12,0,0">
                                        <TextBlock Text="AVAILABLE REGISTRY" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding AvailableUnpickedBeneficiaries}"
                                             SelectedItem="{Binding SelectedAvailableUnpickedBeneficiary}"
                                             ItemContainerStyle="{StaticResource EnrollmentRowStyle}"
                                             BorderThickness="0" Margin="8">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="13"/>
                                                        <TextBlock Text="{Binding BeneficiaryId}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="+"
                                                            Style="{StaticResource MaterialDesignIconButton}"
                                                            Width="28" Height="28"
                                                            Command="{Binding DataContext.MoveToSelectedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <!-- Registry pager: each page shows up to 200 approved beneficiaries -->
                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28"
                                                Command="{Binding PrevUnpickedPageCommand}"
                                                Foreground="{DynamicResource ThemePrimaryActionBrush}">
                                            <materialDesign:PackIcon Kind="ChevronLeft"/>
                                        </Button>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                                            <TextBlock Text="Page " FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding UnpickedCurrentPage}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                            <TextBlock Text=" of " FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding UnpickedTotalPages}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                        </StackPanel>
                                        <Button Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28"
                                                Command="{Binding NextUnpickedPageCommand}"
                                                Foreground="{DynamicResource ThemePrimaryActionBrush}">
                                            <materialDesign:PackIcon Kind="ChevronRight"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Arrows -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                <Button Command="{Binding MoveAllToSelectedCommand}" Style="{StaticResource MaterialDesignIconButton}" Margin="0,0,0,8">
                                    <materialDesign:PackIcon Kind="ChevronDoubleRight"/>
                                </Button>
                                <Button Command="{Binding MoveAllToAvailableCommand}" Style="{StaticResource MaterialDesignIconButton}">
                                    <materialDesign:PackIcon Kind="ChevronDoubleLeft"/>
                                </Button>
                            </StackPanel>

                            <!-- Selected List -->
                            <Border Grid.Column="2" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" CornerRadius="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Background="{DynamicResource BrandMidnightBrush}" Padding="12,8" CornerRadius="12,12,0,0">
                                        <TextBlock Text="SELECTED FOR PROJECT" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                    </Border>
                                    <ListBox Grid.Row="1"
                                             ItemsSource="{Binding SelectedProjectBeneficiaries}"
                                             ItemContainerStyle="{StaticResource EnrollmentRowStyle}"
                                             BorderThickness="0" Margin="8">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding FullName}" FontWeight="Bold" FontSize="13"/>
                                                        <TextBlock Text="{Binding BeneficiaryId}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="-" 
                                                            Style="{StaticResource MaterialDesignIconButton}" 
                                                            Width="28" Height="28" Foreground="{DynamicResource BrandErrorBrush}"
                                                            Command="{Binding DataContext.MoveToAvailableCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Summary Metrics -->
                        <Border Grid.Row="3" Margin="0,16,0,0" Padding="16" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="12">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Margin="0,0,32,0">
                                        <TextBlock Text="ENROLLED" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding NewProjectSelectedCount}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="TOTAL ESTIMATED COST" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding NewProjectTotalCost, StringFormat='PHP {0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Footer -->
                <Border Grid.Row="2" Padding="32,24" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="0,0,28,28">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center" 
                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                   Text="Verify project details before finalization. Enrolled beneficiaries will be moved to the pending queue."
                                   FontSize="12"/>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="DISCARD"
                                    Width="120"
                                    Height="46"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                    Command="{Binding CloseCreateProjectPanelCommand}"
                                    Margin="0,0,12,0"/>
                            <Button Content="FINALIZE &amp; CREATE PROJECT"
                                    Width="260"
                                    Height="46"
                                    Style="{StaticResource GoldActionButton}"
                                    Command="{Binding ConfirmCreateProjectCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Beneficiary Validation Modal (Phase 2) - side-by-side design to match client mockup -->
        <Border Visibility="{Binding IsBeneficiaryValidationModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="#CC0F172A"
                Panel.ZIndex="120">
            <Border Width="1000" Height="680" Background="{DynamicResource ThemeCardBrush}" CornerRadius="16"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Effect="{StaticResource PanelShadow}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="24,16" Background="{DynamicResource ThemePrimaryActionBrush}" CornerRadius="16,16,0,0">
                        <Grid>
                            <TextBlock Text="BENEFICIARY PROFILE FORM" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource ThemePrimaryActionForegroundBrush}"/>
                            <TextBlock Text="VALIDATION MODAL" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandYellowBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Content -->
                    <Grid Grid.Row="1" Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Column: Photo + Profile Details -->
                        <ScrollViewer Grid.Column="0" Margin="0,0,16,0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Width="140" Height="140" CornerRadius="12" Background="{DynamicResource ThemeCardSubtleBrush}"
                                        BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" HorizontalAlignment="Center">
                                    <Grid>
                                        <materialDesign:PackIcon Kind="AccountCircle" Width="90" Height="90"
                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        <!-- Optional Photo if present -->
                                        <Border CornerRadius="12" Visibility="{Binding ValidatingBeneficiary.PhotoPath, Converter={StaticResource NullToHiddenConverter}}">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding ValidatingBeneficiary.PhotoPath}" Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>
                                    </Grid>
                                </Border>
                                <TextBlock Text="ID Card Details" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}" Margin="0,16,0,8" TextAlignment="Center"/>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name: " FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,8,8"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ValidatingBeneficiary.FullName}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Barcode: " FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,8,8"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ValidatingBeneficiary.BeneficiaryId, TargetNullValue='N/A'}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="HH Role: " FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,8,8"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ValidatingBeneficiary.HouseholdRole, TargetNullValue='Member'}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="HH No: " FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,8,8"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ValidatingBeneficiary.HouseholdNumber, TargetNullValue='N/A'}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Address: " FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,8,8"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ValidatingBeneficiary.Address, TargetNullValue='Not Specified'}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Age: " FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,8,8"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ValidatingBeneficiary.Age, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,8"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Gender: " FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ValidatingBeneficiary.Sex, TargetNullValue='Unknown'}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Separator -->
                        <Border Grid.Column="1" Background="{DynamicResource BrandBorderBrush}" Margin="8,0"/>

                        <!-- Right Column: Community Tax & Requirement Lists -->
                        <Grid Grid.Column="2" Margin="16,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="COMMUNITY TAX PAYMENT (CEDULA)" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                            <Grid Grid.Row="1" Margin="0,0,0,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <DataGrid Grid.Row="0" ItemsSource="{Binding ValidatingBeneficiary.CommunityTaxRows}" AutoGenerateColumns="False"
                                          BorderThickness="1" BorderBrush="{DynamicResource BrandBorderBrush}" Background="Transparent" HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Cedula Number" Binding="{Binding CedulaNumber, UpdateSourceTrigger=PropertyChanged}" Width="150" FontWeight="SemiBold"/>
                                        <DataGridTextColumn Header="Paid Amount" Binding="{Binding PaidAmountText, UpdateSourceTrigger=PropertyChanged}" Width="110" FontWeight="Bold"/>
                                        <DataGridTextColumn Header="Date" Binding="{Binding PaidDate, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                                        <DataGridTemplateColumn Header="Action" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="✕" Style="{StaticResource MaterialDesignIconButton}" Width="24" Height="24"
                                                            Foreground="{DynamicResource BrandErrorBrush}" Padding="0"
                                                            Command="{Binding DataContext.RemoveCommunityTaxRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Button Grid.Row="1" Content="+ Add Tax Payment" Style="{StaticResource MaterialDesignFlatButton}"
                                        FontSize="11" Foreground="{DynamicResource BrandMidnightBrush}" HorizontalAlignment="Left" Margin="0,4,0,0"
                                        Command="{Binding AddCommunityTaxRowCommand}"/>
                            </Grid>

                            <TextBlock Grid.Row="2" Text="REQUIREMENT DOCUMENTS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,8"/>
                            <Grid Grid.Row="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <DataGrid Grid.Row="0" ItemsSource="{Binding ValidatingBeneficiary.RequirementRows}" AutoGenerateColumns="False"
                                          BorderThickness="1" BorderBrush="{DynamicResource BrandBorderBrush}" Background="Transparent" HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Document" Binding="{Binding DocumentName, UpdateSourceTrigger=PropertyChanged}" Width="180" FontWeight="SemiBold"/>
                                        <DataGridTextColumn Header="Date" Binding="{Binding SubmittedDate, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                                        <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                        <DataGridTemplateColumn Header="Action" Width="60">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="✕" Style="{StaticResource MaterialDesignIconButton}" Width="24" Height="24"
                                                            Foreground="{DynamicResource BrandErrorBrush}" Padding="0"
                                                            Command="{Binding DataContext.RemoveRequirementRowCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <Button Grid.Row="1" Content="+ Add Requirement" Style="{StaticResource MaterialDesignFlatButton}"
                                        FontSize="11" Foreground="{DynamicResource BrandMidnightBrush}" HorizontalAlignment="Left" Margin="0,4,0,0"
                                        Command="{Binding AddRequirementRowCommand}"/>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- Footer: Action Bar -->
                    <Border Grid.Row="2" Padding="20" Background="{DynamicResource BrandMidnightBrush}" CornerRadius="0,0,16,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- Program Info Summary -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,30,0">
                                    <TextBlock Text="NEW PROJECT TYPE" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding NewProjectSelectedType}" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="PROJECT ITEM / UNIT AMOUNT" FontSize="10" Foreground="#A0B0C0" FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="PHP " FontSize="14" Foreground="{DynamicResource BrandYellowBrush}" FontWeight="Bold"
                                                   Visibility="{Binding NewProjectIsCashKind, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding NewProjectUnitAmountText}" FontSize="14" Foreground="{DynamicResource BrandYellowBrush}" FontWeight="Bold"
                                                   Visibility="{Binding NewProjectIsCashKind, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding NewProjectItemDescription}" FontSize="14" Foreground="{DynamicResource BrandYellowBrush}" FontWeight="Bold"
                                                   Visibility="{Binding NewProjectIsCashKind, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="CANCEL" Command="{Binding CancelBeneficiaryValidationCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Margin="0,0,16,0"/>
                                <Button Content="ADD RECIPIENT" Command="{Binding ConfirmAddRecipientCommand}" Style="{StaticResource GoldActionButton}" Height="45" Padding="30,0" FontSize="16"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- Success state -->
        <Border Visibility="{Binding IsCreateProjectSuccessPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="#EE0F172A"
                Panel.ZIndex="100">
            <materialDesign:Card Width="450" Padding="40" UniformCornerRadius="24">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CheckCircle" Width="80" Height="80" Foreground="{DynamicResource BrandSuccessBrush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                    <TextBlock Text="PROJECT CREATED!" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource BrandMidnightBrush}"/>
                    <TextBlock Text="{Binding StatusMessage}" TextAlignment="Center" FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,16,0,32" TextWrapping="Wrap"/>
                    <Button Content="CONTINUE TO WORKSPACE"
                            Command="{Binding CloseCreateProjectSuccessPanelCommand}"
                            Style="{StaticResource GoldActionButton}"
                            Height="50"/>
                </StackPanel>
            </materialDesign:Card>
        </Border>
    </Grid>
</UserControl>
