<UserControl x:Class="AttendanceShiftingManagement.Views.EngagementWellbeingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Engagement &amp; Wellbeing"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrandMidnightBrush}"/>
            <Button DockPanel.Dock="Right"
                    Content="REFRESH"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="{StaticResource BrandRedBrush}"
                    BorderBrush="{StaticResource BrandRedBrush}"/>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="6" Margin="0,0,0,14">
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandMidnightBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding AverageEnps, StringFormat='{}{0:0.0}'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="AVG eNPS" FontSize="11" Foreground="#D1D5DB"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandRedBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding AverageEngagementScore, StringFormat='{}{0:0.0}%'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="ENGAGEMENT" FontSize="11" Foreground="#FFE9D5"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#1D4ED8">
                <StackPanel>
                    <TextBlock Text="{Binding AverageWellbeingScore, StringFormat='{}{0:0.0}%'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="WELLBEING" FontSize="11" Foreground="#DBEAFE"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#7C2D12">
                <StackPanel>
                    <TextBlock Text="{Binding AbsenteeismRate, StringFormat='{}{0:0.0}%'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="ABSENTEEISM TODAY" FontSize="11" Foreground="#FED7AA"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#14532D">
                <StackPanel>
                    <TextBlock Text="{Binding SurveyParticipationRate, StringFormat='{}{0:0.0}%'}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="SURVEY PARTICIPATION" FontSize="11" Foreground="#DCFCE7"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#111827">
                <StackPanel>
                    <TextBlock Text="{Binding HighBurnoutCount}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="HIGH BURNOUT SIGNALS" FontSize="11" Foreground="#D1D5DB"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <materialDesign:Card Grid.Row="2" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.9*"/>
                    <ColumnDefinition Width="1.0*"/>
                    <ColumnDefinition Width="1.0*"/>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding ActiveEmployees}"
                          SelectedItem="{Binding SelectedEmployee}"
                          DisplayMemberPath="FullName"
                          AutomationProperties.Name="Survey Employee Selector"
                          materialDesign:HintAssist.Hint="Employee"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,8,0"/>

                <DatePicker Grid.Column="1"
                            SelectedDate="{Binding SurveyDate}"
                            AutomationProperties.Name="Survey Date"
                            materialDesign:HintAssist.Hint="Survey Date"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                            Margin="0,0,8,0"/>

                <TextBox Grid.Column="2"
                         Text="{Binding EnpsScoreText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="eNPS"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,8,0"/>

                <TextBox Grid.Column="3"
                         Text="{Binding EngagementScoreText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Engagement %"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,8,0"/>

                <TextBox Grid.Column="4"
                         Text="{Binding WellbeingScoreText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Wellbeing %"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,8,0"/>

                <ComboBox Grid.Column="5"
                          ItemsSource="{Binding BurnoutRiskLevels}"
                          SelectedItem="{Binding SelectedBurnoutRisk}"
                          AutomationProperties.Name="Burnout Risk"
                          materialDesign:HintAssist.Hint="Burnout Risk"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,8,0"/>

                <TextBox Grid.Column="6"
                         Text="{Binding Comments, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Comments (optional)"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,8,0"/>

                <Button Grid.Column="7"
                        Content="SUBMIT"
                        Command="{Binding SubmitSurveyCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="{StaticResource BrandRedBrush}"
                        Foreground="White"
                        Padding="16,0"/>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="3" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Width="300"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Search by employee, burnout level, comments"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <ComboBox Grid.Column="1"
                          Width="170"
                          Margin="10,0,0,0"
                          ItemsSource="{Binding DepartmentFilterOptions}"
                          SelectedItem="{Binding SelectedDepartmentFilter}"
                          DisplayMemberPath="Label"
                          AutomationProperties.Name="Engagement Team Filter"
                          materialDesign:HintAssist.Hint="Team Filter"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                <ItemsControl Grid.Column="2" ItemsSource="{Binding Alerts}" Margin="16,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FEF2F2"
                                    BorderBrush="#FCA5A5"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8"
                                    Margin="0,0,0,6">
                                <DockPanel>
                                    <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                             Foreground="{StaticResource BrandRedBrush}"
                                                             Width="15"
                                                             Height="15"
                                                             Margin="0,2,8,0"/>
                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#7F1D1D"/>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="4" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Survey Responses"
                           FontWeight="Bold"
                           Margin="0,0,0,10"
                           Foreground="{StaticResource BrandMidnightBrush}"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SurveysView}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding SurveyDate, StringFormat='yyyy-MM-dd'}" Width="100"/>
                        <DataGridTextColumn Header="Employee" Binding="{Binding Employee.FullName}" Width="*"/>
                        <DataGridTextColumn Header="Team" Binding="{Binding Employee.Position.Area}" Width="90"/>
                        <DataGridTextColumn Header="eNPS" Binding="{Binding EnpsScore}" Width="70"/>
                        <DataGridTextColumn Header="Engagement" Binding="{Binding EngagementScore, StringFormat='{}{0:N1}%'}" Width="100"/>
                        <DataGridTextColumn Header="Wellbeing" Binding="{Binding WellbeingScore, StringFormat='{}{0:N1}%'}" Width="95"/>
                        <DataGridTextColumn Header="Burnout" Binding="{Binding BurnoutRisk}" Width="90"/>
                        <DataGridTextColumn Header="Comments" Binding="{Binding Comments}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
