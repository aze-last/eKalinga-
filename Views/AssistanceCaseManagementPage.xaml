<UserControl x:Class="AttendanceShiftingManagement.Views.AssistanceCaseManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:local="clr-namespace:AttendanceShiftingManagement.Views"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Background="#F1F5F9"
      FontFamily="{materialDesign:MaterialDesignFont}">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrandBrush" Color="#1E4E89"/>
        <SolidColorBrush x:Key="ActionAccentBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E2E8F0"/>

        <Style x:Key="SidebarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrandBrush}"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        </Style>

        <Style x:Key="SummaryCardStyle" TargetType="materialDesign:Card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="UniformCornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrandBrush}" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ClipboardText" Width="32" Height="32" Foreground="White" VerticalAlignment="Center"/>
                    <StackPanel Margin="15,0,0,0">
                        <TextBlock Text="ASSISTANCE RECORDS" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Manage beneficiary profiles and assistance history." FontSize="12" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content with Blur Support -->
        <Grid Grid.Row="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsRecordAssistancePanelOpen}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15.0" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,20,20,10">
                        <Button Content="DASHBOARD" 
                                Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource PrimaryBrandBrush}" BorderBrush="{StaticResource PrimaryBrandBrush}" Height="45" Margin="0,0,0,20"/>

                        <TextBlock Text="SEARCH BENEFICIARY" Style="{StaticResource SidebarHeaderStyle}"/>

                        <Border Background="White" CornerRadius="8" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Margin="0,0,0,16" Padding="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Magnify" Grid.Column="0" Margin="8,8,4,8" Foreground="#64748B" Width="20" Height="20"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                         materialDesign:HintAssist.Hint="Search Name, ID, QR..." 
                                         BorderThickness="0" VerticalAlignment="Center" Margin="0" Padding="0,4"/>
                            </Grid>
                        </Border>
                        
                        <Button Command="{Binding SearchCommand}" Content="SEARCH" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource PrimaryBrandBrush}" BorderBrush="{StaticResource PrimaryBrandBrush}" Foreground="White" Height="45" Margin="0,0,0,24"/>

                        <TextBlock Text="SEARCH RESULTS" Style="{StaticResource SidebarHeaderStyle}" Margin="0,0,0,8"/>
                    </StackPanel>

                    <!-- Search Results -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedBeneficiary}"
                             Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Margin="20,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Margin="0,0,0,8" Padding="12" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Width="260">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="14" Foreground="#0F172A" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding BeneficiaryId}" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding FlagsSummary}" FontSize="11" Foreground="{StaticResource ActionAccentBrush}" FontWeight="Bold" Margin="0,2,0,0" Visibility="{Binding FlagsSummary, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Search Pagination -->
                    <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding LoadSearchPreviousPageCommand}" ToolTip="Previous Page" Width="30" Height="30" Padding="0" Foreground="{StaticResource PrimaryBrandBrush}">
                                <materialDesign:PackIcon Kind="ChevronLeft" />
                            </Button>
                            <TextBlock Text="{Binding SearchPageInfo}" VerticalAlignment="Center" Margin="10,0" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                            <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding LoadSearchNextPageCommand}" ToolTip="Next Page" Width="30" Height="30" Padding="0" Foreground="{StaticResource PrimaryBrandBrush}">
                                <materialDesign:PackIcon Kind="ChevronRight" />
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Column="1" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Beneficiary Profile" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                        <TextBlock Text="Select a beneficiary to view their assistance history" FontSize="14" Foreground="#64748B" Visibility="{Binding SelectedBeneficiary, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" Command="{Binding OpenRecordAssistanceCommand}" Content="RECORD ASSISTANCE" 
                            Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource ActionAccentBrush}" BorderBrush="{StaticResource ActionAccentBrush}" Foreground="White" Height="45" Padding="20,0"
                            Visibility="{Binding SelectedBeneficiary, Converter={StaticResource NullToHiddenConverter}}"/>
                </Grid>

                <Grid Grid.Row="1" Visibility="{Binding SelectedBeneficiary, Converter={StaticResource NullToHiddenConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Summary Cards -->
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <materialDesign:Card Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                            <Border Padding="20,15" Height="90">
                                <StackPanel>
                                    <TextBlock Text="TOTAL RECORDS" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding BeneficiarySummary.TotalAssistanceRecords}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                </StackPanel>
                            </Border>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="2" Style="{StaticResource SummaryCardStyle}">
                            <Border Padding="20,15" Height="90">
                                <StackPanel>
                                    <TextBlock Text="TOTAL CASH" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding BeneficiarySummary.TotalCashReleased, StringFormat='{}{0:C}'}" FontSize="18" FontWeight="Bold" Foreground="#15803D"/>
                                </StackPanel>
                            </Border>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="4" Style="{StaticResource SummaryCardStyle}">
                            <Border Padding="20,15" Height="90">
                                <StackPanel>
                                    <TextBlock Text="TOTAL GOODS VALUE" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding BeneficiarySummary.TotalGoodsReleased, StringFormat='{}{0:C}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                </StackPanel>
                            </Border>
                        </materialDesign:Card>

                        <materialDesign:Card Grid.Column="6" Style="{StaticResource SummaryCardStyle}">
                            <Border Padding="20,15" Height="90">
                                <StackPanel>
                                    <TextBlock Text="LATEST ASSISTANCE" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding BeneficiarySummary.LatestAssistance, StringFormat='{}{0:MMM dd, yyyy}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource ActionAccentBrush}"/>
                                </StackPanel>
                            </Border>
                        </materialDesign:Card>
                    </Grid>

                    <!-- History Table -->
                    <materialDesign:Card Grid.Row="1" Style="{StaticResource SummaryCardStyle}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <DataGrid Grid.Row="0" ItemsSource="{Binding HistoryRecords}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                                      HeadersVisibility="Column" Background="Transparent" BorderThickness="0" Margin="10">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding ReleaseDate, StringFormat='{}{0:MMM dd, yyyy}'}" Width="120" FontSize="13"/>
                                    <DataGridTextColumn Header="Program / Event" Binding="{Binding ProgramName}" Width="*" FontSize="13"/>
                                    <DataGridTextColumn Header="Source" Binding="{Binding SourceModule}" Width="150" FontSize="13"/>
                                    <DataGridTextColumn Header="Reference No." Binding="{Binding ReferenceNumber}" Width="150" FontSize="13"/>
                                    <DataGridTextColumn Header="Kind" Binding="{Binding ReleaseKind}" Width="100" FontSize="13"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Amount, StringFormat='{}{0:C}'}" Width="120" FontSize="13"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Grid.Row="1" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0" Padding="15">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding LoadPreviousPageCommand}" ToolTip="Previous Page" Width="32" Height="32" Margin="0,0,10,0" Foreground="{StaticResource PrimaryBrandBrush}">
                                        <materialDesign:PackIcon Kind="ChevronLeft" />
                                    </Button>
                                    <TextBlock Text="{Binding HistoryPageInfo}" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                    <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding LoadNextPageCommand}" ToolTip="Next Page" Width="32" Height="32" Foreground="{StaticResource PrimaryBrandBrush}">
                                        <materialDesign:PackIcon Kind="ChevronRight" />
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </materialDesign:Card>
                </Grid>
            </Grid>
        </Grid>

        <!-- RECORD ASSISTANCE OVERLAY -->
        <Border Visibility="{Binding IsRecordAssistancePanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#CC0F172A" Grid.RowSpan="2">
            <Border Background="White" CornerRadius="12" Width="500" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Record Manual Assistance" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}" Margin="0,0,0,24"/>

                    <TextBox Grid.Row="1" materialDesign:HintAssist.Hint="Program Name / Assistance Type" Text="{Binding RecordProgramName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" FontSize="14" Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                    
                    <Grid Grid.Row="2" Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <ComboBox Grid.Column="0" materialDesign:HintAssist.Hint="Release Kind" SelectedItem="{Binding RecordReleaseKind}" ItemsSource="{Binding RecordReleaseKinds}" FontSize="14" Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>

                        <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Amount / Value (₱)" Text="{Binding RecordAmount, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                    </Grid>

                    <TextBox Grid.Row="3" materialDesign:HintAssist.Hint="Remarks" Text="{Binding RecordRemarks, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" VerticalAlignment="Top" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="80" Margin="0,0,0,30" FontSize="14" Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCEL" Command="{Binding CloseRecordAssistanceCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#64748B" Margin="0,0,10,0"/>
                        <Button Content="SAVE RECORD" Command="{Binding SaveRecordAssistanceCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource ActionAccentBrush}" BorderBrush="{StaticResource ActionAccentBrush}" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- STATUS BAR -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20" Grid.RowSpan="2"
                Visibility="{Binding IsStatusVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border CornerRadius="8" Padding="16,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#DCFCE7"/>
                        <Setter Property="BorderBrush" Value="#15803D"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusType}" Value="Error">
                                <Setter Property="Background" Value="#FEE2E2"/>
                                <Setter Property="BorderBrush" Value="#BE123C"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusType}" Value="Warning">
                                <Setter Property="Background" Value="#FEF3C7"/>
                                <Setter Property="BorderBrush" Value="#854D0E"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <materialDesign:PackIcon Grid.Column="0" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0">
                        <materialDesign:PackIcon.Style>
                            <Style TargetType="materialDesign:PackIcon">
                                <Setter Property="Kind" Value="CheckCircle"/>
                                <Setter Property="Foreground" Value="#15803D"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusType}" Value="Error">
                                        <Setter Property="Kind" Value="AlertCircle"/>
                                        <Setter Property="Foreground" Value="#BE123C"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusType}" Value="Warning">
                                        <Setter Property="Kind" Value="Alert"/>
                                        <Setter Property="Foreground" Value="#854D0E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </materialDesign:PackIcon.Style>
                    </materialDesign:PackIcon>
                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#15803D"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusType}" Value="Error">
                                        <Setter Property="Foreground" Value="#BE123C"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusType}" Value="Warning">
                                        <Setter Property="Foreground" Value="#854D0E"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Grid.Column="2" Command="{Binding DismissStatusCommand}" 
                            Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28" Padding="0" ToolTip="Dismiss" Margin="10,0,0,0">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16" Foreground="#64748B"/>
                    </Button>
                </Grid>
            </Border>
        </Border>

        <!-- LOADING OVERLAY -->
        <Border Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#88FFFFFF" Grid.RowSpan="2">
            <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}" Value="0" IsIndeterminate="True" Width="40" Height="40"/>
        </Border>
    </Grid>
</UserControl>
