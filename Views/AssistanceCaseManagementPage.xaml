<UserControl x:Class="AttendanceShiftingManagement.Views.AssistanceCaseManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <materialDesign:Card Grid.Row="0"
                             Padding="20"
                             Background="White">
            <DockPanel LastChildFill="False">
                <TextBlock Text="Aid Request"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrandMidnightBrush}"
                           VerticalAlignment="Center"/>

                <WrapPanel DockPanel.Dock="Right"
                           VerticalAlignment="Center">
                    <Button Content="NEW REQUEST"
                            Command="{Binding NewCaseCommand}"
                            Style="{StaticResource GoldActionButton}"
                            Height="40"
                            Margin="0,0,12,0"/>
                    <Button Content="REFRESH"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryActionButton}"
                            Height="40"/>
                </WrapPanel>
            </DockPanel>
        </materialDesign:Card>

        <UniformGrid Grid.Row="1"
                     Margin="0,18,0,18"
                     Columns="5">
            <materialDesign:Card Margin="0,0,12,0"
                                 Padding="16"
                                 Background="White">
                <StackPanel>
                    <TextBlock Text="{Binding TotalCases, StringFormat=N0}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}"/>
                    <TextBlock Text="TOTAL REQUESTS"
                               FontSize="10"
                               Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="0,0,12,0"
                                 Padding="16"
                                 Background="White">
                <StackPanel>
                    <TextBlock Text="{Binding PendingCount, StringFormat=N0}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}"/>
                    <TextBlock Text="PENDING"
                               FontSize="10"
                               Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="0,0,12,0"
                                 Padding="16"
                                 Background="White">
                <StackPanel>
                    <TextBlock Text="{Binding UnderReviewCount, StringFormat=N0}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}"/>
                    <TextBlock Text="UNDER REVIEW"
                               FontSize="10"
                               Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="0,0,12,0"
                                 Padding="16"
                                 Background="White">
                <StackPanel>
                    <TextBlock Text="{Binding ApprovedCount, StringFormat=N0}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}"/>
                    <TextBlock Text="APPROVED"
                               FontSize="10"
                               Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Padding="16"
                                 Background="White">
                <StackPanel>
                    <TextBlock Text="{Binding ReleasedCount, StringFormat=N0}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}"/>
                    <TextBlock Text="RELEASED"
                               FontSize="10"
                               Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.7*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0"
                                 Padding="18"
                                 Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               LastChildFill="False">
                        <TextBlock Text="Aid Requests"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}"
                                   VerticalAlignment="Center"/>

                        <WrapPanel DockPanel.Dock="Right">
                            <Button Content="ALL"
                                    Command="{Binding ShowAllCasesCommand}"
                                    Height="34"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource GoldActionButton}"/>
                            <Button Content="PENDING"
                                    Command="{Binding ShowPendingCasesCommand}"
                                    Height="34"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource SecondaryActionButton}"/>
                            <Button Content="APPROVED"
                                    Command="{Binding ShowApprovedCasesCommand}"
                                    Height="34"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource SecondaryActionButton}"/>
                            <Button Content="RELEASED"
                                    Command="{Binding ShowReleasedCasesCommand}"
                                    Height="34"
                                    Style="{StaticResource SecondaryActionButton}"/>
                        </WrapPanel>
                    </DockPanel>

                    <Grid Grid.Row="1"
                          Margin="0,16,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding StatusFilters}"
                                  SelectedItem="{Binding SelectedStatusFilter}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Status filter"/>

                        <TextBox Grid.Column="2"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Search request number, beneficiary, type, or program"/>

                        <Button Grid.Column="4"
                                Content="EXPORT"
                                Height="42"
                                Style="{StaticResource SecondaryActionButton}"
                                Command="{Binding ExportCasesCommand}"/>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              MinHeight="400"
                              ItemsSource="{Binding CasesView}"
                              SelectedItem="{Binding SelectedCase}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Case No."
                                                Binding="{Binding CaseNumber}"
                                                Width="140"/>
                            <DataGridTextColumn Header="Type"
                                                Binding="{Binding AssistanceType}"
                                                Width="150"/>
                            <DataGridTextColumn Header="Release"
                                                Binding="{Binding ReleaseKindText}"
                                                Width="90"/>
                            <DataGridTextColumn Header="Beneficiary"
                                                Binding="{Binding RecipientLabel}"
                                                Width="220"/>
                            <DataGridTextColumn Header="Program"
                                                Binding="{Binding AyudaProgramLabel}"
                                                Width="170"/>
                            <DataGridTextColumn Header="Amount"
                                                Binding="{Binding AssistanceAmountText}"
                                                Width="120"/>
                            <DataGridTextColumn Header="Priority"
                                                Binding="{Binding PriorityText}"
                                                Width="90"/>
                            <DataGridTemplateColumn Header="Status"
                                                    Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusBrush}"
                                                CornerRadius="12"
                                                Padding="10,4"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding StatusTextBrush}"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Requested"
                                                Binding="{Binding RequestedOn, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <StackPanel Grid.Column="2">
                <materialDesign:Card Padding="18"
                                     Margin="0,0,0,16"
                                     Background="White">
                    <StackPanel>
                        <TextBlock Text="Actions"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}"/>

                        <Button Content="NEW REQUEST"
                                Margin="0,16,0,0"
                                Height="42"
                                Style="{StaticResource GoldActionButton}"
                                Command="{Binding NewCaseCommand}"/>

                        <Button Content="OPEN REQUEST PANEL"
                                Margin="0,12,0,0"
                                Height="42"
                                Style="{StaticResource SecondaryActionButton}"
                                Command="{Binding OpenCasePanelCommand}"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Padding="18"
                                     Margin="0,0,0,16"
                                     Background="White">
                    <StackPanel>
                        <TextBlock Text="Selected Request"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}"/>

                        <Border Margin="0,16,0,0"
                                Padding="16"
                                CornerRadius="16"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource BrandBorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding EditableCaseNumber}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Text="{Binding ApplicantSummary}"
                                           Margin="0,10,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding SelectedCase.AmountsSummary, TargetNullValue=Amount: --, FallbackValue=Amount: --}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                <TextBlock Text="{Binding ReleaseKindSummary}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                <TextBlock Text="{Binding SelectedCase.AyudaProgramLabel, StringFormat=Program: {0}, TargetNullValue=Program: --, FallbackValue=Program: --}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,16,0,0"
                                Padding="14"
                                CornerRadius="16"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource BrandBorderBrush}"
                                BorderThickness="1">
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="{Binding StatusBrush}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>

            <Border Grid.ColumnSpan="3"
                    Panel.ZIndex="19"
                    Background="#660F172A"
                    CornerRadius="20"
                    Visibility="{Binding IsCasePanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}"/>

            <materialDesign:Card Grid.ColumnSpan="3"
                                 Panel.ZIndex="20"
                                 Width="700"
                                 Margin="24"
                                 Padding="16"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Stretch"
                                 Background="White"
                                 Visibility="{Binding IsCasePanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Request Panel"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}"/>

                        <Button Grid.Column="1"
                                Content="CLOSE PANEL"
                                Height="36"
                                Style="{StaticResource SecondaryActionButton}"
                                Command="{Binding CloseCasePanelCommand}"/>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,12,0,14"
                            Padding="16"
                            CornerRadius="10"
                            Background="#F8FAFC"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding EditableCaseNumber}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBlock Text="{Binding ApplicantSummary}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedCase.AmountsSummary, TargetNullValue=Amount: --, FallbackValue=Amount: --}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ReleaseKindSummary}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBox Margin="0,0,0,10"
                                     Text="{Binding ValidatedBeneficiarySearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Search validated beneficiary"/>

                            <ComboBox Margin="0,0,0,10"
                                      ItemsSource="{Binding ValidatedBeneficiaries}"
                                      SelectedItem="{Binding SelectedValidatedBeneficiary}"
                                      DisplayMemberPath="DisplayLabel"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Validated beneficiary"/>

                            <TextBox Margin="0,0,0,10"
                                     Text="{Binding EditableAssistanceType, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Assistance type"/>

                            <ComboBox Margin="0,0,0,10"
                                      ItemsSource="{Binding ReleaseKindOptions}"
                                      SelectedItem="{Binding SelectedReleaseKind}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Release kind"/>

                            <ComboBox Margin="0,0,0,10"
                                      ItemsSource="{Binding AyudaPrograms}"
                                      SelectedItem="{Binding SelectedAyudaProgram}"
                                      DisplayMemberPath="DisplayLabel"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Ayuda program"/>

                            <ComboBox Margin="0,0,0,10"
                                      ItemsSource="{Binding PriorityOptions}"
                                      SelectedItem="{Binding SelectedPriority}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Priority"/>

                            <TextBox Margin="0,0,0,10"
                                     Text="{Binding EditableAssistanceAmount, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Assistance amount"/>

                            <UniformGrid Columns="2"
                                         Margin="0,0,0,10">
                                <DatePicker Margin="0,0,8,0"
                                            SelectedDate="{Binding RequestedOnDate}"
                                            materialDesign:HintAssist.Hint="Requested date"/>
                                <DatePicker Margin="8,0,0,0"
                                            SelectedDate="{Binding ScheduledReleaseDate}"
                                            materialDesign:HintAssist.Hint="Scheduled release"/>
                            </UniformGrid>

                            <TextBox Margin="0,0,0,10"
                                     Text="{Binding EditableSummary, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Summary"/>

                            <UniformGrid Columns="2"
                                         Margin="0,6,0,0">
                                <Button Content="SAVE REQUEST"
                                        Command="{Binding SaveCaseCommand}"
                                        Margin="0,0,8,8"
                                        Height="40"
                                        Style="{StaticResource GoldActionButton}"/>
                                <Button Content="DELETE"
                                        Command="{Binding DeleteCommand}"
                                        Margin="8,0,0,8"
                                        Height="40"
                                        Style="{StaticResource SecondaryActionButton}"/>
                                <Button Content="UNDER REVIEW"
                                        Command="{Binding MarkUnderReviewCommand}"
                                        Margin="0,0,8,8"
                                        Height="40"
                                        Style="{StaticResource SecondaryActionButton}"/>
                                <Button Content="APPROVE"
                                        Command="{Binding ApproveCommand}"
                                        Margin="8,0,0,8"
                                        Height="40"
                                        Style="{StaticResource SecondaryActionButton}"/>
                                <Button Content="RELEASE"
                                        Command="{Binding ReleaseCommand}"
                                        Margin="0,0,8,8"
                                        Height="40"
                                        Style="{StaticResource SecondaryActionButton}"/>
                                <Button Content="CLOSE"
                                        Command="{Binding CloseCommand}"
                                        Margin="8,0,0,8"
                                        Height="40"
                                        Style="{StaticResource SecondaryActionButton}"/>
                                <Button Content="REJECT"
                                        Command="{Binding RejectCommand}"
                                        Margin="0,0,8,0"
                                        Height="40"
                                        Style="{StaticResource SecondaryActionButton}"/>
                                <Button Content="CANCEL"
                                        Command="{Binding CancelCommand}"
                                        Margin="8,0,0,0"
                                        Height="40"
                                        Style="{StaticResource SecondaryActionButton}"/>
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </materialDesign:Card>
        </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>



