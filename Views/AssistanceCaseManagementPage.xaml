<UserControl x:Class="AttendanceShiftingManagement.Views.AssistanceCaseManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24"
                CornerRadius="18"
                Background="{StaticResource BrandMidnightBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Assistance Case Management"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="Track household assistance requests, review approvals, and manage release or closure using one local case registry."
                               Margin="0,8,0,0"
                               MaxWidth="760"
                               Foreground="#D6E3FF"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top">
                    <Button Content="NEW CASE"
                            Command="{Binding NewCaseCommand}"
                            Style="{StaticResource SecondaryActionButton}"
                            Height="40"
                            Margin="0,0,12,0"/>
                    <Button Content="REFRESH"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource GoldActionButton}"
                            Height="40"/>
                </WrapPanel>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="1" Margin="0,18,0,18">
            <materialDesign:Card Width="160" Margin="8" Background="{StaticResource BrandMidnightBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding TotalCases, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="TOTAL CASES" Foreground="#A5B4FC" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Width="160" Margin="8" Background="{StaticResource BrandYellowBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding PendingCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="{StaticResource BrandGoldTextBrush}"/>
                    <TextBlock Text="PENDING / REVIEW" Foreground="#7A5A00" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Width="160" Margin="8" Background="{StaticResource BrandSuccessBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding ApprovedCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="APPROVED" Foreground="#CFECD8" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Width="160" Margin="8" Background="#0F766E" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding ReleasedCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="RELEASED" Foreground="#CCFBF1" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Width="160" Margin="8" Background="#4B5563" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding ClosedCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="CLOSED / ENDED" Foreground="#E5E7EB" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>
        </WrapPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Padding="16" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="Assistance Cases"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <ComboBox Width="170"
                                      Margin="0,0,12,0"
                                      ItemsSource="{Binding StatusFilters}"
                                      SelectedItem="{Binding SelectedStatusFilter}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                            <TextBox Width="280"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Search case number, household, type..."/>
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,0,0,14"
                               FontWeight="SemiBold"
                               Foreground="{Binding StatusBrush}"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"/>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding CasesView}"
                              SelectedItem="{Binding SelectedCase}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Case No." Binding="{Binding CaseNumber}" Width="140"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding AssistanceType}" Width="160"/>
                            <DataGridTextColumn Header="Household" Binding="{Binding HouseholdLabel}" Width="*"/>
                            <DataGridTextColumn Header="Applicant" Binding="{Binding ApplicantLabel}" Width="170"/>
                            <DataGridTextColumn Header="Priority" Binding="{Binding PriorityText}" Width="90"/>
                            <DataGridTemplateColumn Header="Status" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusBrush}" CornerRadius="12" Padding="8,4" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusTextBrush}" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Requested On" Binding="{Binding RequestedOn, StringFormat='{}{0:yyyy-MM-dd}'}" Width="110"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2" Padding="16" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Case Detail"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}"/>

                    <Border Grid.Row="1"
                            Margin="0,12,0,14"
                            Padding="16"
                            CornerRadius="10"
                            Background="#EEF4FF"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding EditableCaseNumber}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBlock Text="{Binding ApplicantSummary}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedCase.AmountsSummary, TargetNullValue=Requested: -- | Approved: --}"
                                       Margin="0,4,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Case Setup"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}"/>

                            <ComboBox Margin="0,12,0,10"
                                      ItemsSource="{Binding Households}"
                                      SelectedItem="{Binding SelectedHousehold}"
                                      DisplayMemberPath="DisplayLabel"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Household"/>

                            <ComboBox Margin="0,0,0,10"
                                      ItemsSource="{Binding AvailableHouseholdMembers}"
                                      SelectedItem="{Binding SelectedHouseholdMember}"
                                      DisplayMemberPath="DisplayLabel"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Optional household member"/>

                            <TextBox Margin="0,0,0,10"
                                     Text="{Binding EditableAssistanceType, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Assistance type"/>

                            <ComboBox Margin="0,0,0,10"
                                      ItemsSource="{Binding PriorityOptions}"
                                      SelectedItem="{Binding SelectedPriority}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      materialDesign:HintAssist.Hint="Priority"/>

                            <UniformGrid Columns="2" Margin="0,0,0,10">
                                <TextBox Margin="0,0,8,0"
                                         Text="{Binding EditableRequestedAmount, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Requested amount"/>
                                <TextBox Margin="8,0,0,0"
                                         Text="{Binding EditableApprovedAmount, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Approved amount"/>
                            </UniformGrid>

                            <UniformGrid Columns="2" Margin="0,0,0,10">
                                <DatePicker Margin="0,0,8,0"
                                            SelectedDate="{Binding RequestedOnDate}"
                                            materialDesign:HintAssist.Hint="Requested on"/>
                                <DatePicker Margin="8,0,0,0"
                                            SelectedDate="{Binding ScheduledReleaseDate}"
                                            materialDesign:HintAssist.Hint="Scheduled release"/>
                            </UniformGrid>

                            <TextBox Margin="0,0,0,10"
                                     Text="{Binding EditableSummary, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Summary"/>

                            <TextBox Margin="0,0,0,10"
                                     Height="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding EditableNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Case notes"/>

                            <TextBox Margin="0,0,0,10"
                                     Height="90"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding EditableResolutionNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Resolution notes for close, reject, or cancel"/>

                            <WrapPanel Margin="0,4,0,0">
                                <Button Content="SAVE"
                                        Command="{Binding SaveCaseCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource BrandMidnightBrush}"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                                <Button Content="UNDER REVIEW"
                                        Command="{Binding MarkUnderReviewCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#2563EB"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                                <Button Content="APPROVE"
                                        Command="{Binding ApproveCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource BrandSuccessBrush}"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                                <Button Content="RELEASE"
                                        Command="{Binding ReleaseCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#0F766E"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                                <Button Content="CLOSE"
                                        Command="{Binding CloseCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#4B5563"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                                <Button Content="REJECT"
                                        Command="{Binding RejectCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource BrandRedBrush}"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                                <Button Content="CANCEL"
                                        Command="{Binding CancelCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="#7C3AED"
                                        Foreground="White"
                                        Height="38"
                                        Margin="0,0,10,10"
                                        Padding="18,0"/>
                            </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
