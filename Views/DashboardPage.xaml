<UserControl x:Class="AttendanceShiftingManagement.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             Background="{StaticResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="DashboardHeaderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#DA291C" Offset="0"/>
            <GradientStop Color="#C4161C" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="StatCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <helpers:PercentToWidthConverter x:Key="PercentToWidthConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Margin="0,0,0,24" Background="{StaticResource DashboardHeaderBrush}" CornerRadius="12" Padding="16">
                <DockPanel>
                <StackPanel>
                    <TextBlock Text="Admin Dashboard" FontSize="32" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="McDonald's Branch #1024 - Management Overview" Foreground="#FFE9D5" FontSize="16"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentDateTime}" 
                               HorizontalAlignment="Right" Foreground="White"/>
                    <TextBlock Text="{Binding CurrentTime}" 
                               HorizontalAlignment="Right" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                </DockPanel>
            </Border>

            <!-- Stats Cards -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,24">
                <Border Margin="8" Background="{StaticResource BrandMidnightBrush}" Padding="16" CornerRadius="8" MinHeight="130">
                    <Button Command="{Binding ShowAllEmployeesCommand}" Style="{StaticResource StatCardButtonStyle}">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="👥" FontSize="36" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding TotalEmployees}" FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                            <TextBlock Text="TOTAL EMPLOYEES" FontSize="13" Foreground="White" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </Border>

                <Border Margin="8" Background="{StaticResource BrandRedBrush}" Padding="16" CornerRadius="8" MinHeight="130">
                    <Button Command="{Binding ShowAttendanceStatusCommand}" CommandParameter="Absent" Style="{StaticResource StatCardButtonStyle}">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="🚫" FontSize="36" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding AbsentCount}" FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                            <TextBlock Text="ABSENT TODAY" FontSize="13" Foreground="White" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </Border>

                <Border Margin="8" Background="{StaticResource BrandYellowBrush}" Padding="16" CornerRadius="8" MinHeight="130">
                    <Button Command="{Binding ShowAttendanceStatusCommand}" CommandParameter="Late" Style="{StaticResource StatCardButtonStyle}">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="⏰" FontSize="36" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding LateCount}" FontSize="26" FontWeight="Bold" Foreground="#27251F" Margin="0,6,0,0"/>
                            <TextBlock Text="LATE ARRIVALS" FontSize="13" Foreground="#27251F" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </Border>

                <Border Margin="8" Background="#27251F" Padding="16" CornerRadius="8" MinHeight="130">
                    <Button Command="{Binding ShowAttendanceStatusCommand}" CommandParameter="Overtime" Style="{StaticResource StatCardButtonStyle}">
                        <StackPanel HorizontalAlignment="Left">
                            <TextBlock Text="⌛" FontSize="36" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding OvertimeCount}" FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,6,0,0"/>
                            <TextBlock Text="OVERTIME HOURS" FontSize="13" Foreground="White" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </Border>
            </UniformGrid>

            <!-- Charts & Alerts -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Alerts & Chart Placeholder -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <Border Padding="16" Margin="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Critical Alerts" FontSize="20" FontWeight="Bold" Foreground="#D32F2F" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding Alerts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="8">
                                            <DockPanel>
                                                <TextBlock Text="⚠️" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="{Binding Message}" VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Padding="16" Margin="8" Height="300" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Staffing Distribution by Area" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                            <StackPanel VerticalAlignment="Center">
                                <Border Background="#F3F4F6" CornerRadius="8" Padding="6">
                                    <Grid x:Name="DistributionBar" Height="22" Background="#E5E7EB" ClipToBounds="True">
                                        <ItemsControl ItemsSource="{Binding AreaDistributions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding Color}" Height="10" CornerRadius="4" Margin="2,6,2,6">
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                                <Binding Path="Percent"/>
                                                                <Binding ElementName="DistributionBar" Path="ActualWidth"/>
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>

                                <ItemsControl ItemsSource="{Binding AreaDistributions}" Margin="0,10,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <Border Width="10" Height="10" Background="{Binding Color}" CornerRadius="2" Margin="0,2,6,0"/>
                                                <TextBlock Text="{Binding Label}" FontSize="11"/>
                                                <TextBlock Text="{Binding Percent, StringFormat=' {0:0}%'}" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding AreaDistributionSummary}"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           Foreground="Gray"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right Column: Quick Actions & Recent Activity -->
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <Border Padding="16" Margin="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Quick Actions" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
                            <Button Command="{Binding GeneratePayrollCommand}" Margin="0,0,0,10"
                                    Background="{StaticResource BrandRedBrush}" Foreground="White" Height="44" Padding="16,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="💵" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="GENERATE PAYROLL" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding AddEmployeeCommand}" Margin="0,0,0,0"
                                    Height="44" Padding="16,0" BorderBrush="{StaticResource BrandYellowBrush}" Background="White">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="👤+" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="ADD NEW EMPLOYEE" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrandYellowBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Padding="16" Margin="8" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8">
                        <StackPanel>
                            <TextBlock Text="Recent Time-ins" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
                            <DataGrid ItemsSource="{Binding RecentActivities}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" 
                                      HeadersVisibility="Column" GridLinesVisibility="None">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat='hh:mm tt'}" Width="Auto"/>
                                    <DataGridTemplateColumn Header="Status">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding StatusColor}" CornerRadius="12" Padding="8,2" Height="24">
                                                    <TextBlock Text="{Binding Status}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
