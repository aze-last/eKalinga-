<UserControl x:Class="AttendanceShiftingManagement.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             Background="{StaticResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <!-- Stat card: clickable area with no button chrome so text always shows -->
        <Style x:Key="StatCardButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="8">
                            <ContentPresenter Content="{TemplateBinding Content}" ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardCardButtonLight" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="White"/>
                </Style>
                <Style TargetType="materialDesign:PackIcon">
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="DashboardCardButtonDark" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="#27251F"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Resources>
                <Style TargetType="TextBlock">
                    <Setter Property="Foreground" Value="#27251F"/>
                </Style>
                <Style TargetType="materialDesign:PackIcon">
                    <Setter Property="Foreground" Value="#27251F"/>
                </Style>
            </Style.Resources>
        </Style>

        <helpers:PercentToWidthConverter x:Key="PercentToWidthConverter"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Margin="0,0,0,24"
                    Background="{StaticResource BrandMidnightBrush}"
                    CornerRadius="10"
                    Padding="20"
                    BorderBrush="{StaticResource BrandMidnightBrush}"
                    BorderThickness="1">
                <DockPanel>
                <StackPanel>
                    <TextBlock Text="{Binding PortalTitle}" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="Household assistance, cash-for-work operations, and barangay attendance tracking in one dashboard."
                               Foreground="#FFE9D5"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentDateTime}" 
                               HorizontalAlignment="Right" Foreground="White" FontSize="13"/>
                    <TextBlock Text="{Binding CurrentTime}" 
                               HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="White" FontSize="13"/>
                    <TextBlock Text="{Binding LastMetricsRefresh, StringFormat='Last data update: {0}'}"
                               HorizontalAlignment="Right" Foreground="#D6DEEE" FontSize="11" Margin="0,4,0,0"/>
                    <TextBlock Text="Daily snapshot: households and work attendance"
                               HorizontalAlignment="Right" Foreground="#D6DEEE" FontSize="11"/>
                </StackPanel>
                </DockPanel>
            </Border>

            <!-- Stats Cards (custom template so text is never hidden by button chrome) -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,24">
                <materialDesign:Card Margin="8" Background="{StaticResource BrandMidnightBrush}" Padding="16" MinHeight="118" BorderThickness="0">
                    <Button Command="{Binding ShowHouseholdsCommand}" Style="{StaticResource StatCardButton}">
                        <StackPanel HorizontalAlignment="Left">
                            <materialDesign:PackIcon Kind="HomeGroup" Width="36" Height="36" Foreground="{StaticResource BrandYellowBrush}"/>
                            <TextBlock Text="{Binding TotalEmployees}" FontSize="28" FontWeight="Medium" Foreground="White" Margin="0,8,0,0"/>
                            <TextBlock Text="REGISTERED HOUSEHOLDS" FontSize="9" Foreground="#99FFFFFF" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Button>
                </materialDesign:Card>

                <materialDesign:Card Margin="8" Background="{StaticResource BrandYellowBrush}" Padding="16" MinHeight="118" BorderThickness="0">
                    <Button Command="{Binding ShowCashForWorkOcrCommand}" Style="{StaticResource StatCardButton}">
                        <StackPanel HorizontalAlignment="Left">
                            <materialDesign:PackIcon Kind="AccountCheck" Width="36" Height="36" Foreground="{StaticResource BrandGoldTextBrush}"/>
                            <TextBlock Text="{Binding PresentCount}" FontSize="28" FontWeight="Medium" Foreground="{StaticResource BrandGoldTextBrush}" Margin="0,8,0,0"/>
                            <TextBlock Text="ATTENDANCE SAVED TODAY" FontSize="9" Foreground="#7A5A00" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding AttendanceSummary}" FontSize="11" Foreground="{StaticResource BrandGoldTextBrush}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                </materialDesign:Card>

                <materialDesign:Card Margin="8" Background="{StaticResource BrandSuccessBrush}" Padding="16" MinHeight="118" BorderThickness="0">
                    <Button Command="{Binding ShowCashForWorkOcrCommand}" Style="{StaticResource StatCardButton}">
                        <StackPanel HorizontalAlignment="Left">
                            <materialDesign:PackIcon Kind="CalendarClock" Width="36" Height="36" Foreground="White"/>
                            <TextBlock Text="{Binding PendingLeaveCount}" FontSize="28" FontWeight="Medium" Foreground="White" Margin="0,8,0,0"/>
                            <TextBlock Text="OPEN WORK EVENTS" FontSize="9" Foreground="#99FFFFFF" Margin="0,4,0,0"/>
                            <TextBlock Text="Create, update, or complete barangay work activities" FontSize="11" Foreground="#E8F5EF" Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                </materialDesign:Card>

                <materialDesign:Card Margin="8" Background="{StaticResource BrandCardBrush}" Padding="16" MinHeight="118">
                    <Button Command="{Binding ShowCashForWorkOcrCommand}" Style="{StaticResource StatCardButton}">
                        <StackPanel HorizontalAlignment="Left">
                            <materialDesign:PackIcon Kind="AccountGroupOutline" Width="36" Height="36" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBlock Text="{Binding ShiftCoveragePercent, StringFormat='{}{0}%'}" FontSize="28" FontWeight="Medium" Foreground="{StaticResource BrandMidnightBrush}" Margin="0,8,0,0"/>
                            <TextBlock Text="ATTENDANCE COMPLETION" FontSize="9" Foreground="#6B7280" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding ShiftCoverageSummary}" FontSize="11" Foreground="{StaticResource BrandTextSecondaryBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Button>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Charts & Alerts -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Alerts & Chart Placeholder -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <materialDesign:Card Padding="16" Margin="8">
                        <StackPanel>
                            <TextBlock Text="Operational Alerts" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="#D32F2F" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding Alerts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="8">
                                            <DockPanel>
                                                <materialDesign:PackIcon Kind="AlertCircle" Foreground="#D32F2F" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="{Binding Message}" VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="16" Margin="8" Height="300">
                        <Grid>
                            <TextBlock Text="Household Distribution by Purok" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                            <StackPanel VerticalAlignment="Center">
                                <Border Background="#F3F4F6" CornerRadius="8" Padding="6">
                                    <Grid x:Name="DistributionBar" Height="22" Background="#E5E7EB" ClipToBounds="True">
                                        <ItemsControl ItemsSource="{Binding AreaDistributions}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding Color}" Height="10" CornerRadius="4" Margin="2,6,2,6">
                                                        <Border.Width>
                                                            <MultiBinding Converter="{StaticResource PercentToWidthConverter}">
                                                                <Binding Path="Percent"/>
                                                                <Binding ElementName="DistributionBar" Path="ActualWidth"/>
                                                            </MultiBinding>
                                                        </Border.Width>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>

                                <ItemsControl ItemsSource="{Binding AreaDistributions}" Margin="0,10,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,12,6">
                                                <Border Width="10" Height="10" Background="{Binding Color}" CornerRadius="2" Margin="0,2,6,0"/>
                                                <TextBlock Text="{Binding Label}" FontSize="11"/>
                                                <TextBlock Text="{Binding Percent, StringFormat=' {0:0}%'}" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{Binding AreaDistributionSummary}"
                                           HorizontalAlignment="Center"
                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                </StackPanel>

                <!-- Right Column: Quick Actions & Recent Activity -->
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <materialDesign:Card Padding="16" Margin="8">
                        <StackPanel>
                            <TextBlock Text="Quick Actions" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                            <Button Style="{StaticResource PrimaryActionButton}" Command="{Binding ShowCashForWorkOcrCommand}" Margin="0,0,0,10"
                                    Height="44" Padding="16,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="AccountHardHat" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="OPEN CASH-FOR-WORK" FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource GoldActionButton}" Command="{Binding ShowHouseholdsCommand}" Margin="0,0,0,10"
                                    Height="44" Padding="16,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="HomeGroup" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="OPEN HOUSEHOLDS" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="16" Margin="8">
                        <StackPanel>
                            <TextBlock Text="Recent Cash-for-Work Activity" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,12"/>
                            <DataGrid ItemsSource="{Binding RecentActivities}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" 
                                      HeadersVisibility="Column" GridLinesVisibility="None" materialDesign:DataGridAssist.CellPadding="12 8 8 8">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Participant" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Recorded" Binding="{Binding Time, StringFormat='hh:mm tt'}" Width="Auto"/>
                                    <DataGridTemplateColumn Header="Source">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <materialDesign:Chip Content="{Binding Status}" Background="{Binding StatusColor}" Foreground="White" Height="24"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
