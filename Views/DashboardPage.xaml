<UserControl x:Class="AttendanceShiftingManagement.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <LinearGradientBrush x:Key="DashboardHeaderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#DA291C" Offset="0"/>
            <GradientStop Color="#C4161C" Offset="1"/>
        </LinearGradientBrush>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Margin="0,0,0,24" Background="{StaticResource DashboardHeaderBrush}" CornerRadius="12" Padding="16">
                <DockPanel>
                <StackPanel>
                    <TextBlock Text="Admin Dashboard" Style="{StaticResource MaterialDesignHeadline4TextBlock}" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="McDonald's Branch #1024 - Management Overview" Foreground="#FFE9D5" FontSize="16"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentDateTime}" 
                               HorizontalAlignment="Right" Foreground="White"/>
                    <TextBlock Text="{Binding CurrentTime}" 
                               HorizontalAlignment="Right" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                </DockPanel>
            </Border>

            <!-- Stats Cards -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,24">
                <materialDesign:Card Margin="8" Background="{StaticResource BrandMidnightBrush}" Foreground="White" Padding="16" materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel>
                    <materialDesign:PackIcon Kind="AccountGroup" Width="32" Height="32" Foreground="{StaticResource BrandYellowBrush}"/>
                        <TextBlock Text="{Binding TotalEmployees}" Style="{StaticResource MaterialDesignHeadline3TextBlock}" FontWeight="Bold"/>
                        <TextBlock Text="TOTAL EMPLOYEES" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.8"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="8" Background="{StaticResource BrandRedBrush}" Foreground="White" Padding="16" materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel>
                    <materialDesign:PackIcon Kind="AccountOff" Width="32" Height="32" Foreground="White"/>
                        <TextBlock Text="{Binding AbsentCount}" Style="{StaticResource MaterialDesignHeadline3TextBlock}" FontWeight="Bold"/>
                        <TextBlock Text="ABSENT TODAY" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.8"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="8" Background="{StaticResource BrandYellowBrush}" Foreground="#27251F" Padding="16" materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel>
                    <materialDesign:PackIcon Kind="ClockAlert" Width="32" Height="32" Foreground="{StaticResource BrandMidnightBrush}"/>
                        <TextBlock Text="{Binding LateCount}" Style="{StaticResource MaterialDesignHeadline3TextBlock}" FontWeight="Bold"/>
                        <TextBlock Text="LATE ARRIVALS" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.8"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Margin="8" Background="#27251F" Foreground="White" Padding="16" materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel>
                    <materialDesign:PackIcon Kind="TimerPlus" Width="32" Height="32" Foreground="{StaticResource BrandYellowBrush}"/>
                        <TextBlock Text="{Binding OvertimeCount}" Style="{StaticResource MaterialDesignHeadline3TextBlock}" FontWeight="Bold"/>
                        <TextBlock Text="OVERTIME HOURS" Style="{StaticResource MaterialDesignBody2TextBlock}" Opacity="0.8"/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Charts & Alerts -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Alerts & Chart Placeholder -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <materialDesign:Card Padding="16" Margin="8" materialDesign:ElevationAssist.Elevation="Dp2">
                        <StackPanel>
                            <TextBlock Text="Critical Alerts" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="#D32F2F" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding Alerts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1" Padding="8">
                                            <DockPanel>
                                                <materialDesign:PackIcon Kind="AlertCircle" Foreground="#D32F2F" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                <TextBlock Text="{Binding Message}" VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="16" Margin="8" Height="300" materialDesign:ElevationAssist.Elevation="Dp2">
                        <Grid>
                            <TextBlock Text="Staffing Distribution by Area" Style="{StaticResource MaterialDesignHeadline6TextBlock}"/>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="ChartPie" Width="80" Height="80" HorizontalAlignment="Center" Opacity="0.2"/>
                                <TextBlock Text="Kitchen: 40% | POS: 30% | DT: 20% | Lobby: 10%" HorizontalAlignment="Center" Style="{StaticResource MaterialDesignCaptionTextBlock}"/>
                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>
                </StackPanel>

                <!-- Right Column: Quick Actions & Recent Activity -->
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <materialDesign:Card Padding="16" Margin="8" materialDesign:ElevationAssist.Elevation="Dp2">
                        <StackPanel>
                            <TextBlock Text="Quick Actions" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16"/>
                            <Button Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding GeneratePayrollCommand}" Margin="0,0,0,8" Background="{StaticResource BrandRedBrush}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CashRegister" Margin="0,0,8,0"/>
                                    <TextBlock Text="GENERATE PAYROLL"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding AddEmployeeCommand}" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="AccountPlus" Margin="0,0,8,0"/>
                                    <TextBlock Text="ADD NEW EMPLOYEE"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}" Command="{Binding CreateShiftCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CalendarPlus" Margin="0,0,8,0"/>
                                    <TextBlock Text="CREATE NEW SHIFT"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="16" Margin="8" materialDesign:ElevationAssist.Elevation="Dp2">
                        <StackPanel>
                            <TextBlock Text="Recent Time-ins" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,12"/>
                            <DataGrid ItemsSource="{Binding RecentActivities}" AutoGenerateColumns="False" IsReadOnly="True" Background="Transparent" 
                                      HeadersVisibility="Column" GridLinesVisibility="None" materialDesign:DataGridAssist.CellPadding="12 8 8 8">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time, StringFormat='hh:mm tt'}" Width="Auto"/>
                                    <DataGridTemplateColumn Header="Status">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <materialDesign:Chip Content="{Binding Status}" Background="{Binding StatusColor}" Foreground="White" Height="24"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
