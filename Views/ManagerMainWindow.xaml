<Window x:Class="AttendanceShiftingManagement.Views.ManagerMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Manager Command Center | Attendance System" WindowState="Maximized"
        Background="{StaticResource BrandSurfaceBrush}" FontFamily="Segoe UI"
        Icon="/Images/app-icon.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource BrandMidnightBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,40,20,40">
                    <Image Source="/Images/McDonalds-Logo.png" Width="80" Height="48" Stretch="Uniform" HorizontalAlignment="Center"/>
                    <TextBlock Text="MANAGER" Foreground="White" HorizontalAlignment="Center" FontSize="20" FontWeight="ExtraBold" Margin="0,10,0,0" />
                    <TextBlock Text="COMMAND CENTER" Foreground="{StaticResource BrandYellowBrush}" HorizontalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="12,0">
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" IsChecked="True"
                                 Content="DASHBOARD" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowDashboardCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" 
                                 Content="SHIFT PLANNING" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowShiftsCommand}"
                                 Visibility="{Binding IsSchedulingAllowed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" 
                                 Content="WEEKLY SCHEDULE" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowWeeklyCalendarCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" 
                                 Content="ATTENDANCE LOGS" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowAttendanceCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" 
                                 Content="EMPLOYEE LIST" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowEmployeesCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" 
                                 Content="POSITIONS" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowPositionsCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" 
                                 Content="LEAVE APPROVAL" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowLeaveApprovalCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" 
                                 Content="PROFILE SETTINGS" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowProfileSettingsCommand}"/>
                </StackPanel>

                <Button Grid.Row="2" Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="{StaticResource BrandYellowBrush}" Height="50" Margin="12,0,12,30" Click="Logout_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Logout" Margin="0,0,12,0"/>
                        <TextBlock Text="Exit Portal" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="24,0" materialDesign:ElevationAssist.Elevation="Dp2">
                <DockPanel VerticalAlignment="Center">
                    <TextBlock Text="Operational Overview" VerticalAlignment="Center" 
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}" FontWeight="SemiBold" Foreground="#27251F"/>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <materialDesign:Badged Badge="3">
                            <Button Style="{StaticResource MaterialDesignIconButton}" Foreground="#64748B">
                                <materialDesign:PackIcon Kind="BellOutline" />
                            </Button>
                        </materialDesign:Badged>
                        <Border Background="#E2E8F0" Width="1" Height="24" Margin="16,0"/>
                        <TextBlock Text="Store Manager #102" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Medium"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="24"/>
        </Grid>
    </Grid>
</Window>
