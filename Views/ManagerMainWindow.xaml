<Window x:Class="AttendanceShiftingManagement.Views.ManagerMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Manager Command Center | Attendance System" WindowState="Maximized"
        Background="#0F172A" FontFamily="Segoe UI"
        Icon="/Images/app-icon.ico">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Nav Button Style -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="navBorder" CornerRadius="10" Padding="14,0" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="navBorder" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="navBorder" Property="Background" Value="#1E3A2F"/>
                                <Setter Property="Foreground" Value="#4ADE80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Menu Button Style -->
        <Style x:Key="MenuItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="menuBorder" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="menuBorder" Property="Background" Value="#F1F5F9"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             SIDEBAR
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0F172A" Offset="0"/>
                    <GradientStop Color="#0F1F2E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo / Branding -->
                <StackPanel Grid.Row="0" Margin="20,28,20,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border Width="36" Height="36" CornerRadius="10">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFC72C" Offset="0"/>
                                    <GradientStop Color="#DA291C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <materialDesign:PackIcon Kind="CalendarClock" Foreground="White" Width="20" Height="20"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ShiftSync" Foreground="White" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="Manager Portal" Foreground="#64748B" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Height="1" Background="#1E293B" Margin="0,16,0,20"/>

                    <!-- Profile Card -->
                    <Border CornerRadius="12" Padding="12" Margin="0,0,0,4">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1E293B" Offset="0"/>
                                <GradientStop Color="#1A2535" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="20"
                                    BorderThickness="2" VerticalAlignment="Center">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFC72C" Offset="0"/>
                                        <GradientStop Color="#DA291C" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Grid>
                                    <materialDesign:PackIcon Kind="AccountCircle" Foreground="#64748B"
                                                             Width="36" Height="36"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Image Source="{Binding UserPhotoImage}" Stretch="UniformToFill"/>
                                </Grid>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="{Binding UserDisplayName}" Foreground="White"
                                           FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <Border Background="#14532D" CornerRadius="999" Padding="7,2"
                                        HorizontalAlignment="Left" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding RoleBadgeText}" Foreground="#4ADE80"
                                               FontSize="9" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Profile Settings link -->
                    <Button Content="⚙  Profile Settings"
                            Command="{Binding ShowProfileSettingsCommand}"
                            Style="{StaticResource MenuItemButtonStyle}"
                            Foreground="#64748B"
                            FontSize="11"
                            Margin="0,4,0,0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="0,12,0,0">

                    <!-- Section Label -->
                    <TextBlock Text="MAIN" Foreground="#334155" FontSize="9" FontWeight="Bold"
                               Margin="22,0,0,6"/>

                    <RadioButton Style="{StaticResource NavButtonStyle}" IsChecked="True"
                                 Command="{Binding ShowDashboardCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboardOutline" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Dashboard" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Divider + Section -->
                    <Border Height="1" Background="#1E293B" Margin="16,8"/>
                    <TextBlock Text="SCHEDULER TOOLS" Foreground="#FFC72C" FontSize="9" FontWeight="Bold"
                               Margin="22,0,0,6"
                               Visibility="{Binding SchedulerSpotlightVisibility}"/>

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Command="{Binding ShowShiftsCommand}"
                                 Visibility="{Binding IsSchedulingAllowed, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CalendarEdit" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Shift Planning" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Command="{Binding ShowWeeklyCalendarCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CalendarWeekOutline" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Weekly Schedule" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- Divider + Section -->
                    <Border Height="1" Background="#1E293B" Margin="16,8"/>
                    <TextBlock Text="MY WORK" Foreground="#334155" FontSize="9" FontWeight="Bold"
                               Margin="22,0,0,6"/>

                    <RadioButton Style="{StaticResource NavButtonStyle}"
                                 Command="{Binding ShowMyScheduleCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CalendarAccountOutline" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="My Schedule" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

                <!-- Bottom Actions -->
                <StackPanel Grid.Row="2" Margin="12,0,12,24">
                    <Button x:Name="SwitchRoleButton"
                            Click="SwitchRole_Click"
                            Visibility="Collapsed"
                            BorderThickness="0"
                            Background="Transparent"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            Padding="14,12"
                            Margin="0,0,0,8">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="switchRoleBorder" CornerRadius="10" Padding="14,12" Background="#2B3442">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountSwitch" Foreground="White"
                                                                 Width="18" Height="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Switch Role" Foreground="White"
                                                   FontWeight="SemiBold" FontSize="13" Margin="10,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="switchRoleBorder" Property="Background" Value="#374151"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Border CornerRadius="10" Padding="0,4">
                        <Button Click="Logout_Click" BorderThickness="0" Background="Transparent"
                                Cursor="Hand" HorizontalAlignment="Stretch" Padding="14,12">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="logoutBorder" CornerRadius="10" Padding="14,12" Background="Transparent">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="LogoutVariant" Foreground="#EF4444"
                                                                     Width="18" Height="18" VerticalAlignment="Center"/>
                                            <TextBlock Text="Exit Portal" Foreground="#EF4444"
                                                       FontWeight="SemiBold" FontSize="13" Margin="10,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="logoutBorder" Property="Background" Value="#1F0A0A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             MAIN CONTENT AREA
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Background="#F0F4F8">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="White" Padding="28,0">
                <Border.Effect>
                    <DropShadowEffect Color="#E2E8F0" BlurRadius="8" ShadowDepth="2" Opacity="0.5"/>
                </Border.Effect>
                <DockPanel VerticalAlignment="Center">
                    <Button x:Name="ReturnAdminButton"
                            AutomationProperties.Name="Return to Admin"
                            Content="← Return to Admin"
                            DockPanel.Dock="Right"
                            Visibility="Collapsed"
                            Background="#FEF2F2"
                            Foreground="#DA291C"
                            BorderBrush="#FCA5A5"
                            BorderThickness="1"
                            Padding="14,6"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="ReturnToAdmin_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="8" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Breadcrumb / Title -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PortalHeading}" FontWeight="Bold" FontSize="17"
                                   Foreground="#0F172A" VerticalAlignment="Center"/>
                        <TextBlock Text=" · " Foreground="#CBD5E1" FontSize="17" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PortalSubtitle}" FontSize="13" Foreground="#64748B"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Menu button (hamburger-style) -->
                    <Button DockPanel.Dock="Right" Margin="0,0,16,0"
                            Command="{Binding ToggleMenuCommand}"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            ToolTip="More options">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="menuBtn" CornerRadius="8" Padding="10,6"
                                        Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1">
                                    <materialDesign:PackIcon Kind="DotsHorizontal" Foreground="#64748B"
                                                             Width="18" Height="18"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="menuBtn" Property="Background" Value="#F8FAFC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>
            </Border>

            <!-- Page Content -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="24"/>

            <!-- Overlay + Drawer Menu -->
            <Grid Grid.RowSpan="2" Panel.ZIndex="100"
                  Visibility="{Binding IsMenuOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Background="#44000000">
                    <Border.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding CloseMenuCommand}"/>
                    </Border.InputBindings>
                </Border>
                <Border Background="White" Width="260"
                        HorizontalAlignment="Right" VerticalAlignment="Stretch"
                        CornerRadius="0">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="0" Opacity="0.15"/>
                    </Border.Effect>
                    <StackPanel Margin="0,0,0,0">
                        <Border Background="#F8FAFC" Padding="24,20" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                            <TextBlock Text="More Options" FontWeight="Bold" FontSize="15" Foreground="#0F172A"/>
                        </Border>
                        <StackPanel Margin="16,16">
                            <Button Content="Attendance Logs" Style="{StaticResource MenuItemButtonStyle}"
                                    Command="{Binding ShowAttendanceCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                            <Button Content="Employee List" Style="{StaticResource MenuItemButtonStyle}"
                                    Command="{Binding ShowEmployeesCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                            <Button Content="Positions" Style="{StaticResource MenuItemButtonStyle}"
                                    Command="{Binding ShowPositionsCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                            <Button Content="Leave Approval" Style="{StaticResource MenuItemButtonStyle}"
                                    Command="{Binding ShowLeaveApprovalCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
