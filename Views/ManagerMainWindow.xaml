<Window x:Class="AttendanceShiftingManagement.Views.ManagerMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Manager Command Center | Attendance System" WindowState="Maximized"
        Background="{StaticResource BrandSurfaceBrush}" FontFamily="Segoe UI"
        Icon="/Images/app-icon.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource BrandMidnightBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,32,20,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="56" Height="56" CornerRadius="28" Background="#1F2937" VerticalAlignment="Center">
                            <Grid>
                                <materialDesign:PackIcon Kind="AccountCircle" Foreground="{Binding RoleAccentBrush}" Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image Source="{Binding UserPhotoImage}" Stretch="UniformToFill"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="{Binding UserDisplayName}" Foreground="White" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            <Border Background="{Binding RoleBadgeBackground}" CornerRadius="999" Padding="8,3" HorizontalAlignment="Left" Margin="0,6,0,6">
                                <TextBlock Text="{Binding RoleBadgeText}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <Button Content="Profile Settings"
                                    Command="{Binding ShowProfileSettingsCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{Binding RoleAccentBrush}"
                                    Padding="0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>

                    <Border Margin="0,16,0,0"
                            Padding="12"
                            CornerRadius="12"
                            Background="#1A453D"
                            BorderBrush="{Binding RoleAccentBrush}"
                            BorderThickness="1"
                            Visibility="{Binding SchedulerSpotlightVisibility}">
                        <StackPanel>
                            <TextBlock Text="Scheduler Priority"
                                       Foreground="{Binding RoleAccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="12"/>
                            <TextBlock Text="Direct access to shift planning, weekly roster control, and fairness-driven scheduling."
                                       Foreground="#D1FAE5"
                                       FontSize="12"
                                       Margin="0,6,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="12,0">
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" IsChecked="True"
                                 Content="DASHBOARD" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowDashboardCommand}"/>
                    <Border CornerRadius="12"
                            Padding="4"
                            Margin="0,4,0,6"
                            Background="{Binding SchedulerPanelBackground}"
                            BorderBrush="{Binding SchedulerPanelBorderBrush}"
                            BorderThickness="{Binding SchedulerPanelBorderThickness}">
                        <StackPanel>
                            <TextBlock Text="SCHEDULER TOOLS"
                                       Foreground="{Binding RoleAccentBrush}"
                                       FontWeight="Bold"
                                       FontSize="10"
                                       Margin="12,4,0,4"
                                       Visibility="{Binding SchedulerSpotlightVisibility}"/>
                            <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" 
                                         Content="SHIFT PLANNING" Foreground="White" Height="50" Margin="0,2"
                                         Command="{Binding ShowShiftsCommand}"
                                         Visibility="{Binding IsSchedulingAllowed, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" 
                                         Content="WEEKLY SCHEDULE" Foreground="White" Height="50" Margin="0,2"
                                         Command="{Binding ShowWeeklyCalendarCommand}"/>
                        </StackPanel>
                    </Border>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}"
                                 Content="MY SCHEDULE" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowMyScheduleCommand}"/>
                </StackPanel>

                <Button Grid.Row="2" Style="{StaticResource MaterialDesignFlatButton}" 
                        Foreground="{StaticResource BrandYellowBrush}" Height="50" Margin="12,0,12,30" Click="Logout_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Logout" Margin="0,0,12,0"/>
                        <TextBlock Text="Exit Portal" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="24,0" materialDesign:ElevationAssist.Elevation="Dp2">
                <DockPanel VerticalAlignment="Center">
                    <Button Content="Return to Admin"
                            DockPanel.Dock="Right"
                            x:Name="ReturnAdminButton"
                            AutomationProperties.Name="Return to Admin"
                            Visibility="Collapsed"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="{StaticResource BrandRedBrush}"
                            BorderBrush="{StaticResource BrandRedBrush}"
                            Padding="10,4"
                            Click="ReturnToAdmin_Click"/>
                    <StackPanel HorizontalAlignment="Left">
                        <TextBlock Text="{Binding PortalHeading}" VerticalAlignment="Center" FontWeight="Bold" FontSize="16" Foreground="#111827"/>
                        <TextBlock Text="{Binding PortalSubtitle}" VerticalAlignment="Center" FontSize="12" Foreground="#6B7280"/>
                        <Button Content="Menu"
                                Command="{Binding ToggleMenuCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="#27251F"
                                FontSize="12"
                                Padding="0" HorizontalAlignment="Left"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" Margin="24"/>

            <Grid Grid.RowSpan="2" Panel.ZIndex="100" Visibility="{Binding IsMenuOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Background="#66000000">
                    <Border.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding CloseMenuCommand}"/>
                    </Border.InputBindings>
                </Border>
                <Border Background="White"
                        Width="240"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="24,90,0,0"
                        Padding="16"
                        CornerRadius="12"
                        materialDesign:ElevationAssist.Elevation="Dp8">
                    <StackPanel>
                        <TextBlock Text="Menu" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Button Content="Attendance Logs" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,8"
                                Command="{Binding ShowAttendanceCommand}"/>
                        <Button Content="Employee List" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,8"
                                Command="{Binding ShowEmployeesCommand}"/>
                        <Button Content="Positions" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,8"
                                Command="{Binding ShowPositionsCommand}"/>
                        <Button Content="Leave Approval" Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,0,8"
                                Command="{Binding ShowLeaveApprovalCommand}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
