<UserControl x:Class="AttendanceShiftingManagement.Views.HolidaysPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Holiday Management" 
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                       FontWeight="Bold"
                       Foreground="{StaticResource BrandMidnightBrush}"
                       DockPanel.Dock="Left"/>

            <Button Command="{Binding AddHolidayCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="{StaticResource BrandRedBrush}" Foreground="White"
                    HorizontalAlignment="Right"
                    DockPanel.Dock="Right">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CalendarPlus" Margin="0,0,8,0"/>
                        <TextBlock Text="ADD HOLIDAY"/>
                    </StackPanel>
                </Button.Content>
            </Button>
        </DockPanel>

        <!-- Holidays DataGrid -->
        <materialDesign:Card Grid.Row="1" Padding="16" Background="White">
            <DataGrid ItemsSource="{Binding Holidays}" 
                      SelectedItem="{Binding SelectedHoliday}"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Holiday Date" Binding="{Binding HolidayDate, StringFormat='yyyy-MM-dd (dddd)'}" Width="*"/>
                    <DataGridTextColumn Header="Holiday Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridCheckBoxColumn Header="Double Pay" Binding="{Binding IsDoublePay}" Width="120"/>

                    <DataGridTemplateColumn Header="Actions" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                            Command="{Binding DataContext.EditHolidayCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Edit">
                                        <materialDesign:PackIcon Kind="Pencil"/>
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                            Command="{Binding DataContext.DeleteHolidayCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Delete"
                                            Foreground="Red">
                                        <materialDesign:PackIcon Kind="Delete"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>
    </Grid>
</UserControl>
