<Window x:Class="AttendanceShiftingManagement.Views.RoleSwitchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Switch Role (Demo)"
        Height="520" Width="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="{StaticResource BrandSurfaceBrush}"
        Icon="/Images/app-icon.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Quick Role Switch (Demo)"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrandMidnightBrush}"/>
            <TextBlock Text="Select an active account to continue without logging out."
                       Margin="0,6,0,16"
                       Opacity="0.75"/>
        </StackPanel>

        <DataGrid x:Name="UsersGrid"
                  AutomationProperties.Name="Role Switch Accounts"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  materialDesign:DataGridAssist.CellPadding="12 8 8 8">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="2*"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="3*"/>
                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel"
                    AutomationProperties.Name="Cancel Switch"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="110"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Switch"
                    AutomationProperties.Name="Confirm Switch"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Width="130"
                    Background="{StaticResource BrandRedBrush}"
                    Foreground="White"
                    Click="Switch_Click"/>
        </StackPanel>
    </Grid>
</Window>
