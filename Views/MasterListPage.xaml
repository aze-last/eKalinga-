<UserControl x:Class="AttendanceShiftingManagement.Views.MasterListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24"
                CornerRadius="18"
                Background="{StaticResource BrandMidnightBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Validated Beneficiaries"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                    <TextBlock Text="Browse the validated beneficiaries snapshot in smaller pages so large barangay datasets stay responsive while you search, filter, and review records."
                               Margin="0,8,0,0"
                               MaxWidth="640"
                               Foreground="#D6E3FF"
                               TextWrapping="Wrap"/>

                    <WrapPanel Margin="0,16,0,0">
                        <Border Margin="0,0,12,0"
                                Padding="10,6"
                                CornerRadius="14"
                                Background="#26F9C231">
                            <TextBlock Text="LOCAL SNAPSHOT"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandYellowBrush}"/>
                        </Border>
                        <TextBlock Text="{Binding SnapshotSourceSummary}"
                                   VerticalAlignment="Center"
                                   Foreground="#C7D2FE"/>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Content="REFRESH SNAPSHOT"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource GoldActionButton}"
                            Height="40"/>
                    <TextBlock Text="{Binding LastUpdatedSummary}"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Right"
                               Foreground="#D6E3FF"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,18,0,18">
            <materialDesign:Card Margin="8" Background="{StaticResource BrandMidnightBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding TotalBeneficiaries, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="TOTAL BENEFICIARIES" Foreground="#A5B4FC" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="8" Background="{StaticResource BrandYellowBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding LinkedCivilRegistryCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="{StaticResource BrandGoldTextBrush}"/>
                    <TextBlock Text="CIVIL REGISTRY LINKED" Foreground="#7A5A00" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="8" Background="{StaticResource BrandSuccessBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding SeniorCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="SENIOR CITIZENS" Foreground="#CFECD8" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="8" Background="#0F766E" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding PwdCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="PERSONS WITH DISABILITY" Foreground="#CCFBF1" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Padding="16" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="Validated Beneficiary Registry"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <ComboBox Width="180"
                                      Margin="0,0,12,0"
                                      ItemsSource="{Binding QuickFilters}"
                                      SelectedItem="{Binding SelectedQuickFilter}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                            <TextBox Width="280"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Search name, beneficiary ID, address..."/>
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,0,0,14"
                               FontWeight="SemiBold"
                               Foreground="{Binding StatusBrush}"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"/>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Beneficiaries}"
                              SelectedItem="{Binding SelectedBeneficiary}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Beneficiary ID" Binding="{Binding BeneficiaryId}" Width="170"/>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding DisplayName}" Width="*"/>
                            <DataGridTextColumn Header="Civil Registry" Binding="{Binding CivilRegistryId}" Width="150"/>
                            <DataGridTextColumn Header="Sex" Binding="{Binding Sex}" Width="Auto"/>
                            <DataGridTextColumn Header="Age" Binding="{Binding Age}" Width="Auto"/>
                            <DataGridTextColumn Header="Flags" Binding="{Binding FlagsSummary}" Width="140"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <TextBlock Margin="0,0,10,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       Text="Rows per page"/>
                            <ComboBox Width="100"
                                      ItemsSource="{Binding PageSizeOptions}"
                                      SelectedItem="{Binding SelectedPageSize}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </StackPanel>

                        <Grid Grid.Column="2" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       Text="{Binding PageSummary}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="1"
                                       Margin="14,0,0,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}"
                                       Text="{Binding PageIndicator}"/>
                        </Grid>

                        <StackPanel Grid.Column="4"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Width="110"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    Command="{Binding PreviousPageCommand}"
                                    Content="PREVIOUS"
                                    Style="{StaticResource SecondaryActionButton}"/>
                            <Button Width="90"
                                    Height="36"
                                    Command="{Binding NextPageCommand}"
                                    Content="NEXT"
                                    Style="{StaticResource GoldActionButton}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2" Padding="16" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Beneficiary Profile"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}"/>

                    <Border Grid.Row="1"
                            Margin="0,12,0,14"
                            Padding="16"
                            CornerRadius="10"
                            Background="#EEF4FF"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedBeneficiary.DisplayName, TargetNullValue=Select a beneficiary}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedBeneficiary.BeneficiaryId, StringFormat='Beneficiary ID: {0}', TargetNullValue=Beneficiary ID: --}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>

                            <WrapPanel Margin="0,12,0,0">
                                <Border Margin="0,0,8,8"
                                        Padding="10,6"
                                        CornerRadius="12"
                                        Background="#DBEAFE">
                                    <TextBlock Text="{Binding SelectedBeneficiary.CivilRegistryStatus, TargetNullValue=No civil registry link}"
                                               Foreground="#1D4ED8"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <Border Margin="0,0,8,8"
                                        Padding="10,6"
                                        CornerRadius="12"
                                        Background="#DCFCE7">
                                    <TextBlock Text="{Binding SelectedBeneficiary.FlagsSummary, TargetNullValue=Standard}"
                                               Foreground="#166534"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Civil Registry ID" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedBeneficiary.CivilRegistryId, TargetNullValue=--}" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Address" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedBeneficiary.Address, TargetNullValue=--}" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Sex / Age" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedBeneficiary.SexAgeSummary, TargetNullValue=--}" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Date of Birth" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedBeneficiary.DateOfBirth, TargetNullValue=--}" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Marital Status" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedBeneficiary.MaritalStatus, TargetNullValue=--}" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="PWD ID" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedBeneficiary.PwdIdNo, TargetNullValue=--}" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Senior ID" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedBeneficiary.SeniorIdNo, TargetNullValue=--}" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Disability Type" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedBeneficiary.DisabilityType, TargetNullValue=--}" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Cause" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedBeneficiary.CauseOfDisability, TargetNullValue=--}" TextWrapping="Wrap"/>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Updated" FontWeight="SemiBold" Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedBeneficiary.UpdatedAtDisplay, TargetNullValue=--}" TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
