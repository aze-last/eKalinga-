<UserControl x:Class="AttendanceShiftingManagement.Views.MasterListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AttendanceShiftingManagement.Views"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="900" d:DesignWidth="1440"
             Background="{DynamicResource BrandSurfaceBrush}">
    
    <UserControl.Resources>

        <Style x:Key="SidebarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource ThemePrimaryActionBrush}" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Typography.Capitals" Value="AllSmallCaps"/>
        </Style>

        <Style x:Key="DetailCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="25" ShadowDepth="4" Opacity="0.15" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Left rail: uniform icon-leading action buttons -->
        <Style x:Key="RailPrimaryButton" TargetType="Button" BasedOn="{StaticResource GoldActionButton}">
            <Setter Property="Height" Value="46" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="RailBrandButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="{DynamicResource ThemePrimaryActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemePrimaryActionBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Height" Value="46" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>

        <Style x:Key="RailButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="RailDivider" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="Margin" Value="0,4,0,18" />
        </Style>

        <!-- Right panel: segmented section switcher (INFO / ID / HOUSEHOLD) -->
        <Style x:Key="SectionToggleButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Chip" CornerRadius="8" Padding="0,9"
                                Background="Transparent">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon x:Name="Ico" Kind="{TemplateBinding Tag}" Width="16" Height="16"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"
                                                         Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource ThemePrimaryActionBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="Ico" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource ThemeCardSubtleBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Chip" Property="Background" Value="{DynamicResource ThemePrimaryActionBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header (Blue Theme Like Budget Module) -->
        <Border Grid.Row="0" Background="{DynamicResource ThemePrimaryActionBrush}" Padding="20,15" Panel.ZIndex="10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="AccountMultipleCheck" Width="32" Height="32" Foreground="White" VerticalAlignment="Center"/>
                    <StackPanel Margin="15,0,0,0">
                        <TextBlock Text="MASTERLIST &amp; REGISTRY" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Validate beneficiary records, manage staging applications, and issue Digital IDs." FontSize="12" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding ToggleSidebarCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Foreground="White" Width="150" Height="40" Padding="10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0">
                                <materialDesign:PackIcon.Style>
                                    <Style TargetType="materialDesign:PackIcon">
                                        <Setter Property="Kind" Value="MenuOpen"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                <Setter Property="Kind" Value="Menu"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </materialDesign:PackIcon.Style>
                            </materialDesign:PackIcon>
                            <TextBlock VerticalAlignment="Center" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="HIDE SIDEBAR"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                                <Setter Property="Text" Value="SHOW SIDEBAR"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.Effect>
                <BlurEffect Radius="0" x:Name="WorkspaceBlur"/>
            </Grid.Effect>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnyOverlayOpen}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="15" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(Grid.Effect).(BlurEffect.Radius)" To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding SidebarWidth, FallbackValue=320}" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="420" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar Navigation (Light Slate) -->
                <Border Grid.Column="0" Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="20,20,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="DASHBOARD"
                                    Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Height="46"/>
                            <Button Grid.Column="2" Command="{Binding RefreshCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Width="46" Height="46" Padding="0" ToolTip="Refresh lists">
                                <materialDesign:PackIcon Kind="Refresh" Width="22" Height="22"/>
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Border Padding="20,0,20,20">
                                <StackPanel>
                                    <TextBlock Text="DIGITAL ID &amp; TOOLS" Style="{StaticResource SidebarHeaderStyle}"/>
                                    <Button Command="{Binding OpenPcScannerCommand}" Style="{StaticResource RailBrandButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Cctv" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="SCAN VIA PC CAMERA" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding PrintDigitalIdCommand}" Style="{StaticResource RailButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="PrinterOutline" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="PRINT DIGITAL ID" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Command="{Binding UploadDigitalIdPhotoCommand}" Style="{StaticResource RailButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ImagePlusOutline" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock Text="UPLOAD PHOTO" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>

                        <!-- Mobile Scanner Status (Budget Style Footer) -->
                        <Border Grid.Row="2" Padding="20" Background="{DynamicResource ThemeCardBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                            <StackPanel>
                                <TextBlock Text="MOBILE GATEWAY" Style="{StaticResource SidebarHeaderStyle}"/>
                                <materialDesign:Card Padding="12" Background="{DynamicResource BrandMidnightBrush}" UniformCornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="White" Padding="4" CornerRadius="4">
                                            <Image Source="{Binding LookupScannerQrImage}" Height="60" Width="60" Stretch="Uniform"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Foreground="White" FontWeight="Bold" FontSize="14">
                                                <Run Text="PIN:"/><Run Text="{Binding LookupScannerSessionPin}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding LookupScannerSessionExpiresAtText}" Foreground="#94A3B8" FontSize="10"/>
                                        </StackPanel>
                                    </Grid>
                                </materialDesign:Card>
                                <Button Content="CREATE SESSION" Command="{Binding CreateLookupScannerSessionCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{DynamicResource ThemePrimaryActionBrush}" Height="30" Margin="0,8,0,0" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Center Content: Registry (Budget Style) -->
                <Grid Grid.Column="1" Background="Transparent" Margin="30">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.RowSpan="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Permanent Metric Cards Row -->
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <materialDesign:Card Grid.Column="0" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="PENDING STAGING" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding TotalPendingBeneficiaries, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                    </StackPanel>
                                </materialDesign:Card>

                                <materialDesign:Card Grid.Column="2" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="APPROVED REGISTRY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding TotalApprovedBeneficiaries, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandSuccessBrush}"/>
                                    </StackPanel>
                                </materialDesign:Card>

                                <materialDesign:Card Grid.Column="4" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="PWD COUNT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding PwdCount, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                    </StackPanel>
                                </materialDesign:Card>

                                <materialDesign:Card Grid.Column="6" Padding="15">
                                    <StackPanel>
                                        <TextBlock Text="SENIOR COUNT" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding SeniorCount, StringFormat=N0}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                    </StackPanel>
                                </materialDesign:Card>
                            </Grid>

                            <!-- Clean Registry Browser -->
                            <materialDesign:Card Padding="24" Margin="0,0,0,30">
                                <StackPanel>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal">
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                                <TextBlock Text="BENEFICIARY REGISTRY" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}" Typography.Capitals="AllSmallCaps" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding SnapshotSourceSummary}" Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                            </StackPanel>

                                            <!-- Search & Filter Area -->
                                            <Border Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="8" Padding="12,4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Magnify" Foreground="{DynamicResource BrandTextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" materialDesign:HintAssist.Hint="Search registry..." Width="250" BorderThickness="0" Background="Transparent"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Registry Tabs (Pending vs Approved) -->
                                    <TabControl materialDesign:ColorZoneAssist.Mode="Standard" BorderThickness="0" Background="Transparent">
                                        <TabItem Header="PENDING STAGING" FontSize="12" FontWeight="Bold">
                                            <StackPanel Margin="0,20,0,0">
                                                <DataGrid ItemsSource="{Binding PendingBeneficiaries}"
                                                          SelectedItem="{Binding SelectedPendingBeneficiary}"
                                                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MinHeight="450"
                                                          Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                                                          materialDesign:DataGridAssist.CellPadding="12,8">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="FULL NAME" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                                                        <DataGridTextColumn Header="BENEFICIARY ID" Binding="{Binding BeneficiaryId}" Width="150"/>
                                                        <DataGridTextColumn Header="STATUS" Binding="{Binding VerificationStatus}" Width="120"/>
                                                        <DataGridTextColumn Header="AGE" Binding="{Binding Age}" Width="60"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                                <!-- Pagination Pending -->
                                                <Border Margin="0,20,0,0" Padding="0,15,0,0" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                                                    <Grid>
                                                        <TextBlock Text="{Binding PendingPageSummary}" VerticalAlignment="Center" Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <Button Command="{Binding PreviousPendingPageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0">
                                                                <materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24"/>
                                                            </Button>
                                                            <TextBlock Text="{Binding PendingCurrentPage}" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                            <Button Command="{Binding NextPendingPageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0">
                                                                <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem Header="APPROVED REGISTRY" FontSize="12" FontWeight="Bold">
                                            <StackPanel Margin="0,20,0,0">
                                                <DataGrid x:Name="ApprovedDataGrid" ItemsSource="{Binding ApprovedBeneficiaries}"
                                                          SelectedItem="{Binding SelectedApprovedBeneficiary}"
                                                          SelectionMode="Extended"
                                                          AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" MinHeight="450"
                                                          Background="Transparent" BorderThickness="0" HeadersVisibility="Column"
                                                          materialDesign:DataGridAssist.CellPadding="12,8">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="FULL NAME" Binding="{Binding FullName}" Width="*" FontWeight="SemiBold"/>
                                                        <DataGridTextColumn Header="BENEFICIARY ID" Binding="{Binding BeneficiaryId}" Width="150"/>
                                                        <DataGridTextColumn Header="CIVIL REGISTRY #" Binding="{Binding CivilRegistryId}" Width="150"/>
                                                        <DataGridTextColumn Header="STATUS" Binding="{Binding VerificationStatus}" Width="120"/>
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                                <!-- Pagination Approved -->
                                                <Border Margin="0,20,0,0" Padding="0,15,0,0" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                                                    <Grid>
                                                        <TextBlock Text="{Binding ApprovedPageSummary}" VerticalAlignment="Center" Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12"/>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                            <Button Command="{Binding PreviousApprovedPageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0">
                                                                <materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24"/>
                                                            </Button>
                                                            <TextBlock Text="{Binding ApprovedCurrentPage}" VerticalAlignment="Center" Margin="15,0" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                            <Button Command="{Binding NextApprovedPageCommand}" Style="{StaticResource MaterialDesignFlatButton}" Width="40" Height="40" Padding="0">
                                                                <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </TabItem>
                                    </TabControl>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Right Column: Profile Card + Quick Actions -->
                <Border Grid.Column="2" Background="{DynamicResource ThemeCardBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Panel Header -->
                        <Border Grid.Row="0" Padding="24,18" Background="{DynamicResource ThemePrimaryActionBrush}">
                            <StackPanel>
                                <TextBlock Text="BENEFICIARY PROFILE" FontSize="12" FontWeight="Bold" Foreground="#CCFFFFFF" Typography.Capitals="AllSmallCaps" Margin="0,0,0,2"/>
                                <TextBlock Text="{Binding SelectedBeneficiary.DisplayName, FallbackValue='Select a record'}" FontSize="20" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Empty state: no selection -->
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24"
                                    Visibility="{Binding SelectedBeneficiary, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}">
                            <materialDesign:PackIcon Kind="AccountSearchOutline" Width="56" Height="56" HorizontalAlignment="Center" Foreground="{DynamicResource BrandBorderBrush}"/>
                            <TextBlock Text="Select a beneficiary from the registry to view their profile." FontSize="13" TextWrapping="Wrap" TextAlignment="Center" Margin="0,14,0,0" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                        </StackPanel>

                        <!-- Profile Card + Quick Actions -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24"
                                      Visibility="{Binding SelectedBeneficiary, Converter={StaticResource NullToHiddenConverter}}">
                            <StackPanel>
                                <!-- Profile Card -->
                                <Border Style="{StaticResource DetailCardStyle}" Margin="0,0,0,20">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="110" Height="110" CornerRadius="55" Background="{DynamicResource ThemeCardSubtleBrush}" Margin="0,0,0,14">
                                            <Ellipse Width="110" Height="110">
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{Binding DigitalIdPhotoImage}" Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Border>

                                        <TextBlock Text="{Binding SelectedBeneficiary.DisplayName}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" TextAlignment="Center" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedBeneficiary.SexAgeSummary}" FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextAlignment="Center" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding SelectedBeneficiary.Address}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                        <TextBlock Text="{Binding SelectedBeneficiary.FlagsSummary}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}" TextAlignment="Center" Margin="0,6,0,0"/>

                                        <Border CornerRadius="12" Padding="14,5" Margin="0,12,0,0" HorizontalAlignment="Center" Background="{DynamicResource ThemeCardSubtleBrush}">
                                            <TextBlock Text="{Binding SelectedBeneficiary.VerificationStatusLabel}" FontWeight="Bold" FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding SelectedBeneficiary.IsApproved}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource BrandSuccessBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Quick Actions -->
                                <TextBlock Text="QUICK ACTIONS" Style="{StaticResource SidebarHeaderStyle}"/>
                                <Button Command="{Binding OpenFullProfileCommand}" Style="{StaticResource RailBrandButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountDetails" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="VIEW FULL PROFILE" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ApproveCommand}" Style="{StaticResource RailPrimaryButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CheckDecagram" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="APPROVE &amp; ISSUE ID" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding RejectCommand}" Style="{StaticResource RailButton}" Foreground="{DynamicResource BrandRedBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="CloseCircleOutline" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="REJECT RECORD" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding ReturnToPendingCommand}" Style="{StaticResource RailButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Undo" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="RETURN TO PENDING" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding OpenEnrollmentPanelCommand}" Style="{StaticResource RailButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountArrowRight" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="ENROLL IN PROJECT" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding PrintDigitalIdCommand}" Style="{StaticResource RailButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="PrinterOutline" Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="PRINT DIGITAL ID" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer Status -->
                        <Border Grid.Row="2" Padding="20" Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="0,1,0,0">
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontSize="11" TextAlignment="Center" TextWrapping="Wrap" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Backdrop for Overlays -->
        <Border Grid.RowSpan="2" Background="#CC0F172A" Visibility="{Binding IsAnyOverlayOpen, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="100"/>

        <!-- PC Scanner Overlay -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="120" Visibility="{Binding IsPcScannerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <local:DesktopScannerOverlay QrCodeScanned="Scanner_QrCodeScanned"
                                       Closed="Scanner_Closed"/>
        </Grid>

        <!-- Enrollment Overlay -->
        <Border Grid.RowSpan="2" Panel.ZIndex="130" Background="#CC0F172A" Visibility="{Binding IsEnrollmentPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <materialDesign:Card Width="500" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource ThemePrimaryActionBrush}" Padding="20,15">
                        <TextBlock Text="ENROLL IN PROJECT" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="25">
                        <TextBlock Text="SELECT TARGET PROJECT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}" Margin="0,0,0,15"/>
                        <ComboBox materialDesign:HintAssist.Hint="Active Projects" 
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  ItemsSource="{Binding ActiveProjects}"
                                  SelectedItem="{Binding SelectedProjectToEnroll}"
                                  DisplayMemberPath="ProgramName"
                                  Margin="0,0,0,20"/>
                        
                        <TextBlock Text="The selected approved beneficiaries will be added to this project's distribution list." 
                                   FontSize="12" TextWrapping="Wrap" Foreground="#64748B"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20">
                        <Button Content="CANCEL" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding CloseEnrollmentPanelCommand}" Margin="0,0,10,0" Foreground="#64748B"/>
                        <Button Content="CONFIRM ENROLLMENT" 
                                Command="{Binding ConfirmEnrollmentCommand}" 
                                CommandParameter="{Binding ElementName=ApprovedDataGrid, Path=SelectedItems}"
                                Style="{StaticResource MaterialDesignRaisedButton}" 
                                Background="{DynamicResource BrandYellowBrush}" BorderBrush="{DynamicResource BrandYellowBrush}" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Border>

        <!-- Full-Screen In-Page Profile Overlay (Gmail-style) -->
        <Border Grid.RowSpan="2" Panel.ZIndex="140" Background="{DynamicResource BrandSurfaceBrush}"
                Visibility="{Binding IsFullProfileOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Overlay Header with Back -->
                <Border Grid.Row="0" Background="{DynamicResource ThemePrimaryActionBrush}" Padding="20,14">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Command="{Binding CloseFullProfileCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="White" Height="40" Padding="10,0">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ArrowLeft" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="BACK" VerticalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                            <Border Width="1" Background="#33FFFFFF" Margin="12,4"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedBeneficiary.DisplayName, FallbackValue='Beneficiary'}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Full profile, household, documents, and aid history." FontSize="12" Foreground="#CCFFFFFF"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Overlay Body -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30">
                    <Grid MaxWidth="1100" HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="380"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: General Information + Household -->
                        <StackPanel Grid.Column="0">
                            <!-- General Information -->
                            <Border Style="{StaticResource DetailCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="GENERAL INFORMATION" Style="{StaticResource SidebarHeaderStyle}"/>
                                    <UniformGrid Columns="3" Margin="0,4,0,16">
                                        <TextBox Text="{Binding EditableFirstName, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="First Name"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,6,0"/>
                                        <TextBox Text="{Binding EditableMiddleName, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Middle Name"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="6,0,6,0"/>
                                        <TextBox Text="{Binding EditableLastName, UpdateSourceTrigger=PropertyChanged}"
                                                 materialDesign:HintAssist.Hint="Last Name"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="6,0,0,0"/>
                                    </UniformGrid>
                                    <TextBox Text="{Binding EditableAddress, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Permanent Address"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Margin="0,0,0,16"/>
                                    <TextBlock Text="INTERNAL REVIEW NOTES" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,10"/>
                                    <TextBox Text="{Binding EditableReviewNotes, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="Explain rejection or update reason..."
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="90" Margin="0,0,0,18"/>
                                    <Button Content="SAVE CORRECTIONS" Command="{Binding SaveCorrectionsCommand}" Style="{StaticResource GoldActionButton}" Height="46"/>
                                </StackPanel>
                            </Border>

                            <!-- Household (read-only) -->
                            <Border Style="{StaticResource DetailCardStyle}">
                                <StackPanel>
                                    <Label Content="HOUSEHOLD" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource ThemePrimaryActionBrush}" Padding="0" Margin="0,0,0,12"/>

                                    <!-- Empty state -->
                                    <StackPanel HorizontalAlignment="Center" Margin="0,20,0,10"
                                                Visibility="{Binding HasHouseholdContext, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <materialDesign:PackIcon Kind="HomeOffOutline" Width="40" Height="40" HorizontalAlignment="Center" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="No household linked to this beneficiary." FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,0" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- Household summary + roster -->
                                    <StackPanel Visibility="{Binding HasHouseholdContext, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid Margin="0,4,0,16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Household Code" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding HouseholdCode}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Head of Household" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding HouseholdHeadName}" FontSize="13" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="Address / Purok" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding HouseholdAddressSummary}" FontSize="13" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                        <TextBlock Text="HOUSEHOLD MEMBERS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding SelectedHouseholdMembers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="6" Padding="12,8" Margin="0,0,0,6" Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding FullName}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                                                                <materialDesign:PackIcon Kind="AccountCheck" Width="14" Height="14" Margin="6,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource BrandSuccessBrush}" ToolTip="Selected beneficiary"
                                                                                         Visibility="{Binding IsSelectedBeneficiary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding RelationshipToHead}" FontSize="10" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Right: Documents / Digital ID + History -->
                        <StackPanel Grid.Column="2">
                            <!-- Digital ID -->
                            <Border Style="{StaticResource DetailCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="DOCUMENTS &amp; DIGITAL ID" Style="{StaticResource SidebarHeaderStyle}"/>
                                    <Border Width="150" Height="150" HorizontalAlignment="Center" CornerRadius="12" Background="{DynamicResource ThemeCardSubtleBrush}" ClipToBounds="True" Margin="0,4,0,14">
                                        <Grid>
                                            <materialDesign:PackIcon Kind="Account" Width="56" Height="56" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Image Source="{Binding DigitalIdPhotoImage}" Stretch="UniformToFill"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding DigitalIdCardNumber}" FontSize="16" FontWeight="ExtraBold" Foreground="{DynamicResource BrandMidnightBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding DigitalIdIssuedAtText}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>

                                    <materialDesign:Card Background="White" Padding="10" Margin="0,14,0,14" HorizontalAlignment="Center"
                                                         Visibility="{Binding DigitalIdQrImage, Converter={StaticResource NullToHiddenConverter}}">
                                        <Image Source="{Binding DigitalIdQrImage}" Height="140" Width="140" Stretch="Uniform"/>
                                    </materialDesign:Card>

                                    <Button Content="UPLOAD PHOTO" Command="{Binding UploadDigitalIdPhotoCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="38" Margin="0,0,0,8"/>
                                    <Button Content="CROP / REPOSITION" Command="{Binding CropDigitalIdPhotoCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" Height="38" Margin="0,0,0,8"/>
                                    <Button Content="PRINT DIGITAL ID" Command="{Binding PrintDigitalIdCommand}" Style="{StaticResource GoldActionButton}" Height="42"/>
                                </StackPanel>
                            </Border>

                            <!-- History -->
                            <Border Style="{StaticResource DetailCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="AID HISTORY" Style="{StaticResource SidebarHeaderStyle}"/>
                                    <Grid MinHeight="120">
                                        <ListBox ItemsSource="{Binding SelectedBeneficiaryHistory}"
                                                 Background="Transparent" BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="14" Margin="0,0,0,10" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding ReleaseDate, StringFormat='{}{0:MMMM dd, yyyy}'}" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                                <TextBlock Text="{Binding Remarks}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding SourceModule}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandGoldTextBrush}" Margin="0,6,0,0"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat='PHP {0:N2}'}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource BrandSuccessBrush}" VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <ProgressBar IsIndeterminate="True" Width="40" Height="40"
                                                     Visibility="{Binding IsHistoryLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                     Style="{StaticResource MaterialDesignCircularProgressBar}"/>

                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="{Binding HistoryEmptyStateVisibility}">
                                            <materialDesign:PackIcon Kind="History" Width="48" Height="48" Foreground="{DynamicResource BrandBorderBrush}" HorizontalAlignment="Center"/>
                                            <TextBlock Text="No aid history found" Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="12" Margin="0,10,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
