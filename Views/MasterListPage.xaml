<UserControl x:Class="AttendanceShiftingManagement.Views.MasterListPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             Background="{DynamicResource BrandSurfaceBrush}"
             Loaded="MasterListPage_Loaded">

    <UserControl.Resources>
        <helpers:NullToHiddenConverter x:Key="NullToHiddenConverter" />
        
        <Style x:Key="PatternBGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="RowHeight" Value="52"/>
        </Style>

        <Style x:Key="TableChipStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Pattern B Header -->
        <materialDesign:Card Grid.Row="0" Padding="12,8" Background="{DynamicResource ThemeCardBrush}" UniformCornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Title -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="8,0">
                    <TextBlock Text="Masterlist Management" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                    <TextBlock Text="Validate staging records and manage the approved registry." FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                </StackPanel>

                <!-- Center: Stats Card -->
                <materialDesign:Card Grid.Column="1" Padding="16,8" Background="{DynamicResource ThemeCardSubtleBrush}" UniformCornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Margin="0,0,24,0">
                            <TextBlock Text="PENDING" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding PendingBeneficiaries.Count, StringFormat=N0}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource ThemeWarningForegroundBrush}"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="APPROVED" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding TotalBeneficiaries, StringFormat=N0}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrandSuccessBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Right: Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="FILTER / SEARCH" 
                            Style="{StaticResource SecondaryActionButton}" 
                            Height="40" 
                            Padding="16,0"
                            Click="Filter_Click"
                            Margin="0,0,8,0"/>
                    <Button Content="DASHBOARD" 
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Height="40"
                            Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Pattern B Three-Column Workspace -->
        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="56"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Pending/Staging DataGrid -->
            <Border Grid.Column="0" Background="{DynamicResource ThemeCardBrush}" CornerRadius="16" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Padding="16" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BrandBorderBrush}" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="16,16,0,0">
                        <TextBlock Text="STAGING / PENDING" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding PendingBeneficiaries}" SelectedItem="{Binding SelectedPendingBeneficiary}" Style="{StaticResource PatternBGridStyle}" MouseDoubleClick="Grid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Staging ID" Binding="{Binding ResidentsId}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Padding="16" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BrandBorderBrush}">
                        <TextBlock Text="{Binding PendingBeneficiaries.Count, StringFormat='{}{0} Records'}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}" HorizontalAlignment="Right"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Center: Action Column -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button Command="{Binding ApproveCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Approve Selected"
                        Foreground="{DynamicResource BrandSuccessBrush}"
                        Width="44" Height="44">
                    <materialDesign:PackIcon Kind="CheckCircle" Width="24" Height="24"/>
                </Button>
                <Button Command="{Binding RejectCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Reject Selected"
                        Foreground="#B91C1C"
                        Width="44" Height="44" Margin="0,12,0,0">
                    <materialDesign:PackIcon Kind="CloseCircle" Width="24" Height="24"/>
                </Button>
                <Button Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Refresh Lists"
                        Foreground="{DynamicResource BrandMidnightBrush}"
                        Width="44" Height="44" Margin="0,12,0,0">
                    <materialDesign:PackIcon Kind="Refresh" Width="24" Height="24"/>
                </Button>
            </StackPanel>

            <!-- Right: Approved/Registry DataGrid -->
            <Border Grid.Column="2" Background="{DynamicResource ThemeCardBrush}" CornerRadius="16" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Padding="16" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BrandBorderBrush}" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="16,16,0,0">
                        <TextBlock Text="APPROVED REGISTRY" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                    </Border>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ApprovedBeneficiaries}" SelectedItem="{Binding SelectedApprovedBeneficiary}" Style="{StaticResource PatternBGridStyle}" MouseDoubleClick="Grid_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Beneficiary ID" Binding="{Binding BeneficiaryId}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Padding="16" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BrandBorderBrush}">
                        <Grid>
                            <TextBlock Text="{Binding TotalBeneficiaries, StringFormat='{}{0} Total Validated'}" FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding PreviousPageCommand}" Padding="4" Width="28" Height="28">
                                    <materialDesign:PackIcon Kind="ChevronLeft" Width="18" Height="18"/>
                                </Button>
                                <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" Margin="8,0" FontSize="11" FontWeight="Bold"/>
                                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NextPageCommand}" Padding="4" Width="28" Height="28">
                                    <materialDesign:PackIcon Kind="ChevronRight" Width="18" Height="18"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
