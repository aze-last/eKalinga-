<Window x:Class="AttendanceShiftingManagement.Views.CashForWorkAttendanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Edit Attendance"
        Width="520"
        Height="520"
        MinWidth="520"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="5"
                            GlassFrameThickness="0"
                            CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="WindowControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource BrandTextSecondaryBrush}"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="0"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        </Style>

        <Style x:Key="WindowCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EF4444"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BrandSurfaceBrush}"
            CornerRadius="16"
            BorderBrush="{StaticResource BrandBorderBrush}"
            BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Panel.ZIndex="99"
                        Margin="0,-24,-24,0">
                <Button Style="{StaticResource WindowControlButtonStyle}"
                        Click="Minimize_Click"
                        ToolTip="Minimize">
                    <materialDesign:PackIcon Kind="WindowMinimize"
                                             Width="18"
                                             Height="18"/>
                </Button>
                <Button Style="{StaticResource WindowCloseButtonStyle}"
                        Click="Close_Click"
                        ToolTip="Close">
                    <materialDesign:PackIcon Kind="Close"
                                             Width="20"
                                             Height="20"/>
                </Button>
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Edit Attendance"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource BrandMidnightBrush}"/>
                <TextBlock Text="Update the attendance date, status, and capture source for the selected participant."
                           Margin="0,8,0,0"
                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                           TextWrapping="Wrap"/>

                <Border Margin="0,24,0,0"
                        Padding="16"
                        CornerRadius="12"
                        Background="#F8FAFC"
                        BorderBrush="{StaticResource BrandBorderBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock x:Name="ParticipantNameTextBlock"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="BeneficiaryIdTextBlock"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                        <TextBlock x:Name="CivilRegistryIdTextBlock"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <DatePicker x:Name="AttendanceDatePicker"
                            Margin="0,18,0,0"
                            materialDesign:HintAssist.Hint="Attendance date"/>

                <ComboBox x:Name="StatusComboBox"
                          Margin="0,14,0,0"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          materialDesign:HintAssist.Hint="Attendance status"/>

                <ComboBox x:Name="SourceComboBox"
                          Margin="0,14,0,0"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          materialDesign:HintAssist.Hint="Capture source"/>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Margin="0,18,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="CANCEL"
                        Margin="0,0,10,0"
                        Style="{StaticResource SecondaryActionButton}"
                        Click="Cancel_Click"/>
                <Button Content="SAVE CHANGES"
                        Style="{StaticResource GoldActionButton}"
                        Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
