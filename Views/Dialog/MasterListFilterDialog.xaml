<Window x:Class="AttendanceShiftingManagement.Views.Dialog.MasterListFilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Filter Masterlist" 
        Width="400" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BrandSurfaceBrush}">
    
    <Window.Resources>
        <Style x:Key="FilterChipStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ChipBorder"
                                Background="{DynamicResource ThemeInputSurfaceBrush}"
                                BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="14,6"
                                Margin="0,0,0,8">
                            <TextBlock x:Name="ChipText"
                                       Text="{TemplateBinding Content}"
                                       Foreground="{DynamicResource BrandMidnightBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChipBorder" Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}"/>
                                <Setter TargetName="ChipText" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Search &amp; Filters" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
            <TextBlock Text="Refine the beneficiary registry view." FontSize="13" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="SEARCH" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Name, ID, or Address..."
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         Height="50" Margin="0,0,0,24"/>

                <TextBlock Text="REGISTRY STATUS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                <ItemsControl ItemsSource="{Binding FilterOptions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ToggleButton Content="{Binding Label}"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Style="{StaticResource FilterChipStyle}"
                                          Height="40"
                                          Margin="0,0,0,8"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Separator Margin="0,16" Background="{DynamicResource BrandBorderBrush}"/>

                <TextBlock Text="MOBILE SCANNER" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                <materialDesign:Card Padding="12" Background="{DynamicResource ThemeCardSubtleBrush}" UniformCornerRadius="12">
                    <Grid MinHeight="100">
                        <Button Content="CREATE LOOKUP SESSION"
                                Command="{Binding CreateLookupScannerSessionCommand}"
                                Style="{StaticResource GoldActionButton}"
                                Height="36" FontSize="11"
                                Visibility="{Binding LookupScannerSessionUrl, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}"/>

                        <StackPanel Visibility="{Binding LookupScannerSessionUrl, Converter={StaticResource NullToHiddenConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="White" Padding="4" CornerRadius="6" Grid.Column="0">
                                    <Image Source="{Binding LookupScannerQrImage}" Height="80" Width="80"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="PIN" FontSize="9" Foreground="{DynamicResource BrandTextSecondaryBrush}" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding LookupScannerSessionPin}" FontSize="18" Foreground="{DynamicResource BrandMidnightBrush}" FontWeight="ExtraBold" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
            <Button Content="CLOSE" Style="{StaticResource MaterialDesignFlatButton}" IsCancel="True" Click="Close_Click"/>
            <Button Content="APPLY FILTERS" Style="{StaticResource GoldActionButton}" Height="44" Padding="24,0" Click="Apply_Click" Margin="12,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
