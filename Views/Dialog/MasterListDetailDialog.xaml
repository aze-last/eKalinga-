<Window x:Class="AttendanceShiftingManagement.Views.Dialog.MasterListDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
        Title="Beneficiary Details"
        Height="800" Width="600"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="0"
                            GlassFrameThickness="0" CornerRadius="0"/> 
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <helpers:NullToHiddenConverter x:Key="NullToHiddenConverter" />
    </Window.Resources>

    <Border Background="{DynamicResource ThemeCardBrush}" CornerRadius="20"
            BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header Section -->
                <RowDefinition Height="*"/>    <!-- Content Tabs -->
                <RowDefinition Height="Auto"/> <!-- Footer Actions -->
            </Grid.RowDefinitions>

            <!-- Close button -->
            <Button Grid.Row="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,8,8,0"
                    Width="36" Height="36"
                    Style="{StaticResource MaterialDesignFlatButton}"  
                    shell:WindowChrome.IsHitTestVisibleInChrome="True" 
                    Click="Close_Click"
                    Panel.ZIndex="1">
                <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
            </Button>

            <!-- Header Section -->
            <Border Grid.Row="0" Padding="24" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="20,20,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>       
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse Grid.Column="0" Width="72" Height="72" Fill="{DynamicResource BrandMidnightBrush}"/>
                    <TextBlock Grid.Column="0"
                               Text="{Binding SelectedBeneficiary.Initials, TargetNullValue=--}"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"    
                               VerticalAlignment="Center"/>    

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedBeneficiary.DisplayName, TargetNullValue=Select a beneficiary}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource BrandMidnightBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SelectedBeneficiary.VerificationStatusLabel}"
                                   FontSize="12"
                                   FontWeight="ExtraBold"      
                                   Margin="0,4,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock"> 
                                    <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedBeneficiary.IsApproved}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource BrandSuccessBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SelectedBeneficiary.IsPending}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource ThemeWarningForegroundBrush}"/>     
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content Tabs -->
            <TabControl Grid.Row="1" Style="{StaticResource MaterialDesignNavigationRailTabControl}" Foreground="{DynamicResource BrandMidnightBrush}">
                <TabItem Width="150">
                    <TabItem.Header>
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="AccountEdit" Width="24" Height="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="EDIT" FontSize="11" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel>
                            <TextBlock Text="CREDENTIAL CORRECTIONS" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,20"/>

                            <UniformGrid Columns="3" Margin="0,0,0,16">
                                <TextBox Text="{Binding EditableFirstName, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="First Name"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Foreground="{DynamicResource BrandMidnightBrush}"
                                         Background="{DynamicResource ThemeInputSurfaceBrush}"
                                         BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                         Margin="0,0,6,0"/>    

                                <TextBox Text="{Binding EditableMiddleName, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Middle Name"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Foreground="{DynamicResource BrandMidnightBrush}"
                                         Background="{DynamicResource ThemeInputSurfaceBrush}"
                                         BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                         Margin="6,0,6,0"/>    

                                <TextBox Text="{Binding EditableLastName, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Last Name"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Foreground="{DynamicResource BrandMidnightBrush}"
                                         Background="{DynamicResource ThemeInputSurfaceBrush}"
                                         BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                         Margin="6,0,0,0"/>    
                            </UniformGrid>

                            <TextBox Text="{Binding EditableAddress, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Permanent Address"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Foreground="{DynamicResource BrandMidnightBrush}"
                                     Background="{DynamicResource ThemeInputSurfaceBrush}"
                                     BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                     TextWrapping="Wrap"       
                                     AcceptsReturn="True"      
                                     MinHeight="100"
                                     Margin="0,0,0,24"/>       

                            <TextBlock Text="INTERNAL REVIEW NOTES" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,16"/>
                            <TextBox Text="{Binding EditableReviewNotes, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Explain rejection or update reason..."
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Foreground="{DynamicResource BrandMidnightBrush}"
                                     Background="{DynamicResource ThemeInputSurfaceBrush}"
                                     BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                     TextWrapping="Wrap"       
                                     AcceptsReturn="True"      
                                     MinHeight="100"
                                     Margin="0,0,0,24"/>       

                            <Button Content="SAVE CORRECTIONS" 
                                    Command="{Binding SaveCorrectionsCommand}"
                                    Style="{StaticResource SecondaryActionButton}"
                                    Height="50"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Width="150">
                    <TabItem.Header>
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="BadgeAccountHorizontal" Width="24" Height="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="DIGITAL ID" FontSize="11" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel>
                            <TextBlock Text="DIGITAL ID PREVIEW" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,20"/>

                            <materialDesign:Card Background="{DynamicResource ThemeCardSubtleBrush}" UniformCornerRadius="20" Padding="20" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>   
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>  

                                    <Button Grid.Column="0"    
                                            Width="120" Height="120"
                                            Padding="0"        
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            Command="{Binding UploadDigitalIdPhotoCommand}">
                                        <Border CornerRadius="16" Background="{DynamicResource ThemeInputSurfaceBrush}" ClipToBounds="True">
                                            <Grid>
                                                <materialDesign:PackIcon Kind="Account" Width="56" Height="56" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Image Source="{Binding DigitalIdPhotoImage}" Stretch="UniformToFill"/>

                                                <!-- Hover Overlay -->
                                                <Border x:Name="PhotoOverlay" Background="#99000000" Opacity="0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                                    <Setter Property="Opacity" Value="1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <materialDesign:PackIcon Kind="Camera" Foreground="White" Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Button>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DigitalIdCardNumber}" FontSize="18" FontWeight="ExtraBold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                        <TextBlock Text="{Binding DigitalIdIssuedAtText}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>        

                                        <Button Content="CHANGE PHOTO"
                                                Command="{Binding UploadDigitalIdPhotoCommand}"
                                                Style="{StaticResource MaterialDesignFlatButton}"
                                                Foreground="{DynamicResource BrandMidnightBrush}"
                                                Height="36"    
                                                FontSize="11"  
                                                Padding="0"    
                                                HorizontalAlignment="Left"
                                                Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </materialDesign:Card>

                            <Border Background="{DynamicResource ThemeInputSurfaceBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1" CornerRadius="20" Padding="24" Margin="0,0,0,24">
                                <StackPanel>
                                    <Image Source="{Binding DigitalIdQrImage}" Height="200" Width="200" Stretch="Uniform" HorizontalAlignment="Center"/>
                                    <TextBlock Text="SECURE QR PAYLOAD" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                                </StackPanel>
                            </Border>

                            <Button Content="CROP / REPOSITION PHOTO"
                                    Command="{Binding CropDigitalIdPhotoCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                    Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                    Height="40"
                                    FontSize="11"
                                    Margin="0,0,0,12"/>

                            <Button Content="PRINT DIGITAL ID CARD"
                                    Command="{Binding PrintDigitalIdCommand}"
                                    Style="{StaticResource GoldActionButton}"
                                    Height="50"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Width="150">
                    <TabItem.Header>
                        <StackPanel HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="History" Width="24" Height="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="HISTORY" FontSize="11" FontWeight="Bold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="24,20,24,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>        
                        </Grid.RowDefinitions>

                        <ListBox ItemsSource="{Binding SelectedBeneficiaryHistory}"
                                 Background="Transparent"      
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16" Margin="0,0,0,12" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>       
                                                <TextBlock Text="{Binding ReleaseDate, StringFormat='{}{0:MMMM dd, yyyy}'}" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                                                <TextBlock Text="{Binding Remarks}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding SourceModule}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandGoldTextBrush}" Margin="0,8,0,0"/>
                                            </StackPanel>      
                                            <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat='PHP {0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandSuccessBrush}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- History Loading Overlay -->       
                        <ProgressBar Grid.Row="0" IsIndeterminate="True" Width="48" Height="48"
                                     Visibility="{Binding IsHistoryLoading, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                     Style="{StaticResource MaterialDesignCircularProgressBar}"/>

                        <!-- History Empty State -->
                        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding HistoryEmptyStateVisibility}">
                            <materialDesign:PackIcon Kind="History" Width="56" Height="56" Foreground="{DynamicResource ThemeInputBorderBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="No aid history found" Foreground="{DynamicResource BrandTextSecondaryBrush}" FontSize="13" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>

            <!-- Footer Actions -->
            <Border Grid.Row="2" Padding="24" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="0,0,20,20">
                <StackPanel>
                    <UniformGrid Columns="2" Margin="0,0,0,16">
                        <Button Content="RETURN TO PENDING"    
                                Command="{Binding ReturnToPendingCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                Height="44"
                                FontSize="12"
                                Margin="0,0,8,0"/>
                        <Button Content="REJECT RECORD"        
                                Command="{Binding RejectCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                BorderBrush="#FCA5A5"
                                Foreground="#B91C1C"
                                Height="44"
                                FontSize="12"
                                Margin="8,0,0,0"/>
                    </UniformGrid>
                    <Button Content="APPROVE &amp; ISSUE DIGITAL ID"
                            Command="{Binding ApproveCommand}" 
                            Style="{StaticResource GoldActionButton}"
                            Height="56"
                            FontSize="16"
                            FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
