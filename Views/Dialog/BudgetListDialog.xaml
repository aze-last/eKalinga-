<Window x:Class="AttendanceShiftingManagement.Views.Dialog.BudgetListDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Browse Budget Records"
        Height="700" Width="1000"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Pilot theme shadow: overrides the app-level blue with brand green for this dialog only -->
        <SolidColorBrush x:Key="ThemePrimaryActionBrush" Color="#15803D" />

        <Style x:Key="RailButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryActionButton}">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,0" />
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="0"
                            GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border Background="{DynamicResource ThemeCardBrush}" CornerRadius="20"
            BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Close button -->
            <Button Grid.Row="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-8,-8,0"
                    Width="36" Height="36"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="Cancel_Click">
                <materialDesign:PackIcon Kind="Close" Width="18" Height="18" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
            </Button>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,40,0">
                <TextBlock Text="Browse Budget Records"
                           FontSize="24" FontWeight="SemiBold"
                           Foreground="{DynamicResource BrandMidnightBrush}"/>
                <TextBlock Text="Select a budget project or global cap to view or manage details."
                           FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Filters -->
            <Grid Grid.Row="1" Margin="0,20,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" 
                         materialDesign:HintAssist.Hint="Search records (Code, Name, Type...)"
                         Margin="0,0,12,0"/>
                
                <ComboBox Grid.Column="1" 
                          ItemsSource="{Binding TypeFilters}" 
                          SelectedItem="{Binding SelectedTypeFilter}" 
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" 
                          materialDesign:HintAssist.Hint="Filter by category"/>
            </Grid>

            <!-- DataGrid -->
            <materialDesign:Card Grid.Row="2" Padding="0" Background="Transparent" BorderThickness="1" BorderBrush="{DynamicResource BrandBorderBrush}" UniformCornerRadius="12">
                <DataGrid x:Name="BudgetDataGrid" 
                          ItemsSource="{Binding BudgetsView}" 
                          SelectedItem="{Binding SelectedBudget}" 
                          AutoGenerateColumns="False" 
                          CanUserAddRows="False" 
                          CanUserDeleteRows="False" 
                          IsReadOnly="True" 
                          HeadersVisibility="Column" 
                          GridLinesVisibility="Horizontal" 
                          RowHeaderWidth="0" 
                          BorderThickness="0"
                          Background="Transparent"
                          MouseDoubleClick="BudgetDataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="150"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="180"/>
                        <DataGridTextColumn Header="Budget Cap" Binding="{Binding BudgetCap, StringFormat='PHP {0:N2}'}" Width="160"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

            <!-- Footer / Actions -->
            <Grid Grid.Row="3" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="CANCEL"
                            Width="120" Height="44" Margin="0,0,12,0"
                            Style="{StaticResource SecondaryActionButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Cancel_Click"/>
                    <Button Content="SELECT RECORD"
                            Width="180" Height="44"
                            Style="{StaticResource GoldActionButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="Select_Click"
                            IsEnabled="{Binding SelectedBudget, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=NotNull}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
