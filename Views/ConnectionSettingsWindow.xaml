<Window x:Class="AttendanceShiftingManagement.Views.ConnectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Connection Settings"
        Width="760"
        Height="590"
        MinWidth="760"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BrandSurfaceBrush}">
    <Window.Resources>
        <Style x:Key="PresetButtonBaseStyle"
               TargetType="Button"
               BasedOn="{StaticResource SecondaryActionButton}">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="LocalPresetButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PresetButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLocalSelected}" Value="True">
                    <Setter Property="Background" Value="#26F9C231"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BrandYellowBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource BrandMidnightBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LanPresetButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PresetButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLanSelected}" Value="True">
                    <Setter Property="Background" Value="#26F9C231"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BrandYellowBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource BrandMidnightBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RemotePresetButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PresetButtonBaseStyle}">
            <Setter Property="Margin" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRemoteSelected}" Value="True">
                    <Setter Property="Background" Value="#26F9C231"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BrandYellowBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource BrandMidnightBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel Margin="24" LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Margin="0,18,0,0"
                Padding="0,18,0,0"
                BorderBrush="{StaticResource BrandBorderBrush}"
                BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                           Text="Save to apply the preset, then return to the login form."/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="CANCEL"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="TEST CONNECTION"
                            Command="{Binding TestConnectionCommand}"
                            Style="{StaticResource SecondaryActionButton}"
                            Margin="0,0,8,0"/>
                    <Button Content="SAVE AND CONTINUE"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryActionButton}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True"
                      PanningMode="VerticalOnly">
            <StackPanel>
                <StackPanel>
                    <TextBlock Text="Connection Settings"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}"/>
                    <TextBlock Text="Choose a preset or edit the fields manually before the login screen opens."
                               Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                </StackPanel>

                <StackPanel Margin="0,22,0,18">
                    <TextBlock Text="QUICK PRESETS"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandTextSecondaryBrush}"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Command="{Binding SelectLocalPresetCommand}"
                                Style="{StaticResource LocalPresetButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Laptop"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0"/>
                                <TextBlock Text="LOCAL" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1"
                                Command="{Binding SelectLanPresetCommand}"
                                Style="{StaticResource LanPresetButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="Web"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0"/>
                                <TextBlock Text="NETWORK (LAN)" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2"
                                Command="{Binding SelectRemotePresetCommand}"
                                Style="{StaticResource RemotePresetButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <materialDesign:PackIcon Kind="CloudOutline"
                                                         Width="18"
                                                         Height="18"
                                                         Margin="0,0,8,0"/>
                                <TextBlock Text="REMOTE (Hostinger)" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>

                <Border Background="#EAF2FF"
                        BorderBrush="{StaticResource BrandBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="20">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="{Binding CurrentPresetDisplayName}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Text="The selected preset is what EF Core and startup initialization will use."
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                            </StackPanel>

                            <Border DockPanel.Dock="Right"
                                    Padding="10,4"
                                    CornerRadius="20"
                                    Background="#26F9C231"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="ACTIVE PRESET"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandGoldTextBrush}"/>
                            </Border>
                        </DockPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Server"
                                           Margin="2,0,0,6"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Server, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Port"
                                           Margin="2,0,0,6"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Database Name"
                                       Margin="2,0,0,6"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Username"
                                           Margin="2,0,0,6"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Password"
                                           Margin="2,0,0,6"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <Border Padding="14"
                                Background="White"
                                BorderBrush="{StaticResource BrandBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="Connection usage"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Text="The selected preset is saved in your Windows user profile, so you can switch between local, LAN, and Hostinger without editing source files."
                                           Margin="0,6,0,0"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="2,16,2,0"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{Binding StatusBrush}"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
