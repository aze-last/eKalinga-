<UserControl x:Class="AttendanceShiftingManagement.Views.GrievanceCorrectionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="24"
                CornerRadius="18"
                Background="{StaticResource BrandMidnightBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Grievance / Corrections"
                               FontSize="26"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="Track duplicate, wrong identity, missing beneficiary, and wrong release complaints while showing beneficiary-linked assistance warnings."
                               Margin="0,8,0,0"
                               MaxWidth="820"
                               Foreground="#D6E3FF"
                               TextWrapping="Wrap" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top">
                    <Button Content="NEW GRIEVANCE"
                            Command="{Binding NewGrievanceCommand}"
                            Style="{StaticResource SecondaryActionButton}"
                            Height="40"
                            Margin="0,0,12,0" />
                    <Button Content="REFRESH"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource GoldActionButton}"
                            Height="40" />
                </WrapPanel>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="1" Margin="0,18,0,18">
            <materialDesign:Card Width="155" Margin="8" Background="{StaticResource BrandMidnightBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding TotalGrievances, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White" />
                    <TextBlock Text="TOTAL" Foreground="#A5B4FC" FontSize="9" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Width="155" Margin="8" Background="{StaticResource BrandYellowBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding OpenCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="{StaticResource BrandGoldTextBrush}" />
                    <TextBlock Text="OPEN" Foreground="#7A5A00" FontSize="9" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Width="155" Margin="8" Background="#2563EB" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding UnderReviewCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White" />
                    <TextBlock Text="UNDER REVIEW" Foreground="#DBEAFE" FontSize="9" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Width="155" Margin="8" Background="{StaticResource BrandSuccessBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding ResolvedCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White" />
                    <TextBlock Text="RESOLVED" Foreground="#CFECD8" FontSize="9" />
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Width="155" Margin="8" Background="{StaticResource BrandRedBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding RejectedCount, StringFormat=N0}" FontSize="28" FontWeight="Medium" Foreground="White" />
                    <TextBlock Text="REJECTED" Foreground="#FECACA" FontSize="9" />
                </StackPanel>
            </materialDesign:Card>
        </WrapPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Padding="16" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="Grievance Queue"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <ComboBox Width="170"
                                      Margin="0,0,12,0"
                                      ItemsSource="{Binding StatusFilters}"
                                      SelectedItem="{Binding SelectedStatusFilter}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}" />
                            <TextBox Width="260"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Search grievance or ID..." />
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Grid.Row="1"
                               Margin="0,0,0,14"
                               FontWeight="SemiBold"
                               Foreground="{Binding StatusBrush}"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding GrievancesView}"
                              SelectedItem="{Binding SelectedGrievance}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No." Binding="{Binding GrievanceNumber}" Width="150" />
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeText}" Width="140" />
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="Beneficiary" Binding="{Binding BeneficiaryIdentity}" Width="150" />
                            <DataGridTemplateColumn Header="Status" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusBrush}" CornerRadius="12" Padding="8,4" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusTextBrush}" FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2" Padding="16" Background="White">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Grievance Detail"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}" />

                        <Border Margin="0,12,0,12"
                                Padding="16"
                                CornerRadius="10"
                                Background="#EEF4FF"
                                BorderBrush="{StaticResource BrandBorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding EditableGrievanceNumber}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}" />
                                <TextBlock Text="{Binding SelectedBeneficiaryName}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedBeneficiaryIdentity}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,12"
                                Padding="14"
                                CornerRadius="10"
                                Background="#FFF7D6"
                                Visibility="{Binding IsWarningVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding WarningBannerText}"
                                       Foreground="#9A5A00"
                                       TextWrapping="Wrap" />
                        </Border>

                        <ComboBox Margin="0,0,0,10"
                                  ItemsSource="{Binding Beneficiaries}"
                                  SelectedItem="{Binding SelectedBeneficiary}"
                                  DisplayMemberPath="DisplayLabel"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Imported beneficiary" />

                        <Border Margin="0,0,0,12"
                                Padding="14"
                                CornerRadius="10"
                                Background="{StaticResource BrandSurfaceBrush}"
                                BorderBrush="{StaticResource BrandBorderBrush}"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding SelectedBeneficiaryAddress}"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding TotalAssistanceReceivedText, StringFormat=Total recorded assistance: {0}}"
                                           Margin="0,10,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}" />
                                <TextBlock Text="{Binding WarningThresholdText, StringFormat=Warning threshold: {0}}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <ComboBox Margin="0,0,0,10"
                                  ItemsSource="{Binding GrievanceTypes}"
                                  SelectedItem="{Binding SelectedGrievanceType}"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Grievance type" />

                        <ComboBox Margin="0,0,0,10"
                                  ItemsSource="{Binding AssistanceCases}"
                                  SelectedItem="{Binding SelectedAssistanceCase}"
                                  DisplayMemberPath="DisplayLabel"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Optional linked assistance case" />

                        <ComboBox Margin="0,0,0,10"
                                  ItemsSource="{Binding CashForWorkEvents}"
                                  SelectedItem="{Binding SelectedCashForWorkEvent}"
                                  DisplayMemberPath="DisplayLabel"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  materialDesign:HintAssist.Hint="Optional linked cash-for-work event" />

                        <TextBox Margin="0,0,0,10"
                                 Text="{Binding EditableTitle, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Grievance title" />

                        <TextBox Margin="0,0,0,10"
                                 Height="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding EditableDescription, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Description" />

                        <TextBox Margin="0,0,0,10"
                                 Height="80"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding EditableActionRemarks, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Remarks for rejection, correction, or override" />

                        <WrapPanel Margin="0,4,0,10">
                            <Button Content="SAVE"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource BrandMidnightBrush}"
                                    Foreground="White"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Padding="18,0" />
                            <Button Content="OPEN REVIEW"
                                    Command="{Binding OpenReviewCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#2563EB"
                                    Foreground="White"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Padding="18,0" />
                            <Button Content="RESOLVE"
                                    Command="{Binding ResolveCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource BrandSuccessBrush}"
                                    Foreground="White"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Padding="18,0" />
                            <Button Content="REJECT"
                                    Command="{Binding RejectCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource BrandRedBrush}"
                                    Foreground="White"
                                    Height="38"
                                    Margin="0,0,10,10"
                                    Padding="18,0" />
                        </WrapPanel>

                        <Separator Margin="0,8,0,12" />

                        <TextBlock Text="Record Prior Assistance"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}" />

                        <UniformGrid Columns="2" Margin="0,12,0,10">
                            <TextBox Margin="0,0,8,0"
                                     Text="{Binding ManualAssistanceAmount, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Amount" />
                            <DatePicker Margin="8,0,0,0"
                                        SelectedDate="{Binding ManualAssistanceReleaseDate}"
                                        materialDesign:HintAssist.Hint="Release date" />
                        </UniformGrid>

                        <TextBox Margin="0,0,0,10"
                                 Height="70"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ManualAssistanceRemarks, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Source / reason for this prior assistance" />

                        <Button Content="RECORD PRIOR ASSISTANCE"
                                Command="{Binding RecordManualAssistanceCommand}"
                                Style="{StaticResource GoldActionButton}"
                                Height="38"
                                HorizontalAlignment="Left" />

                        <TextBlock Text="Recorded Assistance History"
                                   Margin="0,18,0,8"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}" />

                        <DataGrid ItemsSource="{Binding LedgerEntries}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  Height="160">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Release" Binding="{Binding ReleaseDate, StringFormat='{}{0:yyyy-MM-dd}'}" Width="100" />
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:N2}}" Width="100" />
                                <DataGridTextColumn Header="Source" Binding="{Binding SourceModuleText}" Width="110" />
                                <DataGridTextColumn Header="Remarks" Binding="{Binding Remarks}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Text="Case History"
                                   Margin="0,18,0,8"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}" />

                        <ItemsControl ItemsSource="{Binding HistoryItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            CornerRadius="10"
                                            Background="{StaticResource BrandSurfaceBrush}"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Action}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}" />
                                            <TextBlock Text="{Binding TimestampText}"
                                                       Margin="0,4,0,0"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}" />
                                            <TextBlock Text="{Binding Actor, StringFormat=Actor: {0}}"
                                                       Margin="0,4,0,0"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}" />
                                            <TextBlock Text="{Binding Details}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
