<UserControl x:Class="AttendanceShiftingManagement.Views.ManagerDashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <StackPanel Orientation="Horizontal">
            <materialDesign:Card Content="Total Crew"/>
            <materialDesign:Card Content="On Duty"/>
            <materialDesign:Card Content="Pending Shifts"/>
            <materialDesign:Card Content="Week Hours"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding TodayAttendance}" />
    </Grid>
</UserControl>
