<UserControl x:Class="AttendanceShiftingManagement.Views.ManagerDashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,24">
            
            <!-- Time In/Out Card -->
            <materialDesign:Card Margin="0,0,12,0" Padding="20" UniformCornerRadius="12" Background="{StaticResource BrandMidnightBrush}" Foreground="White">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Kind="ClockOutline" Foreground="{StaticResource BrandYellowBrush}" Width="28" Height="28"/>
                        <materialDesign:Chip Grid.Column="1"
                                             Content="{Binding CurrentStatus, FallbackValue=OFF DUTY}"
                                             Background="{Binding StatusColor, FallbackValue=#FFC72C}"
                                             Foreground="#27251F"
                                             FontSize="10"
                                             Height="24"/>
                    </Grid>
                    
                    <Grid Margin="0,12,0,0">
                        <Button Command="{Binding TimeInCommand}"
                                Visibility="{Binding IsTimedIn, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource BrandRedBrush}" BorderBrush="{StaticResource BrandRedBrush}">
                            <TextBlock Text="TIME IN" Foreground="White" FontWeight="SemiBold"/>
                        </Button>
                        
                        <Button Command="{Binding TimeOutCommand}"
                                Visibility="{Binding IsTimedIn, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource BrandYellowBrush}" BorderBrush="{StaticResource BrandYellowBrush}">
                            <TextBlock Text="TIME OUT" Foreground="#27251F" FontWeight="SemiBold"/>
                        </Button>
                    </Grid>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="6,0,6,0" Padding="20" UniformCornerRadius="12" Background="#1F2937" Foreground="White">
                <StackPanel>
                    <materialDesign:PackIcon Kind="AccountGroupOutline" Foreground="{StaticResource BrandYellowBrush}" Width="28" Height="28"/>
                    <TextBlock Text="{Binding TotalCrew, FallbackValue='42'}" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBlock Text="Total Crew Members" Foreground="#D1D5DB" FontSize="12" FontWeight="Medium"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="6,0,6,0" Padding="20" UniformCornerRadius="12" Background="#111827" Foreground="White">
                <StackPanel>
                    <materialDesign:PackIcon Kind="BriefcaseCheckOutline" Foreground="{StaticResource BrandYellowBrush}" Width="28" Height="28"/>
                    <TextBlock Text="{Binding OnDutyCount, FallbackValue='18'}" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBlock Text="Currently On Duty" Foreground="#D1D5DB" FontSize="12" FontWeight="Medium"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="12,0,0,0" Padding="20" UniformCornerRadius="12" Background="{StaticResource BrandRedBrush}" Foreground="White">
                <StackPanel>
                    <materialDesign:PackIcon Kind="TimerOutline" Foreground="{StaticResource BrandYellowBrush}" Width="28" Height="28"/>
                    <TextBlock Text="{Binding TotalWeekHours, FallbackValue='1,240'}" FontSize="32" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBlock Text="Total Labor Hours (Week)" Foreground="#FDE68A" FontSize="12" FontWeight="Medium"/>
                </StackPanel>
            </materialDesign:Card>
            
        </UniformGrid>

        <materialDesign:Card Grid.Row="1" UniformCornerRadius="12" Padding="16" Background="White" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Announcements Composer -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Announcements" FontWeight="Bold" FontSize="16" Foreground="{StaticResource BrandMidnightBrush}"/>
                        <materialDesign:PackIcon Kind="Bullhorn" Foreground="{StaticResource BrandRedBrush}" Margin="8,0,0,0"/>
                    </DockPanel>
                    <Border Background="#FFF8E1" BorderBrush="{StaticResource BrandYellowBrush}" BorderThickness="1" CornerRadius="10" Padding="12">
                        <StackPanel>
                            <TextBox Text="{Binding AnnouncementText, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Write an announcement for all crew..."
                                     materialDesign:HintAssist.Foreground="#6B7280"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Height="60"
                                     FontFamily="Segoe UI"
                                     FontSize="14"
                                     Foreground="#111"
                                     CaretBrush="#111"
                                     Background="White"
                                     BorderBrush="{StaticResource BrandYellowBrush}"/>
                            <Button Content="SEND ANNOUNCEMENT"
                                    Command="{Binding SendAnnouncementCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource BrandRedBrush}" Foreground="White"
                                    Height="40" Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Manager Notifications -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Your Notifications" FontWeight="Bold" FontSize="16" Foreground="{StaticResource BrandMidnightBrush}" Margin="0,0,0,8"/>
                    <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="10" Padding="10">
                        <ItemsControl ItemsSource="{Binding ManagerNotifications}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding Message}" FontSize="11" Opacity="0.8" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat='MMM dd, hh:mm tt'}" FontSize="10" Opacity="0.6"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="2" UniformCornerRadius="12" Padding="0" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#F8FAFC" Padding="20,15" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock Text="Live Attendance Feed" FontWeight="Bold" VerticalAlignment="Center" FontSize="16"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBox Width="200"
                                     Text="{Binding AttendanceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Search Employee..." 
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}" Margin="0,0,10,0"/>
                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Content="Export"
                                    Height="32"
                                    Padding="12,0"
                                    Command="{Binding ExportAttendanceCommand}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <DataGrid Grid.Row="1" ItemsSource="{Binding TodayAttendanceView}" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalScrollBarVisibility="Disabled">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Crew Member" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="10,5">
                                        <Border Width="32" Height="32" CornerRadius="16" Background="#E2E8F0">
                                            <materialDesign:PackIcon Kind="Account" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#64748B"/>
                                        </Border>
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="12,0,0,0" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="Auto"/>
                        <DataGridTextColumn Header="Clock In" Binding="{Binding ClockInTime}" Width="Auto"/>
                        
                        <DataGridTemplateColumn Header="Status" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <materialDesign:Chip Content="{Binding Status}" 
                                                         Background="{Binding StatusColor}" 
                                                         Foreground="White" Height="24"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <DataGridTemplateColumn Header="Action" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignFlatButton}" Content="Details" Foreground="#3B82F6"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
