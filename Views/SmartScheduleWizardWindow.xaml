<Window x:Class="AttendanceShiftingManagement.Views.SmartScheduleWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="ASMS Smart Schedule Assistant" Height="500" Width="450"
        WindowStartupLocation="CenterOwner" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent">

    <Border Background="{StaticResource BrandSurfaceBrush}" CornerRadius="16" BorderBrush="{StaticResource BrandMidnightBrush}" BorderThickness="1">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                <materialDesign:PackIcon Kind="AutoFix" Width="48" Height="48" Foreground="{StaticResource BrandRedBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="SMART SCHEDULER" Style="{StaticResource MaterialDesignHeadline5TextBlock}" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                <TextBlock Text="AI-Powered Workforce Optimization" Style="{StaticResource MaterialDesignCaptionTextBlock}" HorizontalAlignment="Center" Foreground="Gray"/>
            </StackPanel>

            <!-- Content Area -->
            <Grid Grid.Row="1">
                <!-- Step 1: Processing -->
                <StackPanel x:Name="ProcessingStep" VerticalAlignment="Center" Visibility="Visible">
                    <TextBlock x:Name="StatusTitle" Text="Analyzing constraints..." HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="SemiBold"/>
                    <ProgressBar x:Name="MainProgress" IsIndeterminate="True" Height="10" Foreground="{StaticResource BrandYellowBrush}" Background="#E5E7EB"/>
                    
                    <StackPanel Margin="0,30,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <materialDesign:PackIcon x:Name="Check1" Kind="Check" Foreground="Transparent" VerticalAlignment="Center"/>
                            <TextBlock Text="Scanning active employees..." Margin="10,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <materialDesign:PackIcon x:Name="Check2" Kind="Check" Foreground="Transparent" VerticalAlignment="Center"/>
                            <TextBlock Text="Optimizing manager coverage..." Margin="10,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <materialDesign:PackIcon x:Name="Check3" Kind="Check" Foreground="Transparent" VerticalAlignment="Center"/>
                            <TextBlock Text="Calculating fairness distribution..." Margin="10,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Step 2: Result -->
                <StackPanel x:Name="ResultStep" VerticalAlignment="Center" Visibility="Collapsed">
                    <materialDesign:Card Background="White" Padding="20" UniformCornerRadius="12" materialDesign:ElevationAssist.Elevation="Dp2">
                        <StackPanel>
                            <TextBlock Text="Optimization Complete!" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Foreground="{StaticResource BrandMidnightBrush}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            
                            <Grid Margin="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Fairness Score:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock x:Name="FairnessValue" Text="98.5%" FontSize="24" FontWeight="Bold" Foreground="#10B981" VerticalAlignment="Center"/>
                                    <materialDesign:PackIcon Kind="ShieldCheck" Foreground="#10B981" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Separator Margin="0,10"/>

                            <StackPanel Margin="0,5">
                                <TextBlock Text="Summary:" FontWeight="Bold" FontSize="12" Foreground="Gray"/>
                                <TextBlock x:Name="DraftSummary" Text="64 shifts generated for 12 employees." TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>

                            <Border Background="#F9FAFB" CornerRadius="8" Padding="12" Margin="0,15,0,0">
                                <TextBlock x:Name="FullSummaryText" Text="All positions are covered for the week with zero overlaps detected." FontSize="11" FontStyle="Italic" TextWrapping="Wrap" Foreground="#4B5563"/>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </Grid>

            <!-- Actions -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CancelButton" Content="CANCEL" Style="{StaticResource MaterialDesignFlatButton}" Click="CancelButton_Click" Margin="0,0,10,0"/>
                <Button x:Name="ApplyButton" Content="APPLY SHIFTS" IsEnabled="False" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource BrandMidnightBrush}" Click="ApplyButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
