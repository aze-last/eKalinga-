<Window x:Class="AttendanceShiftingManagement.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AttendanceShiftingManagement.ViewModels"
        Title="eKalinga+ Starting"
        Width="500" Height="460"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">

    <Window.DataContext>
        <vm:SplashViewModel />
    </Window.DataContext>

    <!-- Outer drop shadow container -->
    <Border CornerRadius="16"
            Background="White"
            Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="32" ShadowDepth="6" Opacity="0.16"
                              Color="#1E4E89" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="6" />      <!-- Brand stripe -->
                <RowDefinition Height="Auto" />   <!-- Header: logos + title -->
                <RowDefinition Height="1" />      <!-- Divider -->
                <RowDefinition Height="*" />      <!-- Step checklist -->
                <RowDefinition Height="1" />      <!-- Divider -->
                <RowDefinition Height="Auto" />   <!-- Mode + Last Sync -->
                <RowDefinition Height="44" />     <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ── Brand Stripe ──────────────────────────────────────────── -->
            <Border Grid.Row="0" CornerRadius="16,16,0,0" Background="#1E4E89" />

            <!-- ── Header: Logos + Title ─────────────────────────────────── -->
            <Grid Grid.Row="1" Margin="28,20,28,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />   <!-- Logos -->
                    <ColumnDefinition Width="*" />      <!-- Title -->
                </Grid.ColumnDefinitions>

                <!-- Logos side by side -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,16,0">

                    <!-- Barangay / System logo (from SystemProfileSettings) -->
                    <Border Width="56" Height="56" CornerRadius="10"
                            Background="#EEF4FF" BorderBrush="#BFD0EA"
                            BorderThickness="1" Margin="0,0,8,0">
                        <Grid>
                            <Image Source="{Binding BarangayLogo}"
                                   Width="42" Height="42"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="Uniform">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BarangayLogo}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                            <!-- Fallback icon -->
                            <Image Source="pack://application:,,,/Images/municipal-house.ico"
                                   Width="42" Height="42"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Stretch="Uniform">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BarangayLogo}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Grid>
                    </Border>

                    <!-- eKalinga+ app logo -->
                    <Border Width="56" Height="56" CornerRadius="10"
                            Background="#FEF9EE" BorderBrush="#FDE68A"
                            BorderThickness="1">
                        <Image Source="pack://application:,,,/Images/municipal-house.ico"
                               Width="42" Height="42"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Stretch="Uniform" />
                    </Border>
                </StackPanel>

                <!-- Title block -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="eKalinga+"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#1E4E89" />
                    <TextBlock Text="Ayuda Management System"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#475569"
                               Margin="0,2,0,0" />
                    <TextBlock Text="{Binding AppVersion}"
                               FontSize="10"
                               Foreground="#94A3B8"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>

            <!-- ── Divider ────────────────────────────────────────────────── -->
            <Border Grid.Row="2" Background="#F1F5F9" Margin="28,0" />

            <!-- ── Startup Step Checklist ─────────────────────────────────── -->
            <ItemsControl Grid.Row="3"
                          ItemsSource="{Binding Steps}"
                          Margin="28,16,28,16"
                          VirtualizingPanel.IsVirtualizing="False">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:StartupStep}">
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- State icon -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Icon}"
                                       FontSize="13"
                                       Foreground="{Binding IconBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />

                            <!-- Step label -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Label}"
                                       FontSize="13"
                                       Foreground="{Binding LabelBrush}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Divider ────────────────────────────────────────────────── -->
            <Border Grid.Row="4" Background="#F1F5F9" Margin="28,0" />

            <!-- ── Mode + Last Sync ───────────────────────────────────────── -->
            <Grid Grid.Row="5" Margin="28,12,28,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Mode badge -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="●"
                               FontSize="10"
                               Foreground="{Binding ModeBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0" />
                    <TextBlock FontSize="12" FontWeight="SemiBold"
                               Foreground="{Binding ModeBrush}"
                               VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Mode: {0}">
                                <Binding Path="Mode" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <!-- Last sync -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Last Sync: "
                               FontSize="10"
                               Foreground="#94A3B8"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding LastSync}"
                               FontSize="10"
                               Foreground="#64748B"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- ── Footer ─────────────────────────────────────────────────── -->
            <Border Grid.Row="6" CornerRadius="0,0,16,16" Background="#F8FAFC">
                <TextBlock Text="Barangay Assistance and Distribution Management Platform"
                           FontSize="10"
                           Foreground="#94A3B8"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Margin="20,0" />
            </Border>
        </Grid>
    </Border>
</Window>
