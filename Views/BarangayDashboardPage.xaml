<UserControl x:Class="AttendanceShiftingManagement.Views.BarangayDashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <UserControl.Resources>
        <SolidColorBrush x:Key="DashboardAccentBrush" Color="#3386F9" />
        <SolidColorBrush x:Key="DashboardAccentSoftBrush" Color="#EAF3FF" />
        <SolidColorBrush x:Key="DashboardAccentLineBrush" Color="#B7D3FF" />
        <SolidColorBrush x:Key="DashboardCardBorderBrush" Color="#D9E6FA" />
        <SolidColorBrush x:Key="DashboardCardBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="DashboardMutedBrush" Color="#64748B" />
        <SolidColorBrush x:Key="DashboardTextBrush" Color="#0F172A" />

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,18,0" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Background" Value="{StaticResource DashboardCardBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource DashboardCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ModuleTileButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="194" />
            <Setter Property="Margin" Value="0,0,18,18" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource DashboardTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="24" />
            <Setter Property="CornerRadius" Value="26" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource DashboardCardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ActivityFallbackStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasRecentActivities}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,10">
            <Border Padding="20,16" Margin="0,0,0,20" CornerRadius="24" Background="#F9FBFF" BorderBrush="{StaticResource DashboardCardBorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding TodayLabel}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource DashboardTextBrush}" />
                        <TextBlock Text="{Binding ActiveDatabaseLabel}" Margin="0,6,0,0" FontSize="12" Foreground="{StaticResource DashboardMutedBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding TimeLabel}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" Foreground="{StaticResource DashboardTextBrush}" />
                        <TextBlock Text="{Binding LastRefreshLabel}" Margin="0,6,0,0" FontSize="12" HorizontalAlignment="Right" Foreground="{StaticResource DashboardMutedBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <UniformGrid Columns="4" Margin="0,0,-18,20">
                <Border Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Border Width="6" HorizontalAlignment="Left" CornerRadius="24,0,0,24" Background="{StaticResource DashboardAccentBrush}" />
                        <StackPanel Margin="28,24,24,24">
                            <TextBlock Text="AID REQUESTS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource DashboardMutedBrush}" />
                            <TextBlock Text="{Binding AidRequestCount, StringFormat={}{0:N0}}" Margin="0,14,0,0" FontSize="40" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Border Width="6" HorizontalAlignment="Left" CornerRadius="24,0,0,24" Background="{StaticResource DashboardAccentBrush}" />
                        <StackPanel Margin="28,24,24,24">
                            <TextBlock Text="PENDING" FontSize="12" FontWeight="Bold" Foreground="{StaticResource DashboardMutedBrush}" />
                            <TextBlock Text="{Binding PendingReviewCount, StringFormat={}{0:N0}}" Margin="0,14,0,0" FontSize="40" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}">
                    <Grid>
                        <Border Width="6" HorizontalAlignment="Left" CornerRadius="24,0,0,24" Background="{StaticResource DashboardAccentBrush}" />
                        <StackPanel Margin="28,24,24,24">
                            <TextBlock Text="BUDGET ALERTS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource DashboardMutedBrush}" />
                            <TextBlock Text="{Binding BudgetAlertCount, StringFormat={}{0:N0}}" Margin="0,14,0,0" FontSize="40" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Style="{StaticResource MetricCardStyle}" Margin="0,0,18,0">
                    <Grid>
                        <Border Width="6" HorizontalAlignment="Left" CornerRadius="24,0,0,24" Background="{StaticResource DashboardAccentBrush}" />
                        <StackPanel Margin="28,24,24,24">
                            <TextBlock Text="DISTRIBUTIONS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource DashboardMutedBrush}" />
                            <TextBlock Text="{Binding DistributionCount, StringFormat={}{0:N0}}" Margin="0,14,0,0" FontSize="40" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>
            <UniformGrid Columns="3" Margin="0,0,-18,20">
                <Button Style="{StaticResource ModuleTileButtonStyle}" Command="{Binding DataContext.ShowAssistanceCasesCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <Border CornerRadius="26" Background="{StaticResource DashboardCardBackgroundBrush}" BorderBrush="{StaticResource DashboardCardBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Border Width="6" HorizontalAlignment="Left" CornerRadius="26,0,0,26" Background="{StaticResource DashboardAccentBrush}" />
                            <Grid Margin="24">
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="52" Height="52" CornerRadius="16" Background="{StaticResource DashboardAccentSoftBrush}" BorderBrush="{StaticResource DashboardAccentLineBrush}" BorderThickness="1"><materialDesign:PackIcon Kind="ClipboardTextOutline" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource DashboardAccentBrush}" /></Border>
                                    <TextBlock Margin="16,6,0,0" Text="Aid Request" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Margin="0,20,0,0" Text="Create and manage aid requests." FontSize="15" Foreground="{StaticResource DashboardMutedBrush}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Text="{Binding AidRequestCount, StringFormat={}{0:N0} records}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DashboardAccentBrush}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Button>

                <Button Style="{StaticResource ModuleTileButtonStyle}" Command="{Binding DataContext.ShowMasterListCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <Border CornerRadius="26" Background="{StaticResource DashboardCardBackgroundBrush}" BorderBrush="{StaticResource DashboardCardBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Border Width="6" HorizontalAlignment="Left" CornerRadius="26,0,0,26" Background="{StaticResource DashboardAccentBrush}" />
                            <Grid Margin="24">
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="52" Height="52" CornerRadius="16" Background="{StaticResource DashboardAccentSoftBrush}" BorderBrush="{StaticResource DashboardAccentLineBrush}" BorderThickness="1"><materialDesign:PackIcon Kind="AccountCheckOutline" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource DashboardAccentBrush}" /></Border>
                                    <TextBlock Margin="16,6,0,0" Text="Validated Beneficiaries" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Margin="0,20,0,0" Text="Master list, verification, and lookup." FontSize="15" Foreground="{StaticResource DashboardMutedBrush}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Text="{Binding ApprovedBeneficiaryCount, StringFormat={}{0:N0} approved}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DashboardAccentBrush}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Button>

                <Button Style="{StaticResource ModuleTileButtonStyle}" Command="{Binding DataContext.ShowBudgetCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <Border CornerRadius="26" Background="{StaticResource DashboardCardBackgroundBrush}" BorderBrush="{StaticResource DashboardCardBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Border Width="6" HorizontalAlignment="Left" CornerRadius="26,0,0,26" Background="{StaticResource DashboardAccentBrush}" />
                            <Grid Margin="24">
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="52" Height="52" CornerRadius="16" Background="{StaticResource DashboardAccentSoftBrush}" BorderBrush="{StaticResource DashboardAccentLineBrush}" BorderThickness="1"><materialDesign:PackIcon Kind="WalletOutline" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource DashboardAccentBrush}" /></Border>
                                    <TextBlock Margin="16,6,0,0" Text="Budget" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Margin="0,20,0,0" Text="Track releases, balances, and budget controls." FontSize="15" Foreground="{StaticResource DashboardMutedBrush}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Text="{Binding BudgetAlertCount, StringFormat={}{0:N0} alert(s) to review}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DashboardAccentBrush}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Button>

                <Button Style="{StaticResource ModuleTileButtonStyle}" Command="{Binding DataContext.ShowDistributionCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <Border CornerRadius="26" Background="{StaticResource DashboardCardBackgroundBrush}" BorderBrush="{StaticResource DashboardCardBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Border Width="6" HorizontalAlignment="Left" CornerRadius="26,0,0,26" Background="{StaticResource DashboardAccentBrush}" />
                            <Grid Margin="24">
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="52" Height="52" CornerRadius="16" Background="{StaticResource DashboardAccentSoftBrush}" BorderBrush="{StaticResource DashboardAccentLineBrush}" BorderThickness="1"><materialDesign:PackIcon Kind="PackageVariantClosed" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource DashboardAccentBrush}" /></Border>
                                    <TextBlock Margin="16,6,0,0" Text="Distribution" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Margin="0,20,0,0" Text="Manage item and cash release workflows." FontSize="15" Foreground="{StaticResource DashboardMutedBrush}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Text="{Binding DistributionCount, StringFormat={}{0:N0} claim(s) recorded}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DashboardAccentBrush}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Button>

                <Button Style="{StaticResource ModuleTileButtonStyle}" Command="{Binding DataContext.ShowCashForWorkCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <Border CornerRadius="26" Background="{StaticResource DashboardCardBackgroundBrush}" BorderBrush="{StaticResource DashboardCardBorderBrush}" BorderThickness="1">
                        <Grid>
                            <Border Width="6" HorizontalAlignment="Left" CornerRadius="26,0,0,26" Background="{StaticResource DashboardAccentBrush}" />
                            <Grid Margin="24">
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="52" Height="52" CornerRadius="16" Background="{StaticResource DashboardAccentSoftBrush}" BorderBrush="{StaticResource DashboardAccentLineBrush}" BorderThickness="1"><materialDesign:PackIcon Kind="BriefcaseClockOutline" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource DashboardAccentBrush}" /></Border>
                                    <TextBlock Margin="16,6,0,0" Text="Cash-for-Work" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Margin="0,20,0,0" Text="Attendance and release flow." FontSize="15" Foreground="{StaticResource DashboardMutedBrush}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Text="{Binding OpenEventCount, StringFormat={}{0:N0} open event(s)}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DashboardAccentBrush}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Button>

                <Button Style="{StaticResource ModuleTileButtonStyle}" Command="{Binding DataContext.ShowReportsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                    <Border CornerRadius="26" Background="{StaticResource DashboardCardBackgroundBrush}" BorderBrush="{StaticResource DashboardCardBorderBrush}" BorderThickness="1" Opacity="0.92">
                        <Grid>
                            <Border Width="6" HorizontalAlignment="Left" CornerRadius="26,0,0,26" Background="{StaticResource DashboardAccentBrush}" />
                            <Grid Margin="24">
                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="52" Height="52" CornerRadius="16" Background="{StaticResource DashboardAccentSoftBrush}" BorderBrush="{StaticResource DashboardAccentLineBrush}" BorderThickness="1"><materialDesign:PackIcon Kind="ChartBoxOutline" Width="20" Height="20" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource DashboardAccentBrush}" /></Border>
                                    <TextBlock Margin="16,6,0,0" Text="Reports" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Margin="0,20,0,0" Text="Generate summaries, preview tables, and print-ready exports." FontSize="15" Foreground="{StaticResource DashboardMutedBrush}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Text="Centralized reporting workspace" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource DashboardAccentBrush}" />
                            </Grid>
                        </Grid>
                    </Border>
                </Button>
            </UniformGrid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelCardStyle}" Margin="0,0,18,0">
                    <StackPanel>
                        <TextBlock Text="Recent Activity" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                        <ItemsControl ItemsSource="{Binding RecentActivities}" Margin="0,18,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12" Padding="16" CornerRadius="18" Background="#F6FAFF" BorderBrush="{StaticResource DashboardCardBorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="10" Height="10" Margin="0,7,14,0" Fill="{StaticResource DashboardAccentBrush}" />
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource DashboardTextBrush}" />
                                                    <TextBlock Text="{Binding Detail}" Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource DashboardMutedBrush}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Top" Text="{Binding TimeLabel}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource DashboardAccentBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Margin="0,18,0,0" Style="{StaticResource ActivityFallbackStyle}" Text="No recent activity yet." FontSize="13" Foreground="{StaticResource DashboardMutedBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Today" FontSize="20" FontWeight="Bold" Foreground="{StaticResource DashboardTextBrush}" />
                        <ItemsControl ItemsSource="{Binding TodaySummaries}" Margin="0,18,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,12" Padding="16" CornerRadius="18" Background="#F9FBFF" BorderBrush="{StaticResource DashboardCardBorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource DashboardTextBrush}" />
                                                <TextBlock Text="{Binding Note}" Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource DashboardMutedBrush}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center" Text="{Binding Value}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource DashboardAccentBrush}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Margin="0,8,0,0" Padding="16" CornerRadius="18" Background="{StaticResource DashboardAccentSoftBrush}" BorderBrush="{StaticResource DashboardAccentLineBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="SemiBold" Foreground="{Binding StatusBrush}" />
                                <TextBlock Text="{Binding LastRefreshLabel}" Margin="0,5,0,0" FontSize="12" Foreground="{StaticResource DashboardMutedBrush}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>


