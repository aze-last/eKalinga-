<UserControl x:Class="AttendanceShiftingManagement.Views.BarangayDashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#EEF3FA">

    <UserControl.Resources>
        <Style x:Key="ConfiguredLogoStyle" TargetType="Image">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.HasOfficeLogo, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OfficeInitialsStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2563EB"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.HasOfficeLogo, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="UtilityButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#CFE0F8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LaunchpadButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#EEF3FA">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#EEF3FA">
            <Grid Margin="24">
                <Border Background="#F7FAFF"
                        BorderBrush="#D8E5F7"
                        BorderThickness="1"
                        CornerRadius="28"
                        Padding="28">
                    <StackPanel>
                        <Border Background="#FFFFFF"
                                BorderBrush="#D8E5F7"
                                BorderThickness="1"
                                CornerRadius="24"
                                Padding="26">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.1*"/>
                                    <ColumnDefinition Width="2.7*"/>
                                    <ColumnDefinition Width="2.2*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Border Width="78"
                                            Height="78"
                                            Background="#F4F8FF"
                                            BorderBrush="#BFD6F8"
                                            BorderThickness="1"
                                            CornerRadius="18">
                                        <Grid>
                                            <Image Style="{StaticResource ConfiguredLogoStyle}"
                                                   Source="{Binding DataContext.OfficeLogoImage, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                   Stretch="Uniform"
                                                   Margin="10"/>
                                            <TextBlock Style="{StaticResource OfficeInitialsStyle}"
                                                       Text="{Binding DataContext.OfficeInitials, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Margin="18,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DataContext.OfficeName, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                   Foreground="#0F172A"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding DataContext.OfficeProfileLabel, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                   Margin="0,4,0,0"
                                                   Foreground="#64748B"
                                                   FontSize="13"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DataContext.SoftwareTitle, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Foreground="#0F172A"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding DataContext.SoftwareSubtitle, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                               HorizontalAlignment="Center"
                                               Margin="0,6,0,0"
                                               Foreground="#64748B"
                                               FontSize="14"
                                               TextAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center">
                                    <Button Style="{StaticResource UtilityButtonStyle}"
                                            Click="SettingsButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" Foreground="#2563EB" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Settings" Margin="12,0,0,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource UtilityButtonStyle}"
                                            Click="CheckForUpdateButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE895;" Foreground="#2563EB" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Check for Update" Margin="12,0,0,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource UtilityButtonStyle}"
                                            Margin="0"
                                            Foreground="#2563EB"
                                            Click="LogoutButton_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8AC;" Foreground="#2563EB" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Logout" Margin="12,0,0,0" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Margin="0,24,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3.15*"/>
                                <ColumnDefinition Width="1.15*"/>
                            </Grid.ColumnDefinitions>

                            <UniformGrid Grid.Column="0"
                                         Columns="3"
                                         Margin="0,0,22,0">
                                <Button Style="{StaticResource LaunchpadButtonStyle}" Margin="0,0,18,18" Command="{Binding DataContext.ShowAssistanceCasesCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                                    <Border Background="#FFFFFF" BorderBrush="#D3E1F7" BorderThickness="1" CornerRadius="24">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#2563EB" CornerRadius="24,0,0,24"/>
                                            <StackPanel Grid.Column="1" Margin="24">
                                                <Border Width="52" Height="52" Background="#EDF5FF" BorderBrush="#BED7F8" BorderThickness="1" CornerRadius="14" HorizontalAlignment="Left"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" Foreground="#2563EB" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                <TextBlock Text="Aid Request" Margin="0,20,0,0" Foreground="#0F172A" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="Create and manage aid requests" Margin="0,18,0,0" Foreground="#64748B" FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>

                                <Button Style="{StaticResource LaunchpadButtonStyle}" Margin="0,0,18,18" Command="{Binding DataContext.ShowMasterListCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                                    <Border Background="#FFFFFF" BorderBrush="#D3E1F7" BorderThickness="1" CornerRadius="24">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#2563EB" CornerRadius="24,0,0,24"/>
                                            <StackPanel Grid.Column="1" Margin="24">
                                                <Border Width="52" Height="52" Background="#EDF5FF" BorderBrush="#BED7F8" BorderThickness="1" CornerRadius="14" HorizontalAlignment="Left"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE77B;" Foreground="#2563EB" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                <TextBlock Text="Validated Beneficiaries" Margin="0,20,0,0" Foreground="#0F172A" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="Master list and lookup" Margin="0,18,0,0" Foreground="#64748B" FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>

                                <Button Style="{StaticResource LaunchpadButtonStyle}" Margin="0,0,0,18" Command="{Binding DataContext.ShowBudgetCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                                    <Border Background="#FFFFFF" BorderBrush="#D3E1F7" BorderThickness="1" CornerRadius="24">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#2563EB" CornerRadius="24,0,0,24"/>
                                            <StackPanel Grid.Column="1" Margin="24">
                                                <Border Width="52" Height="52" Background="#EDF5FF" BorderBrush="#BED7F8" BorderThickness="1" CornerRadius="14" HorizontalAlignment="Left"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C7;" Foreground="#2563EB" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                <TextBlock Text="Budget" Margin="0,20,0,0" Foreground="#0F172A" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="Track releases and balances" Margin="0,18,0,0" Foreground="#64748B" FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>

                                <Button Style="{StaticResource LaunchpadButtonStyle}" Margin="0,0,18,0" Command="{Binding DataContext.ShowDistributionCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                                    <Border Background="#FFFFFF" BorderBrush="#D3E1F7" BorderThickness="1" CornerRadius="24">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#2563EB" CornerRadius="24,0,0,24"/>
                                            <StackPanel Grid.Column="1" Margin="24">
                                                <Border Width="52" Height="52" Background="#EDF5FF" BorderBrush="#BED7F8" BorderThickness="1" CornerRadius="14" HorizontalAlignment="Left"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE14C;" Foreground="#2563EB" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                <TextBlock Text="Distribution" Margin="0,20,0,0" Foreground="#0F172A" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="Manage item and cash releases" Margin="0,18,0,0" Foreground="#64748B" FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>
                                <Button Style="{StaticResource LaunchpadButtonStyle}" Margin="0,0,18,0" Command="{Binding DataContext.ShowCashForWorkCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                                    <Border Background="#FFFFFF" BorderBrush="#D3E1F7" BorderThickness="1" CornerRadius="24">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#2563EB" CornerRadius="24,0,0,24"/>
                                            <StackPanel Grid.Column="1" Margin="24">
                                                <Border Width="52" Height="52" Background="#EDF5FF" BorderBrush="#BED7F8" BorderThickness="1" CornerRadius="14" HorizontalAlignment="Left"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7C3;" Foreground="#2563EB" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                <TextBlock Text="Cash-for-Work" Margin="0,20,0,0" Foreground="#0F172A" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="Attendance and release flow" Margin="0,18,0,0" Foreground="#64748B" FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>

                                <Button Style="{StaticResource LaunchpadButtonStyle}" Command="{Binding DataContext.ShowReportsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
                                    <Border Background="#FFFFFF" BorderBrush="#D3E1F7" BorderThickness="1" CornerRadius="24">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#2563EB" CornerRadius="24,0,0,24"/>
                                            <StackPanel Grid.Column="1" Margin="24">
                                                <Border Width="52" Height="52" Background="#EDF5FF" BorderBrush="#BED7F8" BorderThickness="1" CornerRadius="14" HorizontalAlignment="Left"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D2;" Foreground="#2563EB" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                <TextBlock Text="Reports" Margin="0,20,0,0" Foreground="#0F172A" FontSize="20" FontWeight="Bold"/>
                                                <TextBlock Text="View summaries and exports" Margin="0,18,0,0" Foreground="#64748B" FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Button>
                            </UniformGrid>

                            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#D3E1F7" BorderThickness="1" CornerRadius="24">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#2563EB" CornerRadius="24,0,0,24"/>
                                    <StackPanel Grid.Column="1" Margin="24">
                                        <TextBlock Text="Software Trademark" Foreground="#64748B" FontSize="12" FontWeight="Bold"/>

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Width="88" Height="88" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="20" Padding="12">
                                                <Image Source="/Images/default icon.png" Stretch="Uniform"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="eKalinga+" Foreground="#0F172A" FontSize="24" FontWeight="Bold"/>
                                                <TextBlock Text="Ayuda Management System" Margin="0,6,0,0" Foreground="#475569" FontSize="13" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>

                                        <Border Height="1" Background="#E2E8F0" Margin="0,22,0,22"/>

                                        <TextBlock Text="DATABASE STATUS" Foreground="#2563EB" FontSize="14" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding ActiveDatabaseLabel}" Margin="0,16,0,0" Foreground="#334155" FontSize="13" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,0" Foreground="{Binding StatusBrush}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding LastRefreshLabel}" Margin="0,12,0,0" Foreground="#64748B" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
