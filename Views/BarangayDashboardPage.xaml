<UserControl x:Class="AttendanceShiftingManagement.Views.BarangayDashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="Transparent">
    <UserControl.Resources>
        <DropShadowEffect x:Key="DashboardShadow" BlurRadius="24" ShadowDepth="4" Opacity="0.08" Color="Black" />

        <Style x:Key="OfficeLogoImageStyle" TargetType="Image">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.HasOfficeLogo, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OfficeInitialsTextStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.HasOfficeLogo, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardTileButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#40FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.93" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.84" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardInfoBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#40FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="22" />
        </Style>

        <Style x:Key="DashboardTitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,16,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="DashboardNoteTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="#0B2B4A">
        <Border Background="#0B2B4A"
                BorderBrush="#0E7490"
                BorderThickness="1"
                Effect="{StaticResource DashboardShadow}"
                MinHeight="{Binding RelativeSource={RelativeSource AncestorType=ScrollViewer}, Path=ActualHeight}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#133E87" Padding="36,28">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Width="120" Height="120" Background="#26FFFFFF" BorderBrush="#40FFFFFF" BorderThickness="1" Padding="10">
                            <Grid>
                                <Image Style="{StaticResource OfficeLogoImageStyle}"
                                       Source="{Binding DataContext.OfficeLogoImage, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       Stretch="Uniform" />
                                <TextBlock Style="{StaticResource OfficeInitialsTextStyle}"
                                           Text="{Binding DataContext.OfficeInitials, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           Foreground="White" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DataContext.OfficeName, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DataContext.SoftwareSubtitle, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                       FontSize="13"
                                       Foreground="#D6E4FF"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding DataContext.UserDisplayName, RelativeSource={RelativeSource AncestorType={x:Type Window}}, StringFormat=Active user: {0}}"
                                       FontSize="12"
                                       Foreground="#BFDBFE"
                                       Margin="0,6,0,0" />
                            <WrapPanel Margin="0,14,0,0">
                                <Border Background="#26FFFFFF" BorderBrush="#35FFFFFF" BorderThickness="1" Padding="12,8" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding ActiveDatabaseLabel}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                                </Border>
                                <Border Background="#26FFFFFF" BorderBrush="#35FFFFFF" BorderThickness="1" Padding="12,8">
                                    <TextBlock Text="{Binding LastRefreshLabel}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="1.15*" />
                        <ColumnDefinition Width="2.1*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="190" />
                        <RowDefinition Height="190" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Grid.Column="0"
                            Command="{Binding DataContext.ShowAssistanceCasesCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                            Style="{StaticResource DashboardTileButtonStyle}"
                            Background="#0F766E">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="FileDocumentEditOutline" Width="44" Height="44" Foreground="White" />
                            <TextBlock Text="Aid Request" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="Create and manage ayuda requests."
                                       Foreground="#D1FAE5"
                                       Style="{StaticResource DashboardNoteTextStyle}" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="0" Grid.Column="1"
                            Command="{Binding DataContext.ShowMasterListCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                            Style="{StaticResource DashboardTileButtonStyle}"
                            Background="#0E7490">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="AccountCheckOutline" Width="44" Height="44" Foreground="White" />
                            <TextBlock Text="Validated Beneficiaries" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="Review approved records ready for release workflows."
                                       Foreground="#CFFAFE"
                                       Style="{StaticResource DashboardNoteTextStyle}" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="0" Grid.Column="2"
                            Command="{Binding DataContext.ShowBudgetCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                            Style="{StaticResource DashboardTileButtonStyle}"
                            Background="#1D4ED8">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="WalletOutline" Width="44" Height="44" Foreground="White" />
                            <TextBlock Text="Budget" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="Track releases, balances, and budget controls."
                                       Foreground="#DBEAFE"
                                       Style="{StaticResource DashboardNoteTextStyle}" />
                        </StackPanel>
                    </Button>

                    <Border Grid.Row="0" Grid.Column="3" Grid.RowSpan="2"
                            Style="{StaticResource DashboardInfoBorderStyle}"
                            Background="#155E75">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Today" FontSize="14" FontWeight="SemiBold" Foreground="#CFFAFE" />
                                <TextBlock Text="{Binding TodayLabel}" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,10,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding TimeLabel}" FontSize="13" Foreground="#D5F5F6" Margin="0,6,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TodayAttendanceCount, StringFormat={}{0:N0}}" FontSize="44" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="attendance logged today" FontSize="13" Foreground="#CCFBF1" />
                            </StackPanel>
                            <TextBlock Grid.Row="2" Text="{Binding OpenEventCount, StringFormat=Open events: {0:N0}}" FontSize="12" Foreground="#D5F5F6" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="4" Grid.RowSpan="2"
                            Style="{StaticResource DashboardInfoBorderStyle}"
                            Background="#115E59">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="92" Height="92" Background="#1D4ED8" Padding="12">
                                    <Grid>
                                        <Image Style="{StaticResource OfficeLogoImageStyle}"
                                               Source="{Binding DataContext.OfficeLogoImage, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                               Stretch="Uniform" />
                                        <TextBlock Style="{StaticResource OfficeInitialsTextStyle}"
                                                   Text="{Binding DataContext.OfficeInitials, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="White" />
                                    </Grid>
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Software Name and Trademark" FontSize="13" Foreground="#BFDBFE" />
                                    <TextBlock Text="{Binding DataContext.SoftwareTitle, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               Width="280" />
                                    <TextBlock Text="{Binding DataContext.ConnectionSummary, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                               FontSize="12"
                                               Foreground="#D1FAE5"
                                               Margin="0,6,0,0"
                                               TextWrapping="Wrap"
                                               Width="280" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding StatusMessage}" FontSize="16" FontWeight="SemiBold" Foreground="{Binding StatusBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding AidRequestCount, StringFormat=Aid requests: {0:N0}}" FontSize="13" Foreground="#CCFBF1" Margin="0,18,0,0" />
                                <TextBlock Text="{Binding PendingReviewCount, StringFormat=Pending review: {0:N0}}" FontSize="13" Foreground="#CCFBF1" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding BudgetAlertCount, StringFormat=Budget alerts: {0:N0}}" FontSize="13" Foreground="#CCFBF1" Margin="0,6,0,0" />
                            </StackPanel>
                            <Border Grid.Row="2" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" Padding="14">
                                <TextBlock Text="{Binding DataContext.SoftwareSubtitle, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                           FontSize="11"
                                           Foreground="#CBD5E1"
                                           TextWrapping="Wrap" />
                            </Border>
                        </Grid>
                    </Border>

                    <Button Grid.Row="1" Grid.Column="0"
                            Command="{Binding DataContext.ShowDistributionCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                            Style="{StaticResource DashboardTileButtonStyle}"
                            Background="#14532D">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="PackageVariantClosedCheck" Width="44" Height="44" Foreground="White" />
                            <TextBlock Text="Distribution" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="Record claims and item release workflows."
                                       Foreground="#DCFCE7"
                                       Style="{StaticResource DashboardNoteTextStyle}" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="1" Grid.Column="1"
                            Command="{Binding DataContext.ShowCashForWorkCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                            Style="{StaticResource DashboardTileButtonStyle}"
                            Background="#9A3412">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="AccountHardHatOutline" Width="44" Height="44" Foreground="White" />
                            <TextBlock Text="Cash-for-Work" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="Create work events and save attendance."
                                       Foreground="#FFEDD5"
                                       Style="{StaticResource DashboardNoteTextStyle}" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Row="1" Grid.Column="2"
                            Command="{Binding DataContext.ShowReportsCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                            Style="{StaticResource DashboardTileButtonStyle}"
                            Background="#6D28D9">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="ChartBoxOutline" Width="44" Height="44" Foreground="White" />
                            <TextBlock Text="Reports" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="Generate summaries and export report outputs."
                                       Foreground="#F3E8FF"
                                       Style="{StaticResource DashboardNoteTextStyle}" />
                        </StackPanel>
                    </Button>
                </Grid>

                <UniformGrid Grid.Row="2" Columns="6">
                    <Border Style="{StaticResource DashboardInfoBorderStyle}" Background="#92400E">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="ChevronDoubleRight" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="Pending Review" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="{Binding PendingReviewCount, StringFormat={}{0:N0}}" FontSize="34" FontWeight="Bold" Foreground="White" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource DashboardInfoBorderStyle}" Background="#0369A1">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="AccountHardHatOutline" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="Open Events" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="{Binding OpenEventCount, StringFormat={}{0:N0}}" FontSize="34" FontWeight="Bold" Foreground="White" Margin="0,12,0,0" />
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding RefreshCommand}"
                            Style="{StaticResource DashboardTileButtonStyle}"
                            Background="#475569">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="Update" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="Refresh Dashboard" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="Reload counts and status."
                                       Foreground="#E2E8F0"
                                       Style="{StaticResource DashboardNoteTextStyle}" />
                        </StackPanel>
                    </Button>

                    <Button Click="SettingsButton_Click"
                            Style="{StaticResource DashboardTileButtonStyle}"
                            Background="#0F172A">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="CogOutline" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="Settings" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="Open workstation tools."
                                       Foreground="#CBD5E1"
                                       Style="{StaticResource DashboardNoteTextStyle}" />
                        </StackPanel>
                    </Button>

                    <Button Click="CheckForUpdateButton_Click"
                            Style="{StaticResource DashboardTileButtonStyle}"
                            Background="#7C3AED">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="Update" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="Check for Update" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="Check the published build manifest."
                                       Foreground="#F3E8FF"
                                       Style="{StaticResource DashboardNoteTextStyle}" />
                        </StackPanel>
                    </Button>

                    <Button Click="LogoutButton_Click"
                            Style="{StaticResource DashboardTileButtonStyle}"
                            Background="#C2410C">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="LogoutVariant" Width="38" Height="38" Foreground="White" />
                            <TextBlock Text="Logout" Style="{StaticResource DashboardTitleTextStyle}" />
                            <TextBlock Text="Close the current session."
                                       Foreground="#FFEDD5"
                                       Style="{StaticResource DashboardNoteTextStyle}" />
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>
