<UserControl x:Class="AttendanceShiftingManagement.Views.ProfileSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <materialDesign:Card UniformCornerRadius="16" Padding="24" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Profile Settings" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                    <TextBlock Text="Manage your personal details, preferences, and notifications." Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>

                <TabControl Grid.Row="1" Margin="0,20,0,0" Background="Transparent">
                    <TabItem Header="Profile">
                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <Border Width="140" Height="140" CornerRadius="70" Background="#F1F5F9">
                                    <Image Source="{Binding PhotoImage}" Stretch="UniformToFill"/>
                                </Border>
                                <Button Content="Change Photo" Command="{Binding BrowsePhotoCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Margin="0,12,0,0" Height="36"/>
                                <TextBlock Text="{Binding PhotoPath}" FontSize="10" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>

                            <Grid Grid.Column="1" Margin="24,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,12,12"
                                         Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Full Name"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"
                                         Text="{Binding Nickname, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Nickname"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,12,12"
                                         Text="{Binding Email}"
                                         materialDesign:HintAssist.Hint="Email"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         IsEnabled="{Binding CanEditContactInfo}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"
                                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Phone"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         IsEnabled="{Binding CanEditContactInfo}"/>

                                <TextBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12"
                                         Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Address"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                <TextBox Grid.Row="3" Grid.Column="0" Margin="0,0,12,12"
                                         Text="{Binding EmergencyContactName, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Emergency Contact Name"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,12"
                                         Text="{Binding EmergencyContactPhone, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Emergency Contact Phone"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Account">
                        <StackPanel Margin="0,20,0,0" Width="420">
                            <TextBlock Text="Change Password" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}" Margin="0,0,0,8"/>
                            <PasswordBox x:Name="CurrentPasswordBox"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Current Password"
                                         Margin="0,0,0,12"
                                         PasswordChanged="CurrentPasswordBox_PasswordChanged"/>
                            <PasswordBox x:Name="NewPasswordBox"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="New Password"
                                         Margin="0,0,0,12"
                                         PasswordChanged="NewPasswordBox_PasswordChanged"/>
                            <PasswordBox x:Name="ConfirmPasswordBox"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Confirm Password"
                                         Margin="0,0,0,12"
                                         PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                            <Button Content="Update Password" Command="{Binding ChangePasswordCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource BrandRedBrush}" Foreground="White" Height="40"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Preferences">
                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Text="Preferred Shift Block" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <ComboBox ItemsSource="{Binding ShiftBlocks}"
                                      SelectedItem="{Binding SelectedShiftBlock}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Width="220" Margin="0,8,0,16"/>

                            <TextBlock Text="Preferred Days Off" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <WrapPanel Margin="0,8,0,16">
                                <CheckBox Content="Mon" IsChecked="{Binding IsMondayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Tue" IsChecked="{Binding IsTuesdayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Wed" IsChecked="{Binding IsWednesdayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Thu" IsChecked="{Binding IsThursdayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Fri" IsChecked="{Binding IsFridayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Sat" IsChecked="{Binding IsSaturdayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Sun" IsChecked="{Binding IsSundayOff}" Margin="0,0,12,8"/>
                            </WrapPanel>

                            <TextBlock Text="Preferred Positions" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <ItemsControl ItemsSource="{Binding Positions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,0,12,8"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Notifications">
                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Text="Notify me about" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <WrapPanel Margin="0,8,0,16">
                                <CheckBox Content="Leave" IsChecked="{Binding NotifyLeave}" Margin="0,0,12,8"/>
                                <CheckBox Content="Shift" IsChecked="{Binding NotifyShift}" Margin="0,0,12,8"/>
                                <CheckBox Content="Announcement" IsChecked="{Binding NotifyAnnouncement}" Margin="0,0,12,8"/>
                            </WrapPanel>

                            <TextBlock Text="Notification Channels" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <WrapPanel Margin="0,8,0,0">
                                <CheckBox Content="In-App" IsChecked="{Binding NotifyInApp}" Margin="0,0,12,8"/>
                                <CheckBox Content="Email" IsChecked="{Binding NotifyEmail}" Margin="0,0,12,8"/>
                            </WrapPanel>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Manager Settings"
                             Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Margin="0,20,0,0" Width="420">
                            <TextBlock Text="Default View" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <ComboBox ItemsSource="{Binding DefaultViews}"
                                      SelectedItem="{Binding DefaultView}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Margin="0,8,0,16"/>

                            <TextBlock Text="Report Format" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <ComboBox ItemsSource="{Binding ReportFormats}"
                                      SelectedItem="{Binding ReportFormat}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Margin="0,8,0,16"/>

                            <TextBlock Text="Approval Signature" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBox Text="{Binding ApprovalSignature, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="e.g. Approved by Store Manager"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,8,0,16"/>

                            <CheckBox Content="Auto notify crew on approvals" IsChecked="{Binding AutoNotifyOnApproval}"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Cancel" Command="{Binding CancelCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="36" Margin="0,0,12,0"/>
                    <Button Content="Save Changes" Command="{Binding SaveCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource BrandRedBrush}" Foreground="White" Height="36"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
