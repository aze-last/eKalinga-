<UserControl x:Class="AttendanceShiftingManagement.Views.ProfileSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="24">
        <materialDesign:Card UniformCornerRadius="16" Padding="24" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Profile Settings" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                    <TextBlock Text="Manage your personal details, preferences, and notifications." Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>

                <TabControl Grid.Row="1" Margin="0,20,0,0" Background="Transparent">
                    <TabItem Header="Profile">
                        <Grid Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <Border Width="140" Height="140" CornerRadius="70" Background="#F1F5F9">
                                    <Image Source="{Binding PhotoImage}" Stretch="UniformToFill"/>
                                </Border>
                                <Button Content="Change Photo" Command="{Binding BrowsePhotoCommand}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Margin="0,12,0,0" Height="36"/>
                                <TextBlock Text="{Binding PhotoPath}" FontSize="10" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>

                            <Grid Grid.Column="1" Margin="24,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Row="0" Grid.Column="0" Margin="0,0,12,12"
                                         Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Full Name"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Margin="0,0,0,12"
                                         Text="{Binding Nickname, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Nickname"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                <TextBox Grid.Row="1" Grid.Column="0" Margin="0,0,12,12"
                                         Text="{Binding Email}"
                                         materialDesign:HintAssist.Hint="Email"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         IsEnabled="{Binding CanEditContactInfo}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,0,12"
                                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Phone"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         IsEnabled="{Binding CanEditContactInfo}"/>

                                <TextBox Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,12"
                                         Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Address"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                <TextBox Grid.Row="3" Grid.Column="0" Margin="0,0,12,12"
                                         Text="{Binding EmergencyContactName, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Emergency Contact Name"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,0,12"
                                         Text="{Binding EmergencyContactPhone, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Emergency Contact Phone"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            </Grid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Account">
                        <StackPanel Margin="0,20,0,0" Width="420">
                            <TextBlock Text="Change Password" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}" Margin="0,0,0,8"/>
                            <PasswordBox x:Name="CurrentPasswordBox"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Current Password"
                                         Margin="0,0,0,12"
                                         PasswordChanged="CurrentPasswordBox_PasswordChanged"/>
                            <PasswordBox x:Name="NewPasswordBox"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="New Password"
                                         Margin="0,0,0,12"
                                         PasswordChanged="NewPasswordBox_PasswordChanged"/>
                            <PasswordBox x:Name="ConfirmPasswordBox"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         materialDesign:HintAssist.Hint="Confirm Password"
                                         Margin="0,0,0,12"
                                         PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                            <Button Content="Update Password" Command="{Binding ChangePasswordCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{StaticResource BrandRedBrush}" Foreground="White" Height="40"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Preferences">
                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Text="Preferred Shift Block" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <ComboBox ItemsSource="{Binding ShiftBlocks}"
                                      SelectedItem="{Binding SelectedShiftBlock}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Width="220" Margin="0,8,0,16"/>

                            <TextBlock Text="Preferred Days Off" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <WrapPanel Margin="0,8,0,16">
                                <CheckBox Content="Mon" IsChecked="{Binding IsMondayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Tue" IsChecked="{Binding IsTuesdayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Wed" IsChecked="{Binding IsWednesdayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Thu" IsChecked="{Binding IsThursdayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Fri" IsChecked="{Binding IsFridayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Sat" IsChecked="{Binding IsSaturdayOff}" Margin="0,0,12,8"/>
                                <CheckBox Content="Sun" IsChecked="{Binding IsSundayOff}" Margin="0,0,12,8"/>
                            </WrapPanel>

                            <TextBlock Text="Preferred Positions" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <ItemsControl ItemsSource="{Binding Positions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,0,12,8"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Notifications">
                        <StackPanel Margin="0,20,0,0">
                            <TextBlock Text="Notify me about" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <WrapPanel Margin="0,8,0,16">
                                <CheckBox Content="Leave" IsChecked="{Binding NotifyLeave}" Margin="0,0,12,8"/>
                                <CheckBox Content="Shift" IsChecked="{Binding NotifyShift}" Margin="0,0,12,8"/>
                                <CheckBox Content="Announcement" IsChecked="{Binding NotifyAnnouncement}" Margin="0,0,12,8"/>
                            </WrapPanel>

                            <TextBlock Text="Notification Channels" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <WrapPanel Margin="0,8,0,0">
                                <CheckBox Content="In-App" IsChecked="{Binding NotifyInApp}" Margin="0,0,12,8"/>
                                <CheckBox Content="Email" IsChecked="{Binding NotifyEmail}" Margin="0,0,12,8"/>
                            </WrapPanel>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="Manager Settings"
                             Visibility="{Binding IsManager, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Margin="0,20,0,0" Width="420">
                            <TextBlock Text="Default View" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <ComboBox ItemsSource="{Binding DefaultViews}"
                                      SelectedItem="{Binding DefaultView}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Margin="0,8,0,16"/>

                            <TextBlock Text="Report Format" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <ComboBox ItemsSource="{Binding ReportFormats}"
                                      SelectedItem="{Binding ReportFormat}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Margin="0,8,0,16"/>

                            <TextBlock Text="Approval Signature" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBox Text="{Binding ApprovalSignature, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="e.g. Approved by Store Manager"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,8,0,16"/>

                            <CheckBox Content="Auto notify crew on approvals" IsChecked="{Binding AutoNotifyOnApproval}"/>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="System Tools"
                             Visibility="{Binding CanManageSystemImport, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ScrollViewer Margin="0,20,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <Grid Margin="0,0,8,12">
                                <StackPanel MaxWidth="980"
                                            HorizontalAlignment="Stretch">
                                    <TextBlock Text="CRS Beneficiary Import"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                    <TextBlock Text="Connect to the Civil Registry System, test the read-only source connection, then import `val_beneficiaries` into your local `BeneficiaryStaging` table."
                                               Margin="0,6,0,0"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap"/>

                                    <Border Margin="0,16,0,0"
                                            Padding="18"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock Text="CRS Source Connection"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>

                                            <Grid Margin="0,8,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="1*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBox Grid.Column="0"
                                                         Text="{Binding ImportSourceServer, UpdateSourceTrigger=PropertyChanged}"
                                                         materialDesign:HintAssist.Hint="Server / Host"
                                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                                <TextBox Grid.Column="2"
                                                         Text="{Binding ImportSourcePortText, UpdateSourceTrigger=PropertyChanged}"
                                                         materialDesign:HintAssist.Hint="Port"
                                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                            </Grid>

                                            <TextBox Text="{Binding ImportSourceDatabase, UpdateSourceTrigger=PropertyChanged}"
                                                     materialDesign:HintAssist.Hint="Database Name"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     Margin="0,0,0,12"/>

                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBox Grid.Column="0"
                                                         Text="{Binding ImportSourceUsername, UpdateSourceTrigger=PropertyChanged}"
                                                         materialDesign:HintAssist.Hint="Username / Email"
                                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                                <TextBox Grid.Column="2"
                                                         Text="{Binding ImportSourcePassword, UpdateSourceTrigger=PropertyChanged}"
                                                         materialDesign:HintAssist.Hint="Password"
                                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                            </Grid>

                                            <TextBlock Text="Local Target"
                                                        Margin="0,16,0,0"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource BrandMidnightBrush}"/>
                                            <TextBlock Text="{Binding LocalImportTargetSummary}"
                                                       Margin="0,8,0,0"
                                                       Foreground="#475569"
                                                       TextWrapping="Wrap"/>

                                            <Border Margin="0,16,0,0"
                                                    Padding="12"
                                                    Background="#FEF3C7"
                                                    CornerRadius="8">
                                                <TextBlock Text="Import writes new records into your own `BeneficiaryStaging` table as Pending. Duplicate Civil Registry IDs are skipped."
                                                           Foreground="#92400E"
                                                           TextWrapping="Wrap"/>
                                            </Border>

                                            <WrapPanel Margin="0,18,0,0"
                                                       ItemHeight="40"
                                                       Orientation="Horizontal">
                                                <Button Content="TEST CONNECTION"
                                                        Command="{Binding TestImportConnectionCommand}"
                                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                                        Height="40"
                                                        Margin="0,0,12,12"
                                                        Padding="18,0"/>
                                                <Button Content="SAVE IMPORT CONNECTION"
                                                        Command="{Binding SaveImportConnectionCommand}"
                                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                                        Height="40"
                                                        Margin="0,0,12,12"
                                                        Padding="18,0"/>
                                                <Button Content="IMPORT BENEFICIARIES"
                                                        Command="{Binding ImportBeneficiariesCommand}"
                                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                                        Background="{StaticResource BrandRedBrush}"
                                                        Foreground="White"
                                                        Height="40"
                                                        Margin="0,0,12,12"
                                                        Padding="18,0"/>
                                                <Button Content="REFRESH STAGING"
                                                        Command="{Binding RefreshStagingPreviewCommand}"
                                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                                        Height="40"
                                                        Margin="0,0,12,12"
                                                        Padding="18,0"/>
                                            </WrapPanel>

                                            <ProgressBar Height="6"
                                                         Margin="0,2,0,0"
                                                         IsIndeterminate="True">
                                                <ProgressBar.Style>
                                                    <Style TargetType="ProgressBar">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsImportBusy}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ProgressBar.Style>
                                            </ProgressBar>

                                            <TextBlock Text="{Binding ImportStatusMessage}"
                                                       Margin="0,14,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{Binding ImportStatusBrush}"
                                                       TextWrapping="Wrap"/>

                                            <Border Margin="0,18,0,0"
                                                    Padding="16"
                                                    Background="White"
                                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Text="Local Staging Preview"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource BrandMidnightBrush}"/>

                                                    <Grid Margin="0,10,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Button Grid.Column="0"
                                                                Content="REFRESH PREVIEW"
                                                                Command="{Binding RefreshStagingPreviewCommand}"
                                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                Height="40"
                                                                Padding="18,0"/>
                                                    </Grid>

                                                    <TextBlock Text="{Binding TableReviewSummary}"
                                                               Margin="0,12,0,0"
                                                               Foreground="{StaticResource BrandMidnightBrush}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>

                                                    <TextBlock Text="{Binding SelectedTableColumnsSummary}"
                                                               Margin="0,8,0,0"
                                                               Foreground="#64748B"
                                                               TextWrapping="Wrap"/>

                                                    <DataGrid ItemsSource="{Binding TablePreviewView}"
                                                              AutoGenerateColumns="True"
                                                              CanUserAddRows="False"
                                                              CanUserDeleteRows="False"
                                                              IsReadOnly="True"
                                                              Margin="0,14,0,0"
                                                              Height="260"
                                                              HeadersVisibility="Column"
                                                              GridLinesVisibility="Horizontal"
                                                              RowHeaderWidth="0"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Margin="0,18,0,0"
                                                    Padding="16"
                                                    Background="White"
                                                    BorderBrush="{StaticResource BrandBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Text="Database Backup"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                                    <TextBlock Text="Create or restore a full snapshot of the currently selected app database preset. This does not connect to the CRS source."
                                                               Margin="0,8,0,0"
                                                               Foreground="#64748B"
                                                               TextWrapping="Wrap"/>

                                                    <TextBlock Text="Current Backup Target"
                                                               Margin="0,14,0,0"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                                    <TextBlock Text="{Binding BackupTargetSummary}"
                                                               Margin="0,8,0,0"
                                                               Foreground="#475569"
                                                               TextWrapping="Wrap"/>

                                                    <Border Margin="0,16,0,0"
                                                            Padding="12"
                                                            Background="#FEF3C7"
                                                            CornerRadius="8">
                                                        <TextBlock Text="Backup archives contain database rows only. Fingerprint templates, local configuration files, and image files are excluded."
                                                                   Foreground="#92400E"
                                                                   TextWrapping="Wrap"/>
                                                    </Border>

                                                    <WrapPanel Margin="0,18,0,0"
                                                               ItemHeight="40"
                                                               Orientation="Horizontal">
                                                        <Button Content="CREATE BACKUP"
                                                                Command="{Binding CreateBackupCommand}"
                                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                                Background="{StaticResource BrandRedBrush}"
                                                                Foreground="White"
                                                                Height="40"
                                                                Margin="0,0,12,12"
                                                                Padding="18,0"/>
                                                        <Button Content="RESTORE BACKUP"
                                                                Command="{Binding RestoreBackupCommand}"
                                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                Height="40"
                                                                Margin="0,0,12,12"
                                                                Padding="18,0"/>
                                                    </WrapPanel>

                                                    <ProgressBar Height="6"
                                                                 Margin="0,2,0,0"
                                                                 IsIndeterminate="True">
                                                        <ProgressBar.Style>
                                                            <Style TargetType="ProgressBar">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBackupBusy}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ProgressBar.Style>
                                                    </ProgressBar>

                                                    <TextBlock Text="{Binding BackupStatusMessage}"
                                                               Margin="0,14,0,0"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding BackupStatusBrush}"
                                                               TextWrapping="Wrap"/>

                                                    <TextBlock Text="{Binding LastBackupSummary}"
                                                               Margin="0,12,0,0"
                                                               Foreground="{StaticResource BrandMidnightBrush}"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"/>

                                                    <TextBlock Text="{Binding LastBackupFilePath}"
                                                               Margin="0,8,0,0"
                                                               Foreground="#64748B"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button Content="Cancel" Command="{Binding CancelCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}" Height="36" Margin="0,0,12,0"/>
                    <Button Content="Save Changes" Command="{Binding SaveCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource BrandRedBrush}" Foreground="White" Height="36"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
