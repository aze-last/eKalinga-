<UserControl x:Class="AttendanceShiftingManagement.Views.DeiMetricsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="DEI &amp; Equity Metrics"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrandMidnightBrush}"/>
            <Button DockPanel.Dock="Right"
                    Content="REFRESH"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Foreground="{StaticResource BrandRedBrush}"
                    BorderBrush="{StaticResource BrandRedBrush}"/>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,14">
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandMidnightBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding TotalActiveEmployees}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="ACTIVE HEADCOUNT" FontSize="12" Foreground="#D1D5DB"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="{StaticResource BrandRedBrush}">
                <StackPanel>
                    <TextBlock Text="{Binding AverageHourlyRate, StringFormat='{}{0:N2}'}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="AVG HOURLY RATE" FontSize="12" Foreground="#FFE9D5"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#7C2D12">
                <StackPanel>
                    <TextBlock Text="{Binding PayEquityGapPercent, StringFormat='{}{0:0.0}%'}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="PAY EQUITY GAP" FontSize="12" Foreground="#FED7AA"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#1D4ED8">
                <StackPanel>
                    <TextBlock Text="{Binding HighestPayArea}" FontSize="16" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                    <TextBlock Text="HIGHEST PAY AREA" FontSize="12" Foreground="#DBEAFE"/>
                </StackPanel>
            </materialDesign:Card>
            <materialDesign:Card Margin="6" Padding="14" Background="#14532D">
                <StackPanel>
                    <TextBlock Text="{Binding LowestPayArea}" FontSize="16" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                    <TextBlock Text="LOWEST PAY AREA" FontSize="12" Foreground="#DCFCE7"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <materialDesign:Card Grid.Row="2" Padding="12" Margin="0,0,0,14">
            <ItemsControl ItemsSource="{Binding Alerts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FEF2F2"
                                BorderBrush="#FCA5A5"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="8"
                                Margin="0,0,0,6">
                            <DockPanel>
                                <materialDesign:PackIcon Kind="AlertCircleOutline"
                                                         Foreground="{StaticResource BrandRedBrush}"
                                                         Width="16"
                                                         Height="16"
                                                         Margin="0,2,8,0"/>
                                <TextBlock Text="{Binding}" Foreground="#7F1D1D" TextWrapping="Wrap"/>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="3" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Representation &amp; Equity Breakdown"
                           FontWeight="Bold"
                           Margin="0,0,0,10"
                           Foreground="{StaticResource BrandMidnightBrush}"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding AreaMetrics}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Area" Binding="{Binding Area}" Width="*"/>
                        <DataGridTextColumn Header="Headcount" Binding="{Binding Headcount}" Width="100"/>
                        <DataGridTextColumn Header="Representation" Binding="{Binding RepresentationPercent, StringFormat='{}{0:0.0}%'}" Width="120"/>
                        <DataGridTextColumn Header="Avg Hourly Rate" Binding="{Binding AverageHourlyRate, StringFormat='{}{0:N2}'}" Width="130"/>
                        <DataGridTextColumn Header="Hires (Last 90 Days)" Binding="{Binding HiresLast90Days}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
