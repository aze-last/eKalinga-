<UserControl x:Class="AttendanceShiftingManagement.Views.LeaveRequestPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Leave Request"
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                   FontWeight="Bold"
                   Foreground="{StaticResource BrandMidnightBrush}"
                   Margin="0,0,0,16"/>

        <materialDesign:Card Grid.Row="1" Padding="16" Margin="0,0,0,16" Background="White">
            <StackPanel>
                <TextBlock Text="Submit a Leave Request" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding LeaveTypes}"
                              SelectedItem="{Binding SelectedLeaveType}"
                              materialDesign:HintAssist.Hint="Leave Type"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                    <DatePicker Grid.Column="2"
                                SelectedDate="{Binding StartDate}"
                                materialDesign:HintAssist.Hint="Start Date"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>

                    <DatePicker Grid.Column="4"
                                SelectedDate="{Binding EndDate}"
                                materialDesign:HintAssist.Hint="End Date"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                </Grid>

                <TextBox Margin="0,12,0,0"
                         Text="{Binding Reason}"
                         materialDesign:HintAssist.Hint="Reason"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Height="80"
                         TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="SUBMIT"
                            Command="{Binding SubmitCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource BrandRedBrush}"
                            Foreground="White"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="2" Padding="16" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="My Leave Requests" FontWeight="SemiBold" Margin="0,0,0,12"/>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding MyRequests}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="100"/>
                        <DataGridTextColumn Header="Start" Binding="{Binding StartDate, StringFormat='yyyy-MM-dd'}" Width="120"/>
                        <DataGridTextColumn Header="End" Binding="{Binding EndDate, StringFormat='yyyy-MM-dd'}" Width="120"/>
                        <DataGridTextColumn Header="Days" Binding="{Binding TotalDays}" Width="60"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>
    </Grid>
</UserControl>
