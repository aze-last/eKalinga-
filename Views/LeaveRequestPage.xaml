<Page x:Class="AttendanceShiftingManagement.Views.LeaveRequestPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1000"
      Background="{StaticResource BrandSurfaceBrush}"
      Title="Leave Request">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Leave Request" FontSize="32" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}" Margin="0,0,0,24"/>

        <!-- Leave Balance Cards -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Vacation Balance -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Vacation Leave" FontSize="14" Foreground="#64748B" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding VacationBalance}" FontSize="28" FontWeight="Bold" Foreground="#10B981"/>
                    <TextBlock Text="Remaining" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Sick Leave Balance -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="24" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Sick Leave" FontSize="14" Foreground="#64748B" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding SickBalance}" FontSize="28" FontWeight="Bold" Foreground="#3B82F6"/>
                    <TextBlock Text="Remaining" FontSize="12" Foreground="#94A3B8" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Leave Request Form -->
            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="24" materialDesign:ElevationAssist.Elevation="Dp2">
                <StackPanel>
                    <TextBlock Text="Submit Leave Request" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <!-- Leave Type -->
                    <TextBlock Text="Leave Type" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding LeaveTypes}" 
                              SelectedItem="{Binding SelectedLeaveType}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,0,16"/>

                    <!-- Start Date -->
                    <TextBlock Text="Start Date" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <DatePicker SelectedDate="{Binding StartDate}"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                Margin="0,0,0,16"/>

                    <!-- End Date -->
                    <TextBlock Text="End Date" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <DatePicker SelectedDate="{Binding EndDate}"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                Margin="0,0,0,16"/>

                    <!-- Reason -->
                    <TextBlock Text="Reason" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Height="100"
                             VerticalScrollBarVisibility="Auto"
                             materialDesign:HintAssist.Hint="Please provide a reason for your leave request"
                             Margin="0,0,0,24"/>

                    <!-- Submit Button -->
                    <Button Content="SUBMIT REQUEST"
                            Command="{Binding SubmitLeaveCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource BrandMidnightBrush}"
                            BorderBrush="{StaticResource BrandMidnightBrush}"
                            Height="48"
                            FontSize="14"
                            FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- My Leave Requests -->
            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="24" materialDesign:ElevationAssist.Elevation="Dp2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header with Refresh -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="My Leave Requests" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <Button Content="REFRESH"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Height="32"
                                Padding="16,0"
                                HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Leave Requests List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding MyLeaveRequests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8FAFC" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Header Row -->
                                            <Grid Grid.Row="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="CalendarBlank" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding Type}" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Status Badge -->
                                                <Border HorizontalAlignment="Right" CornerRadius="12" Padding="12,4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Approved">
                                                                    <Setter Property="Background" Value="#D1FAE5"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                    <Setter Property="Background" Value="#E5E7EB"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                                        <Setter Property="Foreground" Value="#92400E"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Approved">
                                                                        <Setter Property="Foreground" Value="#065F46"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Rejected">
                                                                        <Setter Property="Foreground" Value="#991B1B"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                        <Setter Property="Foreground" Value="#4B5563"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </Grid>

                                            <!-- Date Range -->
                                            <TextBlock Grid.Row="1" Margin="0,8,0,0" Foreground="#64748B">
                                                <Run Text="{Binding StartDate, StringFormat='MMM dd, yyyy'}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding EndDate, StringFormat='MMM dd, yyyy'}"/>
                                                <Run Text=" ("/>
                                                <Run Text="{Binding TotalDays}"/>
                                                <Run Text=" days)"/>
                                            </TextBlock>

                                            <!-- Reason & Actions -->
                                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                                <TextBlock Text="{Binding Reason}" TextWrapping="Wrap" Foreground="#475569" FontSize="13"/>

                                                <!-- Cancel Button (only for Pending/Approved) -->
                                                <Button Content="CANCEL"
                                                        Command="{Binding DataContext.CancelLeaveCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                                        Height="28"
                                                        Padding="12,0"
                                                        FontSize="11"
                                                        BorderBrush="#EF4444"
                                                        Foreground="#EF4444"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom">
                                                    <Button.Visibility>
                                                        <MultiBinding Converter="{StaticResource BoolToVis}">
                                                            <Binding Path="Status" Converter="{StaticResource StatusToBoolConverter}"/>
                                                        </MultiBinding>
                                                    </Button.Visibility>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
