<Window x:Class="AttendanceShiftingManagement.Views.CrewMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Crew Portal | McDonald's" WindowState="Maximized"
        Background="#F5F5F5" FontFamily="Segoe UI"
        Icon="/Images/app-icon.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#27251F">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,32,20,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="56" Height="56" CornerRadius="28" Background="#1F2937" VerticalAlignment="Center">
                            <Grid>
                                <materialDesign:PackIcon Kind="AccountCircle" Foreground="{StaticResource BrandYellowBrush}" Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image Source="{Binding UserPhotoImage}" Stretch="UniformToFill"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="{Binding UserDisplayName}" Foreground="White" FontSize="16" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            <Button Content="Profile Settings"
                                    Command="{Binding ShowProfileSettingsCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{StaticResource BrandYellowBrush}"
                                    Padding="0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="12,0">
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}" IsChecked="True"
                                 Content="DASHBOARD" Foreground="White" Height="50" Margin="0,2"
                                 Tag="{materialDesign:PackIcon Kind=ViewDashboard}"
                                 Command="{Binding ShowDashboardCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}"
                                 Content="PROFILE SETTINGS" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowProfileSettingsCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}"
                                 Content="MY SCHEDULE" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowScheduleCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}"
                                 Content="CREWMATES SCHEDULE" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowCrewmatesScheduleCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}"
                                 Content="HISTORY" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowHistoryCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}"
                                 Content="PAYSLIP" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowPayslipCommand}"/>
                    <RadioButton Style="{StaticResource MaterialDesignTabRadioButton}"
                                 Content="LEAVE REQUEST" Foreground="White" Height="50" Margin="0,2"
                                 Command="{Binding ShowLeaveRequestCommand}"/>
                </StackPanel>

                <Button Grid.Row="2" Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#FFC72C" Height="50" Margin="12,0,12,30" Click="Logout_Click">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Logout" Margin="0,0,12,0"/>
                        <TextBlock Text="Sign Out" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <ContentControl Content="{Binding CurrentView}" />
            
            <Grid x:Name="DialogOverlay" Visibility="Collapsed">
                <Border Background="Black" Opacity="0.5"/>
                <materialDesign:Card UniformCornerRadius="25" HorizontalAlignment="Center" VerticalAlignment="Center" Width="380" Padding="0" materialDesign:ElevationAssist.Elevation="Dp24">
                    <StackPanel>
                        <Border Background="#FFC72C" Height="120" CornerRadius="25,25,0,0">
                            <materialDesign:PackIcon Kind="CheckCircle" Foreground="#27251F" Width="70" Height="70" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="30">
                            <TextBlock Text="TIME RECORDED!" FontSize="22" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="#27251F"/>
                            <TextBlock Text="You have successfully updated your status. Have a great shift!" TextWrapping="Wrap" TextAlignment="Center" Margin="0,10,0,25" Opacity="0.7"/>
                            <Button Content="DONE" Height="45" Background="#DA291C" BorderBrush="#DA291C" Foreground="White"
                                    materialDesign:ButtonAssist.CornerRadius="22" Click="CloseDialog_Click"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</Window>
