<Window x:Class="AttendanceShiftingManagement.Views.CashForWorkEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="New Cash-for-Work Event"
        Width="520"
        Height="560"
        MinWidth="520"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" 
                      ResizeBorderThickness="5" 
                      GlassFrameThickness="0" 
                      CornerRadius="0" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="WindowControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource BrandTextSecondaryBrush}"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="0"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        </Style>

        <Style x:Key="WindowCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BE123C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BrandSurfaceBrush}"
            CornerRadius="16"
            BorderBrush="{StaticResource BrandBorderBrush}"
            BorderThickness="1">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CUSTOM WINDOW CONTROLS -->
        <StackPanel Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Panel.ZIndex="99"
                    Margin="0,-24,-24,0">
            <Button Style="{StaticResource WindowControlButtonStyle}"
                    Click="Minimize_Click"
                    ToolTip="Minimize">
                <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18"/>
            </Button>
            <Button Style="{StaticResource WindowCloseButtonStyle}"
                    Click="Close_Click"
                    ToolTip="Close">
                <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
            </Button>
        </StackPanel>

        <StackPanel>
            <TextBlock x:Name="WindowHeadingTextBlock"
                       Text="New Cash-for-Work Event"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrandMidnightBrush}"/>
            <TextBlock Text="Enter the event details once, then the page can use the selected event for attendance, scanner sessions, and release operations."
                       Margin="0,8,0,0"
                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <TextBox x:Name="TitleTextBox"
                     Margin="0,24,0,0"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Event title"/>

            <TextBox x:Name="LocationTextBox"
                     Margin="0,14,0,0"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Location / site"/>

            <DatePicker x:Name="EventDatePicker"
                        Margin="0,14,0,0"
                        materialDesign:HintAssist.Hint="Event date"/>

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="StartTimeTextBox"
                         Grid.Column="0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Start (HH:mm)"/>

                <TextBox x:Name="EndTimeTextBox"
                         Grid.Column="2"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="End (HH:mm)"/>
            </Grid>

            <TextBox x:Name="NotesTextBox"
                     Margin="0,14,0,0"
                     Height="140"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Notes"/>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Margin="0,18,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="CANCEL"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryActionButton}"
                    Click="Cancel_Click"/>
            <Button x:Name="SubmitButton"
                    Content="CREATE EVENT"
                    Style="{StaticResource GoldActionButton}"
                    Click="Create_Click"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>



