<Window x:Class="AttendanceShiftingManagement.Views.CashForWorkEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="New Cash-for-Work Event"
        Width="520"
        Height="560"
        MinWidth="520"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="New Cash-for-Work Event"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrandMidnightBrush}"/>
            <TextBlock Text="Enter the event details once, then the page can use the selected event for attendance, scanner sessions, and release operations."
                       Margin="0,8,0,0"
                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <TextBox x:Name="TitleTextBox"
                     Margin="0,24,0,0"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Event title"/>

            <TextBox x:Name="LocationTextBox"
                     Margin="0,14,0,0"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Location / site"/>

            <DatePicker x:Name="EventDatePicker"
                        Margin="0,14,0,0"
                        materialDesign:HintAssist.Hint="Event date"/>

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="StartTimeTextBox"
                         Grid.Column="0"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Start (HH:mm)"/>

                <TextBox x:Name="EndTimeTextBox"
                         Grid.Column="2"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="End (HH:mm)"/>
            </Grid>

            <TextBox x:Name="NotesTextBox"
                     Margin="0,14,0,0"
                     Height="140"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     materialDesign:HintAssist.Hint="Notes"/>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Margin="0,18,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="CANCEL"
                    Margin="0,0,10,0"
                    Style="{StaticResource SecondaryActionButton}"
                    Click="Cancel_Click"/>
            <Button Content="CREATE EVENT"
                    Style="{StaticResource GoldActionButton}"
                    Click="Create_Click"/>
        </StackPanel>
    </Grid>
</Window>
