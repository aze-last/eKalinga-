<Window x:Class="AttendanceShiftingManagement.Views.EmployeeIdCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Employee ID Card" Height="550" Width="380"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid>
        <!-- Card Shadow -->
        <Border Margin="15" CornerRadius="24" Background="White" materialDesign:ElevationAssist.Elevation="Dp8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="140"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- Top Section (Branding) -->
                <Border Grid.Row="0" CornerRadius="24,24,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#DA291C" Offset="0"/>
                            <GradientStop Color="#FFC72C" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <materialDesign:PackIcon Kind="McDonalds" Width="50" Height="50" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="EMPLOYEE ID" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>
                        <!-- Top-right decoration -->
                        <Border Width="100" Height="100" Background="White" Opacity="0.1" CornerRadius="50" Margin="-50,-50,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    </Grid>
                </Border>

                <!-- Middle Section (Info) -->
                <StackPanel Grid.Row="1" Margin="20,-50,20,0">
                    <!-- Photo -->
                    <Border Width="130" Height="130" CornerRadius="65" BorderBrush="White" BorderThickness="4" Background="#F1F5F9" materialDesign:ElevationAssist.Elevation="Dp4">
                        <Grid>
                            <materialDesign:PackIcon Kind="Account" Width="80" Height="80" Foreground="#CBD5E1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <!-- Actual Photo would be an Image control here -->
                        </Grid>
                    </Border>

                    <TextBlock x:Name="EmpName" Text="JUAN DELA CRUZ" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrandMidnightBrush}" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    <TextBlock x:Name="EmpPosition" Text="STORE MANAGER" FontSize="14" Foreground="{StaticResource BrandRedBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    
                    <StackPanel Margin="0,30,0,0">
                        <Grid Margin="0,5">
                            <TextBlock Text="EMPLOYEE ID" Foreground="Gray" FontSize="11" FontWeight="Bold"/>
                            <TextBlock x:Name="EmpIdNumber" Text="EMP-2024-001" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Separator Background="#E2E8F0"/>
                        <Grid Margin="0,5">
                            <TextBlock Text="DEPARTMENT" Foreground="Gray" FontSize="11" FontWeight="Bold"/>
                            <TextBlock x:Name="EmpDept" Text="Operations" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Separator Background="#E2E8F0"/>
                        <Grid Margin="0,5">
                            <TextBlock Text="DATE HIRED" Foreground="Gray" FontSize="11" FontWeight="Bold"/>
                            <TextBlock x:Name="IssueDate" Text="Jan 2024" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Bottom Section (QR/Actions) -->
                <Border Grid.Row="2" Background="#F8FAFC" CornerRadius="0,0,24,24" Padding="15">
                    <DockPanel>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="SCAN FOR ACCESS" FontSize="9" FontWeight="Bold" Foreground="Gray"/>
                            <materialDesign:PackIcon Kind="Qrcode" Width="40" Height="40" Foreground="{StaticResource BrandMidnightBrush}"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button x:Name="PrintButton" Content="PRINT" Style="{StaticResource MaterialDesignFlatButton}" Foreground="{StaticResource BrandRedBrush}" Click="PrintButton_Click"/>
                            <Button Content="CLOSE" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource BrandMidnightBrush}" Click="Close_Click" Width="80"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
