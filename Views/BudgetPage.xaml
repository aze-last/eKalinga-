<UserControl x:Class="AttendanceShiftingManagement.Views.BudgetPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AttendanceShiftingManagement.Views"
             xmlns:viewModels="clr-namespace:AttendanceShiftingManagement.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#F1F5F9"
             FontFamily="{materialDesign:MaterialDesignFont}">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PrimaryBrandBrush" Color="#15803D"/>
        <SolidColorBrush x:Key="ActionAccentBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E2E8F0"/>

        <helpers:NullToWidthConverter x:Key="NullToWidthConverter"/>

        <Style x:Key="SidebarHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrandBrush}"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        </Style>

        <Style x:Key="SummaryCardStyle" TargetType="materialDesign:Card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="UniformCornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="363*"/>
            <RowDefinition Height="364*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrandBrush}" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="CashMultiple" Width="32" Height="32" Foreground="White" VerticalAlignment="Center"/>
                    <StackPanel Margin="15,0,0,0">
                        <TextBlock Text="BUDGET &amp; FINANCE" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Manage government allocations, private donations, and project caps." FontSize="12" Foreground="#CCFFFFFF"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="REFRESH" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="Transparent" 
                            BorderBrush="White" 
                            BorderThickness="1" 
                            Foreground="White" 
                            Margin="0,0,10,0"
                            Command="{Binding RefreshCommand}"/>
                    <Button Content="BROWSE / SELECT" 
                            Style="{StaticResource MaterialDesignRaisedButton}" 
                            Background="White" 
                            Foreground="{StaticResource PrimaryBrandBrush}" 
                            Command="{Binding OpenDashboardPanelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Margin="0,73,0,0" Grid.RowSpan="3">
            <Grid.Effect>
                <BlurEffect Radius="{Binding IsAnyOverlayOpen, Converter={StaticResource BooleanToBlurRadiusConverter}, FallbackValue=0}"/>
            </Grid.Effect>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar / Action Panel (Light Brand Theme) -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,20,20,10">
                        <Button Content="DASHBOARD" 
                                Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="{StaticResource PrimaryBrandBrush}" BorderBrush="{StaticResource PrimaryBrandBrush}" Height="45" Margin="0,0,0,20"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Border Padding="20,0,20,20">
                            <StackPanel>
                                <TextBlock Text="SOURCES" Style="{StaticResource SidebarHeaderStyle}"/>

                                <Button Content="SYNC GGMS"
                                        Command="{Binding SyncGovernmentBudgetCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource ActionAccentBrush}"
                                        Foreground="White" HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,8" FontSize="14"/>

                                <Button Content="CREATE PROJECT"
                                        Command="{Binding OpenNewDonationProjectCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Background="{StaticResource ActionAccentBrush}"
                                        Foreground="White" HorizontalContentAlignment="Left" Height="45" Margin="0,0,0,20" FontSize="14"/>

                                <TextBlock Text="AUDIT (CLAIM)" Style="{StaticResource SidebarHeaderStyle}"/>

                                <Button Content="OPEN LEDGER" 
                                        Command="{Binding OpenLedgerPanelCommand}"
                                        Style="{StaticResource MaterialDesignRaisedButton}" 
                                        Background="{StaticResource ActionAccentBrush}" Foreground="White" Height="50" Margin="0,0,0,25" FontSize="15" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </ScrollViewer>

                    <!-- Status Area -->
                    <Border Grid.Row="2" Padding="20" Background="White" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <TextBlock Text="MODULE STATUS" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Center Content: Search & List -->
            <Grid Grid.Column="1" Background="Transparent" Visibility="{Binding EmptyStateVisibility}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30">
                        <!-- Primary Summary Cards -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <materialDesign:Card Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                                <Border Padding="20,15" Height="90">
                                    <StackPanel>
                                        <TextBlock Text="GGMS ALLOCATION" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding GovernmentAllocated, StringFormat='PHP {0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                    </StackPanel>
                                </Border>
                            </materialDesign:Card>

                            <materialDesign:Card Grid.Column="2" Style="{StaticResource SummaryCardStyle}">
                                <Border Padding="20,15" Height="90">
                                    <StackPanel>
                                        <TextBlock Text="PRIVATE DONATIONS" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding PrivateAvailable, StringFormat='PHP {0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                    </StackPanel>
                                </Border>
                            </materialDesign:Card>

                            <materialDesign:Card Grid.Column="4" Style="{StaticResource SummaryCardStyle}">
                                <Border Padding="15,10" Height="90">
                                    <StackPanel VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                            <TextBlock Text="COMBINED AVAILABLE: " FontSize="9" FontWeight="Bold" Foreground="#64748B"/>
                                            <TextBlock Text="{Binding CombinedAvailable, StringFormat='PHP {0:N2}'}" FontSize="9" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="General Use" FontSize="9" FontWeight="Bold" Foreground="#64748B"/>
                                                <TextBlock Text="{Binding UnrestrictedAvailable, StringFormat='PHP {0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="#15803D"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Locked/Earmarked" FontSize="9" FontWeight="Bold" Foreground="#64748B"/>
                                                <TextBlock Text="{Binding LockedAvailable, StringFormat='PHP {0:N2}'}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource ActionAccentBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </materialDesign:Card>

                            <materialDesign:Card Grid.Column="6" Style="{StaticResource SummaryCardStyle}">
                                <Border Padding="20,15" Height="90">
                                    <StackPanel>
                                        <TextBlock Text="TOTAL RELEASED" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding ReleasedTotal, StringFormat='PHP {0:N2}'}" FontSize="18" FontWeight="Bold" Foreground="#15803D"/>
                                    </StackPanel>
                                </Border>
                            </materialDesign:Card>
                        </Grid>

                        <!-- Spending Velocity Cards -->
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <materialDesign:Card Grid.Column="0" Style="{StaticResource SummaryCardStyle}">
                                <Border Padding="20,15" Height="75">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="SPENT THIS WEEK" FontSize="9" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding WeeklySpent, StringFormat='PHP {0:N2}'}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                        </StackPanel>
                                        <materialDesign:PackIcon Kind="TrendingDown" Foreground="#64748B" Opacity="0.3" Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </materialDesign:Card>

                            <materialDesign:Card Grid.Column="2" Style="{StaticResource SummaryCardStyle}">
                                <Border Padding="20,15" Height="75">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="SPENT THIS MONTH" FontSize="9" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding MonthlySpent, StringFormat='PHP {0:N2}'}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                        </StackPanel>
                                        <materialDesign:PackIcon Kind="CalendarMonth" Foreground="#64748B" Opacity="0.3" Width="24" Height="24" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </materialDesign:Card>
                        </Grid>

                        <!-- Browser Card -->
                        <materialDesign:Card Style="{StaticResource SummaryCardStyle}" Padding="0">
                            <Border Padding="28">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                        <materialDesign:PackIcon Kind="DatabaseSearch" Foreground="{StaticResource PrimaryBrandBrush}" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock Text="BUDGET BROWSER" FontSize="17" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox materialDesign:HintAssist.Hint="Search budget code or name..." 
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="44" Margin="0,0,16,0"/>
                                        <ComboBox Grid.Column="1" Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                  ItemsSource="{Binding TypeFilters}"
                                                  SelectedItem="{Binding SelectedTypeFilter}"
                                                  Height="44"/>
                                        <Button Grid.Column="2" 
                                                Style="{StaticResource MaterialDesignRaisedButton}" 
                                                Background="{StaticResource ActionAccentBrush}" 
                                                BorderBrush="{StaticResource ActionAccentBrush}" 
                                                Foreground="White"
                                                Height="44"
                                                Margin="16,0,0,0"
                                                Command="{Binding RefreshCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="REFRESH" VerticalAlignment="Center" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <DataGrid ItemsSource="{Binding BudgetsView}"
                                              SelectedItem="{Binding SelectedBudget}"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              Height="400"
                                              SelectionMode="Single"
                                              Background="Transparent"
                                              BorderThickness="0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="CODE" Binding="{Binding Code}" Width="120"/>
                                            <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/>
                                            <DataGridTextColumn Header="CATEGORY" Binding="{Binding Category}" Width="150"/>
                                            <DataGridTextColumn Header="CAP / BUDGET" Binding="{Binding BudgetCap, StringFormat='N2'}" Width="130"/>
                                            <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" Width="100"/>
                                            <DataGridTemplateColumn Header="ACTION" Width="180">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <!-- Button for funds without a project -->
                                                            <Button Content="CREATE PROJECT" 
                                                                    Command="{Binding DataContext.OpenProjectCreationPanelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                    CommandParameter="{Binding}"
                                                                    Height="30" FontSize="11"
                                                                    Background="{StaticResource ActionAccentBrush}"
                                                                    Foreground="White"
                                                                    HorizontalAlignment="Center">
                                                                <Button.Visibility>
                                                                    <Binding Path="IsFundSource" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                                                                </Button.Visibility>
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatDarkBgButton}">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsFundSource}" Value="False">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding HasLinkedProject}" Value="True">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>

                                                            <!-- Badge for funds with a linked project -->
                                                            <Border Background="#15803D" 
                                                                    CornerRadius="12" Padding="8,4" 
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding IsFundSource}" Value="True"/>
                                                                                    <Condition Binding="{Binding HasLinkedProject}" Value="True"/>
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="White" Width="12" Height="12" Margin="0,0,4,0"/>
                                                                    <TextBlock Text="{Binding LinkedProjectName}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </materialDesign:Card>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Center Content: Detail View (Pattern A) -->
            <Grid Grid.Column="1" Background="Transparent" Visibility="{Binding DetailVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Detail Header -->
                <Border Grid.Row="0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="30,20" Background="White">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Back Button -->
                        <Button Grid.Column="0" 
                                Style="{StaticResource MaterialDesignFlatButton}" 
                                Command="{Binding ClearSelectedBudgetCommand}"
                                Foreground="{StaticResource PrimaryBrandBrush}"
                                Margin="0,0,15,0"
                                VerticalAlignment="Center"
                                ToolTip="Back to Listing">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="BACK" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Border Background="{StaticResource PrimaryBrandBrush}" CornerRadius="4" Padding="8,2" Margin="0,0,10,0">
                                    <TextBlock Text="{Binding SelectedBudget.Category}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                                <TextBlock Text="{Binding SelectedBudget.Code}" FontWeight="Bold" Foreground="#64748B"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SelectedBudget.Name}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <!-- Detail View Create Project Button Removed as requested -->
                            <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding NavigatePreviousCommand}" Foreground="{StaticResource PrimaryBrandBrush}">
                                <materialDesign:PackIcon Kind="ChevronLeft"/>
                            </Button>
                            <TextBlock Text="{Binding CurrentPosition}" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                            <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding NavigateNextCommand}" Foreground="{StaticResource PrimaryBrandBrush}">
                                <materialDesign:PackIcon Kind="ChevronRight"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Detail Body -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Border Padding="30">
                        <StackPanel MaxWidth="900" HorizontalAlignment="Left">
                            <!-- Summary Cards -->
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <materialDesign:Card Grid.Column="0" Margin="0,0,15,0" Style="{StaticResource SummaryCardStyle}">
                                    <Border Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="BUDGET CAP" FontSize="12" Foreground="#0F172A" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding SelectedBudget.BudgetCap, StringFormat='N2'}" FontSize="24" FontWeight="Black" Margin="0,5" Foreground="#0F172A"/>
                                            <TextBlock Text="Total allocated limit" FontSize="11" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>
                                </materialDesign:Card>

                                <materialDesign:Card Grid.Column="1" Margin="0,0,15,0" Style="{StaticResource SummaryCardStyle}">
                                    <Border Padding="20">
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="REMAINING" FontSize="12" Foreground="#15803D" FontWeight="Bold" HorizontalAlignment="Left"/>
                                                <Button Style="{StaticResource MaterialDesignFlatButton}" 
                                                        Height="20" Padding="0" Margin="0" 
                                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Foreground="{StaticResource ActionAccentBrush}"
                                                        Command="{Binding DataContext.UnlockFundsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        ToolTip="Unlock Remaining Funds">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="LockOpen" Width="12" Height="12"/>
                                                        <TextBlock Text="UNLOCK" FontSize="9" Margin="3,0,0,0" FontWeight="Bold"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                            <TextBlock Text="{Binding SelectedBudgetRemaining, StringFormat='N2'}" FontSize="24" FontWeight="Black" Margin="0,5" Foreground="#15803D"/>
                                            <TextBlock Text="Available for release" FontSize="11" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>
                                </materialDesign:Card>

                                <materialDesign:Card Grid.Column="2" Style="{StaticResource SummaryCardStyle}">
                                    <Border Padding="20">
                                        <StackPanel>
                                            <TextBlock Text="STATUS" FontSize="12" Foreground="#854D0E" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding SelectedBudget.Status}" FontSize="24" FontWeight="Black" Margin="0,5" Foreground="#854D0E"/>
                                            <TextBlock Text="Current distribution state" FontSize="11" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>
                                </materialDesign:Card>
                            </Grid>

                            <TextBlock Text="OPERATIONAL SETTINGS" FontSize="14" FontWeight="Bold" Margin="0,0,0,15" Foreground="{StaticResource PrimaryBrandBrush}"/>

                            <!-- Dynamic Section Content based on Category -->
                            <ContentControl Content="{Binding SelectedBudget}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type viewModels:BudgetRecordListItem}">
                                        <materialDesign:Card Background="White" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Padding="20">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="PROJECT INITIATION" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}" Margin="0,0,0,5"/>
                                                    <TextBlock Text="Spawn a new distribution project drawing from this funding source." Foreground="#64748B" TextWrapping="Wrap" Margin="0,0,0,15"/>
                                                </StackPanel>
                                                
                                                <Button Grid.Column="1" Content="CREATE PROJECT" 
                                                        Command="{Binding DataContext.OpenProjectCreationPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignRaisedButton}" 
                                                        Background="{StaticResource ActionAccentBrush}" BorderBrush="{StaticResource ActionAccentBrush}" Foreground="White"
                                                        Height="40" VerticalAlignment="Center"
                                                        Visibility="{Binding HasLinkedProject, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                                            Visibility="{Binding HasLinkedProject, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <materialDesign:PackIcon Kind="CheckCircle" Foreground="#15803D" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                    <TextBlock Text="PROJECT ASSIGNED" FontWeight="Bold" Foreground="#15803D" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Ledger History Panel Overlay -->
        <Border Grid.RowSpan="3" Panel.ZIndex="100" Background="#CC0F172A" Visibility="{Binding LedgerVisibility}">
            <materialDesign:Card Width="1100" VerticalAlignment="Stretch" Margin="50">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource PrimaryBrandBrush}" Padding="25,20">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="History" Width="28" Height="28" Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="BUDGET LEDGER &amp; TRANSACTION HISTORY" Foreground="White" FontSize="20" FontWeight="Bold" Margin="15,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button HorizontalAlignment="Right" Style="{StaticResource MaterialDesignIconButton}" Foreground="White" Command="{Binding ClosePanelCommand}">
                                <materialDesign:PackIcon Kind="Close"/>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="25,15">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBox materialDesign:HintAssist.Hint="Search transactions..." 
                                         Width="300"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Text="{Binding LedgerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="White"/>
                                <ComboBox materialDesign:HintAssist.Hint="Source Filter" 
                                          Width="200" Margin="15,0,0,0"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          ItemsSource="{Binding LedgerSourceFilters}"
                                          SelectedItem="{Binding SelectedLedgerSourceFilter}"
                                          Background="White"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="EXPORT CSV" Command="{Binding ExportLedgerCommand}" Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{StaticResource PrimaryBrandBrush}" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                <Button Content="REFRESH" Command="{Binding RefreshCommand}" Margin="10,0,0,0" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource ActionAccentBrush}" BorderBrush="{StaticResource ActionAccentBrush}" Foreground="White"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="25">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="{Binding SelectedLedgerEntry, Converter={StaticResource NullToWidthConverter}, ConverterParameter=350}"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Row="0" Grid.Column="0"
                                  ItemsSource="{Binding LedgerEntriesView}"
                                  SelectedItem="{Binding SelectedLedgerEntry}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  materialDesign:DataGridAssist.CellPadding="10"
                                  BorderThickness="1" BorderBrush="{StaticResource CardBorderBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="DATE" Binding="{Binding EntryDate, StringFormat='MMM dd, yyyy'}" Width="120"/>
                                <DataGridTextColumn Header="ENTRY" Binding="{Binding EntryType}" Width="100"/>
                                <DataGridTextColumn Header="SOURCE" Binding="{Binding FeatureSource}" Width="120"/>
                                <DataGridTextColumn Header="PROGRAM / PROJECT" Binding="{Binding ProgramName}" Width="*"/>
                                <DataGridTextColumn Header="TOTAL PHP" Binding="{Binding TotalAmount, StringFormat='N2'}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <Button Style="{StaticResource MaterialDesignIconButton}" 
                                    Command="{Binding PreviousLedgerPageCommand}"
                                    Foreground="{StaticResource PrimaryBrandBrush}">
                                <materialDesign:PackIcon Kind="ChevronLeft"/>
                            </Button>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                                <TextBlock Text="Page " Foreground="#64748B"/>
                                <TextBlock Text="{Binding CurrentLedgerPage}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                <TextBlock Text=" of " Foreground="#64748B"/>
                                <TextBlock Text="{Binding TotalLedgerPages}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                <TextBlock Text=" (" Foreground="#64748B" Margin="10,0,0,0"/>
                                <TextBlock Text="{Binding TotalLedgerEntries}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                <TextBlock Text=" total entries)" Foreground="#64748B"/>
                            </StackPanel>

                            <Button Style="{StaticResource MaterialDesignIconButton}" 
                                    Command="{Binding NextLedgerPageCommand}"
                                    Foreground="{StaticResource PrimaryBrandBrush}">
                                <materialDesign:PackIcon Kind="ChevronRight"/>
                            </Button>
                        </StackPanel>

                        <materialDesign:Card Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="20,0,0,0" Background="White" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" Visibility="{Binding HistoryDetailVisibility}">
                            <Border Padding="20">
                                <StackPanel>
                                    <TextBlock Text="TRANSACTION DETAIL" FontSize="14" FontWeight="Bold" Margin="0,0,0,20" Foreground="{StaticResource PrimaryBrandBrush}"/>

                                    <TextBlock Text="DATE" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                    <TextBlock Text="{Binding SelectedLedgerEntry.EntryDate, StringFormat='MMMM dd, yyyy'}" Margin="0,2,0,15" Foreground="{StaticResource PrimaryBrandBrush}"/>

                                    <TextBlock Text="PROGRAM" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                    <TextBlock Text="{Binding SelectedLedgerEntry.ProgramName}" TextWrapping="Wrap" Margin="0,2,0,15" Foreground="{StaticResource PrimaryBrandBrush}"/>

                                    <TextBlock Text="DISTRIBUTION DETAIL" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,15">
                                        <TextBlock Text="{Binding SelectedLedgerEntry.RecipientCount}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                        <TextBlock Text=" Beneficiaries Claims" Margin="5,0,0,0" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                    </StackPanel>

                                    <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource CardBorderBrush}" Margin="0,5,0,15"/>

                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="GOVERNMENT" FontSize="12" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedLedgerEntry.GovernmentPortion, StringFormat='N2'}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,15">
                                        <TextBlock Text="PRIVATE" FontSize="12" Foreground="#64748B"/>
                                        <TextBlock Text="{Binding SelectedLedgerEntry.PrivatePortion, StringFormat='N2'}" HorizontalAlignment="Right" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                    </Grid>

                                    <Border Background="{StaticResource PrimaryBrandBrush}" Padding="15,10" CornerRadius="4">
                                        <Grid>
                                            <TextBlock Text="TOTAL RELEASED" Foreground="White" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SelectedLedgerEntry.TotalAmount, StringFormat='N2'}" Foreground="White" FontSize="18" FontWeight="Black" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="REMARKS" FontSize="10" FontWeight="Bold" Foreground="#64748B" Margin="0,20,0,5"/>
                                    <TextBlock Text="{Binding SelectedLedgerEntry.Remarks}" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource PrimaryBrandBrush}"/>

                                    <Button Content="CLOSE DETAIL" Command="{Binding CloseHistoryDetailCommand}" Margin="0,30,0,0" Style="{StaticResource MaterialDesignOutlinedButton}" BorderBrush="{StaticResource PrimaryBrandBrush}" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                </StackPanel>
                            </Border>
                        </materialDesign:Card>
                    </Grid>
                </Grid>
            </materialDesign:Card>
        </Border>

        <!-- Project Creation Panel Overlay (Combined: Donation Entry + Project + Enrollment) -->
        <Border Grid.RowSpan="3" Panel.ZIndex="103" Background="#CC0F172A" Visibility="{Binding ProjectCreationPanelVisibility}">
            <materialDesign:Card Width="1100" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource PrimaryBrandBrush}" Padding="20,15">
                        <TextBlock Text="CREATE NEW PROJECT (WATERFALL)" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    </Border>

                    <ScrollViewer Grid.Row="1" MaxHeight="600" VerticalScrollBarVisibility="Auto">
                        <Border Padding="25">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Basic Information -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="BASIC INFORMATION" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}" Margin="0,0,0,15"/>

                                    <TextBox materialDesign:HintAssist.Hint="Project Name *"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Text="{Binding NewProjectName, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,15"/>

                                    <TextBox materialDesign:HintAssist.Hint="Project Code *"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Text="{Binding NewProjectCode, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,0,15"/>

                                    <ComboBox materialDesign:HintAssist.Hint="Program Type"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              ItemsSource="{Binding ProgramTypes}"
                                              SelectedItem="{Binding SelectedProgramType}"
                                              Margin="0,0,0,15"/>

                                    <TextBox materialDesign:HintAssist.Hint="Description"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Text="{Binding NewProjectDescription}"
                                             AcceptsReturn="True" Height="60"
                                             Margin="0,0,0,15"/>

                                    <TextBlock Text="RELEASE SETTINGS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}" Margin="0,10,0,15"/>

                                    <ComboBox materialDesign:HintAssist.Hint="Release Method"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              ItemsSource="{Binding ReleaseKinds}"
                                              SelectedItem="{Binding SelectedReleaseKind}"
                                              Margin="0,0,0,15"/>

                                    <!-- Cash Fields -->
                                    <StackPanel Visibility="{Binding IsCashReleaseKind, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBox materialDesign:HintAssist.Hint="Max Payout Amount (PHP) *"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Text="{Binding NewProjectUnitAmountText, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="18" FontWeight="Bold"
                                                 Margin="0,0,0,15"/>
                                    </StackPanel>

                                    <!-- Goods Fields -->
                                    <StackPanel Visibility="{Binding IsGoodsReleaseKind, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBox materialDesign:HintAssist.Hint="Item Name (e.g. Rice) *"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Text="{Binding NewProjectItemName, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,15"/>
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="10" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Quantity Per Beneficiary *"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     Text="{Binding NewProjectQuantityText, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Unit of Measure (e.g. kg, pack) *"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     Text="{Binding NewProjectUnitOfMeasure, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                        <TextBox materialDesign:HintAssist.Hint="Item Description (Optional)"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Text="{Binding NewProjectItemDescription, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,15"/>
                                    </StackPanel>

                                    <TextBlock Text="DURATION &amp; CAP" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}" Margin="0,10,0,15"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <DatePicker Grid.Column="0" materialDesign:HintAssist.Hint="Start Date"
                                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                                    SelectedDate="{Binding NewProjectStartDate}"/>
                                        <DatePicker Grid.Column="2" materialDesign:HintAssist.Hint="End Date"
                                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                                    SelectedDate="{Binding NewProjectEndDate}"/>
                                    </Grid>

                                    <TextBox materialDesign:HintAssist.Hint="Hard Budget Cap (Optional)"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Text="{Binding NewProjectBudgetCapText}"
                                             Margin="0,15,0,0"/>
                                </StackPanel>

                                <!-- Funding Source (dual-mode) -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="FUNDING SOURCE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}" Margin="0,0,0,5"/>
                                    <TextBlock Text="This project will draw funds exclusively from the source below." FontSize="10" Foreground="#64748B" Margin="0,0,0,15"/>

                                    <!-- Existing source (from grid row) -->
                                    <Border BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="4" MinHeight="60" Background="#F8FAFC" Padding="15"
                                            Visibility="{Binding IsNewDonationMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding NewProjectSourceDescription}" VerticalAlignment="Center" FontWeight="Bold" TextWrapping="Wrap" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                    </Border>

                                    <!-- New donation entry (from sidebar) -->
                                    <StackPanel Visibility="{Binding IsNewDonationMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <ComboBox materialDesign:HintAssist.Hint="Donor Type *"
                                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                  ItemsSource="{Binding DonorTypes}"
                                                  SelectedItem="{Binding SelectedDonorType}"
                                                  Margin="0,0,0,15"/>

                                        <TextBox materialDesign:HintAssist.Hint="Donor Name *"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Text="{Binding DonorName, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,15"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <RadioButton Content="Cash" IsChecked="{Binding IsCashDonation}" Style="{StaticResource MaterialDesignRadioButton}" Margin="0,0,20,0" Foreground="{StaticResource PrimaryBrandBrush}" Cursor="Hand"/>
                                            <RadioButton Content="Goods" IsChecked="{Binding IsGoodsDonation}" Style="{StaticResource MaterialDesignRadioButton}" Foreground="{StaticResource PrimaryBrandBrush}" Cursor="Hand"/>
                                        </StackPanel>

                                        <TextBox materialDesign:HintAssist.Hint="Donation Amount (PHP) *"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Text="{Binding DonationAmountText, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="18" FontWeight="Bold"
                                                 Visibility="{Binding IsCashDonation, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                 Margin="0,0,0,15"/>

                                        <StackPanel Visibility="{Binding IsGoodsDonation, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,15">
                                            <TextBox materialDesign:HintAssist.Hint="Item Name *"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     Text="{Binding DonationItemName, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,10"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" materialDesign:HintAssist.Hint="Quantity *"
                                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                         Text="{Binding DonationQuantityText, UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBox Grid.Column="2" materialDesign:HintAssist.Hint="Unit (e.g. Sacks) *"
                                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                         Text="{Binding DonationUnitOfMeasure, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>
                                        </StackPanel>

                                        <DatePicker materialDesign:HintAssist.Hint="Date Received *"
                                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                                    SelectedDate="{Binding DonationDateReceived}"
                                                    Margin="0,0,0,15"/>

                                        <TextBox materialDesign:HintAssist.Hint="Reference Number / Receipt #"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Text="{Binding DonationReferenceNumber}"
                                                 Margin="0,0,0,15"/>

                                        <ComboBox materialDesign:HintAssist.Hint="Proof Type"
                                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                                  ItemsSource="{Binding ProofTypes}"
                                                  SelectedItem="{Binding SelectedProofType}"
                                                  Margin="0,0,0,15"/>

                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox materialDesign:HintAssist.Hint="Proof File Path"
                                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                     Text="{Binding ProofFilePath}" IsReadOnly="True"/>
                                            <Button Grid.Column="1" Content="..." Command="{Binding BrowseProofCommand}" Margin="5,0,0,0" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource PrimaryBrandBrush}" Foreground="White" Cursor="Hand"/>
                                        </Grid>

                                        <TextBox materialDesign:HintAssist.Hint="Remarks"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Text="{Binding DonationRemarks}"
                                                 AcceptsReturn="True" Height="60"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Enroll Beneficiaries (optional) — picked through the ADD BENEFICIARIES modal -->
                                <Grid Grid.Column="4">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Text="ENROLL BENEFICIARIES (OPTIONAL)" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}" VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource ActionAccentBrush}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding SelectedEnrollmentCount}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                                <TextBlock Text=" SELECTED" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <Button Grid.Row="1" Content="ADD BENEFICIARIES"
                                            Command="{Binding OpenBeneficiaryPickerCommand}"
                                            Style="{StaticResource MaterialDesignRaisedButton}"
                                            Background="{StaticResource ActionAccentBrush}" BorderBrush="{StaticResource ActionAccentBrush}"
                                            Foreground="White" Height="40" Margin="0,10,0,10" Cursor="Hand"/>

                                    <!-- Compact preview of the confirmed roster -->
                                    <ListBox Grid.Row="2" ItemsSource="{Binding SelectedEnrollmentBeneficiaries}"
                                             MinHeight="200" MaxHeight="420"
                                             BorderThickness="1" BorderBrush="{StaticResource CardBorderBrush}"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             VirtualizingPanel.IsVirtualizing="True">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding FullName}" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding BeneficiaryId, StringFormat=' ({0})'}" FontSize="11" Foreground="#64748B" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Style="{StaticResource MaterialDesignIconButton}" Width="24" Height="24"
                                                            Command="{Binding DataContext.RemoveSelectedBeneficiaryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}" Foreground="#BE123C" ToolTip="Remove from project">
                                                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </Grid>
                        </Border>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20">
                        <Button Content="CANCEL" Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding CloseProjectCreationPanelCommand}" Margin="0,0,10,0" Foreground="#64748B"/>
                        <Button Content="CREATE PROJECT" Command="{Binding ConfirmCreateProjectCommand}" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource ActionAccentBrush}" BorderBrush="{StaticResource ActionAccentBrush}" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Border>

        <!-- ============ BENEFICIARIES FORM MODAL (client's dual-list design) ============ -->
        <Border Grid.RowSpan="3" Panel.ZIndex="104" Background="#CC0F172A"
                Visibility="{Binding IsBeneficiaryPickerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <materialDesign:Card Width="1050" MaxHeight="680" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#15803D" Padding="20,12">
                        <TextBlock Text="BENEFICIARIES FORM" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    </Border>

                    <Grid Grid.Row="1" Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search + pager over the validated registry -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                            <TextBox materialDesign:HintAssist.Hint="Search validated residents..."
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding EnrollmentSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <Button Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28"
                                        Command="{Binding PreviousEnrollmentPageCommand}" Foreground="{StaticResource PrimaryBrandBrush}">
                                    <materialDesign:PackIcon Kind="ChevronLeft"/>
                                </Button>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                    <TextBlock Text="Page " FontSize="11" Foreground="#64748B"/>
                                    <TextBlock Text="{Binding CurrentEnrollmentPage}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                    <TextBlock Text=" of " FontSize="11" Foreground="#64748B"/>
                                    <TextBlock Text="{Binding TotalEnrollmentPages}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                                </StackPanel>
                                <Button Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28"
                                        Command="{Binding NextEnrollmentPageCommand}" Foreground="{StaticResource PrimaryBrandBrush}">
                                    <materialDesign:PackIcon Kind="ChevronRight"/>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="{Binding EnrollmentResultSummary}" FontSize="11" Foreground="#64748B" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Left list: Validated Residence -->
                        <Border Grid.Row="1" Grid.Column="0" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Background="#15803D" Padding="10,8">
                                    <TextBlock Text="Validated Residence" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Border>
                                <ListBox Grid.Row="1" ItemsSource="{Binding FilteredEnrollmentBeneficiaries}"
                                         MinHeight="300" BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingPanel.IsVirtualizing="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FullName}" FontSize="12" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding BeneficiaryId}" FontSize="10" Foreground="#64748B"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Style="{StaticResource MaterialDesignIconButton}" Width="26" Height="26"
                                                        Command="{Binding DataContext.RequestAddBeneficiaryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" Foreground="#15803D" ToolTip="Review household and add"
                                                        Visibility="{Binding IsSelected, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                    <materialDesign:PackIcon Kind="ArrowRightBold" Width="16" Height="16"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Middle: Add / Remove arrows (visual affordance matching the client's mock) -->
                        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="14,0">
                            <TextBlock Text="Add" FontSize="11" Foreground="#15803D" HorizontalAlignment="Center"/>
                            <materialDesign:PackIcon Kind="ArrowRightBoldOutline" Width="34" Height="34" Foreground="#15803D" HorizontalAlignment="Center"/>
                            <materialDesign:PackIcon Kind="ArrowLeftBoldOutline" Width="34" Height="34" Foreground="#BE123C" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                            <TextBlock Text="Remove" FontSize="11" Foreground="#BE123C" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Right list: Beneficiaries for the Project -->
                        <Border Grid.Row="1" Grid.Column="2" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Background="#15803D" Padding="10,8">
                                    <TextBlock Text="Beneficiaries for the Project" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Border>
                                <ListBox Grid.Row="1" ItemsSource="{Binding SelectedEnrollmentBeneficiaries}"
                                         MinHeight="300" BorderThickness="0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         VirtualizingPanel.IsVirtualizing="True">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding FullName}" FontSize="12" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding BeneficiaryId}" FontSize="10" Foreground="#64748B"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="Unreleased / Unclaimed" FontSize="10" Foreground="#854D0E" VerticalAlignment="Center" Margin="6,0"/>
                                                <Button Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}" Width="26" Height="26"
                                                        Command="{Binding DataContext.RemoveSelectedBeneficiaryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}" Foreground="#BE123C" ToolTip="Remove from project">
                                                    <materialDesign:PackIcon Kind="ArrowLeftBold" Width="16" Height="16"/>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0,20,16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="{Binding SelectedEnrollmentCount}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}"/>
                            <TextBlock Text=" beneficiaries selected" FontSize="12" Foreground="#64748B"/>
                        </StackPanel>
                        <Button Content="DONE" Command="{Binding CloseBeneficiaryPickerCommand}" Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource ActionAccentBrush}" BorderBrush="{StaticResource ActionAccentBrush}" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Border>

        <!-- ============ HOUSEHOLD RECORDS CONFIRMATION MODAL (before add) ============ -->
        <Border Grid.RowSpan="3" Panel.ZIndex="105" Background="#CC0F172A"
                Visibility="{Binding IsHouseholdRecordsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <materialDesign:Card Width="560" MaxHeight="620" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource PrimaryBrandBrush}" Padding="20,12">
                        <TextBlock Text="HOUSEHOLD RECORDS REVIEW" Foreground="White" FontSize="15" FontWeight="Bold"/>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="20,16,20,8">
                        <TextBlock Text="{Binding HouseholdRecordsCandidateName}" FontSize="17" FontWeight="Bold" Foreground="{StaticResource PrimaryBrandBrush}" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                    Visibility="{Binding HouseholdRecordsHasHousehold, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding HouseholdRecordsCode}" FontSize="11" Foreground="#64748B"/>
                            <TextBlock Text="{Binding HouseholdRecordsHeadName, StringFormat=' — Head: {0}'}" FontSize="11" Foreground="#64748B"/>
                        </StackPanel>
                        <Border Background="#F8FAFC" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10,8" Margin="0,10,0,0">
                            <TextBlock Text="{Binding HouseholdRecordsSummary}" FontSize="12" FontWeight="Bold" TextWrapping="Wrap" Foreground="{StaticResource PrimaryBrandBrush}"/>
                        </Border>
                    </StackPanel>

                    <ScrollViewer Grid.Row="2" Margin="20,0,20,0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="FAMILY MEMBERS &amp; BENEFITS RECEIVED" FontSize="11" FontWeight="Bold" Foreground="#64748B" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding HouseholdRecordsMembers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="10,7" Margin="0,0,0,5" Background="#F8FAFC"
                                                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding FullName}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <materialDesign:PackIcon Kind="AccountCheck" Width="14" Height="14" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                                 Foreground="#15803D"
                                                                                 Visibility="{Binding IsCandidateBeneficiary, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding RelationshipToHead}" FontSize="10" Foreground="#64748B"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding BenefitsReceivedText}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Foreground="#854D0E"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,14,20,16">
                        <Button Content="CANCEL" Command="{Binding CancelHouseholdRecordsCommand}" Style="{StaticResource MaterialDesignFlatButton}" Foreground="#64748B" Margin="0,0,10,0"/>
                        <Button Content="ADD TO PROJECT" Command="{Binding ConfirmAddBeneficiaryCommand}" Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="{StaticResource ActionAccentBrush}" BorderBrush="{StaticResource ActionAccentBrush}" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Border>

    </Grid>
</UserControl>
