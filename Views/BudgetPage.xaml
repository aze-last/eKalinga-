<UserControl x:Class="AttendanceShiftingManagement.Views.BudgetPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:helpers="clr-namespace:AttendanceShiftingManagement.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1440"
             Background="{DynamicResource BrandSurfaceBrush}">

    <UserControl.Resources>
        <helpers:NullToHiddenConverter x:Key="NullToHiddenConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:Card Grid.Row="0" Padding="12,8" Background="{DynamicResource ThemeCardBrush}" UniformCornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Title -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="8,0">
                    <TextBlock Text="Budget Management" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                    <TextBlock Text="{Binding CurrentPanelTitle}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                </StackPanel>

                <!-- Center: Navigation -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Padding="8"
                            Command="{Binding NavigatePreviousCommand}"
                            ToolTip="Previous Record">
                        <materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24"/>
                    </Button>
                    
                    <Border Margin="12,0" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="8" Padding="16,6">
                        <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}">
                            <Run Text="{Binding CurrentPosition, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>

                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Padding="8"
                            Command="{Binding NavigateNextCommand}"
                            ToolTip="Next Record">
                        <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24"/>
                    </Button>
                </StackPanel>

                <!-- Right: Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="BROWSE / SELECT" 
                            Style="{StaticResource SecondaryActionButton}" 
                            Height="40" 
                            Padding="16,0"
                            Click="Browse_Click"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="0,18,0,0">
            <!-- Empty State -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                        Visibility="{Binding SelectedBudget, Converter={StaticResource NullToHiddenConverter}, ConverterParameter=Inverse}">
                <materialDesign:PackIcon Kind="DatabaseSearch" Width="80" Height="80" Foreground="{DynamicResource BrandBorderBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="No Budget Record Selected" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,16,0,8" HorizontalAlignment="Center"/>
                <TextBlock Text="Browse project budgets or global caps to manage allocations." FontSize="14" Foreground="{DynamicResource BrandTextSecondaryBrush}" HorizontalAlignment="Center"/>
                <Button Content="BROWSE BUDGET RECORDS" Style="{StaticResource SecondaryActionButton}" Margin="0,24,0,0" Height="44" Click="Browse_Click"/>
            </StackPanel>

            <!-- Detail View -->
            <Grid Visibility="{Binding SelectedBudget, Converter={StaticResource NullToHiddenConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar Actions & Global Summary -->
                <StackPanel Grid.Column="0">
                    <!-- Global Budget Summary Card -->
                    <materialDesign:Card Padding="16" Background="{DynamicResource BrandMidnightBrush}" UniformCornerRadius="16" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="GLOBAL SNAPSHOT" FontSize="11" FontWeight="Bold" Foreground="#A5B4FC" Margin="0,0,0,12"/>
                            
                            <TextBlock Text="TOTAL AVAILABLE" FontSize="10" Foreground="#94A3B8" FontWeight="Bold"/>
                            <TextBlock Text="{Binding CombinedAvailable, StringFormat='PHP {0:N2}'}" FontSize="24" Foreground="White" FontWeight="ExtraBold" Margin="0,2,0,12"/>
                            
                            <UniformGrid Columns="1">
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="GGMS SYNCED" FontSize="9" Foreground="#94A3B8"/>
                                    <TextBlock Text="{Binding GovernmentAllocated, StringFormat='PHP {0:N2}'}" FontSize="13" Foreground="White" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="GOV REMAINING" FontSize="9" Foreground="#94A3B8"/>
                                    <TextBlock Text="{Binding GovernmentAvailable, StringFormat='PHP {0:N2}'}" FontSize="13" Foreground="#4ADE80" FontWeight="SemiBold"/>
                                </StackPanel>
                            </UniformGrid>

                            <Button Content="SYNC GGMS" Command="{Binding SyncGovernmentBudgetCommand}" Margin="0,16,0,0" Height="36" Style="{StaticResource GoldActionButton}" FontSize="11"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="16" Background="{DynamicResource ThemeCardBrush}" UniformCornerRadius="16">
                        <StackPanel>
                            <TextBlock Text="OPERATIONAL ACTIONS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,12"/>
                            
                            <!-- Actions depend on selection -->
                            <Button Content="SYNC LEDGER" Command="{Binding RefreshCommand}" Margin="0,0,0,8" Height="40" Style="{StaticResource SecondaryActionButton}"/>
                            <Button Content="EXPORT LEDGER" Command="{Binding ExportLedgerCommand}" Margin="0,0,0,8" Height="40" Style="{StaticResource SecondaryActionButton}"/>
                            
                            <Separator Margin="0,12" Background="{DynamicResource BrandBorderBrush}"/>
                            
                            <Button Content="RECORD DONATION" Command="{Binding OpenDonationPanelCommand}" Margin="0,0,0,8" Height="40" Style="{StaticResource SecondaryActionButton}"/>
                            <Button Content="OPEN LEDGER" Command="{Binding OpenLedgerPanelCommand}" Height="40" Style="{StaticResource SecondaryActionButton}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <Border Margin="0,16,0,0" Padding="16" CornerRadius="16" Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="MODULE STATUS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                            <TextBlock Margin="0,8,0,0" Text="{Binding StatusMessage}" Foreground="{Binding StatusBrush}" FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Detail Content -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,16,0">
                        
                        <!-- Ayuda Projects Detail (Pattern A) -->
                        <StackPanel Visibility="{Binding AyudaProjectsSectionVisibility}">
                            <materialDesign:Card Padding="24" Background="{DynamicResource ThemeCardBrush}" UniformCornerRadius="16" Margin="0,0,0,16">
                                <StackPanel>
                                    <DockPanel LastChildFill="False" Margin="0,0,0,24">
                                        <TextBlock Text="PROJECT DETAILS" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" VerticalAlignment="Center"/>
                                        <Button DockPanel.Dock="Right" Content="SAVE PROJECT" Style="{StaticResource GoldActionButton}" Height="40" Command="{Binding CreateProgramCommand}"/>
                                    </DockPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Project Code" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                            <TextBox Text="{Binding ProgramCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                                            <TextBlock Text="Project Name" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,16,0,8"/>
                                            <TextBox Text="{Binding ProgramName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Program Type" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding ProgramTypes}" SelectedItem="{Binding SelectedProgramType}" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                                            <TextBlock Text="Status" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,16,0,8"/>
                                            <ComboBox ItemsSource="{Binding ProgramDistributionStatuses}" SelectedItem="{Binding SelectedProgramDistributionStatus}" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Assistance Type" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                            <TextBox Text="{Binding ProgramAssistanceType, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Release Kind" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                            <ComboBox ItemsSource="{Binding ProgramReleaseKinds}" SelectedItem="{Binding SelectedProgramReleaseKind}" Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,16,0,0">
                                        <TextBlock Text="Budget Cap (PHP)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                        <TextBox Text="{Binding ProgramBudgetCapText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="18" FontWeight="Bold"/>
                                    </StackPanel>
                                    
                                    <StackPanel Margin="0,16,0,0" Visibility="{Binding ProgramCashAmountVisibility}">
                                        <TextBlock Text="Cash Amount per Beneficiary" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                        <TextBox Text="{Binding ProgramUnitAmountText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,16,0,0" Visibility="{Binding ProgramGoodsDescriptionVisibility}">
                                        <TextBlock Text="Goods / Item Details" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                        <TextBox Text="{Binding ProgramItemDescription, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" AcceptsReturn="True" MinHeight="60"/>
                                    </StackPanel>

                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Start Date" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                            <DatePicker SelectedDate="{Binding ProgramStartDate}" Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="End Date" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                            <DatePicker SelectedDate="{Binding ProgramEndDate}" Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Margin="0,16,0,0">
                                        <TextBlock Text="Description" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                        <TextBox Text="{Binding ProgramDescription, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" AcceptsReturn="True" MinHeight="80"/>
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>

                        <!-- Global Cap Detail (Assistance) -->
                        <StackPanel Visibility="{Binding AssistanceCaseBudgetsSectionVisibility}">
                            <materialDesign:Card Padding="24" Background="{DynamicResource ThemeCardBrush}" UniformCornerRadius="16" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="GLOBAL AID REQUEST CAP" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,20"/>
                                    
                                    <Border Padding="24" CornerRadius="16" Background="{DynamicResource ThemeAccentSoftBrush}" BorderBrush="{DynamicResource ThemeAccentBorderBrush}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="CURRENT CAP" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding AssistanceCaseBudgetCapTotal, StringFormat='PHP {0:N2}'}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Margin="0,24,0,0">
                                        <TextBlock Text="NEW BUDGET CAP (PHP)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                        <TextBox Text="{Binding AssistanceCaseBudgetCapText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="24" FontWeight="Bold"/>
                                        <Button Content="VERIFY &amp; UPDATE AID CAP" Margin="0,16,0,0" Height="52" Style="{StaticResource GoldActionButton}" Command="{Binding CreateAssistanceCaseBudgetCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>

                        <!-- Global Cap Detail (CFW) -->
                        <StackPanel Visibility="{Binding CashForWorkBudgetsSectionVisibility}">
                            <materialDesign:Card Padding="24" Background="{DynamicResource ThemeCardBrush}" UniformCornerRadius="16" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="GLOBAL CASH-FOR-WORK CAP" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,0,0,20"/>
                                    
                                    <Border Padding="24" CornerRadius="16" Background="{DynamicResource ThemeAccentSoftBrush}" BorderBrush="{DynamicResource ThemeAccentBorderBrush}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="CURRENT CAP" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding CashForWorkBudgetCapTotal, StringFormat='PHP {0:N2}'}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Margin="0,24,0,0">
                                        <TextBlock Text="NEW BUDGET CAP (PHP)" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                                        <TextBox Text="{Binding CashForWorkBudgetCapText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MaterialDesignOutlinedTextBox}" FontSize="24" FontWeight="Bold"/>
                                        <Button Content="VERIFY &amp; UPDATE CFW CAP" Margin="0,16,0,0" Height="52" Style="{StaticResource GoldActionButton}" Command="{Binding CreateCashForWorkBudgetCommand}"/>
                                    </StackPanel>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- OTP Challenge Overlay -->
        <Border Grid.RowSpan="2" Panel.ZIndex="100" Background="#CC0F172A" Visibility="{Binding ShowOtpPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
            <materialDesign:Card Width="440" Padding="32" UniformCornerRadius="24" Background="{DynamicResource ThemeCardBrush}" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <materialDesign:PackIcon Kind="ShieldLock" Width="48" Height="48" Foreground="{DynamicResource BrandGoldBrush}" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                    <TextBlock Text="Security Verification" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Margin="0,12,0,0" Text="Updating global budget caps requires a security code. We've sent a 6-digit OTP to your registered system email." Foreground="{DynamicResource BrandTextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
                    
                    <TextBox Margin="0,32,0,0"
                             Text="{Binding OtpCode, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Foreground="{DynamicResource BrandMidnightBrush}"
                             Background="{DynamicResource ThemeInputSurfaceBrush}"
                             BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                             materialDesign:HintAssist.Hint="6-DIGIT CODE"
                             FontSize="28"
                             FontWeight="Bold"
                             HorizontalContentAlignment="Center"
                             MaxLength="6">
                        <TextBox.InputBindings>
                            <KeyBinding Command="{Binding VerifyOtpCommand}" Key="Return" />
                        </TextBox.InputBindings>
                    </TextBox>

                    <TextBlock Margin="0,16,0,0"
                               Text="{Binding OtpStatusMessage}"
                               Foreground="{Binding OtpStatusBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>

                    <Button Margin="0,28,0,0"
                            Content="VERIFY &amp; APPLY CHANGES"
                            Height="52"
                            Style="{StaticResource GoldActionButton}"
                            Command="{Binding VerifyOtpCommand}"/>

                    <UniformGrid Columns="2" Margin="0,16,0,0">
                        <Button Content="{Binding ResendOtpButtonText, FallbackValue=RESEND OTP}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding ResendOtpCommand}"/>
                        <Button Content="CANCEL"
                                Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Command="{Binding CloseOtpPanelCommand}"/>
                    </UniformGrid>
                </StackPanel>
            </materialDesign:Card>
        </Border>
    </Grid>
</UserControl>
