<UserControl x:Class="AttendanceShiftingManagement.Views.BudgetPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid>
        <ScrollViewer x:Name="BudgetScrollViewer"
                      VerticalScrollBarVisibility="Auto">
            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <materialDesign:Card Grid.Row="0"
                                     Padding="20"
                                     Background="White">
                    <DockPanel LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left"
                                    Width="760">
                            <TextBlock Text="Budget Control"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBlock Text="Manage the combined Ayuda budget, sync GGMS allocation snapshots, record private donations, and keep one shared release ledger."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="0,10,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding StatusBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <Button Content="SYNC GGMS BUDGET"
                                    Margin="0,0,12,0"
                                    Height="40"
                                    Style="{StaticResource GoldActionButton}"
                                    Command="{Binding SyncGovernmentBudgetCommand}"/>
                            <Button Content="REFRESH"
                                    Height="40"
                                    Style="{StaticResource SecondaryActionButton}"
                                    Command="{Binding RefreshCommand}"/>
                        </StackPanel>
                    </DockPanel>
                </materialDesign:Card>

                <UniformGrid Grid.Row="1"
                             Margin="0,18,0,18"
                             Columns="4">
                    <materialDesign:Card Margin="0,0,12,0"
                                         Padding="16"
                                         Background="{StaticResource BrandMidnightBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding CombinedAvailable, StringFormat=N2}"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="COMBINED AVAILABLE"
                                       FontSize="10"
                                       Foreground="#D6E3FF"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Margin="0,0,12,0"
                                         Padding="16"
                                         Background="#0F766E">
                        <StackPanel>
                            <TextBlock Text="{Binding GovernmentAvailable, StringFormat=N2}"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="GOVERNMENT AVAILABLE"
                                       FontSize="10"
                                       Foreground="#CCFBF1"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Margin="0,0,12,0"
                                         Padding="16"
                                         Background="{StaticResource BrandYellowBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding PrivateAvailable, StringFormat=N2}"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandGoldTextBrush}"/>
                            <TextBlock Text="PRIVATE AVAILABLE"
                                       FontSize="10"
                                       Foreground="#7A5A00"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Padding="16"
                                         Background="{StaticResource BrandSuccessBrush}">
                        <StackPanel>
                            <TextBlock Text="{Binding ReleasedTotal, StringFormat=N2}"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="TOTAL RELEASED"
                                       FontSize="10"
                                       Foreground="#DDF7E5"/>
                        </StackPanel>
                    </materialDesign:Card>
                </UniformGrid>

                <!-- Main workspace -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <materialDesign:Card Padding="18"
                                             Background="White">
                            <StackPanel>
                                <DockPanel LastChildFill="False">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Budget Ledger / Liquidation"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandMidnightBrush}"/>
                                        <TextBlock Text="Make the ledger the default workspace so users land directly on the list and only open forms when needed."
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="Click a history row to inspect the full entry in the detail card."
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Top">
                                        <Border Margin="0,0,8,0"
                                                Padding="14,8"
                                                CornerRadius="17"
                                                Background="{StaticResource BrandMidnightBrush}">
                                            <TextBlock Text="ALL"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                        </Border>
                                        <Border Margin="0,0,8,0"
                                                Padding="14,8"
                                                CornerRadius="17"
                                                Background="#F8FAFC"
                                                BorderBrush="{StaticResource BrandBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="RELEASES"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                        </Border>
                                        <Border Margin="0,0,8,0"
                                                Padding="14,8"
                                                CornerRadius="17"
                                                Background="#F8FAFC"
                                                BorderBrush="{StaticResource BrandBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="PROGRAMS"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                        </Border>
                                        <Border Padding="14,8"
                                                CornerRadius="17"
                                                Background="#F8FAFC"
                                                BorderBrush="{StaticResource BrandBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="DONATIONS"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                        </Border>
                                    </StackPanel>
                                </DockPanel>

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="210"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Text="{Binding LedgerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Search program, source, or remarks"/>

                                    <ComboBox Grid.Column="2"
                                              ItemsSource="{Binding LedgerSourceFilters}"
                                              SelectedItem="{Binding SelectedLedgerSourceFilter}"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              materialDesign:HintAssist.Hint="Source filter"/>

                                    <Button Grid.Column="4"
                                            Content="EXPORT"
                                            Height="42"
                                            Style="{StaticResource SecondaryActionButton}"
                                            Command="{Binding ExportLedgerCommand}"/>
                                </Grid>

                                <DataGrid Margin="0,16,0,0"
                                          ItemsSource="{Binding LedgerEntriesView}"
                                          SelectedItem="{Binding SelectedLedgerEntry, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          MinHeight="420"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowHeaderWidth="0"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Date"
                                                            Binding="{Binding EntryDate, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                            Width="130"/>
                                        <DataGridTextColumn Header="Entry"
                                                            Binding="{Binding EntryType}"
                                                            Width="110"/>
                                        <DataGridTextColumn Header="Source"
                                                            Binding="{Binding FeatureSource}"
                                                            Width="150"/>
                                        <DataGridTextColumn Header="Release"
                                                            Binding="{Binding ReleaseKind}"
                                                            Width="110"/>
                                        <DataGridTextColumn Header="Program"
                                                            Binding="{Binding ProgramName}"
                                                            Width="260"/>
                                        <DataGridTextColumn Header="Recipients"
                                                            Binding="{Binding RecipientCount}"
                                                            Width="100"/>
                                        <DataGridTextColumn Header="Total"
                                                            Binding="{Binding TotalAmount, StringFormat=N2}"
                                                            Width="130"/>
                                        <DataGridTextColumn Header="Gov't"
                                                            Binding="{Binding GovernmentPortion, StringFormat=N2}"
                                                            Width="130"/>
                                        <DataGridTextColumn Header="Private"
                                                            Binding="{Binding PrivatePortion, StringFormat=N2}"
                                                            Width="130"/>
                                        <DataGridTextColumn Header="Remarks"
                                                            Binding="{Binding Remarks}"
                                                            Width="340"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Margin="0,18,0,0"
                                             Padding="18"
                                             Background="White">
                            <StackPanel>
                                <DockPanel>
                                    <StackPanel>
                                        <TextBlock Text="Quick Actions"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandMidnightBrush}"/>
                                        <TextBlock Text="Separate form entry points from the main list view so users only open setup panels when they need to create something new."
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                </DockPanel>

                                <UniformGrid Margin="0,16,0,0"
                                             Columns="3">
                                    <materialDesign:Card Margin="0,0,12,0"
                                                         Padding="16"
                                                         Background="#F8FAFC">
                                        <StackPanel>
                                            <TextBlock Text="New Donation"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                            <TextBlock Text="Record private donor entries, proof details, amount, and remarks in a separate panel."
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                            <Button Content="OPEN DONATION PANEL"
                                                    Margin="0,14,0,0"
                                                    Height="42"
                                                    Style="{StaticResource GoldActionButton}"
                                                    Command="{Binding OpenDonationPanelCommand}"/>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <materialDesign:Card Margin="0,0,12,0"
                                                         Padding="16"
                                                         Background="#F8FAFC">
                                        <StackPanel>
                                            <TextBlock Text="New Program"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                            <TextBlock Text="Create ayuda projects, event distributions, item definitions, and budget caps from a dedicated setup panel."
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                            <Button Content="OPEN PROGRAM PANEL"
                                                    Margin="0,14,0,0"
                                                    Height="42"
                                                    Style="{StaticResource GoldActionButton}"
                                                    Command="{Binding OpenProgramPanelCommand}"/>
                                        </StackPanel>
                                    </materialDesign:Card>

                                    <materialDesign:Card Padding="16"
                                                         Background="#F8FAFC">
                                        <StackPanel>
                                            <TextBlock Text="New Seminar"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                            <TextBlock Text="Capture seminar details, support kind, credentials, and agenda without interrupting the main ledger view."
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                                       TextWrapping="Wrap"/>
                                            <Button Content="OPEN SEMINAR PANEL"
                                                    Margin="0,14,0,0"
                                                    Height="42"
                                                    Style="{StaticResource GoldActionButton}"
                                                    Command="{Binding OpenSeminarPanelCommand}"/>
                                        </StackPanel>
                                    </materialDesign:Card>
                                </UniformGrid>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <materialDesign:Card Padding="18"
                                             Margin="0,0,0,16"
                                             Background="White"
                                             Visibility="{Binding IsLedgerHistoryCardOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="History Detail"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandMidnightBrush}"/>
                                        <TextBlock Text="Full view of the selected budget ledger history."
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Margin="16,0,0,0"
                                            Content="CLOSE"
                                            Height="34"
                                            VerticalAlignment="Top"
                                            Style="{StaticResource SecondaryActionButton}"
                                            Command="{Binding CloseLedgerHistoryCardCommand}"/>
                                </Grid>

                                <UniformGrid Margin="0,16,0,0"
                                             Columns="2">
                                    <Border Margin="0,0,8,10"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="DATE"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedLedgerEntry.EntryDate, StringFormat={}{0:MMMM dd, yyyy}, TargetNullValue=--}"
                                                       Margin="0,6,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="8,0,0,10"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="ENTRY TYPE"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedLedgerEntry.EntryType, TargetNullValue=--}"
                                                       Margin="0,6,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,0,8,10"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="SOURCE"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedLedgerEntry.FeatureSource, TargetNullValue=--}"
                                                       Margin="0,6,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="8,0,0,10"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="RELEASE"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedLedgerEntry.ReleaseKind, TargetNullValue=--}"
                                                       Margin="0,6,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,0,8,10"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="RECIPIENTS"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedLedgerEntry.RecipientCount, StringFormat=N0, TargetNullValue=--}"
                                                       Margin="0,6,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="8,0,0,10"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="PROGRAM"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedLedgerEntry.ProgramName, TargetNullValue=--}"
                                                       Margin="0,6,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,0,8,10"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="TOTAL"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedLedgerEntry.TotalAmount, StringFormat={}{0:N2}, TargetNullValue=--}"
                                                       Margin="0,6,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="8,0,0,10"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="GOVERNMENT"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedLedgerEntry.GovernmentPortion, StringFormat={}{0:N2}, TargetNullValue=--}"
                                                       Margin="0,6,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,0,8,0"
                                            Padding="12"
                                            CornerRadius="12"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="PRIVATE"
                                                       FontSize="10"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding SelectedLedgerEntry.PrivatePortion, StringFormat={}{0:N2}, TargetNullValue=--}"
                                                       Margin="0,6,0,0"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <Border Margin="0,6,0,0"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="REMARKS"
                                                   FontSize="10"
                                                   Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedLedgerEntry.Remarks, TargetNullValue=--}"
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource BrandMidnightBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Padding="18"
                                             Margin="0,0,0,16"
                                             Background="White">
                            <StackPanel>
                                <TextBlock Text="GGMS Government Snapshot"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Text="{Binding LatestGovernmentSyncLabel}"
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap"/>

                                <UniformGrid Margin="0,14,0,0"
                                             Columns="1">
                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            CornerRadius="12"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding GovernmentOfficeCode, StringFormat=Office Code: {0}}"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                            <TextBlock Text="{Binding GovernmentOfficeName, StringFormat=Office: {0}}"
                                                       Margin="0,6,0,0"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Margin="0,0,0,10"
                                            Padding="14"
                                            CornerRadius="12"
                                            Background="#F8FAFC"
                                            BorderBrush="{StaticResource BrandBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding GovernmentAllocated, StringFormat=Allocated: {0:N2}}"
                                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                                            <TextBlock Text="{Binding GovernmentSpentReference, StringFormat=GGMS Spent Ref.: {0:N2}}"
                                                       Margin="0,6,0,0"
                                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Padding="18"
                                             Margin="0,0,0,16"
                                             Background="White">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="Programs"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                </DockPanel>

                                <DataGrid Margin="0,14,0,0"
                                          ItemsSource="{Binding Programs}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          IsReadOnly="True"
                                          MinHeight="220"
                                          MaxHeight="260"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowHeaderWidth="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Code"
                                                            Binding="{Binding ProgramCode}"
                                                            Width="90"/>
                                        <DataGridTextColumn Header="Program"
                                                            Binding="{Binding ProgramName}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="Status"
                                                            Binding="{Binding DistributionStatus}"
                                                            Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </materialDesign:Card>

                        <materialDesign:Card Padding="18"
                                             Background="White">
                            <StackPanel>
                                <DockPanel>
                                    <TextBlock Text="Private Donations"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                </DockPanel>

                                <DataGrid Margin="0,14,0,0"
                                          ItemsSource="{Binding Donations}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          MinHeight="220"
                                          MaxHeight="260"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowHeaderWidth="0">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Date"
                                                            Binding="{Binding DateReceived, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                            Width="100"/>
                                        <DataGridTextColumn Header="Donor"
                                                            Binding="{Binding DonorName}"
                                                            Width="*"/>
                                        <DataGridTextColumn Header="Amount"
                                                            Binding="{Binding Amount, StringFormat=N2}"
                                                            Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </materialDesign:Card>
                    </StackPanel>
                </Grid>

                <!-- Backdrop -->
                <Border Grid.RowSpan="3"
                        Panel.ZIndex="19"
                        Background="#660F172A"
                        CornerRadius="20"
                        Visibility="{Binding IsAnySetupPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Donation panel -->
                <materialDesign:Card Grid.RowSpan="3"
                                     Panel.ZIndex="20"
                                     Width="720"
                                     Margin="0,24,0,24"
                                     Padding="18"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Stretch"
                                     Background="White"
                                     Visibility="{Binding IsDonationPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Private Donation Panel"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           Text="Record the donor type, amount, date received, proof details, optional supporting file, and remarks here."
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Margin="16,0,0,0"
                                    Content="CLOSE"
                                    Height="36"
                                    VerticalAlignment="Top"
                                    Style="{StaticResource SecondaryActionButton}"
                                    Command="{Binding CloseDonationPanelCommand}"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,16,0,0"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <UniformGrid Columns="2">
                                    <ComboBox Margin="0,0,8,10"
                                              ItemsSource="{Binding DonorTypes}"
                                              SelectedItem="{Binding SelectedDonorType}"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              materialDesign:HintAssist.Hint="Donor type"/>
                                    <ComboBox Margin="8,0,0,10"
                                              ItemsSource="{Binding ProofTypes}"
                                              SelectedItem="{Binding SelectedProofType}"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              materialDesign:HintAssist.Hint="Proof type"/>
                                </UniformGrid>

                                <TextBox Margin="0,0,0,10"
                                         Text="{Binding DonorName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Donor name"/>

                                <UniformGrid Columns="2">
                                    <TextBox Margin="0,0,8,10"
                                             Text="{Binding DonationAmountText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Amount"/>
                                    <DatePicker Margin="8,0,0,10"
                                                SelectedDate="{Binding DonationDateReceived}"
                                                materialDesign:HintAssist.Hint="Date received"/>
                                </UniformGrid>

                                <UniformGrid Columns="2">
                                    <TextBox Margin="0,0,8,10"
                                             Text="{Binding DonationReferenceNumber, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Reference number"/>
                                    <TextBox Margin="8,0,0,10"
                                             Text="{Binding ProofReferenceNumber, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Proof reference"/>
                                </UniformGrid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             IsReadOnly="True"
                                             Text="{Binding ProofFilePath}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Optional proof file"/>

                                    <Button Grid.Column="2"
                                            Content="Browse Proof"
                                            Height="42"
                                            Style="{StaticResource SecondaryActionButton}"
                                            Command="{Binding BrowseProofCommand}"/>
                                </Grid>

                                <TextBox Height="100"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding DonationRemarks, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Remarks / liquidation notes"/>

                                <Button Content="RECORD PRIVATE DONATION"
                                        Margin="0,14,0,0"
                                        Height="42"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding RecordDonationCommand}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>

                <!-- Program panel -->
                <materialDesign:Card Grid.RowSpan="3"
                                     Panel.ZIndex="20"
                                     Width="720"
                                     Margin="0,24,0,24"
                                     Padding="18"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Stretch"
                                     Background="White"
                                     Visibility="{Binding IsProgramPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Program Setup Panel"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           Text="Create the project, define the assistance item or amount, keep dates optional, and save the program here before it moves to distribution."
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Margin="16,0,0,0"
                                    Content="CLOSE"
                                    Height="36"
                                    VerticalAlignment="Top"
                                    Style="{StaticResource SecondaryActionButton}"
                                    Command="{Binding CloseProgramPanelCommand}"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,16,0,0"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <UniformGrid Columns="2">
                                    <TextBox Margin="0,0,8,10"
                                             Text="{Binding ProgramCode, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Program code"/>
                                    <ComboBox Margin="8,0,0,10"
                                              ItemsSource="{Binding ProgramTypes}"
                                              SelectedItem="{Binding SelectedProgramType}"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              materialDesign:HintAssist.Hint="Program type"/>
                                </UniformGrid>

                                <TextBox Margin="0,0,0,10"
                                         Text="{Binding ProgramName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Program / event name"/>

                                <UniformGrid Columns="2">
                                    <TextBox Margin="0,0,8,10"
                                             Text="{Binding ProgramAssistanceType, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Assistance type"/>
                                    <TextBox Margin="8,0,0,10"
                                             Text="{Binding ProgramUnitAmountText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Unit amount"/>
                                </UniformGrid>

                                <TextBox Margin="0,0,0,10"
                                         Text="{Binding ProgramItemDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Item description / package details"/>

                                <UniformGrid Columns="2">
                                    <DatePicker Margin="0,0,8,10"
                                                SelectedDate="{Binding ProgramStartDate}"
                                                materialDesign:HintAssist.Hint="Optional start date"/>
                                    <DatePicker Margin="8,0,0,10"
                                                SelectedDate="{Binding ProgramEndDate}"
                                                materialDesign:HintAssist.Hint="Optional end date"/>
                                </UniformGrid>

                                <UniformGrid Columns="2">
                                    <TextBox Margin="0,0,8,10"
                                             Text="{Binding ProgramBudgetCapText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Project budget cap"/>
                                    <ComboBox Margin="8,0,0,10"
                                              ItemsSource="{Binding ProgramDistributionStatuses}"
                                              SelectedItem="{Binding SelectedProgramDistributionStatus}"
                                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                              materialDesign:HintAssist.Hint="Distribution status"/>
                                </UniformGrid>

                                <TextBox Height="100"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding ProgramDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Description"/>

                                <Button Content="CREATE PROGRAM"
                                        Margin="0,14,0,0"
                                        Height="42"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding CreateProgramCommand}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>

                <!-- Seminar panel -->
                <materialDesign:Card Grid.RowSpan="3"
                                     Panel.ZIndex="20"
                                     Width="720"
                                     Margin="0,24,0,24"
                                     Padding="18"
                                     HorizontalAlignment="Right"
                                     VerticalAlignment="Stretch"
                                     Background="White"
                                     Visibility="{Binding IsSeminarPanelOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Seminar Setup Panel"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrandMidnightBrush}"/>
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource BrandTextSecondaryBrush}"
                                           Text="Record the seminar title, credentials, support kind, amount or goods details, and the agenda here."
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Margin="16,0,0,0"
                                    Content="CLOSE"
                                    Height="36"
                                    VerticalAlignment="Top"
                                    Style="{StaticResource SecondaryActionButton}"
                                    Command="{Binding CloseSeminarPanelCommand}"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,16,0,0"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <UniformGrid Columns="2">
                                    <TextBox Margin="0,0,8,10"
                                             Text="{Binding SeminarCode, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             materialDesign:HintAssist.Hint="Seminar code"/>
                                    <DatePicker Margin="8,0,0,10"
                                                SelectedDate="{Binding SeminarDate}"
                                                materialDesign:HintAssist.Hint="Seminar date"/>
                                </UniformGrid>

                                <TextBox Margin="0,0,0,10"
                                         Text="{Binding SeminarTitle, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Seminar title"/>

                                <TextBox Margin="0,0,0,10"
                                         Text="{Binding SeminarCredentials, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Speaker / organizer credentials"/>

                                <ComboBox Margin="0,0,0,10"
                                          ItemsSource="{Binding SeminarSupportKinds}"
                                          SelectedItem="{Binding SelectedSeminarSupportKind}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          materialDesign:HintAssist.Hint="Support kind"/>

                                <TextBox Margin="0,0,0,10"
                                         Text="{Binding SeminarAmountText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Visibility="{Binding SeminarAmountVisibility}"
                                         materialDesign:HintAssist.Hint="Amount for seminar support"/>

                                <TextBox Margin="0,0,0,10"
                                         Text="{Binding SeminarGoodsDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         Visibility="{Binding SeminarGoodsVisibility}"
                                         materialDesign:HintAssist.Hint="Goods / package details"/>

                                <TextBox Height="110"
                                         Margin="0,0,0,10"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding SeminarAgenda, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Seminar agenda"/>

                                <Button Content="CREATE SEMINAR"
                                        Height="42"
                                        Style="{StaticResource GoldActionButton}"
                                        Command="{Binding CreateSeminarCommand}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>



