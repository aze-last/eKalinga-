<UserControl x:Class="AttendanceShiftingManagement.Views.BudgetPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BrandSurfaceBrush}">
    <UserControl.Resources>
        <Style x:Key="RailButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BrandMidnightBrush}" />
        </Style>

        <Style x:Key="GoldActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="{DynamicResource BrandYellowBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource BrandGoldTextBrush}" />
        </Style>

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="OverviewPanelStyle" TargetType="Border" BasedOn="{StaticResource PanelCardStyle}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding DrawerVisibility}" Value="Visible">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="24"
                Padding="20"
                CornerRadius="22"
                Background="{DynamicResource ThemeCardRaisedBrush}"
                BorderBrush="{DynamicResource BrandBorderBrush}"
                BorderThickness="1">
            <StackPanel>
                <Button Content="Dashboard"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding OpenDashboardPanelCommand}" />
                <Button Content="Sync GGMS Budget"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding SyncGovernmentBudgetCommand}" />
                <Button Content="Budget Ledger"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding OpenLedgerPanelCommand}" />
                <Button Content="Private Donations"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding OpenDonationPanelCommand}" />
                <Button Content="Programs"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding OpenProgramPanelCommand}" />
                <Button Content="Seminars"
                        Style="{StaticResource RailButtonStyle}"
                        Command="{Binding OpenSeminarPanelCommand}" />
                <Button Content="Refresh Workspace"
                        Height="42"
                        Margin="0,12,0,0"
                        Style="{StaticResource GoldActionButton}"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="2"
                      Margin="0,24,24,24"
                      VerticalScrollBarVisibility="Auto">
            <Border Padding="20"
                    CornerRadius="22"
                    Background="{DynamicResource ThemeCardBrush}"
                    BorderBrush="{DynamicResource BrandBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.6*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding CurrentPanelTitle}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding CurrentPanelSubtitle}"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top">
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding StatusBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Right" />
                        </StackPanel>
                    </Grid>

                    <!-- Dashboard Panel -->
                    <Border Style="{StaticResource OverviewPanelStyle}"
                            Visibility="{Binding DashboardVisibility}">
                        <StackPanel>
                            <UniformGrid Columns="4" Margin="0,0,0,18">
                                <materialDesign:Card Margin="0,0,12,0"
                                                     Padding="16"
                                                     Background="{StaticResource BrandMidnightBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CombinedAvailable, StringFormat=N2}"
                                                   FontSize="26"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                        <TextBlock Text="COMBINED AVAILABLE"
                                                   FontSize="10"
                                                   Foreground="#D6E3FF"/>
                                    </StackPanel>
                                </materialDesign:Card>

                                <materialDesign:Card Margin="0,0,12,0"
                                                     Padding="16"
                                                     Background="#0F766E">
                                    <StackPanel>
                                        <TextBlock Text="{Binding GovernmentAvailable, StringFormat=N2}"
                                                   FontSize="26"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                        <TextBlock Text="GOVERNMENT AVAILABLE"
                                                   FontSize="10"
                                                   Foreground="#CCFBF1"/>
                                    </StackPanel>
                                </materialDesign:Card>

                                <materialDesign:Card Margin="0,0,12,0"
                                                     Padding="16"
                                                     Background="{StaticResource BrandYellowBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding PrivateAvailable, StringFormat=N2}"
                                                   FontSize="26"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandGoldTextBrush}"/>
                                        <TextBlock Text="PRIVATE AVAILABLE"
                                                   FontSize="10"
                                                   Foreground="#7A5A00"/>
                                    </StackPanel>
                                </materialDesign:Card>

                                <materialDesign:Card Padding="16"
                                                     Background="{StaticResource BrandSuccessBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ReleasedTotal, StringFormat=N2}"
                                                   FontSize="26"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                        <TextBlock Text="TOTAL RELEASED"
                                                   FontSize="10"
                                                   Foreground="#DDF7E5"/>
                                    </StackPanel>
                                </materialDesign:Card>
                            </UniformGrid>

                            <TextBlock Text="Budget Overview"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrandMidnightBrush}"
                                       Margin="0,0,0,12" />
                            <TextBlock Text="Use left rail to switch between budget operations. The budget ledger shows all financial transactions."
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- Budget Ledger Panel -->
                    <Border Style="{StaticResource PanelCardStyle}"
                            Visibility="{Binding LedgerVisibility}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Budget Ledger / Liquidation"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Text="Complete financial history of all budget transactions and releases."
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="EXPORT"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding ExportLedgerCommand}" />
                            </DockPanel>

                            <StackPanel Orientation="Horizontal"
                                        Margin="0,18,0,12">
                                <Border Margin="0,0,8,0"
                                        Padding="14,8"
                                        CornerRadius="17"
                                        Background="{StaticResource BrandMidnightBrush}">
                                    <TextBlock Text="ALL"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>
                                </Border>
                                <Border Margin="0,0,8,0"
                                        Padding="14,8"
                                        CornerRadius="17"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="RELEASES"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                </Border>
                                <Border Margin="0,0,8,0"
                                        Padding="14,8"
                                        CornerRadius="17"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="PROGRAMS"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                </Border>
                                <Border Padding="14,8"
                                        CornerRadius="17"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="DONATIONS"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                </Border>
                            </StackPanel>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding LedgerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Search program, source, or remarks" />

                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding LedgerSourceFilters}"
                                          SelectedItem="{Binding SelectedLedgerSourceFilter}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          materialDesign:HintAssist.Hint="Source filter" />
                            </Grid>

                            <DataGrid ItemsSource="{Binding LedgerEntriesView}"
                                      SelectedItem="{Binding SelectedLedgerEntry, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      MinHeight="320"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      Background="{DynamicResource ThemeCardSubtleBrush}"
                                      BorderBrush="{StaticResource BrandBorderBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date"
                                                        Binding="{Binding EntryDate, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                        Width="130"/>
                                    <DataGridTextColumn Header="Entry"
                                                        Binding="{Binding EntryType}"
                                                        Width="110"/>
                                    <DataGridTextColumn Header="Source"
                                                        Binding="{Binding FeatureSource}"
                                                        Width="150"/>
                                    <DataGridTextColumn Header="Release"
                                                        Binding="{Binding ReleaseKind}"
                                                        Width="110"/>
                                    <DataGridTextColumn Header="Program"
                                                        Binding="{Binding ProgramName}"
                                                        Width="260"/>
                                    <DataGridTextColumn Header="Recipients"
                                                        Binding="{Binding RecipientCount}"
                                                        Width="100"/>
                                    <DataGridTextColumn Header="Total"
                                                        Binding="{Binding TotalAmount, StringFormat=N2}"
                                                        Width="130"/>
                                    <DataGridTextColumn Header="Gov't"
                                                        Binding="{Binding GovernmentPortion, StringFormat=N2}"
                                                        Width="130"/>
                                    <DataGridTextColumn Header="Private"
                                                        Binding="{Binding PrivatePortion, StringFormat=N2}"
                                                        Width="130"/>
                                    <DataGridTextColumn Header="Remarks"
                                                        Binding="{Binding Remarks}"
                                                        Width="340"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <!-- Donation Panel -->
                    <Border Style="{StaticResource PanelCardStyle}"
                            Visibility="{Binding DonationPanelVisibility}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Private Donation Entry"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Text="Record private donor contributions with proof attachments and amount details."
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="CLOSE"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding ClosePanelCommand}" />
                            </DockPanel>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0"
                                         Grid.Column="0"
                                         Margin="0,0,12,12"
                                         Text="{Binding DonationAmountText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Donation Amount" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="12,0,0,12"
                                         Text="{Binding DonorName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Donor Name" />

                                <TextBox Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         Margin="0,0,0,12"
                                         Text="{Binding DonationRemarks, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Remarks" />

                                <Button Grid.Row="2"
                                        Grid.Column="0"
                                        Content="Browse Proof"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Command="{Binding BrowseProofCommand}" />
                                <Button Grid.Row="2"
                                        Grid.Column="1"
                                        Content="RECORD PRIVATE DONATION"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Command="{Binding RecordDonationCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Program Panel -->
                    <Border Style="{StaticResource PanelCardStyle}"
                            Visibility="{Binding ProgramPanelVisibility}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Program Setup"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Text="Create new ayuda projects, define distribution parameters, and set budget caps."
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="CLOSE"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding ClosePanelCommand}" />
                            </DockPanel>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0"
                                         Grid.Column="0"
                                         Margin="0,0,12,12"
                                         Text="{Binding ProgramName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Program Name" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="12,0,0,12"
                                         Text="{Binding ProgramBudgetCapText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Budget Cap" />

                                <TextBox Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         Margin="0,0,0,12"
                                         Text="{Binding ProgramDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Description" />

                                <Button Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Content="CREATE PROGRAM"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Command="{Binding CreateProgramCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Seminar Panel -->
                    <Border Style="{StaticResource PanelCardStyle}"
                            Visibility="{Binding SeminarPanelVisibility}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Seminar Setup"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Text="Record seminar events, participant counts, and associated costs."
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="CLOSE"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding ClosePanelCommand}" />
                            </DockPanel>

                            <Grid Margin="0,18,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBox Grid.Row="0"
                                         Grid.Column="0"
                                         Margin="0,0,12,12"
                                         Text="{Binding SeminarTitle, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Seminar Title" />
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="12,0,0,12"
                                         Text="{Binding SeminarAmountText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Total Cost" />

                                <TextBox Grid.Row="1"
                                         Grid.ColumnSpan="2"
                                         Margin="0,0,0,12"
                                         Text="{Binding SeminarAgenda, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                         materialDesign:HintAssist.Hint="Description" />

                                <Button Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Content="CREATE SEMINAR"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                        Command="{Binding CreateSeminarCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- History Detail Panel -->
                    <Border Style="{StaticResource PanelCardStyle}"
                            Visibility="{Binding HistoryDetailVisibility}">
                        <StackPanel>
                            <DockPanel LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="History Detail"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrandMidnightBrush}" />
                                    <TextBlock Text="Full view of selected budget ledger history entry."
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Content="CLOSE"
                                        Style="{StaticResource SecondaryActionButton}"
                                        Command="{Binding CloseHistoryDetailCommand}" />
                            </DockPanel>

                            <UniformGrid Margin="0,16,0,0"
                                         Columns="2">
                                <Border Margin="0,0,8,10"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="DATE"
                                                   FontSize="10"
                                                   Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedLedgerEntry.EntryDate, StringFormat={}{0:MMMM dd, yyyy}, TargetNullValue=--}"
                                                   Margin="0,6,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandMidnightBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="8,0,0,10"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="ENTRY TYPE"
                                                   FontSize="10"
                                                   Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedLedgerEntry.EntryType, TargetNullValue=--}"
                                                   Margin="0,6,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandMidnightBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,8,10"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="SOURCE"
                                                   FontSize="10"
                                                   Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedLedgerEntry.FeatureSource, TargetNullValue=--}"
                                                   Margin="0,6,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandMidnightBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="8,0,0,10"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="RELEASE"
                                                   FontSize="10"
                                                   Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedLedgerEntry.ReleaseKind, TargetNullValue=--}"
                                                   Margin="0,6,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandMidnightBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,8,10"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="TOTAL"
                                                   FontSize="10"
                                                   Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedLedgerEntry.TotalAmount, StringFormat={}{0:N2}, TargetNullValue=--}"
                                                   Margin="0,6,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandMidnightBrush}"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="8,0,0,10"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="#F8FAFC"
                                        BorderBrush="{StaticResource BrandBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="REMARKS"
                                                   FontSize="10"
                                                   Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedLedgerEntry.Remarks, TargetNullValue=--}"
                                                   Margin="0,6,0,0"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrandMidnightBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>



