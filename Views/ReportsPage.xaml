<UserControl x:Class="AttendanceShiftingManagement.Views.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1440"
             Background="{DynamicResource BrandSurfaceBrush}"
             Loaded="ReportsPage_Loaded">
    <UserControl.Resources>
        <Style x:Key="ReportsCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="24" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Pattern A Header -->
        <materialDesign:Card Grid.Row="0" Padding="12,8" Background="{DynamicResource ThemeCardBrush}" UniformCornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Title -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="8,0">
                    <TextBlock Text="{Binding ReportTitle}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource BrandMidnightBrush}"/>
                    <TextBlock Text="{Binding ReportSubtitle}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                </StackPanel>

                <!-- Center: Navigation -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Padding="8"
                            Command="{Binding NavigatePreviousCommand}"
                            ToolTip="Previous Report Template">
                        <materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24"/>
                    </Button>
                    
                    <Border Margin="12,0" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="8" Padding="16,6">
                        <TextBlock VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}">
                            <Run Text="{Binding CurrentPosition, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>

                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Padding="8"
                            Command="{Binding NavigateNextCommand}"
                            ToolTip="Next Report Template">
                        <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24"/>
                    </Button>
                </StackPanel>

                <!-- Right: Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="BROWSE TEMPLATES" 
                            Style="{StaticResource SecondaryActionButton}" 
                            Height="40" 
                            Padding="16,0"
                            Click="Browse_Click"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <ScrollViewer Grid.Row="1" Margin="0,18,0,0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Configuration Sidebar -->
                <StackPanel Grid.Column="0">
                    <!-- Dashboard Navigation -->
                    <Button Content="DASHBOARD" 
                            Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="45" Margin="0,0,0,18"/>

                    <Border Style="{StaticResource ReportsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="REPORT CONFIGURATION" FontSize="11" FontWeight="Bold" 
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,20"/>

                            <TextBlock Text="Date Range" FontSize="12" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,0,0,8"/>
                            <Border Padding="12,0" Height="48" CornerRadius="12" 
                                    Background="{DynamicResource ThemeInputSurfaceBrush}" 
                                    BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <DatePicker Grid.Column="0" SelectedDate="{Binding DateFrom}" 
                                                materialDesign:HintAssist.Hint="From" BorderThickness="0" 
                                                Background="Transparent" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="-" VerticalAlignment="Center" Margin="4,0"/>
                                    <DatePicker Grid.Column="2" SelectedDate="{Binding DateTo}" 
                                                materialDesign:HintAssist.Hint="To" BorderThickness="0" 
                                                Background="Transparent" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <StackPanel Visibility="{Binding IsProgramFilterRelevant, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Scope / Program Override" FontSize="12" FontWeight="SemiBold" 
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="4,16,0,8"/>
                                <ComboBox ItemsSource="{Binding ProgramFilters}" 
                                          SelectedItem="{Binding SelectedProgramFilter}" 
                                          DisplayMemberPath="Name" 
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                            </StackPanel>

                            <Button Content="REFRESH DATA" Command="{Binding RefreshReportCommand}" 
                                    Margin="0,24,0,0" Height="48" Style="{StaticResource GoldActionButton}"/>
                        </StackPanel>
                    </Border>

                    <!-- Export Actions Card -->
                    <Border Style="{StaticResource ReportsCardStyle}">
                        <StackPanel>
                            <TextBlock Text="EXPORT &amp; DISTRIBUTION" FontSize="11" FontWeight="Bold" 
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,20"/>
                            
                            <Button Content="PRINT PREVIEW" Command="{Binding PrintReportCommand}" 
                                    Margin="0,0,0,10" Height="44" Style="{StaticResource SecondaryActionButton}"/>
                            <Button Content="SAVE AS PDF" Command="{Binding SavePdfCommand}" 
                                    Margin="0,0,0,10" Height="44" Style="{StaticResource SecondaryActionButton}"/>
                            <Button Content="EXPORT CSV" Command="{Binding ExportCsvCommand}" 
                                    Height="44" Style="{StaticResource SecondaryActionButton}"/>
                        </StackPanel>
                    </Border>

                    <!-- Summary Info Card -->
                    <Border Style="{StaticResource ReportsCardStyle}" Background="{DynamicResource ThemeAccentSoftBrush}">
                        <StackPanel>
                            <TextBlock Text="TEMPLATE GUIDANCE" FontSize="11" FontWeight="Bold" 
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding TemplateDescription}" FontSize="12" 
                                       Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap"/>
                            <Separator Margin="0,12" Background="{DynamicResource ThemeAccentBorderBrush}"/>
                            <TextBlock Text="{Binding LayoutSummary}" FontSize="11" FontWeight="Bold" 
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Preview Area -->
                <StackPanel Grid.Column="2">
                    <!-- Metrics Row -->
                    <ItemsControl ItemsSource="{Binding Metrics}" Margin="0,0,0,18">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ReportsCardStyle}" Margin="0,0,12,0" Padding="20,16">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}" FontSize="11" FontWeight="Bold" 
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding Value}" FontSize="28" FontWeight="Bold" 
                                                   Foreground="{DynamicResource BrandMidnightBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Data Workspace -->
                    <Border Style="{StaticResource ReportsCardStyle}" Padding="0">
                        <StackPanel>
                            <Border Padding="24,16" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BrandBorderBrush}">
                                <Grid>
                                    <TextBlock Text="Preview Workspace" FontSize="16" FontWeight="Bold" 
                                               Foreground="{DynamicResource BrandMidnightBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding RangeSummary}" FontSize="12" 
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}" 
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <DataGrid ItemsSource="{Binding PreviewRows}"
                                      AutoGenerateColumns="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      MinHeight="500"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      SelectionUnit="FullRow">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{DynamicResource ThemeCardSubtleBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource BrandMidnightBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="Padding" Value="16,12" />
                                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
                                    </Style>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Resources>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
