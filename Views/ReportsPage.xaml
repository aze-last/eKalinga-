<UserControl x:Class="AttendanceShiftingManagement.Views.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BrandSurfaceBrush}">
    <UserControl.Resources>
        <Style x:Key="ReportsCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ReportsRaisedCardStyle" TargetType="Border" BasedOn="{StaticResource ReportsCardStyle}">
            <Setter Property="Background" Value="{DynamicResource ThemeCardRaisedBrush}" />
        </Style>
        <Style x:Key="ReportsTintCardStyle" TargetType="Border" BasedOn="{StaticResource ReportsCardStyle}">
            <Setter Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource ReportsRaisedCardStyle}" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Reports" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" />
                        <TextBlock Margin="0,8,0,0" Text="Centralized summaries, export-ready tables, and print-ready reports across aid requests, beneficiaries, budget, and distribution workflows." Foreground="{DynamicResource BrandTextSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,12,0,0" Text="{Binding StatusMessage}" FontWeight="SemiBold" Foreground="{Binding StatusBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1" Padding="16" CornerRadius="18" Background="{DynamicResource ThemeAccentSoftBrush}" BorderBrush="{DynamicResource ThemeAccentBorderBrush}" BorderThickness="1">
                        <StackPanel Width="240">
                            <TextBlock Text="PDF Layout" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding LayoutSummary}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding ExportHint}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource ReportsRaisedCardStyle}" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="0.9*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" Margin="0,0,12,0" ItemsSource="{Binding ReportTypeOptions}" SelectedItem="{Binding SelectedReportType}" DisplayMemberPath="Label" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:HintAssist.Hint="Report Type" />
                    <ComboBox Grid.Column="1" Margin="0,0,12,0" ItemsSource="{Binding ProgramFilters}" SelectedItem="{Binding SelectedProgramFilter}" DisplayMemberPath="Name" IsEnabled="{Binding IsProgramFilterRelevant}" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:HintAssist.Hint="Program / Project" />
                    <DatePicker Grid.Column="2" Margin="0,0,12,0" SelectedDate="{Binding DateFrom}" materialDesign:HintAssist.Hint="Date From" />
                    <DatePicker Grid.Column="3" Margin="0,0,12,0" SelectedDate="{Binding DateTo}" materialDesign:HintAssist.Hint="Date To" />
                    <WrapPanel Grid.Column="4">
                        <Button Content="REFRESH" Margin="0,0,10,0" Style="{StaticResource SecondaryActionButton}" Command="{Binding RefreshReportCommand}" />
                        <Button Content="EXPORT CSV" Margin="0,0,10,0" Style="{StaticResource SecondaryActionButton}" Command="{Binding ExportCsvCommand}" />
                        <Button Content="PRINT / SAVE AS PDF" Style="{StaticResource GoldActionButton}" Command="{Binding PrintReportCommand}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <ItemsControl Grid.Row="2" Margin="0,0,0,18" ItemsSource="{Binding Metrics}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ReportsCardStyle}" Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                <TextBlock Margin="0,12,0,0" Text="{Binding Value}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" />
                                <TextBlock Margin="0,8,0,0" Text="{Binding Note}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid Grid.Row="3" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource ReportsCardStyle}" Margin="0,0,18,0">
                    <StackPanel>
                        <TextBlock Text="{Binding ReportTitle}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" />
                        <TextBlock Margin="0,8,0,0" Text="{Binding ReportSubtitle}" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,12,0,0" Text="{Binding TemplateDescription}" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,18,0,0" Text="Highlights" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                        <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Highlights}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" Padding="14" CornerRadius="16" Background="{DynamicResource ThemeAccentSoftBrush}" BorderBrush="{DynamicResource ThemeAccentBorderBrush}" BorderThickness="1">
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource BrandMidnightBrush}" TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ReportsCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Report Summary" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" />
                        <TextBox Margin="0,14,0,0" Text="{Binding RangeSummary, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="Date Range" />
                        <TextBox Margin="0,12,0,0" Text="{Binding ProgramSummary, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="Program Scope" />
                        <TextBox Margin="0,12,0,0" Text="{Binding LayoutSummary, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource MaterialDesignOutlinedTextBox}" materialDesign:HintAssist.Hint="PDF Output" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource ReportsCardStyle}">
                <StackPanel>
                    <TextBlock Text="Preview Table" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" />
                    <TextBlock Margin="0,8,0,0" Text="This preview grid is the same dataset used for CSV export and the printable report shell." Foreground="{DynamicResource BrandTextSecondaryBrush}" TextWrapping="Wrap" />
                    <DataGrid Margin="0,16,0,0"
                              ItemsSource="{Binding PreviewRows}"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              MinHeight="360"
                              Background="{DynamicResource ThemeCardSubtleBrush}"
                              BorderBrush="{DynamicResource BrandBorderBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
