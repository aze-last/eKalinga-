<UserControl x:Class="AttendanceShiftingManagement.Views.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BrandSurfaceBrush}">
    <UserControl.Resources>
        <Style x:Key="ReportsCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ReportsRaisedCardStyle" TargetType="Border" BasedOn="{StaticResource ReportsCardStyle}">
            <Setter Property="Background" Value="{DynamicResource ThemeCardRaisedBrush}" />
        </Style>
        <Style x:Key="ReportsTintCardStyle" TargetType="Border" BasedOn="{StaticResource ReportsCardStyle}">
            <Setter Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 1. Header & Summary Card -->
            <Border Grid.Row="0" Style="{StaticResource ReportsRaisedCardStyle}" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Executive Reports" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" DockPanel.Dock="Left" />
                            <Button Content="Back to Dashboard" 
                                    Margin="24,0,0,0"
                                    Style="{StaticResource SecondaryActionButton}"
                                    Command="{Binding DataContext.ShowDashboardCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                    VerticalAlignment="Center"
                                    DockPanel.Dock="Left" />
                        </DockPanel>
                        <TextBlock Margin="0,8,0,0" Text="Analyze automated summaries, export datasets, and generate official printable documentation." Foreground="{DynamicResource BrandTextSecondaryBrush}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <materialDesign:PackIcon Kind="ClockOutline" Foreground="{DynamicResource BrandTextSecondaryBrush}" VerticalAlignment="Center" />
                            <TextBlock Margin="8,0,0,0" Text="Last updated just now" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Padding="16" CornerRadius="18" Background="{DynamicResource ThemeAccentSoftBrush}" BorderBrush="{DynamicResource ThemeAccentBorderBrush}" BorderThickness="1">
                        <StackPanel Width="240">
                            <TextBlock Text="READY FOR EXPORT" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandSuccessBrush}" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding LayoutSummary}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Margin="0,8,0,0" Text="{Binding ExportHint}" FontSize="12" Foreground="{DynamicResource BrandTextSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 2. Command Hub (Filters & Actions) -->
            <Border Grid.Row="1" Style="{StaticResource ReportsRaisedCardStyle}" Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" Margin="0,0,12,0" ItemsSource="{Binding ReportTypeOptions}" SelectedItem="{Binding SelectedReportType}" DisplayMemberPath="Label" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:HintAssist.Hint="Active Module" />
                    <ComboBox Grid.Column="1" Margin="0,0,12,0" ItemsSource="{Binding ProgramFilters}" SelectedItem="{Binding SelectedProgramFilter}" DisplayMemberPath="Name" IsEnabled="{Binding IsProgramFilterRelevant}" Style="{StaticResource MaterialDesignOutlinedComboBox}" materialDesign:HintAssist.Hint="Scope Override" />
                    
                    <Border Grid.Column="2" Margin="0,0,12,0" Padding="12,0" VerticalAlignment="Center" Height="48" CornerRadius="12" Background="{DynamicResource ThemeCardSubtleBrush}" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <DatePicker SelectedDate="{Binding DateFrom}" materialDesign:HintAssist.Hint="From" Width="100" BorderThickness="0" Background="Transparent" />
                            <TextBlock Text="to" VerticalAlignment="Center" Margin="8,0" Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                            <DatePicker SelectedDate="{Binding DateTo}" materialDesign:HintAssist.Hint="To" Width="100" BorderThickness="0" Background="Transparent" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="REFRESH" Margin="0,0,10,0" Style="{StaticResource SecondaryActionButton}" Command="{Binding RefreshReportCommand}" />
                        <Button Content="EXPORT CSV" Margin="0,0,10,0" Style="{StaticResource SecondaryActionButton}" Command="{Binding ExportCsvCommand}" />
                        <Button Content="SAVE PDF" Margin="0,0,10,0" Style="{StaticResource GoldActionButton}" Command="{Binding SavePdfCommand}" />
                        <Button Padding="24,0" Content="PRINT PREVIEW" Style="{StaticResource SecondaryActionButton}" Command="{Binding PrintReportCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3. Intelligence Row (Metrics & Analytics) -->
            <Grid Grid.Row="2" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <!-- KPI Belt -->
                <ItemsControl Grid.Column="0" ItemsSource="{Binding Metrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ReportsCardStyle}" Margin="0,0,12,12">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                        <TextBlock Margin="0,8,0,0" Text="{Binding Value}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" />
                                    </StackPanel>
                                    <materialDesign:PackIcon Kind="TrendingUp" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.3" Foreground="{DynamicResource BrandSuccessBrush}" Width="24" Height="24" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Visual Distribution Analytics -->
                <Border Grid.Column="1" Style="{StaticResource ReportsCardStyle}" Margin="12,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Data Distribution" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" />
                        <TextBlock Text="Composition analysis for the current report scope." FontSize="11" Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                        
                        <StackPanel Margin="0,18,0,0">
                            <!-- Simulated Charts via Styled Borders -->
                            <TextBlock Text="Completion Rate" FontSize="12" Foreground="{DynamicResource BrandMidnightBrush}" />
                            <Grid Margin="0,6,0,14">
                                <ProgressBar Value="85" Height="10" Foreground="{DynamicResource BrandSuccessBrush}" Background="{DynamicResource ThemeCardSubtleBrush}" />
                                <TextBlock Text="85%" HorizontalAlignment="Right" Margin="0,-22,0,0" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource BrandSuccessBrush}" />
                            </Grid>

                            <TextBlock Text="Validation Status" FontSize="12" Foreground="{DynamicResource BrandMidnightBrush}" />
                            <Grid Margin="0,6,0,14">
                                <ProgressBar Value="92" Height="10" Foreground="#2563EB" Background="{DynamicResource ThemeCardSubtleBrush}" />
                                <TextBlock Text="92%" HorizontalAlignment="Right" Margin="0,-22,0,0" FontSize="11" FontWeight="Bold" Foreground="#2563EB" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 4. Data Preview Workspace -->
            <Border Grid.Row="3" Style="{StaticResource ReportsCardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Report Workspace" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource BrandTextSecondaryBrush}" Text="{Binding ReportSubtitle}" />
                        </StackPanel>
                        
                        <!-- Workspace Search -->
                        <Border Grid.Column="1" Background="{DynamicResource ThemeCardSubtleBrush}" CornerRadius="12" Padding="12,4" BorderBrush="{DynamicResource BrandBorderBrush}" BorderThickness="1">
                            <Grid>
                                <materialDesign:PackIcon Kind="Search" VerticalAlignment="Center" Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                <TextBox Margin="28,0,0,0" BorderThickness="0" Background="Transparent" materialDesign:HintAssist.Hint="Search in report..." VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </Grid>

                    <DataGrid ItemsSource="{Binding PreviewRows}"
                              AutoGenerateColumns="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              MinHeight="400"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectionUnit="FullRow">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource ThemeCardRaisedBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource BrandMidnightBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Padding" Value="12,14" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                                <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
