<Window x:Class="AttendanceShiftingManagement.Views.RoleSwitchPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Confirm Admin Switch"
        Height="270" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BrandSurfaceBrush}"
        Icon="/Images/app-icon.ico">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Admin Access Required"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="{StaticResource BrandMidnightBrush}"/>
            <TextBlock x:Name="PromptText"
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Foreground="#475569"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,20,0,0">
            <TextBlock Text="Password" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <PasswordBox x:Name="PasswordInput"
                         Height="38"
                         materialDesign:HintAssist.Hint="Enter Admin password"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel"
                    Width="110"
                    Margin="0,0,10,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Click="Cancel_Click"/>
            <Button Content="Continue"
                    Width="120"
                    Background="{StaticResource BrandRedBrush}"
                    Foreground="White"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="Continue_Click"/>
        </StackPanel>
    </Grid>
</Window>
