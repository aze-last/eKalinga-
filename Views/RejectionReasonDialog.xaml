<Window x:Class="AttendanceShiftingManagement.Views.RejectionReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Rejection Reason" Height="300" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrandSurfaceBrush}"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Rejection Reason" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <TextBox x:Name="ReasonTextBox"
                 Grid.Row="1"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 materialDesign:HintAssist.Hint="Please provide a reason for rejecting this leave request"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 VerticalScrollBarVisibility="Auto"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="CANCEL"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Height="40"
                    Width="100"
                    Margin="0,0,12,0"
                    Click="Cancel_Click"/>
            <Button Content="REJECT"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#EF4444"
                    BorderBrush="#EF4444"
                    Height="40"
                    Width="100"
                    Click="Reject_Click"/>
        </StackPanel>
    </Grid>
</Window>
