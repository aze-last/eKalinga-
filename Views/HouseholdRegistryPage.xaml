<UserControl x:Class="AttendanceShiftingManagement.Views.HouseholdRegistryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BrandSurfaceBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock Text="Household Registry"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource BrandMidnightBrush}"/>
            <TextBlock Text="Browse registered households, view members, and identify who is eligible for cash-for-work activities."
                       Margin="0,6,0,0"
                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,18">
            <materialDesign:Card Margin="8" Background="{StaticResource BrandMidnightBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding TotalHouseholds}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="REGISTERED HOUSEHOLDS" Foreground="#99FFFFFF" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="8" Background="{StaticResource BrandYellowBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding TotalMembers}" FontSize="28" FontWeight="Medium" Foreground="{StaticResource BrandGoldTextBrush}"/>
                    <TextBlock Text="HOUSEHOLD MEMBERS" Foreground="#7A5A00" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Margin="8" Background="{StaticResource BrandSuccessBrush}" Padding="16" BorderThickness="0">
                <StackPanel>
                    <TextBlock Text="{Binding CashForWorkEligibleCount}" FontSize="28" FontWeight="Medium" Foreground="White"/>
                    <TextBlock Text="CASH-FOR-WORK ELIGIBLE" Foreground="#99FFFFFF" FontSize="9"/>
                </StackPanel>
            </materialDesign:Card>
        </UniformGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Padding="16" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="Registered Households"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}"/>
                        <TextBox DockPanel.Dock="Right"
                                 Width="260"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 materialDesign:HintAssist.Hint="Search household..."/>
                    </DockPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding HouseholdsView}"
                              SelectedItem="{Binding SelectedHousehold}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding HouseholdCode}" Width="110"/>
                            <DataGridTextColumn Header="Head" Binding="{Binding HeadName}" Width="*"/>
                            <DataGridTextColumn Header="Address" Binding="{Binding AddressLine}" Width="220"/>
                            <DataGridTextColumn Header="Purok" Binding="{Binding Purok}" Width="100"/>
                            <DataGridTextColumn Header="Members" Binding="{Binding MemberCount}" Width="90"/>
                            <DataGridTextColumn Header="Eligible" Binding="{Binding EligibleMemberCount}" Width="90"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2" Padding="16" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Household Members"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrandMidnightBrush}"/>

                    <Border Grid.Row="1"
                            Margin="0,12,0,12"
                            Padding="12"
                            CornerRadius="8"
                            Background="{StaticResource BrandSurfaceBrush}"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedHousehold.HeadName, TargetNullValue=Select a household}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedHousehold.AddressLine, TargetNullValue=Household address appears here}" Foreground="{StaticResource BrandTextSecondaryBrush}" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding SelectedHousehold.ContactNumber, StringFormat='Contact: {0}', TargetNullValue=Contact: --}" Foreground="{StaticResource BrandTextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding SelectedMembers}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Full Name" Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Relation" Binding="{Binding RelationshipToHead}" Width="110"/>
                            <DataGridTextColumn Header="Occupation" Binding="{Binding Occupation}" Width="140"/>
                            <DataGridCheckBoxColumn Header="Eligible" Binding="{Binding IsCashForWorkEligible}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
