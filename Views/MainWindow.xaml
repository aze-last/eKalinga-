<Window x:Class="AttendanceShiftingManagement.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Barangay Ayuda System"
        WindowState="Maximized"
        Background="{StaticResource BrandSurfaceBrush}"
        FontFamily="Segoe UI"
        Icon="/Images/municipal-house.ico">

    <Window.Resources>
        <Style x:Key="SidebarButtonBaseStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="#B8C7E8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="6" />
        </Style>

        <Style x:Key="DashboardSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource BrandYellowBrush}" />
                    <Setter Property="Background" Value="#26F9C231" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CashForWorkSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCashForWorkSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource BrandYellowBrush}" />
                    <Setter Property="Background" Value="#26F9C231" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BudgetSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBudgetSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource BrandYellowBrush}" />
                    <Setter Property="Background" Value="#26F9C231" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DistributionSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDistributionSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource BrandYellowBrush}" />
                    <Setter Property="Background" Value="#26F9C231" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MasterListSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMasterListSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource BrandYellowBrush}" />
                    <Setter Property="Background" Value="#26F9C231" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AssistanceCasesSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAssistanceCasesSelected}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource BrandYellowBrush}" />
                    <Setter Property="Background" Value="#26F9C231" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource BrandMidnightBrush}"
                Padding="16,24,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Barangay Ayuda System"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="White" />
                    <TextBlock Text="Administrator portal"
                               Margin="0,4,0,0"
                               FontSize="11"
                               Foreground="{StaticResource BrandYellowBrush}" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,24,0,0">
                    <Button Style="{StaticResource DashboardSidebarButtonStyle}"
                            Command="{Binding ShowDashboardCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="HomeGroup" Width="18" Height="18" Margin="0,0,10,0" />
                            <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource CashForWorkSidebarButtonStyle}"
                            Command="{Binding ShowCashForWorkCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="BriefcaseClockOutline" Width="18" Height="18" Margin="0,0,10,0" />
                            <TextBlock Text="Cash-for-work" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource BudgetSidebarButtonStyle}"
                            Command="{Binding ShowBudgetCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="WalletBifoldOutline" Width="18" Height="18" Margin="0,0,10,0" />
                            <TextBlock Text="Budget" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource DistributionSidebarButtonStyle}"
                            Command="{Binding ShowDistributionCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="GiftOutline" Width="18" Height="18" Margin="0,0,10,0" />
                            <TextBlock Text="Distribution" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MasterListSidebarButtonStyle}"
                            Command="{Binding ShowMasterListCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TableLarge" Width="18" Height="18" Margin="0,0,10,0" />
                            <TextBlock Text="Validated Beneficiaries" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource AssistanceCasesSidebarButtonStyle}"
                            Command="{Binding ShowAssistanceCasesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClipboardPulseOutline" Width="18" Height="18" Margin="0,0,10,0" />
                            <TextBlock Text="Aid Request" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>

                <Border Grid.Row="2"
                        Margin="0,20,0,0"
                        Padding="12"
                        CornerRadius="10"
                        Background="#123980">
                    <StackPanel>
                        <TextBlock Text="{Binding UserDisplayName}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock Text="{Binding ConnectionSummary}"
                                   Margin="0,6,0,0"
                                   FontSize="11"
                                   Foreground="#D7E3FF"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="{StaticResource BrandBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="24,18">
                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentSectionTitle}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrandMidnightBrush}" />
                        <TextBlock Text="{Binding CurrentSectionSubtitle}"
                                   Margin="0,4,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource BrandTextSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Content="SETTINGS"
                                Height="40"
                                Margin="0,0,12,0"
                                Style="{StaticResource SecondaryActionButton}"
                                Click="Settings_Click" />
                        <Button Content="LOAD TABLES"
                                Height="40"
                                Margin="0,0,12,0"
                                Style="{StaticResource GoldActionButton}"
                                Click="LoadTables_Click" />
                        <Button Content="LOGOUT"
                                Height="40"
                                Style="{StaticResource SecondaryActionButton}"
                                Click="Logout_Click" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <ContentControl Grid.Row="1"
                            Margin="24"
                            Content="{Binding CurrentView}" />
        </Grid>
    </Grid>
</Window>
