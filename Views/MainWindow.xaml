<Window x:Class="AttendanceShiftingManagement.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title=""
        WindowState="Maximized"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <LinearGradientBrush x:Key="SidebarShellBrush"
                             StartPoint="0,0"
                             EndPoint="0,1">
            <GradientStop Color="#153055" Offset="0" />
            <GradientStop Color="#214B7B" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SidebarShellSoftBrush"
                             StartPoint="0,0"
                             EndPoint="1,1">
            <GradientStop Color="#F8FBFF" Offset="0" />
            <GradientStop Color="#EEF4FF" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SidebarShellBorderBrush" Color="#3A5F90" />
        <SolidColorBrush x:Key="SidebarTextBrush" Color="#F1F6FD" />
        <SolidColorBrush x:Key="SidebarMutedTextBrush" Color="#C8D6EC" />
        <SolidColorBrush x:Key="SidebarHoverBrush" Color="#2C5487" />
        <SolidColorBrush x:Key="SidebarPanelBorderBrush" Color="#D3DDF0" />
        <SolidColorBrush x:Key="SidebarPanelTextBrush" Color="#20314D" />

        <Style x:Key="WindowControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="WindowCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EF4444" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarNavButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="54" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="20" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource SidebarShellBorderBrush}" />
                </Trigger>
                <Trigger Property="Tag" Value="True">
                    <Setter Property="Background" Value="White" />
                    <Setter Property="Foreground" Value="{DynamicResource BrandMidnightBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarUtilityButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
            <Setter Property="Background" Value="#17365E" />
            <Setter Property="BorderBrush" Value="{StaticResource SidebarShellBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="18" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20446F" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarLogoutButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarUtilityButtonStyle}">
            <Setter Property="Background" Value="#2C1C21" />
            <Setter Property="BorderBrush" Value="#6D3440" />
            <Setter Property="Foreground" Value="#F8D4DB" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="OfficeLogoImageStyle" TargetType="Image">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasOfficeLogo}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OfficeLogoFallbackStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasOfficeLogo}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardSidebarShellStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardWorkspaceShellStyle" TargetType="Border">
            <Setter Property="Grid.ColumnSpan" Value="1" />
            <Setter Property="Background" Value="{DynamicResource ThemeCardRaisedBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="36" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                    <Setter Property="Grid.ColumnSpan" Value="3" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="CornerRadius" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardWorkspaceGridStyle" TargetType="Grid">
            <Setter Property="Margin" Value="24" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                    <Setter Property="Margin" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardWorkspaceHeaderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardWorkspaceContentStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,20,0,0" />
            <Setter Property="Background" Value="{DynamicResource BrandSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="32" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="CornerRadius" Value="0" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardHeaderWindowControlsStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardOverlayWindowControlsStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="0"
            CornerRadius="30"
            Background="{DynamicResource ThemeWindowShellBrush}"
            BorderBrush="{DynamicResource ThemeWindowShellBorderBrush}"
            BorderThickness="1">
        <Grid Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="308" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="2"
                    x:Name="SidebarShell"
                    Style="{StaticResource DashboardSidebarShellStyle}"
                    Background="{StaticResource SidebarShellBrush}"
                    BorderBrush="{StaticResource SidebarShellBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="32"
                    Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Padding="18"
                            Background="{StaticResource SidebarShellSoftBrush}"
                            BorderBrush="{StaticResource SidebarPanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="26">
                        <StackPanel>
                            <DockPanel LastChildFill="True">
                                <Border Width="66"
                                        Height="66"
                                        CornerRadius="20"
                                        Background="White"
                                        BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                                        BorderThickness="1"
                                        DockPanel.Dock="Left">
                                    <Image Source="/Images/default%20icon.png"
                                           Stretch="Uniform"
                                           Margin="10" />
                                </Border>

                                <StackPanel Margin="14,0,0,0">
                                    <TextBlock Text="eKalinga+"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SidebarPanelTextBrush}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="App Trademark"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource ThemeAccentBrush}" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="{Binding OfficeProfileLabel}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                                </StackPanel>
                            </DockPanel>

                            <TextBlock Margin="0,18,0,0"
                                       Text="{Binding OfficeName}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SidebarPanelTextBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding SoftwareTitle}"
                                       FontSize="21"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrandMidnightBrush}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding SoftwareSubtitle}"
                                       FontSize="12"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />

                            <Border Margin="0,18,0,0"
                                    Padding="14,12"
                                    Background="White"
                                    BorderBrush="{DynamicResource BrandBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="AccountCircleOutline"
                                                                 Width="18"
                                                                 Height="18"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource ThemeAccentBrush}" />
                                        <TextBlock Margin="10,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding UserDisplayName}"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource SidebarPanelTextBrush}" />
                                    </StackPanel>

                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding ConnectionSummary}"
                                               FontSize="11"
                                               Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,18,0,18"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Margin="6,0,0,14"
                                       Text="Workspaces"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource SidebarMutedTextBrush}" />

                            <Button Style="{StaticResource SidebarNavButtonStyle}"
                                    Tag="{Binding IsDashboardSelected}"
                                    Command="{Binding ShowDashboardCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="ViewDashboardOutline"
                                                             Width="20"
                                                             Height="20"
                                                             VerticalAlignment="Center"
                                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="Dashboard"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource SidebarNavButtonStyle}"
                                    Tag="{Binding IsAssistanceCasesSelected}"
                                    Command="{Binding ShowAssistanceCasesCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="FileDocumentEditOutline"
                                                             Width="20"
                                                             Height="20"
                                                             VerticalAlignment="Center"
                                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="Aid Requests"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource SidebarNavButtonStyle}"
                                    Tag="{Binding IsMasterListSelected}"
                                    Command="{Binding ShowMasterListCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="AccountCheckOutline"
                                                             Width="20"
                                                             Height="20"
                                                             VerticalAlignment="Center"
                                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="Validated Beneficiaries"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource SidebarNavButtonStyle}"
                                    Tag="{Binding IsDistributionSelected}"
                                    Command="{Binding ShowDistributionCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="PackageVariantClosedCheck"
                                                             Width="20"
                                                             Height="20"
                                                             VerticalAlignment="Center"
                                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="Project Distribution"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource SidebarNavButtonStyle}"
                                    Tag="{Binding IsBudgetSelected}"
                                    Command="{Binding ShowBudgetCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="WalletOutline"
                                                             Width="20"
                                                             Height="20"
                                                             VerticalAlignment="Center"
                                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="Budget"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource SidebarNavButtonStyle}"
                                    Tag="{Binding IsCashForWorkSelected}"
                                    Command="{Binding ShowCashForWorkCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="AccountHardHatOutline"
                                                             Width="20"
                                                             Height="20"
                                                             VerticalAlignment="Center"
                                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="Cash-for-Work"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Grid>
                            </Button>

                            <Button Style="{StaticResource SidebarNavButtonStyle}"
                                    Tag="{Binding IsReportsSelected}"
                                    Command="{Binding ShowReportsCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <materialDesign:PackIcon Kind="ChartBoxOutline"
                                                             Width="20"
                                                             Height="20"
                                                             VerticalAlignment="Center"
                                                             Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="14,0,0,0"
                                               VerticalAlignment="Center"
                                               Text="Reports"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Grid>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2">
                        <Button Style="{StaticResource SidebarUtilityButtonStyle}"
                                Click="Settings_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="CogOutline"
                                                         Width="18"
                                                         Height="18"
                                                         VerticalAlignment="Center"
                                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="Settings"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource SidebarUtilityButtonStyle}"
                                Click="CheckForUpdate_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Update"
                                                         Width="18"
                                                         Height="18"
                                                         VerticalAlignment="Center"
                                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="Check for Update"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Grid>
                        </Button>

                        <Button Style="{StaticResource SidebarLogoutButtonStyle}"
                                Click="Logout_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="LogoutVariant"
                                                         Width="18"
                                                         Height="18"
                                                         VerticalAlignment="Center"
                                                         Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="Logout"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="0"
                    x:Name="WorkspaceShell"
                    Style="{StaticResource DashboardWorkspaceShellStyle}">
                <Grid Style="{StaticResource DashboardWorkspaceGridStyle}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource DashboardWorkspaceHeaderStyle}"
                            Background="{DynamicResource ThemeCardBrush}"
                            BorderBrush="{DynamicResource BrandBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="30"
                            Padding="26,22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel MaxWidth="760">
                                <TextBlock Text="{Binding CurrentSectionTitle}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource BrandMidnightBrush}" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding CurrentSectionSubtitle}"
                                           FontSize="14"
                                           Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                           TextWrapping="Wrap" />
                                <Border Margin="0,16,0,0"
                                        Padding="12,8"
                                        Background="{DynamicResource ThemeAccentSoftBrush}"
                                        BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ChevronDoubleRight"
                                                                 Width="16"
                                                                 Height="16"
                                                                 VerticalAlignment="Center"
                                                                 Foreground="{DynamicResource ThemeAccentBrush}" />
                                        <TextBlock Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Text="Use the launch tiles or the right rail to move between workspaces."
                                                   FontSize="12"
                                                   Foreground="{DynamicResource ThemeAccentBrush}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="20,0,0,0">
                                <Border Padding="14,12"
                                        Background="{DynamicResource ThemeAccentSoftBrush}"
                                        BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="20">
                                    <StackPanel Width="240">
                                        <TextBlock Text="Active Connection"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource ThemeSecondaryActionForegroundBrush}" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Text="{Binding ConnectionSummary}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal"
                                            Style="{StaticResource DashboardHeaderWindowControlsStyle}"
                                            HorizontalAlignment="Right"
                                            Margin="0,16,0,0">
                                    <Button Style="{StaticResource WindowControlButtonStyle}"
                                            Click="Minimize_Click"
                                            ToolTip="Minimize">
                                        <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18" />
                                    </Button>
                                    <Button Style="{StaticResource WindowControlButtonStyle}"
                                            Click="MaximizeRestore_Click"
                                            ToolTip="Maximize/Restore">
                                        <materialDesign:PackIcon Kind="WindowMaximize" Width="18" Height="18" />
                                    </Button>
                                    <Button Style="{StaticResource WindowCloseButtonStyle}"
                                            Click="Close_Click"
                                            ToolTip="Close">
                                        <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Style="{StaticResource DashboardWorkspaceContentStyle}"
                            ClipToBounds="True">
                        <ContentControl Content="{Binding CurrentView}" />
                    </Border>
                </Grid>
            </Border>

            <StackPanel Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        Style="{StaticResource DashboardOverlayWindowControlsStyle}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,6,0"
                        Panel.ZIndex="30">
                <Button Style="{StaticResource WindowControlButtonStyle}"
                        Click="Minimize_Click"
                        ToolTip="Minimize">
                    <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18" />
                </Button>
                <Button Style="{StaticResource WindowControlButtonStyle}"
                        Click="MaximizeRestore_Click"
                        ToolTip="Maximize/Restore">
                    <materialDesign:PackIcon Kind="WindowMaximize" Width="18" Height="18" />
                </Button>
                <Button Style="{StaticResource WindowCloseButtonStyle}"
                        Click="Close_Click"
                        ToolTip="Close">
                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
