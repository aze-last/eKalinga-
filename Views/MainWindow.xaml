<Window x:Class="AttendanceShiftingManagement.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title=""
        WindowState="Maximized"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        FontFamily="Segoe UI">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style x:Key="TopbarActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="72" />
            <Setter Property="MinWidth" Value="146" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="{DynamicResource ThemeSecondaryActionForegroundBrush}" />
            <Setter Property="Background" Value="{DynamicResource ThemeSecondaryActionBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeSecondaryActionBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="20" />
        </Style>

        <Style x:Key="TopbarActionLogoutButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TopbarActionButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource ThemeAccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBorderBrush}" />
            <Setter Property="Background" Value="{DynamicResource ThemeAccentSoftBrush}" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style x:Key="WindowControlButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource BrandTextSecondaryBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12" />
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True" />
        </Style>

        <Style x:Key="WindowCloseButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource WindowControlButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EF4444" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardBackButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="16" />
        </Style>

        <Style x:Key="OfficeLogoImageStyle" TargetType="Image">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasOfficeLogo}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OfficeLogoFallbackStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasOfficeLogo}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Margin="0"
            CornerRadius="30"
            Background="{DynamicResource ThemeWindowShellBrush}"
            BorderBrush="{DynamicResource ThemeWindowShellBorderBrush}"
            BorderThickness="1">
        <Grid>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,12,0"
                        Panel.ZIndex="99">
                <Button Style="{StaticResource WindowControlButtonStyle}"
                        Click="Minimize_Click"
                        ToolTip="Minimize">
                    <materialDesign:PackIcon Kind="WindowMinimize" Width="18" Height="18" />
                </Button>
                <Button Style="{StaticResource WindowControlButtonStyle}"
                        Click="MaximizeRestore_Click"
                        ToolTip="Maximize/Restore">
                    <materialDesign:PackIcon Kind="WindowMaximize" Width="18" Height="18" />
                </Button>
                <Button Style="{StaticResource WindowCloseButtonStyle}"
                        Click="Close_Click"
                        ToolTip="Close">
                    <materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
                </Button>
            </StackPanel>

            <Grid Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="26,22"
                        Margin="0,20,0,18"
                        CornerRadius="30"
                        Background="{DynamicResource ThemeCardRaisedBrush}"
                        BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="1.55*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Border Width="74"
                                    Height="74"
                                    CornerRadius="22"
                                    Background="{DynamicResource ThemeAccentSoftBrush}"
                                    BorderBrush="{DynamicResource ThemeAccentBorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Image Source="{Binding OfficeLogoImage}"
                                           Stretch="UniformToFill"
                                           Style="{StaticResource OfficeLogoImageStyle}" />
                                    <TextBlock Text="{Binding OfficeInitials}"
                                               Style="{StaticResource OfficeLogoFallbackStyle}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource ThemeAccentBrush}" />
                                 </Grid>
                             </Border>

                             <StackPanel Margin="18,0,0,0"
                                         VerticalAlignment="Center">
                                 <TextBlock Text="{Binding OfficeName}"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Foreground="{DynamicResource BrandMidnightBrush}" />
                                 <TextBlock Text="{Binding OfficeProfileLabel}"
                                            Margin="0,5,0,0"
                                            FontSize="14"
                                            Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                             </StackPanel>
                         </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="24,0"
                                    VerticalAlignment="Center">
                             <TextBlock Text="{Binding SoftwareTitle}"
                                        TextAlignment="Center"
                                        FontSize="28"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource BrandMidnightBrush}"
                                        TextWrapping="Wrap" />
                             <TextBlock Text="{Binding SoftwareSubtitle}"
                                        Margin="0,8,0,0"
                                        TextAlignment="Center"
                                        FontSize="15"
                                        Foreground="{DynamicResource BrandTextSecondaryBrush}" />
                         </StackPanel>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <Button Style="{StaticResource TopbarActionButtonStyle}"
                                    Click="Settings_Click">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                     <materialDesign:PackIcon Kind="CogOutline"
                                                              Width="18"
                                                              Height="18"
                                                              Foreground="{DynamicResource ThemeAccentBrush}" />
                                     <TextBlock Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="Settings" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource TopbarActionButtonStyle}"
                                    Click="CheckForUpdate_Click">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                     <materialDesign:PackIcon Kind="Update"
                                                              Width="18"
                                                              Height="18"
                                                              Foreground="{DynamicResource ThemeAccentBrush}" />
                                     <TextBlock Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="Check for Update"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource TopbarActionLogoutButtonStyle}"
                                    Click="Logout_Click">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                     <materialDesign:PackIcon Kind="LogoutVariant"
                                                              Width="18"
                                                              Height="18"
                                                              Foreground="{DynamicResource ThemeAccentBrush}" />
                                     <TextBlock Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                Text="Logout" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,0,0,18"
                        Padding="24,18"
                        CornerRadius="24"
                        Background="{DynamicResource ThemeCardBrush}"
                        BorderBrush="{DynamicResource BrandBorderBrush}"
                        BorderThickness="1"
                        Visibility="{Binding IsSecondarySectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding CurrentSectionTitle}"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource BrandMidnightBrush}" />
                            <TextBlock Text="{Binding CurrentSectionSubtitle}"
                                       Margin="0,6,0,0"
                                       FontSize="13"
                                       Foreground="{DynamicResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource DashboardBackButtonStyle}"
                                Command="{Binding ShowDashboardCommand}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ArrowLeft"
                                                         Width="18"
                                                         Height="18"
                                                         Foreground="White" />
                                <TextBlock Margin="10,0,0,0"
                                           VerticalAlignment="Center"
                                           Text="Back to Dashboard" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <ContentControl Grid.Row="2"
                                Content="{Binding CurrentView}" />
            </Grid>
        </Grid>
    </Border>
</Window>

