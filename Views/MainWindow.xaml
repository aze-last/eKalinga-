<Window x:Class="AttendanceShiftingManagement.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="eKalinga+"
        WindowState="Maximized"
        Background="{StaticResource BrandSurfaceBrush}"
        FontFamily="Segoe UI"
        Icon="/Images/municipal-house.ico">

    <Window.Resources>
        <Style x:Key="SidebarButtonBaseStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="#E6E8FF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="14"/>
        </Style>

        <Style x:Key="DashboardSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#4338CA"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CashForWorkSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCashForWorkSelected}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#4338CA"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BudgetSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBudgetSelected}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#4338CA"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DistributionSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDistributionSelected}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#4338CA"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MasterListSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMasterListSelected}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#4338CA"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AssistanceCasesSidebarButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource SidebarButtonBaseStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAssistanceCasesSelected}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#4338CA"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarUtilityButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4338CA"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="14"/>
        </Style>
    </Window.Resources>

    <Border Margin="0"
            CornerRadius="26"
            BorderBrush="{StaticResource BrandBorderBrush}"
            BorderThickness="1"
            Background="#312E81">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#312E81"
                    Padding="18,22,18,18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="eKalinga+"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Administrator portal"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource BrandYellowBrush}"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,26,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,22">
                                <TextBlock Text="OVERVIEW"
                                           Margin="12,0,0,10"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#C7D2FE"/>

                                <Button Style="{StaticResource DashboardSidebarButtonStyle}"
                                        Command="{Binding ShowDashboardCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="4"
                                                CornerRadius="4"
                                                Background="{StaticResource BrandYellowBrush}"/>
                                        <materialDesign:PackIcon Grid.Column="2"
                                                                 Kind="HomeGroup"
                                                                 Width="18"
                                                                 Height="18"
                                                                 VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Margin="10,0,0,0"
                                                   Text="Dashboard"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,22">
                                <TextBlock Text="OPERATIONS"
                                           Margin="12,0,0,10"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#C7D2FE"/>

                                <Button Style="{StaticResource CashForWorkSidebarButtonStyle}"
                                        Command="{Binding ShowCashForWorkCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="4"
                                                CornerRadius="4"
                                                Background="{StaticResource BrandYellowBrush}"/>
                                        <materialDesign:PackIcon Grid.Column="2"
                                                                 Kind="BriefcaseClockOutline"
                                                                 Width="18"
                                                                 Height="18"
                                                                 VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Margin="10,0,0,0"
                                                   Text="Cash-for-work"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <Button Style="{StaticResource DistributionSidebarButtonStyle}"
                                        Command="{Binding ShowDistributionCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="4"
                                                CornerRadius="4"
                                                Background="{StaticResource BrandYellowBrush}"/>
                                        <materialDesign:PackIcon Grid.Column="2"
                                                                 Kind="GiftOutline"
                                                                 Width="18"
                                                                 Height="18"
                                                                 VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Margin="10,0,0,0"
                                                   Text="Distribution"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <Button Style="{StaticResource AssistanceCasesSidebarButtonStyle}"
                                        Command="{Binding ShowAssistanceCasesCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="4"
                                                CornerRadius="4"
                                                Background="{StaticResource BrandYellowBrush}"/>
                                        <materialDesign:PackIcon Grid.Column="2"
                                                                 Kind="ClipboardPulseOutline"
                                                                 Width="18"
                                                                 Height="18"
                                                                 VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Margin="10,0,0,0"
                                                   Text="Aid Request"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="MANAGEMENT"
                                           Margin="12,0,0,10"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#C7D2FE"/>

                                <Button Style="{StaticResource BudgetSidebarButtonStyle}"
                                        Command="{Binding ShowBudgetCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="4"
                                                CornerRadius="4"
                                                Background="{StaticResource BrandYellowBrush}"/>
                                        <materialDesign:PackIcon Grid.Column="2"
                                                                 Kind="WalletBifoldOutline"
                                                                 Width="18"
                                                                 Height="18"
                                                                 VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Margin="10,0,0,0"
                                                   Text="Budget"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <Button Style="{StaticResource MasterListSidebarButtonStyle}"
                                        Command="{Binding ShowMasterListCommand}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="4"
                                                CornerRadius="4"
                                                Background="{StaticResource BrandYellowBrush}"/>
                                        <materialDesign:PackIcon Grid.Column="2"
                                                                 Kind="TableLarge"
                                                                 Width="18"
                                                                 Height="18"
                                                                 VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3"
                                                   Margin="10,0,0,0"
                                                   Text="Validated Beneficiaries"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2"
                                Margin="0,18,0,0">
                        <Button Content="SETTINGS"
                                Style="{StaticResource SidebarUtilityButtonStyle}"
                                Click="Settings_Click"/>

                        <Button Content="LOGOUT"
                                Style="{StaticResource SidebarUtilityButtonStyle}"
                                Click="Logout_Click"/>

                        <Button Style="{StaticResource SidebarUtilityButtonStyle}"
                                Content="CHECK FOR UPDATE"
                                Click="CheckForUpdate_Click"
                                ToolTip="Open the Updates tab and run an update check now."/>

                        <Border Margin="0,14,0,0"
                                Padding="16"
                                CornerRadius="18">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4338CA" Offset="0"/>
                                    <GradientStop Color="#1D4ED8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <StackPanel>
                                <TextBlock Text="{Binding UserDisplayName}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                                <TextBlock Text="{Binding ConnectionSummary}"
                                           Margin="0,8,0,0"
                                           FontSize="11"
                                           Foreground="#E2E8F0"
                                           TextWrapping="Wrap"/>

                                <DockPanel Margin="0,14,0,0">
                                    <Border Padding="10,4"
                                            CornerRadius="12"
                                            Background="#334155">
                                        <TextBlock Text="Online"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#86EFAC"/>
                                    </Border>

                                    <TextBlock DockPanel.Dock="Right"
                                               Margin="10,2,0,0"
                                               FontSize="11"
                                               Foreground="#CBD5E1"
                                               Text="Last sync 3:42 PM"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="#F8FAFC"
                    CornerRadius="0,26,26,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#FDFDFD"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="28,22">
                        <StackPanel>
                            <TextBlock Text="Operations overview"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"/>
                            <TextBlock Text="{Binding CurrentSectionTitle}"
                                       Margin="0,6,0,0"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandMidnightBrush}"/>
                            <TextBlock Text="{Binding CurrentSectionSubtitle}"
                                       Margin="0,8,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource BrandTextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="28"
                            Padding="24"
                            CornerRadius="24"
                            Background="White"
                            BorderBrush="{StaticResource BrandBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel>
                                <StackPanel>
                                    <TextBlock Text="Main workspace"
                                               FontSize="20"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                    <TextBlock Text="Your selected page loads here with stronger spacing and a softer content container."
                                               Margin="0,6,0,0"
                                               FontSize="13"
                                               Foreground="{StaticResource BrandTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Border DockPanel.Dock="Right"
                                        Padding="12,6"
                                        CornerRadius="14"
                                        Background="#F1F5F9">
                                    <TextBlock Text="ContentControl area"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrandMidnightBrush}"/>
                                </Border>
                            </DockPanel>

                            <ContentControl Grid.Row="1"
                                            Margin="0,20,0,0"
                                            Content="{Binding CurrentView}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
