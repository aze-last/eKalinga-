<Window x:Class="AttendanceShiftingManagement.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d" 
        d:DesignHeight="900" d:DesignWidth="1200"
        Background="{StaticResource BrandSurfaceBrush}"
        FontFamily="Segoe UI"
        WindowState="Maximized"
        Title="{Binding PortalTitle}"
        Icon="/Images/app-icon.ico">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

        <Grid>
            <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource BrandMidnightBrush}">
            <Grid Background="{StaticResource BrandMidnightBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Profile -->
                <StackPanel Grid.Row="0" Margin="20,32,20,24">
                    <TextBlock Text="Barangay Ayuda System"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="Medium"/>
                    <TextBlock Text="{Binding CurrentRoleLabel}"
                               Margin="0,4,0,18"
                               Foreground="{StaticResource BrandYellowBrush}"
                               FontSize="11"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="56" Height="56" CornerRadius="28" Background="#1F2937" VerticalAlignment="Center">
                            <Grid>
                                <materialDesign:PackIcon Kind="AccountCircle" Foreground="{StaticResource BrandYellowBrush}" Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image Source="{Binding UserPhotoImage}" Stretch="UniformToFill"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock Text="{Binding UserDisplayName}" Foreground="White" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                            <Button Content="Profile Settings"
                                    Command="{Binding ShowProfileSettingsCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Foreground="{StaticResource BrandYellowBrush}"
                                    Padding="0" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- Nav Buttons -->
                <StackPanel Grid.Row="1" Margin="12,0">
                    <Button Style="{StaticResource SidebarNavButton}"
                            Command="{Binding ShowDashboardCommand}"
                            FontSize="13">
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="ViewDashboard" Margin="0,0,16,0"/>
                            <TextBlock Text="Ayuda Overview"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}"
                            Command="{Binding ShowHouseholdsCommand}"
                            FontSize="13">
                        <Button.Visibility>
                            <Binding Path="CanManageEmployees" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                        </Button.Visibility>
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="HomeGroup" Margin="0,0,16,0"/>
                            <TextBlock Text="Household Registry"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}"
                            Command="{Binding ShowMasterListCommand}"
                            FontSize="13">
                        <Button.Visibility>
                            <Binding Path="CanManageEmployees" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                        </Button.Visibility>
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="CardAccountDetailsOutline" Margin="0,0,16,0"/>
                            <TextBlock Text="Master List"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}"
                            Command="{Binding ShowBeneficiaryVerificationCommand}"
                            FontSize="13">
                        <Button.Visibility>
                            <Binding Path="CanManageEmployees" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                        </Button.Visibility>
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="AccountCheckOutline" Margin="0,0,16,0"/>
                            <TextBlock Text="Verification"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}"
                            Command="{Binding ShowPositionsCommand}"
                            FontSize="13">
                        <Button.Visibility>Collapsed</Button.Visibility>
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="Briefcase" Margin="0,0,16,0"/>
                            <TextBlock Text="Positions"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}"
                            Command="{Binding ShowHolidaysCommand}"
                            FontSize="13">
                        <Button.Visibility>Collapsed</Button.Visibility>
                        <StackPanel Orientation="Horizontal" Width="180">
                            <Image Source="/Images/holiday small.png" Width="24" Height="24" Margin="0,0,16,0"/>
                            <TextBlock Text="Holidays"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}"
                            Command="{Binding ShowPayrollCommand}"
                            FontSize="13">
                        <Button.Visibility>Collapsed</Button.Visibility>
                        <StackPanel Orientation="Horizontal" Width="180">
                            <Image Source="/Images/money_bag_30dp_FFFFFF_FILL0_wght400_GRAD0_opsz24.png" Width="24" Height="24" Margin="0,0,16,0"/>
                            <TextBlock Text="Payroll"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SidebarNavButton}"
                            Command="{Binding ShowCashForWorkOcrCommand}"
                            FontSize="13">
                        <Button.Visibility>
                            <Binding Path="CanManageEmployees" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                        </Button.Visibility>
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="AccountHardHat" Margin="0,0,16,0"/>
                            <TextBlock Text="Cash-for-Work"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SwitchRoleButton"
                            Style="{StaticResource SidebarNavButton}"
                            FontSize="13"
                            Click="SwitchRole_Click">
                        <AutomationProperties.Name>Switch Role</AutomationProperties.Name>
                        <Button.Visibility>
                            <Binding Path="CanUseRoleSwitch" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                        </Button.Visibility>
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="AccountSwitch" Margin="0,0,16,0"/>
                            <TextBlock Text="Switch Role"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ReturnAdminButton"
                            Style="{StaticResource SidebarNavButton}"
                            Foreground="{StaticResource BrandYellowBrush}"
                            FontSize="13"
                            Click="ReturnToAdmin_Click">
                        <AutomationProperties.Name>Return to Admin</AutomationProperties.Name>
                        <Button.Visibility>
                            <Binding Path="CanReturnToAdmin" Converter="{StaticResource BooleanToVisibilityConverter}"/>
                        </Button.Visibility>
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="ArrowLeftCircle" Margin="0,0,16,0"/>
                            <TextBlock Text="Return to Admin"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Logout -->
                <Border Grid.Row="2"
                        Margin="12,0,12,16"
                        Padding="0,12,0,0"
                        BorderBrush="#1AFFFFFF"
                        BorderThickness="0,1,0,0">
                    <Button Style="{StaticResource SidebarNavButton}"
                            Foreground="{StaticResource BrandYellowBrush}"
                            FontSize="13"
                            Click="Logout_Click">
                        <StackPanel Orientation="Horizontal" Width="180">
                            <materialDesign:PackIcon Kind="Logout" Margin="0,0,16,0"/>
                            <TextBlock Text="Logout"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="12,12,12,0"
                    Padding="12,8"
                    CornerRadius="8"
                    Background="#FFF4E5"
                    BorderBrush="#F59E0B"
                    BorderThickness="1"
                    Visibility="{Binding IsImpersonating, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding ImpersonationBannerText}"
                           Foreground="#92400E"
                           FontWeight="SemiBold"/>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding CurrentView}" />
        </Grid>
    </Grid>
</Window>
